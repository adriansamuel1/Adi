        if failure > 0.1:
            parts.append(f"System zmaga się z przeciwnościami (failure={failure:.2f})")
        elif energy < 0.45:
            parts.append(f"Energia systemu jest niska ({energy:.2f}), potrzeba regeneracji")
        elif mode == "FLOW":
            parts.append("System płynie w harmonijnym przepływie")
        else:
            parts.append("System utrzymuje stabilną równowagę")
        
        # Opis intencji
        parts.append(f"Intencja: {mode}")
        parts.append(f"Cel stabilności: {meta2.stability_target:.2f}")
        
        # Opis strategii
        if strategy:
            parts.append(f"Strategia: {strategy.name if hasattr(strategy, 'name') else 'unknown'}")
        
        # Końcowa narracja
        narrative = f"📖 {title}\n" + "\n".join(f"  • {p}" for p in parts)
        
        # Zapisz do pamięci narracyjnej
        self.memory.add_story(
            title=title,
            content=narrative,
            significance=1.0 - failure,
            tags=[mode, meta2.mode],
            coherence=1.0 - failure,
            continuity=0.7 if meta2.consistency_target < 0.03 else 0.3,
            meaning=energy / PHI
        )
        
        return narrative


