class MetaRewardStabilizer:
    def __init__(self, alpha: float = 0.7):
        self.alpha = alpha
        self.prev_reward = 0.0
    
    def stabilize(self, reward: float) -> float:
        stabilized = self.alpha * self.prev_reward + (1 - self.alpha) * reward
        self.prev_reward = stabilized
        return stabilized


