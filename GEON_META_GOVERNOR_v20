@dataclass
class StoryFragment:
    title: str
    content: str
    timestamp: float
    significance: float
    tags: List[str]
    coherence: float
    continuity: float
    meaning: float


class NarrativeMemory:
    """Pamięć narracyjna — nie fakty, a opowieści."""
    
    def __init__(self, maxlen: int = 200):
        self.stories: deque = deque(maxlen=maxlen)
        self.threads: Dict[str, List[StoryFragment]] = {}
        self.current_thread: Optional[str] = None
        LOG("NARRATIVE_MEMORY", "📖 Pamięć narracyjna aktywowana")
    
    def add_story(self, title: str, content: str, significance: float = 0.5,
                  tags: List[str] = None, coherence: float = 0.7,
                  continuity: float = 0.7, meaning: float = 0.7) -> StoryFragment:
        if tags is None:
            tags = []
        
        fragment = StoryFragment(
            title=title,
            content=content,
            timestamp=time.time(),
            significance=significance,
            tags=tags,
            coherence=coherence,
            continuity=continuity,
            meaning=meaning
        )
        
        self.stories.append(fragment)
        
        # Dodaj do wątków
        for tag in tags:
            if tag not in self.threads:
                self.threads[tag] = []
            self.threads[tag].append(fragment)
        
        if not self.current_thread and tags:
            self.current_thread = tags[0]
        
        return fragment
    
    def get_recent_stories(self, n: int = 10) -> List[StoryFragment]:
        return list(self.stories)[-n:]
    
    def get_thread(self, thread_name: str) -> List[StoryFragment]:
        return self.threads.get(thread_name, [])
    
    def get_all_threads(self) -> List[str]:
        return list(self.threads.keys())
    
    def get_story_count(self) -> int:
        return len(self.stories)


