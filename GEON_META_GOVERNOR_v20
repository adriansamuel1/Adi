class ReflectiveDampingEngine:
    @staticmethod
    def damp(trace_engine: ReflectiveTraceEngine, max_reflection_error: float = 0.15) -> float:
        recent = trace_engine.get_recent_errors(20)
        if not recent:
            return 1.0
        avg_error = sum(recent) / len(recent)
        damping = max(0.3, min(1.0, avg_error / max_reflection_error))
        return damping


