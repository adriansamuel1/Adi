            "current_state": self.meta_state.snapshot(),
            "current_id": self.future_sim7.base.get_id(),
            "priority_weights": self.priority_graph.get_weights(),
            "last_policy": self.last_policy.to_dict() if self.last_policy else None,
            "last_intent_mode": self.last_prioritized.intent.mode if self.last_prioritized else None,
            "meta2_mode": self.last_meta2.mode if self.last_meta2 else None,
            "narrative_mode": self.last_narrative_intent.mode if self.last_narrative_intent else None,
            "narrative_quality": self.last_prediction.narrative_quality if self.last_prediction else 0.0,
