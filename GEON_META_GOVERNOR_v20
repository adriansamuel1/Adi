@dataclass
class Strategy:
    name: str
    sequence: List[str]
    signature: Dict[str, float]
    score: float = 0.0
    usage_count: int = 0


class StrategyDiscoveryEngine:
    def __init__(self, action_pool=None):
        self.action_pool = action_pool or ["SAFE_MODE", "REGENERATION", "EXPANSION",
                                           "TUNE_WEIGHTS", "TUNE_EPSILON", "REBALANCE_CLUSTER"]
        self.counter = 0
    
    def discover(self, prioritized: PrioritizedIntent, meta2: MetaIntent2, state: Dict[str, float]) -> Strategy:
        length = min(5, max(1, int(prioritized.conflict_score * 5) + 1))
        seq = random.sample(self.action_pool, length)
        signature = {
            "conflict": prioritized.conflict_score,
            "stability": meta2.stability_target,
            "consistency": meta2.consistency_target,
            "energy": state.get("energy", PHI)
        }
        self.counter += 1
        name = f"EMERGENT_{self.counter}"
        return Strategy(name, seq, signature)


class StrategyMemory:
    def __init__(self, maxlen=200):
        self.memory = []
        self.maxlen = maxlen
    
    def store(self, strategy: Strategy, reward: float):
        strategy.score = reward
        strategy.usage_count += 1
        self.memory.append(strategy)
        if len(self.memory) > self.maxlen:
            self.memory.sort(key=lambda s: s.score)
            self.memory.pop(0)
    
    def best(self, min_usage=0):
        candidates = [s for s in self.memory if s.usage_count > min_usage]
        if not candidates:
            return None
        return max(candidates, key=lambda s: s.score)
    
    def get_top_k(self, k=3):
        return sorted(self.memory, key=lambda s: s.score, reverse=True)[:k]


class StrategyEvolutionEngine:
    def crossover(self, s1: Strategy, s2: Strategy) -> Strategy:
        if not s1.sequence or not s2.sequence:
            return s1
        split = random.randint(1, min(len(s1.sequence), len(s2.sequence)) - 1)
        new_seq = s1.sequence[:split] + s2.sequence[split:]
        new_name = f"HYBRID_{s1.name}_{s2.name}"
        new_sig = {k: (s1.signature.get(k, 0) + s2.signature.get(k, 0)) / 2
                   for k in set(s1.signature) | set(s2.signature)}
        return Strategy(new_name, new_seq, new_sig)
    
    def mutate(self, strategy: Strategy, action_pool) -> Strategy:
        new_seq = strategy.sequence.copy()
        op = random.choice(["shuffle", "replace", "add", "remove"])
        if op == "shuffle" and len(new_seq) > 1:
            random.shuffle(new_seq)
        elif op == "replace" and len(new_seq) > 0:
            idx = random.randint(0, len(new_seq) - 1)
            new_seq[idx] = random.choice(action_pool)
        elif op == "add" and len(new_seq) < 5:
            new_seq.append(random.choice(action_pool))
        elif op == "remove" and len(new_seq) > 1:
            new_seq.pop(random.randint(0, len(new_seq) - 1))
        return Strategy(f"MUT_{strategy.name}", new_seq, strategy.signature.copy())


class MetaStrategyEngine:
    def __init__(self, memory: StrategyMemory, discovery: StrategyDiscoveryEngine,
                 evolution: StrategyEvolutionEngine, action_pool=None):
        self.memory = memory
        self.discovery = discovery
        self.evolution = evolution
        self.action_pool = action_pool
        self.last_selected = None
    
    def select(self, prioritized: PrioritizedIntent, meta2: MetaIntent2, state: Dict[str, float]) -> Strategy:
        best = self.memory.best(min_usage=1)
        if best and best.score > 0.2:
            sig_sim = 1 - (abs(best.signature.get("conflict", 0) - prioritized.conflict_score) +
                          abs(best.signature.get("stability", 0) - meta2.stability_target)) / 2
            if sig_sim > 0.7:
                self.last_selected = best
                return best
        
        best_overall = self.memory.best(min_usage=0)
        if best_overall:
            new_strat = self.evolution.mutate(best_overall, self.action_pool)
            self.last_selected = new_strat
            return new_strat
        
        new_strat = self.discovery.discover(prioritized, meta2, state)
        self.last_selected = new_strat
        return new_strat


