@dataclass
class ReflectiveTrace:
    ts: float
    state_snapshot: Dict[str, float]
    chosen_strategy: str
    reason: Dict[str, Any]
    expected_outcome: Dict[str, float]
    actual_outcome: Optional[Dict[str, float]] = None
    error_estimate: Optional[float] = None


class ReflectiveTraceEngine:
    def __init__(self, maxlen=100):
        self.traces = []
        self.maxlen = maxlen
    
    def record_decision(self, state, strategy, reason_dict, expected):
        trace = ReflectiveTrace(
            ts=time.time(),
            state_snapshot=state.copy(),
            chosen_strategy=strategy.name if strategy else "NONE",
            reason=reason_dict,
            expected_outcome=expected
        )
        self.traces.append(trace)
        if len(self.traces) > self.maxlen:
            self.traces = self.traces[-self.maxlen:]
        return trace
    
    def record_outcome(self, trace: ReflectiveTrace, actual_state: Dict[str, float]):
        trace.actual_outcome = actual_state.copy()
        exp_conflict = trace.expected_outcome.get("conflict", 0.0)
        act_conflict = actual_state.get("failure", exp_conflict)
        trace.error_estimate = abs(exp_conflict - act_conflict)
    
    def get_recent_errors(self, n=20):
        return [t.error_estimate for t in self.traces[-n:] if t.error_estimate is not None]


class ErrorInsightEngine:
    @staticmethod
    def analyze(traces: List[ReflectiveTrace]) -> Dict[str, Any]:
        errors_by_strategy = {}
        errors_by_state_region = {}
        
        for t in traces:
            if t.error_estimate is None:
                continue
            errors_by_strategy.setdefault(t.chosen_strategy, []).append(t.error_estimate)
            conflict_region = int(t.state_snapshot.get("failure", 0) * 10)
            errors_by_state_region.setdefault((t.chosen_strategy, conflict_region), []).append(t.error_estimate)
        
        avg_by_strategy = {k: sum(v) / len(v) for k, v in errors_by_strategy.items()}
        worst = max(avg_by_strategy, key=avg_by_strategy.get) if avg_by_strategy else None
        
        return {
            "avg_errors_by_strategy": avg_by_strategy,
            "worst_strategy": worst,
            "worst_error": avg_by_strategy.get(worst, 0.0) if worst else 0.0,
            "high_error_regions": [(s, r, sum(v) / len(v))
                                   for (s, r), v in errors_by_state_region.items()
                                   if sum(v) / len(v) > 0.2]
        }


class LimitAwarenessEngine:
    @staticmethod
    def assess(confidence: float, meta_self, priority_graph: PriorityGraph) -> Dict[str, Any]:
        uncertainty = 1.0 - confidence
        weights = list(priority_graph.get_weights().values())
        entropy = -sum(w * math.log(w + 1e-6) for w in weights) if weights else 0.0
        complexity = min(1.0, entropy / 2.0)
        needs_caution = (uncertainty > 0.4 or complexity > 0.7 or
                         (meta_self and meta_self.get_quality_trend() < -0.02))
        return {"uncertainty": uncertainty, "complexity": complexity, "needs_caution": needs_caution}


