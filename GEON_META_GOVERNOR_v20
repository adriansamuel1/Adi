class MetaPolicies:
    @staticmethod
    def generate_from_action(action: str, meta_state) -> GlobalPolicy:
        if action == "SAFE_MODE":
            return GlobalPolicy("GLOBAL_SAFE_MODE", 0.01, {"w_f": 0.5, "w_c": 0.4, "w_h": 0.1})
        if action == "REGENERATION":
            return GlobalPolicy("GLOBAL_REGENERATION", 0.05, {"w_h": 0.5, "w_f": 0.3, "w_l": 0.2})
        if action == "EXPANSION":
            return GlobalPolicy("GLOBAL_EXPANSION", 0.20, {"w_l": 0.35, "w_f": 0.25, "w_h": 0.2, "w_c": 0.2})
        if action == "TUNE_WEIGHTS":
            return GlobalPolicy("GLOBAL_TUNING", 0.10, {"w_f": 0.28, "w_h": 0.28, "w_l": 0.22, "w_c": 0.22})
        if action == "TUNE_EPSILON":
            return GlobalPolicy("GLOBAL_TUNING", 0.30, {"w_l": 0.30, "w_f": 0.25, "w_h": 0.25, "w_c": 0.20})
        return GlobalPolicy("GLOBAL_EXPANSION", 0.15, {"w_f": 0.35, "w_l": 0.25, "w_h": 0.20, "w_c": 0.20})
    
    @staticmethod
    def generate(meta_state):
        if meta_state.global_cb > 0.5 or meta_state.global_failure > 0.12:
            return MetaPolicies.generate_from_action("SAFE_MODE", meta_state)
        if meta_state.global_delta_H > 0.08 or meta_state.global_energy < 0.45:
            return MetaPolicies.generate_from_action("REGENERATION", meta_state)
        return MetaPolicies.generate_from_action("EXPANSION", meta_state)


class GovernorRLv2:
    def __init__(self, lr=0.12, gamma=0.97, epsilon=0.15):
        self.lr = lr
        self.gamma = gamma
        self.epsilon = epsilon
        self.q = {}
        self.action_hist = []
        self.reward_hist = []
    
    def actions(self):
        return ["SAFE_MODE", "REGENERATION", "EXPANSION", "TUNE_WEIGHTS", "TUNE_EPSILON", "REBALANCE_CLUSTER"]
    
    def _discretize(self, s):
        return (min(19, int(s.get("failure", 0) * 20)),
                min(19, int(s.get("delta_H", 0) * 20)),
                min(19, int(s.get("pressure", 0) * 20)),
                min(9, int(s.get("energy", PHI) * 10)),
                min(9, int(s.get("ID", 1.0) * 5)))
    
    def select(self, state):
        ds = self._discretize(state)
        if random.random() < self.epsilon or ds not in self.q:
            a = random.choice(self.actions())
        else:
            a = max(self.q[ds], key=self.q[ds].get)
        self.action_hist.append(a)
        if len(self.action_hist) > 200:
            self.action_hist = self.action_hist[-100:]
        return a
    
    def update(self, s, a, r, s2):
        ds = self._discretize(s)
        ds2 = self._discretize(s2)
        if ds not in self.q:
            self.q[ds] = {x: 0.0 for x in self.actions()}
        if ds2 not in self.q:
            self.q[ds2] = {x: 0.0 for x in self.actions()}
        old = self.q[ds][a]
        new = old + self.lr * (r + self.gamma * max(self.q[ds2].values()) - old)
        self.q[ds][a] = new
        self.reward_hist.append(r)
        if len(self.reward_hist) > 200:
            self.reward_hist = self.reward_hist[-100:]
    
    def set_exploration_rate(self, eps):
        self.epsilon = max(0.01, min(0.5, eps))
    
    def stats(self):
        return {
            "epsilon": self.epsilon,
            "q_size": len(self.q),
            "avg_reward": sum(self.reward_hist[-20:]) / max(1, len(self.reward_hist[-20:])),
            "action_distribution": {a: self.action_hist.count(a) / max(1, len(self.action_hist))
                                    for a in self.actions()}
        }


class FractalRewardTuner:
    def __init__(self, lr=0.05, depth=3):
        self.lr = lr
        self.depth = depth
        self.phi = PHI
    
    def update(self, policy: GlobalPolicy, new_state: Dict[str, float]) -> None:
        pass
    
    def get_fractal_state(self):
        return {"golden_ratio": self.phi, "depth": self.depth, "lr": self.lr}


