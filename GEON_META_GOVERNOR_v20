    def observe(self) -> None:
        self.meta_state.update(self.clusters)
    
    def _compute_meta_reward_v20(self, pred11, meta4, narrative_pred, damping_factor) -> float:
        # Podstawowa nagroda
        reward = pred11["combined"]
        reward -= 0.3 * pred11["expected_error"]
        reward -= 0.2 * pred11["expected_uncertainty"]
        
        # Nagroda za refleksję
        if meta4.mode == "REDUCE_SYSTEMATIC_ERROR":
            reward += 0.05 * (1.0 - pred11["expected_error"])
        if meta4.mode == "INCREASE_CAUTION":
            reward += 0.05 * (1.0 - pred11["expected_uncertainty"])
        
        # NARRATIVE REWARD — nagroda za jakość opowieści
        if narrative_pred:
            reward += 0.2 * narrative_pred.narrative_quality
            reward += 0.1 * narrative_pred.predicted_coherence
            reward += 0.1 * narrative_pred.predicted_continuity
        
        # Kara za nadmiar refleksji
        recent_errors = self.trace_engine.get_recent_errors(10)
        if len(recent_errors) > 5:
            avg_err = sum(recent_errors) / len(recent_errors)
            if avg_err > 0.1:
                reward -= 0.01 * len(recent_errors) * (1 - damping_factor)
        
        return reward
    
    def decide(self) -> GlobalPolicy:
        state = self.meta_state.snapshot()
        state["ID"] = self.future_sim7.base.get_id()
        
        # 1. Intencja pierwszego rzędu
        intent = self.intent_engine.generate(state)
        
        # 2. Priorytetyzacja
        prioritized = self.priority_engine.prioritize(intent, state)
        self.last_prioritized = prioritized
        
        # 3. Meta-intencja 2. rzędu
        meta2 = self.meta2_engine.generate(prioritized, self.priority_graph, state)
        self.last_meta2 = meta2
        
        # 4. Regulacja celów
        raw_regulation = self.regulation_engine.regulate(meta2, prioritized, self.priority_graph)
        regulation = self.regulation_limiter.limit(raw_regulation, self.regulation_depth)
        self.last_regulation = regulation
        
        # 5. Morfing intencji
        morphed_intent = self.morph_engine.morph(intent, regulation)
        if regulation is not None:
            intent = morphed_intent
            prioritized = self.priority_engine.prioritize(intent, state)
        
        # 6. Wybór strategii
        strategy = self.meta_strategy.select(prioritized, meta2, state)
        
        # 7. Filtracja strategii
        stable_strategies = self.strategy_filter.filter(self.strategy_memory, min_score=0.1, min_usage=1)
        if stable_strategies and strategy not in stable_strategies:
            strategy = self.strategy_discovery.discover(prioritized, meta2, state)
        
        # 8. Predykcja Ω⁹
        pred9 = self.future_sim9.simulate(state, strategy, prioritized, meta2)
        
        # 9. Wygładzenie jakości
        smoothed_quality = self.self_smoother.smooth(self.self_model)
        
        # 10. Aktualizacja samo-modelu
        self.self_model.update(
            intent.targets, meta2, strategy.name, smoothed_quality,
            self.priority_graph.get_weights(), regulation is not None,
            prioritized.conflict_score, pred9["stability"], pred9["consistency"]
        )
        
        # 11. Meta-intencja 4. rzędu (refleksja)
        error_insight = self.error_insight.analyze(self.trace_engine.traces)
        limit_awareness = self.limit_awareness.assess(0.5, self.self_model, self.priority_graph)
        meta4 = self.meta4_engine.generate(error_insight, limit_awareness)
        
        # 12. Intencja narracyjna (5. rzędu)
        narrative_intent = self.narrative_intent_engine.generate(state, meta2, meta4)
        self.last_narrative_intent = narrative_intent
        
        # 13. Predykcja narracyjna Ω¹²
        narrative_pred = self.future_sim12.simulate(state, narrative_intent, meta2, meta4)
        
        # 14. Generowanie narracji
        narrative = self.narrative_engine.generate(state, intent, meta2, strategy)
        
        # 15. Aktualizacja autobiografii
        if self.tick % 10 == 0:
            chapter_title = f"Rozdział {self.self_story_engine.counter + 1}: {strategy.name}"
            self.self_story_engine.add_chapter(
                title=chapter_title,
                content=narrative,
                significance=pred9["score"],
                lessons=[f"Conflict: {pred9['conflict']:.2f}", f"Stability: {pred9['stability']:.2f}"]
            )
        
        # 16. Wybór akcji RL
        action = self.rl.select(state) if self.learning_mode != "HEURISTIC" else None
        policy = self.policies.generate_from_action(action, self.meta_state) if action else self.policies.generate(self.meta_state)
        
        self.last_policy = policy
        self.last_state = state
        self.last_action = action
        
        # 17. Refleksyjny ślad
        reason_dict = {
            "meta2_mode": meta2.mode,
            "meta4_mode": meta4.mode,
            "narrative_mode": narrative_intent.mode,
            "strategy_quality": smoothed_quality,
            "conflict_trend": self.self_model.get_quality_trend()
        }
        trace = self.trace_engine.record_decision(
            state, strategy, reason_dict,
            {"conflict": pred9["conflict"], "score": pred9["score"]}
        )
        
        # 18. Damping
        damping = self.reflective_damper.damp(self.trace_engine, max_reflection_error=0.15)
        
        # 19. Predykcja Ω¹¹
        class PlaceholderMeta3:
            mode = "BALANCED"
            strategy_stability_target = 0.03
            strategy_consistency_target = 0.02
        meta3 = PlaceholderMeta3()
        pred11 = self.future_sim11.simulate(state, strategy, prioritized, meta2, meta3, meta4)
        
        # 20. Nagroda
        raw_reward = self._compute_meta_reward_v20(pred11, meta4, narrative_pred, damping)
        stabilized_reward = self.reward_stabilizer.stabilize(raw_reward)
        
        # 21. Przechowanie strategii
        self.strategy_memory.store(strategy, stabilized_reward)
        
        # 22. Historia nagrody
        self.meta_reward_history.append(stabilized_reward)
        if len(self.meta_reward_history) > 200:
            self.meta_reward_history = self.meta_reward_history[-100:]
        
        # 23. Uczenie RL
        if action:
            self.rl.update(state, action, stabilized_reward, state)
        
        # 24. Ewolucja priorytetów
        self.evolution_engine.evolve(self.priority_graph, regulation, meta2)
        self.consistency_engine.update(prioritized, self.priority_graph)
        
        LOG("META_GOVERNOR", f"📖 Narracja: {narrative[:100]}...")
        
        return policy
    
    def apply(self, policy: GlobalPolicy) -> None:
        for cluster in self.clusters:
            if hasattr(cluster, "cluster_rl"):
                cluster.cluster_rl.apply_policies(policy)
            for node in getattr(cluster, "nodes", {}).values():
                if hasattr(node, "engine"):
                    engine = node.engine
                    if hasattr(engine, "self_healing"):
                        engine.self_healing.mode = policy.global_mode
                    if hasattr(engine, "rl_agent"):
                        engine.rl_agent.set_exploration_rate(policy.epsilon)
                    if hasattr(engine, "reward_engine"):
                        engine.reward_engine.update_weights(policy.reward_weights)
    
