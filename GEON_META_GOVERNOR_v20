class PriorityEvolutionEngine:
    """Ewolucja wag priorytetów niezależna od nagrody."""
    
    def evolve(self, pg: PriorityGraph, regulation: Optional[GoalRegulation], meta2: MetaIntent2) -> None:
        if regulation is None:
            return
        
        for k, node in pg.nodes.items():
            delta = regulation.intensity * 0.01
            if regulation.reason == "HIGH_CONFLICT":
                delta *= -1
            elif regulation.reason == "UNSTABLE_PRIORITIES":
                delta *= 0.5
            pg.update_priority(k, delta)


