class IntentMorphingEngine:
    """Przekształca intencję pierwszego rzędu na podstawie regulacji celów."""
    
    def morph(self, intent: MetaIntent, regulation: Optional[GoalRegulation]) -> MetaIntent:
        if regulation is None:
            return intent
        
        new_targets = intent.targets.copy()
        for k, v in regulation.new_targets.items():
            new_targets[k] = v
        
        new_weights = {k: w * 0.95 for k, w in intent.weights.items()}
        total = sum(new_weights.values())
        if total > 0:
            new_weights = {k: w / total for k, w in new_weights.items()}
        
        new_mode = intent.mode + "_MORPHED" if regulation.intensity > 0.1 else intent.mode
        return MetaIntent(new_targets, new_weights, new_mode)


