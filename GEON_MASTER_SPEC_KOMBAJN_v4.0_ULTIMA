def LOG(module: str, msg: str, level: str = "INFO") -> None:
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S.%f")[:-3]
    print(f"[{timestamp}] [{level}] [{module}] :: {msg}")

def LOG_INFO(module: str, msg: str) -> None:
    LOG(module, msg, "INFO")

def LOG_WARN(module: str, msg: str) -> None:
    LOG(module, msg, "WARN")

def LOG_ERR(module: str, msg: str) -> None:
    LOG(module, msg, "ERROR")

def LOG_DEBUG(module: str, msg: str) -> None:
    LOG(module, msg, "DEBUG")


