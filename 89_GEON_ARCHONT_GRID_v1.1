            "votes": [a.status.value for a in self.archonts],
            "confidence": [a.confidence for a in self.archonts],
            "archont_vectors": [a.to_vector() for a in self.archonts],
            "global_status": self.global_status.value,
            "grid_health": self.grid_health,
            "anomaly_score": self.anomaly_score,
            "oracle_era": self.oracle_era,
            "maya_phase": self.maya_phase,
            "ludlum_decision": self.ludlum_decision,
            # Nowe pola AFC
            "afc_global_stability": self.afc_global_stability,
            "afc_global_decision": self.afc_global_decision,
            "afc_global_policy": self.afc_global_policy
        }

