class ArchontGridBridge:
    def __init__(self, grid: GeonArchontGrid):
        self.grid = grid

    def get_archetype_context(self) -> Dict[str, Any]:
        status = self.grid.get_status()
        return {
            "tryb": VERSION,
            "archonci": status["archonts"],
            "statusy": status["status_levels"],
            "segment_size": status["segment_size"],
            "historia": status["history_size"],
            "integracja": status["integration"]
        }

    def get_autopilot_state(self) -> Dict[str, Any]:
        history = self.grid.get_history(1)
        if history:
            last = history[-1]
            return {
                "mode": VERSION,
                "global_status": last.get("global_status", "UNKNOWN"),
                "grid_health": last.get("grid_health", 0.0),
                "anomaly_score": last.get("anomaly_score", 0.0),
                "oracle_era": last.get("oracle_era", "UNKNOWN"),
                "maya_phase": last.get("maya_phase", 0),
                "grid_ready": True
            }
        return {
            "mode": VERSION,
            "global_status": "NO_DATA",
            "grid_health": 0.0,
            "grid_ready": True
        }

    def get_governor_context(self) -> Dict[str, Any]:
        history = self.grid.get_history(1)
        if history:
            last = history[-1]
            return {
                "intent": "ARCHONT_GRID_ANALYSIS",
                "confidence": last.get("grid_health", 0.5),
                "entropy": 1.0 - last.get("grid_health", 0.5),
                "grid_ready": True,
                "global_status": last.get("global_status", "UNKNOWN"),
                "council_payload": last.get("council_payload", {})
            }
        return {
            "intent": "ARCHONT_GRID_ANALYSIS",
            "confidence": 0.5,
            "entropy": 0.5,
            "grid_ready": True,
            "global_status": "NO_DATA"
        }

    def get_trio_state(self) -> Dict[str, str]:
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": VERSION,
            "grid": "AKTYWNY_INTEGRATED"
        }

    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        history = self.grid.get_history(n)
        fragments = []
        for entry in history:
            fragments.append({
                "source": VERSION,
                "content": f"Grid: {entry.get('global_status', 'UNKNOWN')} | health: {entry.get('grid_health', 0):.3f} | era: {entry.get('oracle_era', 'UNKNOWN')}",
                "archonts": entry.get("archonts", []),
                "health": entry.get("grid_health", 0.0),
                "council_ready": bool(entry.get("council_payload"))
            })
        return fragments

