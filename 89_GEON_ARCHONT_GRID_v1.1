class ArchontStatus(Enum):
    """5 poziomów statusów Archontów."""
    STABILNOSC = "STABILNOŚĆ"
    PRESJA = "PRESJA"
    NIESTABILNOSC = "NIESTABILNOŚĆ"
    KRYZYS = "KRYZYS"
    APOTEOSIS = "APOTEOSIS"
    NIEZNANY = "NIEZNANY"

    def numeric_value(self) -> int:
        """Wartość numeryczna dla ważenia global_status."""
        values = {
            ArchontStatus.APOTEOSIS: 0,
            ArchontStatus.STABILNOSC: 1,
            ArchontStatus.PRESJA: 2,
            ArchontStatus.NIESTABILNOSC: 3,
            ArchontStatus.KRYZYS: 4,
            ArchontStatus.NIEZNANY: 2
        }
        return values.get(self, 2)

    def description(self) -> str:
        desc = {
            ArchontStatus.APOTEOSIS: "Stan doskonałej harmonii – domknięcie cyklu.",
            ArchontStatus.STABILNOSC: "Stan równowagi – system działa optymalnie.",
            ArchontStatus.PRESJA: "Narastające napięcie – wymaga uwagi.",
            ArchontStatus.NIESTABILNOSC: "Zaburzenia struktury – potencjalne ryzyko.",
            ArchontStatus.KRYZYS: "Krytyczne zaburzenie – wymaga interwencji.",
            ArchontStatus.NIEZNANY: "Stan nieokreślony."
        }
        return desc.get(self, "Stan nieznany.")


@dataclass
class Archont:
    """Pojedynczy Archont – tożsamość, metryki i wektor."""
    name: str
    segment: List[float]
    mean: float = 0.0
    variance: float = 0.0
    energy: float = 0.0
    entropy: float = 0.0
    status: ArchontStatus = ArchontStatus.NIEZNANY
    confidence: float = 0.0
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "name": self.name,
            "mean": round(self.mean, 4),
            "variance": round(self.variance, 4),
            "energy": round(self.energy, 4),
            "entropy": round(self.entropy, 4),
            "status": self.status.value,
            "status_numeric": self.status.numeric_value(),
            "confidence": round(self.confidence, 4),
            "archont_vector": self.to_vector(),
            "segment_preview": [round(x, 3) for x in self.segment[:5]]
        }
    
    def to_vector(self) -> List[float]:
        """Archont Vector – wektor metryk dla Council i Synodu."""
        return [
            round(self.mean, 4),
            round(self.variance, 4),
            round(self.entropy, 4),
            round(self.energy, 4),
            float(self.status.numeric_value())
        ]


@dataclass
class GridReport:
    """Pełny raport sieci nadzorczej z Council Payload."""
    archonts: List[Archont]
