class ArchontGridBridge:
    def __init__(self, grid: GeonArchontGrid):
        self.grid = grid

    # ===== ORYGINALNE METODY (ZACHOWANE) =====
    
    def get_archetype_context(self) -> Dict[str, Any]:
        status = self.grid.get_status()
        return {
            "tryb": VERSION,
            "archonci": status["archonts"],
            "statusy": status["status_levels"],
            "segment_size": status["segment_size"],
            "historia": status["history_size"],
            "integracja": status["integration"]
        }

    def get_autopilot_state(self) -> Dict[str, Any]:
        history = self.grid.get_history(1)
        if history:
            last = history[-1]
            return {
                "mode": VERSION,
                "global_status": last.get("global_status", "UNKNOWN"),
                "grid_health": last.get("grid_health", 0.0),
                "anomaly_score": last.get("anomaly_score", 0.0),
                "oracle_era": last.get("oracle_era", "UNKNOWN"),
                "maya_phase": last.get("maya_phase", 0),
                "afc_global_stability": last.get("afc_global_stability", 0.0),
                "afc_global_decision": last.get("afc_global_decision", "UNKNOWN"),
                "grid_ready": True
            }
        return {
            "mode": VERSION,
            "global_status": "NO_DATA",
            "grid_health": 0.0,
            "grid_ready": True
        }

    def get_governor_context(self) -> Dict[str, Any]:
        history = self.grid.get_history(1)
        if history:
            last = history[-1]
            return {
                "intent": "ARCHONT_GRID_ANALYSIS",
                "confidence": last.get("grid_health", 0.5),
                "entropy": 1.0 - last.get("grid_health", 0.5),
                "grid_ready": True,
                "global_status": last.get("global_status", "UNKNOWN"),
                "council_payload": last.get("council_payload", {}),
                "afc_global_stability": last.get("afc_global_stability", 0.0)
            }
        return {
            "intent": "ARCHONT_GRID_ANALYSIS",
            "confidence": 0.5,
            "entropy": 0.5,
            "grid_ready": True,
            "global_status": "NO_DATA"
        }

    def get_trio_state(self) -> Dict[str, str]:
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": VERSION,
            "grid": "AKTYWNY_AFC_INTEGRATED"
        }

    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        history = self.grid.get_history(n)
        fragments = []
        for entry in history:
            fragments.append({
                "source": VERSION,
                "content": f"Grid: {entry.get('global_status', 'UNKNOWN')} | health: {entry.get('grid_health', 0):.3f} | afc_stab: {entry.get('afc_global_stability', 0):.3f}",
                "archonts": entry.get("archonts", []),
                "health": entry.get("grid_health", 0.0),
                "council_ready": bool(entry.get("council_payload"))
            })
        return fragments

    # ===== NOWE METODY AFC =====

    def get_afc_context(self) -> Dict[str, Any]:
        """Zwraca kontekst AFC z ostatniego raportu."""
        history = self.grid.get_history(1)
        if history:
            last = history[-1]
            return {
                "afc_global_stability": last.get("afc_global_stability", 0.0),
                "afc_global_decision": last.get("afc_global_decision", "UNKNOWN"),
                "afc_global_policy": last.get("afc_global_policy", "UNKNOWN"),
                "council_payload": last.get("council_payload", {})
            }
        return {"afc_global_stability": 0.0, "afc_global_decision": "UNKNOWN"}

    def analyze_with_afc(self, tensor_45d: List[float],
                         afc_result: Dict[str, Any],
                         anomaly_score: float = 0.0,
                         oracle_interpretation: Optional[Dict[str, Any]] = None,
                         maya_phase: int = 0,
                         ludlum_decision: Optional[str] = None) -> GridReport:
        """Wygodna metoda – analiza z AFC."""
        return self.grid.analyze_with_afc(
            tensor_45d=tensor_45d,
            afc_result=afc_result,
            anomaly_score=anomaly_score,
            oracle_interpretation=oracle_interpretation,
            maya_phase=maya_phase,
            ludlum_decision=ludlum_decision
        )

    def get_full_status(self) -> Dict[str, Any]:
        """Zwraca pełny status – grid + AFC."""
        return {
            "grid": self.grid.get_status(),
            "afc_context": self.get_afc_context(),
            "last_report": self.grid.get_history(1)[0] if self.grid.get_history(1) else None
        }

