class GeonArchontGrid:
    """
    🏛️ GEON_ARCHONT_GRID – Sieć nadzorcza 5 Archontów z pełną integracją AFC.
    """
    
    ARCHONT_NAMES = ["SAMAEL", "ENKI", "RA", "OPTIMUS", "HEILONG"]
    
    def __init__(self, config: Optional[Dict[str, Any]] = None):
        self.config = config or {}
        self.memory_limit = self.config.get("memory_limit", MEMORY_LIMIT)
        self.history: deque = deque(maxlen=self.memory_limit)
        self.kroniki = SamaelHeilong
        self.egregor = Egregor
        self._lock = threading.Lock()
        
        # Progi klasyfikacji
        self.stability_threshold = self.config.get("stability_threshold", 0.38)
        self.pressure_threshold = self.config.get("pressure_threshold", 0.72)
        self.variance_crisis_threshold = self.config.get("variance_crisis_threshold", 0.12)
        self.entropy_crisis_threshold = self.config.get("entropy_crisis_threshold", 0.85)
        self.apotheosis_mean_threshold = self.config.get("apotheosis_mean_threshold", 0.25)
        self.apotheosis_entropy_threshold = self.config.get("apotheosis_entropy_threshold", 0.3)
        
        # ===== NOWE PROGI AFC =====
        self.afc_stability_threshold = self.config.get("afc_stability_threshold", 0.5)
        
        log(f"🐉 {VERSION} aktywowany | {FRACTAL_SIGNATURE}")
        log(f"   ARCHONCI: {', '.join(self.ARCHONT_NAMES)} | SEGMENT: {SEGMENT_SIZE}D")
        log(f"   STATUSY: 5 poziomów (APOTEOSIS, STABILNOŚĆ, PRESJA, NIESTABILNOŚĆ, KRYZYS)")
        log(f"   AFC INTEGRACJA: AKTYWNA")

    # -------------------------------------------------------------------------
    # ANALIZA GŁÓWNA (ZACHOWANA KOMPATYBILNOŚĆ)
    # -------------------------------------------------------------------------

    def analyze(self, tensor_45d: List[float],
                anomaly_score: float = 0.0,
                oracle_interpretation: Optional[Dict[str, Any]] = None,
                maya_phase: int = 0,
                ludlum_decision: Optional[str] = None,
                afc_result: Optional[Dict[str, Any]] = None) -> GridReport:
        """
        Analizuje tensor 45D z integracją warstw 83-88 oraz AFC.
        """
        if len(tensor_45d) != TENSOR_DIM:
            raise ValueError(f"Tensor musi mieć {TENSOR_DIM} wymiarów")

        # Ekstrakcja danych AFC
        afc_global_stability = 0.0
        afc_global_decision = None
        afc_global_policy = None
        afc_archont_vectors = {}
        
        if afc_result:
            afc_global_stability = afc_result.get("core", {}).get("stability", 0.0)
            afc_global_decision = afc_result.get("decision", {}).get("mode")
            afc_global_policy = afc_result.get("policy", {}).get("final_mode")
            
            # Jeśli AFC zwróciło wektory dla Archontów, możemy je wykorzystać
            if "segments" in afc_result:
                for i, seg in enumerate(afc_result["segments"][:ARCHONT_COUNT]):
                    if len(seg) >= 3:
                        afc_archont_vectors[i] = seg[:3]

        # 1. Analiza Archontów
        archonts = []
        for i, name in enumerate(self.ARCHONT_NAMES):
            start = i * SEGMENT_SIZE
            end = start + SEGMENT_SIZE
            segment = tensor_45d[start:end]
            
            # Pobierz wektor AFC dla tego Archonta (jeśli dostępny)
            afc_vec = afc_archont_vectors.get(i)
            
            archont = self._analyze_archont(
                name, segment,
                anomaly_score=anomaly_score,
                maya_phase=maya_phase,
                ludlum_decision=ludlum_decision,
                afc_stability=afc_global_stability,
                afc_decision=afc_global_decision,
                afc_vector=afc_vec
            )
            archonts.append(archont)

        # 2. Status globalny – ważony
        global_status = self._determine_global_status_weighted(archonts)
        
        # 3. Zdrowie gridu – średnia pewność
        grid_health = sum(a.confidence for a in archonts) / len(archonts)
        
        # 4. Ekstrakcja epoki z Oracle
        oracle_era = None
        if oracle_interpretation:
            oracle_era = oracle_interpretation.get("era")

        report = GridReport(
            archonts=archonts,
            global_status=global_status,
            grid_health=grid_health,
            anomaly_score=anomaly_score,
            oracle_era=oracle_era,
            maya_phase=maya_phase,
            ludlum_decision=ludlum_decision,
            afc_global_stability=afc_global_stability,
            afc_global_decision=afc_global_decision,
            afc_global_policy=afc_global_policy
        )

        # 5. Zapis do historii
        with self._lock:
            self.history.append(report.to_dict())
        
        # 6. Certyfikacja
        cert = self.kroniki.certyfikuj_grid(f"ANALYZE_{hash(str(tensor_45d[:5]))}")
        
        # 7. Zapis do Egregora
        if (global_status in [ArchontStatus.KRYZYS, ArchontStatus.NIESTABILNOSC] or 
            grid_health < 0.5 or len(self.history) % 5 == 0):
            entry = {
                "type": "ARCHONT_GRID_REPORT_AFC",
                "report": report.to_dict(),
                "certificate": cert,
                "timestamp": datetime.now().isoformat()
            }
            self.egregor.commit(entry, node_id="GEON_ARCHONT_GRID_AFC")
        
        self.kroniki.log_event("GRID_ANALYSIS_AFC", {
            "global_status": global_status.value,
            "grid_health": grid_health,
            "anomaly_score": anomaly_score,
            "afc_global_stability": afc_global_stability,
            "afc_global_decision": afc_global_decision
        })
        
        return report

    # -------------------------------------------------------------------------
    # ANALIZA Z AFC (NOWA METODA)
    # -------------------------------------------------------------------------

    def analyze_with_afc(self, tensor_45d: List[float],
                         afc_result: Dict[str, Any],
                         anomaly_score: float = 0.0,
                         oracle_interpretation: Optional[Dict[str, Any]] = None,
                         maya_phase: int = 0,
                         ludlum_decision: Optional[str] = None) -> GridReport:
        """
        Wygodna metoda – analiza z wprost podanym wynikiem AFC.
        """
        return self.analyze(
            tensor_45d=tensor_45d,
            anomaly_score=anomaly_score,
            oracle_interpretation=oracle_interpretation,
            maya_phase=maya_phase,
            ludlum_decision=ludlum_decision,
            afc_result=afc_result
        )

    # -------------------------------------------------------------------------
    # ANALIZA POJEDYNCZEGO ARCHONTA (ROZSZERZONA O AFC)
    # -------------------------------------------------------------------------

    def _analyze_archont(self, name: str, segment: List[float],
                         anomaly_score: float = 0.0,
                         maya_phase: int = 0,
                         ludlum_decision: Optional[str] = None,
                         afc_stability: float = 0.0,
                         afc_decision: Optional[str] = None,
                         afc_vector: Optional[List[float]] = None) -> Archont:
        """Analizuje segment z uwzględnieniem metadanych z warstw 83-88 i AFC."""
        if not segment:
            return Archont(name, [], status=ArchontStatus.NIEZNANY, confidence=0.0)
        
        # Podstawowe metryki
        mean = sum(segment) / len(segment)
        variance = sum((x - mean) ** 2 for x in segment) / len(segment)
        energy = sum(abs(x) for x in segment) / len(segment)
        
        # Entropia
        max_val = max(segment) + 1e-9
        norm = [x / max_val for x in segment]
        probs = [x / (sum(norm) + 1e-9) for x in norm]
        entropy = -sum(p * math.log(p + 1e-9) for p in probs)
        entropy = clamp(entropy / math.log(len(segment) + 1e-9), 0.0, 1.0)
        
        # Klasyfikacja statusu (z uwzględnieniem AFC)
        status, confidence = self._classify_status_enhanced(
            mean, variance, entropy,
            anomaly_score=anomaly_score,
            maya_phase=maya_phase,
            ludlum_decision=ludlum_decision,
            afc_stability=afc_stability,
            afc_decision=afc_decision
        )
        
        return Archont(
            name=name,
            segment=segment,
            mean=mean,
            variance=variance,
            energy=energy,
            entropy=entropy,
            status=status,
            confidence=confidence,
            afc_stability=afc_stability,
            afc_decision=afc_decision,
            afc_vector=afc_vector
        )

    # -------------------------------------------------------------------------
    # KLASYFIKACJA STATUSU (ROZSZERZONA O AFC)
    # -------------------------------------------------------------------------

    def _classify_status_enhanced(self, mean: float, variance: float, entropy: float,
                                   anomaly_score: float = 0.0,
                                   maya_phase: int = 0,
                                   ludlum_decision: Optional[str] = None,
                                   afc_stability: float = 0.0,
                                   afc_decision: Optional[str] = None) -> Tuple[ArchontStatus, float]:
        """
        Klasyfikacja statusu z 5 poziomami i uwzględnieniem metadanych AFC.
        """
        # ===== Korekta na podstawie AFC =====
        afc_boost = 0.0
        if afc_stability > 0.6:
            afc_boost = 0.1  # AFC stabilny → poprawa klasyfikacji
        elif afc_stability < 0.3:
            afc_boost = -0.1  # AFC niestabilny → pogorszenie
        
        # Korekta na podstawie decyzji AFC
        if afc_decision == "ALERT" or afc_decision == "HARD_ALERT":
            afc_boost -= 0.15
        elif afc_decision == "EXPLORE" or afc_decision == "EXPLORE_EXTENDED":
            afc_boost += 0.05

        # 1. KRYZYS
        if variance > self.variance_crisis_threshold or entropy > self.entropy_crisis_threshold or anomaly_score > 0.7:
            return ArchontStatus.KRYZYS, clamp(0.5 + variance * 2.0 + afc_boost * 0.5, 0.4, 0.95)
        
        # 2. NIESTABILNOŚĆ
        if variance > 0.06 or entropy > 0.55:
            return ArchontStatus.NIESTABILNOSC, clamp(0.5 + variance * 1.5 + afc_boost * 0.3, 0.4, 0.90)
        
        # 3. PRESJA
        if mean > self.pressure_threshold:
            return ArchontStatus.PRESJA, clamp(0.5 + (mean - self.pressure_threshold) * 1.2 + afc_boost * 0.2, 0.4, 0.90)
        
        # 4. APOTEOSIS
        if mean < self.apotheosis_mean_threshold and entropy < self.apotheosis_entropy_threshold:
            return ArchontStatus.APOTEOSIS, clamp(0.7 - variance * 3.0 + afc_boost * 0.3, 0.5, 0.95)
        
        # 5. STABILNOŚĆ
        if mean < self.stability_threshold and variance < 0.03 and entropy < 0.4:
            return ArchontStatus.STABILNOSC, clamp(0.7 - variance * 5.0 - entropy * 0.3 + afc_boost * 0.3, 0.5, 0.95)
        
        # 6. Przypadek graniczny
        if mean < self.pressure_threshold and variance < 0.05:
            return ArchontStatus.STABILNOSC, clamp(0.5 + afc_boost * 0.2, 0.4, 0.8)
        
        return ArchontStatus.NIEZNANY, 0.3

    # -------------------------------------------------------------------------
    # WAŻONY STATUS GLOBALNY
    # -------------------------------------------------------------------------

    def _determine_global_status_weighted(self, archonts: List[Archont]) -> ArchontStatus:
        total_weight = 0.0
        weighted_sum = 0.0
        
        for a in archonts:
            weight = a.confidence
            numeric = a.status.numeric_value()
            weighted_sum += weight * numeric
            total_weight += weight
        
        if total_weight == 0:
            return ArchontStatus.NIEZNANY
        
        avg_score = weighted_sum / total_weight
        if avg_score <= 0.5:
            return ArchontStatus.APOTEOSIS
        elif avg_score <= 1.5:
            return ArchontStatus.STABILNOSC
        elif avg_score <= 2.5:
            return ArchontStatus.PRESJA
        elif avg_score <= 3.5:
            return ArchontStatus.NIESTABILNOSC
        else:
            return ArchontStatus.KRYZYS

    # -------------------------------------------------------------------------
    # METODY POMOCNICZE
    # -------------------------------------------------------------------------

    def get_history(self, n: Optional[int] = None) -> List[Dict[str, Any]]:
        with self._lock:
            snapshot = list(self.history)
        if n is not None and n > 0:
            return snapshot[-n:]
        return snapshot

    def reset(self) -> None:
        with self._lock:
            self.history.clear()
        self.kroniki.log_event("GRID_RESET", {"status": "CLEARED"})

    def get_status(self) -> Dict[str, Any]:
        with self._lock:
            hist_size = len(self.history)
        return {
            "system": "GEON_ARCHONT_GRID",
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "vibe": VIBE,
            "archonts": self.ARCHONT_NAMES,
            "status_levels": ["APOTEOSIS", "STABILNOŚĆ", "PRESJA", "NIESTABILNOŚĆ", "KRYZYS"],
            "segment_size": SEGMENT_SIZE,
            "tensor_dim": TENSOR_DIM,
            "history_size": hist_size,
            "memory_limit": self.memory_limit,
            "integration": {
                "AI_ANALYTICS": "anomaly_score",
                "ORACLE": "oracle_era",
                "MAYA_GROWTH": "maya_phase",
                "LUDLUM_ENGINE": "ludlum_decision",
                "AFC_9": "afc_result (stability, decision, policy)"
            }
        }

