class SilnikB:
    """
    SILNIK B — 9 Pierścieni Beny.
    
    Przekształca surowe dane w Finalny Wektor — precyzyjną decyzję.
    Finalny Wektor to logiczny kierunek dla Triady GEON.
    
    API:
        process(raw_input) -> Dict (zawiera "finalny_wektor")
        status() -> Dict
        reset() -> None
        pobierz_historie() -> List[Dict]
    """
    def __init__(self, verbose: bool = True):
        self.B1 = B1_Logika_Twarda()
        self.B2 = B2_Analiza_Kierunkowa()
        self.B3 = B3_Korekta_Filtracja()
        self.B4 = B4_Decyzja_Konsekwencja()
        self.B5 = B5_Stabilizacja_Kierunku()
        self.B6 = B6_Analiza_Gleboka()
        self.B7 = B7_Meta_Korekta()
        self.B8 = B8_Meta_Analiza()
        self.B9 = B9_Integracja_Decyzyjna()
        self.status = "B_FAZA_ZAKONCZONA_SUKCESEM"
        self.ostatni_wektor: Optional[Any] = None
        self.historia_procesow: List[Dict] = []
        self.tick_counter = 0
        self._verbose = verbose
        self._hooks: List[Callable] = []
        
        if self._verbose:
            logger.info(f"🖤 SILNIK B BENY aktywowany | {FRACTAL_SIGNATURE}")
            logger.info(f"   PIERŚCIENI: 9 | TOTEMY: 27")
            logger.info(f"   B1 Logika → B2 Kierunek → B3 Filtracja → B4 Decyzja → B5 Stabilizacja → B6 Analiza → B7 Meta-Korekta → B8 Meta-Analiza → B9 Wektor")
    
    def process(self, raw_input: Dict) -> Dict:
        """
        Główna metoda — przetwarza surowe dane.
        
        Args:
            raw_input: Słownik z danymi (dane_surowe, narracje, emocje)
            
        Returns:
            Słownik zawierający "finalny_wektor" (wynik B9)
        """
        self.tick_counter += 1
        
        # Walidacja wejścia
        if not isinstance(raw_input, dict):
            raw_input = {"dane_surowe": {"domyslna": 0.5}}
        if "dane_surowe" not in raw_input:
            raw_input["dane_surowe"] = {"domyslna": 0.5}
        
        # Łańcuchowa obróbka przez B1..B9
        out1 = self.B1.execute(raw_input)
        if not out1.get("decyzja_binarna"):
            return {"error": "B1 odrzucił sygnał", "status": "FAIL"}
        
        out2 = self.B2.execute(out1["czysty_sygnal"])
        if out2.get("status") == "ERROR":
            return {"error": out2.get("msg", "B2 error"), "status": "FAIL"}
        
        out3 = self.B3.execute(out2.get("kierunki_finalne", {}))
        out4 = self.B4.execute(out3.get("kierunki_spojne"))
        out5 = self.B5.execute(out4.get("decyzja_finalna"))
        out6 = self.B6.execute(out5.get("kurs_stabilny"))
        out7 = self.B7.execute(out6.get("analiza_gleboka"))
        out8 = self.B8.execute(out7.get("korekta_systemu"))
        out9 = self.B9.execute(out8.get("nadzor_logiki"))
        
        self.ostatni_wektor = out9.get("finalny_wektor")
        
        wynik = {
            "finalny_wektor": self.ostatni_wektor,
            "status": self.status,
            "kroki": {
                "B1": out1, "B2": out2, "B3": out3, "B4": out4,
                "B5": out5, "B6": out6, "B7": out7, "B8": out8, "B9": out9
            }
        }
        
        self.historia_procesow.append({
            "tick": self.tick_counter,
            "wejscie": raw_input.get("dane_surowe", {}),
            "wyjscie": self.ostatni_wektor
        })
        if len(self.historia_procesow) > 100:
            self.historia_procesow = self.historia_procesow[-50:]
        
        # Hooki
        self._on_process(wynik)
        
        if self._verbose:
            logger.info(f"🖤 Finalny Wektor: {self.ostatni_wektor}")
        
        return wynik
    
    def status(self) -> Dict:
        """Zwraca status systemu"""
        return {
            "system": "SILNIK_B_BENY",
            "wersja": VERSION,
            "tick": self.tick_counter,
            "pierścienie": 9,
            "totemy": 27,
            "ostatni_wektor": self.ostatni_wektor,
            "historia_procesow": len(self.historia_procesow),
            "status": self.status
        }
    
    def reset(self) -> None:
        """Resetuje stan silnika (bez utraty historii)"""
        for attr in ["B1", "B2", "B3", "B4", "B5", "B6", "B7", "B8", "B9"]:
            getattr(self, attr).historia = []
        self.ostatni_wektor = None
        self.tick_counter = 0
        if self._verbose:
            logger.info("🖤 SILNIK B BENY — reset wykonany")
    
    def pobierz_historie(self, ostatnie_n: int = 10) -> List[Dict]:
        """Zwraca ostatnie n procesów"""
        return self.historia_procesow[-ostatnie_n:] if ostatnie_n > 0 else self.historia_procesow
    
    def pobierz_wektor(self) -> Optional[Any]:
        """Zwraca ostatni Finalny Wektor"""
        return self.ostatni_wektor
    
    def register_hook(self, hook: Callable) -> None:
        """Rejestruje hook wołany po każdym procesie"""
        self._hooks.append(hook)
    
    def _on_process(self, wynik: Dict) -> None:
        for hook in self._hooks:
            try:
                hook(wynik)
            except Exception as e:
                if self._verbose:
                    logger.warning(f"[HOOK ERROR] {e}")


# =============================================================================
# ROZSZERZENIE — INTEGRACJA Z SYSTEMEM
# =============================================================================

class BenyCore:
    """
    BENY CORE — Rozszerzenie Silnika B o integrację z systemem.
    
    Dodaje:
    • Pamięć logiczną (GEON_MEM_Ω)
    • Synchronizację z OŁSii CORE (równowaga serce ↔ logika)
    • Kontekst dla MetaGovernor
    • Stan dla G_CORE
    • Fragmenty dla NARRATIVE
    """
    def __init__(self, verbose: bool = True):
        self.silnik = SilnikB(verbose=verbose)
        self.pamiec_logiczna: deque = deque(maxlen=100)
        self.logic_sync = 0.0
        self.ostatni_poziom = "BALANS"
        self._verbose = verbose
        self._sync_hooks: List[Callable] = []
    
    def process(self, raw_input: Dict) -> Dict:
        """Przetwarza dane i synchronizuje z systemem"""
        wynik = self.silnik.process(raw_input)
        wektor = wynik.get("finalny_wektor")
        
        # Zapis do pamięci logicznej
        self.pamiec_logiczna.append({
            "timestamp": time.time(),
            "wektor": wektor,
            "sync": self.logic_sync
        })
        
        # Aktualizacja poziomu logicznego
        if wektor is not None:
            self.ostatni_poziom = "TWARDA" if isinstance(wektor, dict) and wektor.get("status") == "OK" else "BALANS"
        else:
            self.ostatni_poziom = "MIĘKKA"
        
        # Hooki synchronizacji
        self._on_sync(wynik)
        
        return wynik
    
    def synchronizuj_z_olsii(self, serce: Dict) -> None:
        """
        Synchronizuje z OŁSii CORE — równowaga serce ↔ logika
        """
        # Prosta synchronizacja: logika dostosowuje się do serca
        stabilnosc = serce.get("stabilnosc", 0.5)
        self.logic_sync = stabilnosc * 0.6 + 0.4 * (1 - self.logic_sync) * 0.2
        self.logic_sync = max(0.0, min(1.0, self.logic_sync))
        
        if self._verbose:
            logger.info(f"🔄 LOGIC SYNC: serce={stabilnosc:.2f} → logic={self.logic_sync:.2f}")
    
    def get_kontekst_governor(self) -> Dict:
        """Zwraca kontekst dla MetaGovernor"""
        wektor = self.silnik.ostatni_wektor
        return {
            "logic_vector": wektor,
            "logic_confidence": self.logic_sync,
            "logic_entropy": 1.0 - self.logic_sync,
            "logic_level": self.ostatni_poziom
        }
    
    def get_autopilot_state(self) -> Dict:
        """Zwraca stan dla G_CORE"""
        wektor = self.silnik.ostatni_wektor
        return {
            "mode": "BENY_CORE",
            "stability": self.logic_sync,
            "energy": 0.5 + self.logic_sync * 0.3,
            "pressure": 1.0 - self.logic_sync,
            "resilience": self.logic_sync * 0.8 + 0.2,
            "logic_vector": wektor
        }
    
    def get_narrative_fragments(self, n: int = 3) -> List[Dict]:
        """Zwraca fragmenty narracyjne z logiki"""
        fragments = []
        wektor = self.silnik.ostatni_wektor
        if wektor is not None:
            fragments.append({
                "source": "BENY_CORE",
                "content": f"Logika: {wektor} | sync={self.logic_sync:.2f}",
                "energy": self.logic_sync
            })
        
        # Dodaj fragmenty z pamięci logicznej
        for entry in list(self.pamiec_logiczna)[-n:]:
            if entry.get("wektor") is not None:
                fragments.append({
                    "source": "BENY_MEMORY",
                    "content": f"Wektor: {entry['wektor']} | sync={entry.get('sync', 0):.2f}",
                    "energy": self.logic_sync
                })
        
        return fragments[:n]
    
    def register_sync_hook(self, hook: Callable) -> None:
        """Rejestruje hook synchronizacji"""
        self._sync_hooks.append(hook)
    
    def _on_sync(self, data: Dict) -> None:
        for hook in self._sync_hooks:
            try:
                hook(data)
            except Exception as e:
                if self._verbose:
                    logger.warning(f"[HOOK ERROR] sync: {e}")
    
    def status(self) -> Dict:
        """Zwraca status BENY CORE"""
        return {
            **self.silnik.status(),
            "logic_sync": self.logic_sync,
            "poziom": self.ostatni_poziom,
            "pamiec_logiczna": len(self.pamiec_logiczna)
        }


