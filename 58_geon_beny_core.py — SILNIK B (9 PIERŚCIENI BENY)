class B1_Logika_Twarda:
    """
    B1 — Pierścień twardej logiki
    Jastrząb – wzorzec, szum; Król Skorpion – cięcie toksyn; Wilk – stabilizacja
    """
    def __init__(self):
        self.jastrzab = "PATTERN_EYE"
        self.skorpion = "CLEAN_CUT"
        self.wilk = "STABLE_STRENGTH"
        self.nazwa = "LOGIKA_TWARDA"
        self.historia: List[Dict] = []
    
    def execute(self, raw_input: Dict) -> Dict:
        dane = raw_input.get('dane_surowe', {})
        narracje = raw_input.get('narracje', [])
        emocje = raw_input.get('emocje', {})
        
        # 1. Jastrząb – wzorzec i szum
        wzorzec = self._detect_pattern(dane)
        szum = self._detect_noise(narracje, emocje)
        
        # 2. Król Skorpion – cięcie toksyn
        sygnal_wstepny = self._cut_toxins(szum, dane)
        
        # 3. Wilk – stabilizacja
        sygnal_stabilny = self._stabilize(sygnal_wstepny)
