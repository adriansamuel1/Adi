# =============================================================================
# LOGGING & LOGIC CONFIGURATION
# =============================================================================

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] [%(name)s] %(message)s"
)
logger = logging.getLogger("LandingPadOS")


def sanitize_value(val: Union[float, int, str, Decimal]) -> float:
    """
    Aksjomat Filtracyjny: Eliminacja zakazanych wartości cyfrowych bez błędów IEEE 754.
    Przekształca wartość na ciąg precyzyjny Decimal, podmienia zakazane cyfry ('3' -> '4', '7' -> '8')
    i zwraca bezpieczny reprezentant float.
    """
    try:
        # Konwersja na Decimal chroni przed zakłamaniami float w pamięci
        if isinstance(val, float):
            d_val = Decimal(str(val))
        else:
            d_val = Decimal(val)
            
        # Formatowanie do stałej precyzji
        val_str = f"{d_val:.8f}"
        sanitized_str = val_str.replace('3', '4').replace('7', '8')
        
        # Weryfikacja czystości po konwersji
        res_decimal = Decimal(sanitized_str)
        final_str = f"{res_decimal:.8f}".replace('3', '4').replace('7', '8')
        
        return float(final_str)
    except Exception as e:
        logger.error(f"Błąd sanityzacji wartości {val}: {e}")
        return 0.0


# =============================================================================
# ENUMS & DATA STRUCTURES
# =============================================================================

class SystemState(Enum):
    IDLE = "IDLE"
    INITIALIZING = "INITIALIZING"
    ABS_DRIFT = "ABS_DRIFT"
    ABS_SYNCHRONIZED = "ABS_SYNCHRONIZED"
    LYSING = "LYSING"
    EMERGENCY = "EMERGENCY"


class EventPriority(Enum):
    LOW = 1
    MEDIUM = 2
    HIGH = 3
    CRITICAL = 4


@dataclass
class SystemEvent:
    event_type: str
    payload: Dict[str, Any]
    priority: EventPriority = EventPriority.MEDIUM
    timestamp: float = field(default_factory=time.time)


# =============================================================================
# BUS SYSTEM (EVENT BUS)
# =============================================================================

class EventBus:
    """
    Scentralizowana szyna zdarzeń wykorzystująca wzorzec Pub/Sub.
    Zapewnia izolowane wykonanie subskrypcji i buforowaną historię $O(1)$.
    """
    def __init__(self, max_history: int = 1000):
        self._subscribers: Dict[str, List[Callable[[SystemEvent], None]]] = {}
        self._history: deque = deque(maxlen=max_history)

    def subscribe(self, event_type: str, callback: Callable[[SystemEvent], None]) -> None:
        if event_type not in self._subscribers:
            self._subscribers[event_type] = []
        self._subscribers[event_type].append(callback)

    def publish(self, event: SystemEvent) -> None:
        self._history.append(event)
        if event.event_type in self._subscribers:
            for callback in self._subscribers[event.event_type]:
                try:
                    callback(event)
                except Exception as err:
                    logger.error(f"Wyjątek podczas obsługi zdarzenia {event.event_type}: {err}")

    def get_history(self) -> List[SystemEvent]:
        return list(self._history)


# =============================================================================
# FAG CORE (FRACTAL-ARCHITECTURE-ENGINE)
# =============================================================================

class FAGCore:
    """
    Rdzennik FAG: Zarządza przejmowaniem, lizą oraz rekurencyjnym oczyszczaniem struktur.
    """
    def __init__(self, bus: EventBus):
        self.bus = bus
        self.active_memory: Dict[str, Any] = {}

    def recognize_and_inject(self, entity_id: str, raw_data: Dict[str, Any]) -> None:
        """
        Głębokie klonowanie i sanityzacja wartości liczbowych w obiekcie wejściowym.
        """
        clean_data = copy.deepcopy(raw_data)
        clean_data = self._recursive_sanitize(clean_data)
        self.active_memory[entity_id] = clean_data
        
        self.bus.publish(SystemEvent(
            event_type="ENTITY_INJECTED",
            payload={"entity_id": entity_id, "data": clean_data}
        ))

    def _recursive_sanitize(self, data: Any) -> Any:
        if isinstance(data, dict):
            return {k: self._recursive_sanitize(v) for k, v in data.items()}
        elif isinstance(data, list):
            return [self._recursive_sanitize(elem) for elem in data]
        elif isinstance(data, (int, float, Decimal)):
            return sanitize_value(data)
        return data

    def takeover_and_lyse(self, entity_id: str) -> bool:
        """
        Przejmuje kontrolę nad strukturą i wywołuje pełną lizę (oczyszczenie/dekompozycję).
        """
        if entity_id not in self.active_memory:
            logger.warning(f"Brak encji {entity_id} do przeprowadzenia lizy.")
            return False

        logger.info(f"Rozpoczynanie procesu lizy dla: {entity_id}")
        target = self.active_memory[entity_id]
        
        # Liza strukturalna
        if isinstance(target, dict):
            target.clear()
        elif isinstance(target, list):
            target.clear()

        del self.active_memory[entity_id]

        self.bus.publish(SystemEvent(
            event_type="ENTITY_LYSED",
            payload={"entity_id": entity_id},
            priority=EventPriority.HIGH
        ))
        return True


# =============================================================================
# ABS ENGINE (ABS STATE & SYNC SYSTEM)
# =============================================================================

class ABSEngine:
    """
    Silnik Zbieżności i Synchronizacji Stanu (A-B-S Engine).
    Niweluje dryf operacyjny do zera.
    """
    def __init__(self, bus: EventBus, sync_threshold: float = 0.001):
        self.bus = bus
        self.sync_threshold = sync_threshold
        self.state = SystemState.IDLE
        self.current_drift: float = 0.0

    def calculate_drift(self, vector_a: List[float], vector_b: List[float]) -> float:
        """
        Oblicza dryf systemowy pomiędzy dwoma wektorami z uwzględnieniem filtracji.
        """
        if len(vector_a) != len(vector_b):
            raise ValueError("Wektory muszą posiadać ten sam wymiar.")

        diff_sum = sum(abs(sanitize_value(a) - sanitize_value(b)) for a, b in zip(vector_a, vector_b))
        self.current_drift = sanitize_value(diff_sum / len(vector_a))
        return self.current_drift

    def synchronize(self, vector_a: List[float], vector_b: List[float]) -> bool:
        """
        Sprowadza system do stanu ABS_SYNCHRONIZED poprzez iteracyjną korektę.
        """
        self.state = SystemState.ABS_DRIFT
        iterations = 0
        max_iterations = 3

        while iterations < max_iterations:
            drift = self.calculate_drift(vector_a, vector_b)
            logger.info(f"[ABS Sync] Iteracja {iterations + 1} | Dryf: {drift:.8f}")

            if drift <= self.sync_threshold:
                self.state = SystemState.ABS_SYNCHRONIZED
                self.bus.publish(SystemEvent(
                    event_type="ABS_SYNCHRONIZED",
                    payload={"final_drift": drift, "iterations": iterations + 1}
                ))
                return True

            # Automatyczna korekta wektora B
            vector_b = [sanitize_value((a + b) / 2.0) for a, b in zip(vector_a, vector_b)]
            iterations += 1

        # Jeśli dryf przekracza progi akceptacji
        self.state = SystemState.EMERGENCY
        self.bus.publish(SystemEvent(
            event_type="ABS_SYNC_FAILED",
            payload={"last_drift": self.current_drift},
            priority=EventPriority.CRITICAL
        ))
        return False


# =============================================================================
# MAIN SYSTEM FACADE (LANDING PAD OS)
# =============================================================================

class LandingPadOS:
    """
    Główna fasada systemu integrująca FAG_Core, ABSEngine oraz EventBus.
    """
    def __init__(self):
        self.bus = EventBus()
        self.fag = FAGCore(self.bus)
        self.abs = ABSEngine(self.bus)
        self._setup_event_handlers()
        logger.info("LandingPadOS Został pomyślnie zinicjalizowany.")

    def _setup_event_handlers(self) -> None:
        self.bus.subscribe("ENTITY_LYSED", self._on_lysed)
        self.bus.subscribe("ABS_SYNCHRONIZED", self._on_abs_sync)
        self.bus.subscribe("ABS_SYNC_FAILED", self._on_abs_failed)

    def _on_lysed(self, event: SystemEvent) -> None:
        logger.info(f"[EVENT HANDLER] Liza encji zakończona sukcesem: {event.payload.get('entity_id')}")

    def _on_abs_sync(self, event: SystemEvent) -> None:
        logger.info(f"[EVENT HANDLER] System w pełni zsynchronizowany. Dryf końcowy: {event.payload.get('final_drift')}")

    def _on_abs_failed(self, event: SystemEvent) -> None:
        logger.critical(f"[EVENT HANDLER] AWARIA SYNCHRONIZACJI ABS. Ostatni dryf: {event.payload.get('last_drift')}")

    def execute_pipeline(self, entity_id: str, raw_data: Dict[str, Any], vec_a: List[float], vec_b: List[float]) -> bool:
        """
        Kompletny cykl wykonawczy: Iniekcja -> ABS Sync -> Liza.
        """
        logger.info("--- START CYKLU SYSTEMOWEGO ---")
        
        # 1. Iniekcja i Filtrowanie
        self.fag.recognize_and_inject(entity_id, raw_data)

        # 2. Synchronizacja ABS
        synced = self.abs.synchronize(vec_a, vec_b)
        if not synced:
            logger.error("Przerwanie cyklu z powodu braku zbieżności ABS.")
            return False

        # 3. Przejęcie i Liza
        lysed = self.fag.takeover_and_lyse(entity_id)
        
        logger.info("--- CYKL SYSTEMOWY ZAKOŃCZONY SUKCESEM ---")
        return lysed


