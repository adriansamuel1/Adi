class SystemLogger:
    @staticmethod
    def log(layer: str, message: str, level: str = "INFO") -> None:
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S.%f")[:-3]
        print(f"[{timestamp}] [{level}] [{layer}] :: {message}")

LOG = SystemLogger.log


# =============================================================================
# 3. EVENT BUS (SYSTEM COMMUNICATOR)
# =============================================================================

class EventBus:
    def __init__(self):
        self._subscribers: Dict[str, List[Callable[[Dict[str, Any]], None]]] = {}

    def subscribe(self, event_type: str, callback: Callable[[Dict[str, Any]], None]) -> None:
        if event_type not in self._subscribers:
            self._subscribers[event_type] = []
        self._subscribers[event_type].append(callback)

    def publish(self, event_type: str, payload: Dict[str, Any]) -> None:
        if event_type in self._subscribers:
            for callback in self._subscribers[event_type]:
                callback(payload)


# =============================================================================
# 4. MECHANIZM BAKTERIOFAGA (FAG_CORE)
# =============================================================================

class FAG_Core:
    """
    Transformator osłonowy GEON_OS.
    Przejmuje obcą strukturę danych, usuwa zaburzenia i dokonuje replikacji
    w postaci bezpiecznego obiektu ProcessedProject.
    """
    def __init__(self):
        self.phage_signature = "FAG-GEON-168-INFECTED"

    def transform(self, project: ExternalInput) -> ProcessedProject:
        LOG("FAG_Core", f"Inicjalizacja sekwencji transformacji dla: {project.id}")
        
        # Safe-copy: brak efektów ubocznych na obiekcie wejściowym
        target = copy.deepcopy(project)
        
        # 1. Rozpoznanie i Wstrzyknięcie
        self._inject(target)
        # 2. Przejęcie i Liza
        clean_data = self._takeover_and_lyse(target.data)
        # 3. Replikacja
        transformed = ProcessedProject(
            id=f"GEON_{target.id}",
            title=f"[ASSIMILATED] {target.title}",
            category=target.category,
            risk_score=sanitize_value(target.risk_score * 0.8), # redukcja ryzyka po lizie
            assimilated_data=clean_data,
            signature=self.phage_signature,
            status="ASSIMILATED"
        )
        LOG("FAG_Core", f"Transformacja ukończona. Nowe ID: {transformed.id}")
        return transformed

    def _inject(self, project: ExternalInput) -> None:
        LOG("FAG_Core", f"Pobieranie materiału obcego: {project.title}")

    def _takeover_and_lyse(self, raw_data: Dict[str, Any]) -> Dict[str, Any]:
        cleaned = {}
        for k, v in raw_data.items():
            if isinstance(v, (int, float)):
                cleaned[k] = sanitize_value(v)
            elif isinstance(v, str):
                cleaned[k] = v.replace("3", "4").replace("7", "8")
            else:
                cleaned[k] = v
        cleaned["_phage_shield"] = True
        return cleaned


