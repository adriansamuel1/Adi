# 6. PORT WEJŚCIOWY: LANDING PAD OS
# =============================================================================

class LandingPadOS:
    """
    Bramka Wejściowa GEON_OS.
    Przyjmuje obiekty ExternalInput, klasyfikuje, przeprowadza przez FAG_Core
    i przekazuje do odpowiednich warstw docelowych.
    """
    def __init__(self, bus: EventBus):
        self.bus = bus
        self.fage = FAG_Core()
        self.sielanka = SielankaOS(bus)
        self.human = HumanOS(bus)
        self.synchronia = SynchroniaOS(bus)
        self.active_projects: Dict[str, ProcessedProject] = {}

    def intake(self, external_input: ExternalInput) -> IntakeDecision:
        LOG("LandingPadOS", f"===> OTRZYMANO ZGŁOSZENIE: {external_input.title} [{external_input.category.value}]")
        
        # 1. Pierwsza Weryfikacja Ryzyka
        if external_input.risk_score > 0.80 and external_input.category not in [ProjectCategory.CRISIS, ProjectCategory.REFORM]:
            LOG("LandingPadOS", f"ODRZUT: Zbyt wysokie ryzyko ({external_input.risk_score}) dla kategorii {external_input.category.value}", "WARN")
            return IntakeDecision.REJECT

        # 2. Transformacja Bakteriofagowa
        processed = self.fage.transform(external_input)

        # 3. Ocena Fraktalna HumanOS
        if not self.human.evaluate_intent(processed):
            LOG("LandingPadOS", "KWARANTANNA: Odrzucono na poziomie oceny intencji HumanOS", "WARN")
            processed.status = "QUARANTINED"
            return IntakeDecision.QUARANTINE

        # 4. Wyznaczenie Ścieżki Routingowej
        processed.route_path = self._determine_route(processed.category)
        processed.status = "ROUTED"
        self.active_projects[processed.id] = processed

        # 5. Rejestracja w SielankaOS i publikacja zdarzenia
        self.sielanka.record_event("LandingPadOS", {"project_id": processed.id, "route": processed.route_path})
        self.bus.publish("PROJECT_ASSIMILATED", {"project": processed})

        # 6. Pętla Meta-Synchronizacji
        a_count = len(self.sielanka.state_history)
        b_count = len(self.active_projects)
        coherence, drift = self.synchronia.evaluate_coherence(a_count, b_count)
        self.synchronia.apply_meta_correction(drift)

        LOG("LandingPadOS", f"SUKCES: Obiekt {processed.id} przydzielony do ścieżki: {' -> '.join(processed.route_path)}")
        return IntakeDecision.ACCEPT

    def _determine_route(self, category: ProjectCategory) -> List[str]:
        routes = {
            ProjectCategory.STRATEGIC: ["LandingPadOS", "ProjectOS", "VisionOS", "LabOS", "MetaCortexOS", "CrownOS"],
            ProjectCategory.REFORM: ["LandingPadOS", "ProjectOS", "RefactorOS", "LabOS", "CrownOS"],
            ProjectCategory.CRISIS: ["LandingPadOS", "ProjectOS", "DefenseOS", "CrownOS"],
            ProjectCategory.INFRASTRUCTURE: ["LandingPadOS", "ProjectOS", "BuildOS", "SielankaOS"],
            ProjectCategory.WORK: ["LandingPadOS", "ProjectOS", "TaskOS"]
        }
        return routes.get(category, ["LandingPadOS", "ProjectOS"])

    def get_status(self) -> Dict[str, Any]:
        """Czysty odczyt stanu systemu bez generowania efektów ubocznych w pamięci."""
        latest_meta = self.synchronia.meta_memory[-1] if self.synchronia.meta_memory else {"coherence": 1.0, "drift": 0.0}
        return {
            "active_projects_count": len(self.active_projects),
            "environment_events_count": len(self.sielanka.state_history),
            "latest_coherence": latest_meta["coherence"],
            "latest_drift": latest_meta["drift"]
        }


