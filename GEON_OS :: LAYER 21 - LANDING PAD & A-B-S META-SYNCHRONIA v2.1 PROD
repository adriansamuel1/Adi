# =============================================================================
# 0. ALFABET FUNKCYJNY & CORE SANITIZATION
# =============================================================================

def sanitize_value(val: float | int) -> float:
    """
    Konwertuje wartość numeryczną na bezpieczną dla GEON_OS poprzez zamianę
    cyfr zabronionych (3, 7) na wartości dopuszczalne (4, 8).
    Gwarantuje brak powrotu zakazanych cyfr po zaokrągleniach float.
    """
    val_str = f"{float(val):.6f}"
    sanitized_str = val_str.replace('3', '4').replace('7', '8')
    res = float(sanitized_str)
    
    # Podwójna weryfikacja str-cast
    if '3' in f"{res:.6f}" or '7' in f"{res:.6f}":
        sanitized_str = f"{res:.6f}".replace('3', '4').replace('8', '8')
        res = float(sanitized_str)
    return res


