class SielankaOS:
    """Fraktal A - Baza Środowiskowa / Kontekst Stabilny."""
    def __init__(self, bus: EventBus):
        self.bus = bus
        self.state_history: List[Dict[str, Any]] = []

    def record_event(self, source: str, event_data: Dict[str, Any]) -> None:
        entry = {
            "timestamp": datetime.now(),
            "source": source,
            "data": event_data
        }
        self.state_history.append(entry)
        LOG("SielankaOS", f"Zarejestrowano zdarzenie środowiskowe z {source}")


class HumanOS:
    """Fraktal B - Logika Decyzyjna i Modelowanie Intencji."""
    def __init__(self, bus: EventBus):
        self.bus = bus
        self.decision_sequence = [4, 1, 2, 5, 6, 6, 5, 8, 1]

    def evaluate_intent(self, project: ProcessedProject) -> bool:
        LOG("HumanOS", f"Ewaluacja pętli decyzyjnej dla: {project.id}")
        # Algorytm oceny na podstawie wektora intencji
        score = sum(self.decision_sequence) / len(self.decision_sequence)
        threshold = 4.0
        approved = score >= threshold and project.risk_score <= 0.8
        LOG("HumanOS", f"Wynik oceny intencji: {approved} (Score: {score:.2f})")
        return approved


class SynchroniaOS:
    """Fraktal S - Meta-Synchronizator i Arbiter Spójności."""
    def __init__(self, bus: EventBus):
        self.bus = bus
        self.coherence_threshold = 0.80
        self.meta_memory: List[Dict[str, float]] = []

    def evaluate_coherence(self, a_state: int, b_state: int) -> Tuple[float, float]:
        """Oblicza spójność i dryf systemu."""
        raw_coherence = 1.0 - (abs(a_state - b_state) / 10.0)
        coherence = sanitize_value(max(0.0, min(1.0, raw_coherence)))
        drift = sanitize_value(1.0 - coherence)
        
        self.meta_memory.append({
            "coherence": coherence,
            "drift": drift
        })
        LOG("SynchroniaOS", f"Pomiary meta-spójności :: Coherence: {coherence:.4f} | Drift: {drift:.4f}")
        return coherence, drift

    def apply_meta_correction(self, drift: float) -> None:
        if drift > (1.0 - self.coherence_threshold):
            LOG("SynchroniaOS", f"KOREKTA SYSTEMOWA! Dryf {drift:.4f} przekroczył próg.", "WARNING")
            self.bus.publish("SYSTEM_RECALIBRATE", {"drift": drift, "action": "FORCE_REALIGNMENT"})
        else:
            LOG("SynchroniaOS", "System w stanie równowagi fraktalnej.")


