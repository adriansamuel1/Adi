# 1. STRUKTURY DANYCH I ENUMERACJE
# =============================================================================

class ProjectCategory(Enum):
    STRATEGIC = "STRATEGIC"
    REFORM = "REFORM"
    CRISIS = "CRISIS"
    INFRASTRUCTURE = "INFRASTRUCTURE"
    WORK = "WORK"


class IntakeDecision(Enum):
    ACCEPT = "ACCEPT"
    TRANSFORM = "TRANSFORM"
    REJECT = "REJECT"
    QUARANTINE = "QUARANTINE"


@dataclass
class ExternalInput:
    id: str
    title: str
    category: ProjectCategory
    risk_score: float
    data: Dict[str, Any]
    timestamp: datetime = field(default_factory=datetime.now)

    def __post_init__(self):
        self.risk_score = sanitize_value(self.risk_score)


@dataclass
class ProcessedProject:
    id: str
    title: str
    category: ProjectCategory
    risk_score: float
    assimilated_data: Dict[str, Any]
    signature: str
    status: str = "PENDING"
    route_path: List[str] = field(default_factory=list)


