class GeonKombajnFull:
    """
    Główny silnik GEON_KOMBAJN_FULL v4.0.
    Wpięcie docelowe: kombajn/geon_kombajn_full.py w GEON_DRAGON_OS.
    """
    
    def __init__(self) -> None:
        self.flow_engine = EmotionalFlowEngine9D()
        self.fag_core = FAG_Core()
        self.mind_engine = FMPCMindEngine()
        self.world_engine = WorldVectorEngine()
        self.olsii = OlsiiHeartEngine()
        self.geon_guardian = Geon168Guardian()
        self.vision = VisionOS()
        self.meta = MetaAggregator()
        
        self.history: List[KombajnResult] = []
        self.stats = {
            "runs": 0,
            "decisions": {"AKCEPTUJĘ": 0, "BLOKADA": 0},
            "flows": {"GREEN": 0, "YELLOW": 0, "RED": 0},
        }
        
        LOG("GEON_KOMBAJN_FULL", "INIT", "🐉 Kombajn poznawczy v4.0 OMEGA aktywowany")
        LOG("GEON_KOMBAJN_FULL", "INIT", f"   Sygnatura: {FRACTAL_SIGNATURE}")
    
    def run(self, inp: KombajnInput) -> KombajnResult:
        start = time.time()
        self.stats["runs"] += 1
        
        LOG("GEON_KOMBAJN_FULL", "RUN", f"Iskra: {inp.iskra[:80]}")
        
        # 0. FAG_Core — transformacja iskry
        transformed_text = self.fag_core.process(inp.iskra)
        fag_transformed = transformed_text != inp.iskra
        
        # 1. FLOW — pełny 9D
        flow_status = self.flow_engine.evaluate(transformed_text, inp.meta)
        self.stats["flows"][flow_status.flow_level.value] += 1
        
        vector_9d = flow_status.vector_9d
        
        # 2. MIND — FMPC
        mind_status = self.mind_engine.compute(inp.human_profile)
        
        # 3. WORLD — Dom / Wspólnota / Planeta / Meta-wektor
        world_status = self.world_engine.compute(
            fmpc=mind_status,
            dom=inp.dom,
            wsp=inp.wspolnota,
            plan=inp.planeta,
        )
        
        # 4. OŁSii — serce
        olsii_out = self.olsii.process(transformed_text, inp.meta)
        
        # 5. GEON_168 — strażnik integralności
        geon_out = self.geon_guardian.analyze(vector_9d, olsii_out["vibe"])
        
        # 6. VISION — wizja
        vision = self.vision.generate(transformed_text, flow_status, mind_status)
        
        # 7. META — agregacja
        meta_out = self.meta.weigh(olsii_out, geon_out)
        
        # 8. Decyzja końcowa
        decision = KombajnDecision(
            global_decision=meta_out["decyzja"],
            geon_status=geon_out["status"],
            geon_score=geon_out["score"],
            olsii_response=olsii_out["response"],
            vibe=olsii_out["vibe"],
            vision_core=vision["core"],
            vision_trajectory=vision["trajectory"],
            conflicts=meta_out["conflicts"],
            protocol_168_ok=meta_out["protocol_168_ok"],
        )
        self.stats["decisions"][decision.global_decision] += 1
        
        elapsed_ms = round((time.time() - start) * 1000.0, 2)
        
        result = KombajnResult(
            input=inp,
            flow=flow_status,
            mind=mind_status,
            world=world_status,
            vector=vector_9d,
            decision=decision,
            fag_transformed=fag_transformed,
            elapsed_ms=elapsed_ms,
        )
        
        self.history.append(result)
        if len(self.history) > 300:
            self.history.pop(0)
        
        LOG(
            "GEON_KOMBAJN_FULL",
            "COMPLETE",
            f"Decyzja={decision.global_decision}, Vibe={decision.vibe}, "
            f"GEON={decision.geon_status}({decision.geon_score}), "
            f"Stability={flow_status.stability:.3f}",
        )
        
        return result
    
    def get_stats(self) -> Dict[str, Any]:
        return {
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "runs": self.stats["runs"],
            "decisions": self.stats["decisions"],
            "flows": self.stats["flows"],
            "history_size": len(self.history),
        }
    
    def last_result(self) -> Optional[KombajnResult]:
        return self.history[-1] if self.history else None