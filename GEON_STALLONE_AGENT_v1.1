class KernelHookManager:
    """
    Zarządza hookami do GEON_OS_KERNEL (71).
    Hooki przed- i po-cyklu, przerwania systemowe.
    """
    def __init__(self, agent_id: str = "STALLONE_AGENT"):
        self.agent_id = agent_id
        self.pre_hooks: List[Callable] = []
        self.post_hooks: List[Callable] = []
        self.interrupt_handlers: Dict[str, Callable] = {}
        self.priority = AGENT_PRIORITY

    def register_pre_hook(self, hook: Callable) -> None:
        self.pre_hooks.append(hook)

    def register_post_hook(self, hook: Callable) -> None:
        self.post_hooks.append(hook)

    def register_interrupt_handler(self, interrupt_type: str, handler: Callable) -> None:
        self.interrupt_handlers[interrupt_type] = handler

    def trigger_pre_hooks(self, context: Dict) -> Dict:
        for hook in self.pre_hooks:
            try:
                context = hook(context)
            except Exception as e:
                log(f"Pre-hook error: {e}", "WARN")
        return context

    def trigger_post_hooks(self, result: Dict) -> Dict:
        for hook in self.post_hooks:
            try:
                result = hook(result)
            except Exception as e:
                log(f"Post-hook error: {e}", "WARN")
        return result

    def handle_interrupt(self, interrupt_type: str, data: Dict) -> Dict:
        if interrupt_type in self.interrupt_handlers:
            return self.interrupt_handlers[interrupt_type](data)
        return {"status": "ignored", "reason": f"No handler for {interrupt_type}"}

    def get_priority(self) -> int:
        return self.priority


class SystemInterruptHandler:
    """
    Obsługa przerwań systemowych – np. emergency stop, rekonfiguracja.
    """
    @staticmethod
    def emergency_stop(data: Dict) -> Dict:
        log("🔥 EMERGENCY STOP – natychmiastowe wstrzymanie działania!", "CRITICAL")
        return {"action": "EMERGENCY_STOP", "status": "HALTED"}

    @staticmethod
    def reconfigure(data: Dict) -> Dict:
        log(f"🔄 REKONFIGURACJA – nowe parametry: {data}", "INFO")
        return {"action": "RECONFIGURE", "status": "PENDING", "params": data}

    @staticmethod
    def soft_reset(data: Dict) -> Dict:
        log(f"🔁 SOFT RESET – przywrócenie domyślnych ustawień", "INFO")
        return {"action": "SOFT_RESET", "status": "COMPLETE"}


class PriorityScheduler:
    """
    Integracja z schedulerem priorytetów GEON_OS_KERNEL.
    Umożliwia ustalanie priorytetu i żądanie czasu procesora.
    """
    def __init__(self, agent_id: str = "STALLONE_AGENT"):
        self.agent_id = agent_id
        self.base_priority = AGENT_PRIORITY
        self.current_priority = self.base_priority
        self.quantum_used = 0
        self.quantum_limit = 10  # liczba cykli przed zezwoleniem na przejęcie

    def request_processing_time(self, urgency: float) -> bool:
        """
        Prosi o czas procesora. Zwraca True, jeśli agent może kontynuować.
        """
        # Jeśli priorytet został podniesiony, zawsze kontynuuj
        if self.current_priority > self.base_priority:
            return True

        # Jeśli zużyto kwantum, oddaj kontrolę
        if self.quantum_used >= self.quantum_limit:
            self.quantum_used = 0
            return False

        self.quantum_used += 1
        return True

    def raise_priority(self, urgency: float) -> None:
        """
        Podnosi priorytet w sytuacjach krytycznych.
        """
        if urgency > 0.8:
            self.current_priority = min(10, self.base_priority + 3)
        elif urgency > 0.5:
            self.current_priority = min(10, self.base_priority + 1)
        else:
            self.current_priority = self.base_priority

    def lower_priority(self) -> None:
        self.current_priority = self.base_priority
        self.quantum_used = 0

    def get_current_priority(self) -> int:
        return self.current_priority

