class GEONStalloneBridge:
    def __init__(self, trunk, heilong, osmiornica, team_core=None, os_kernel=None):
        self.trunk = trunk
        self.heilong = heilong
        self.osmiornica = osmiornica
        self.team_core = team_core
        self.os_kernel = os_kernel

        self.stallone = GEONStalloneModule(
            legacy_config={
                "heilong": True,
                "osmiornica": True,
                "olsii": True,
                "beny": True,
                "rings": True
            },
            agent_id="STALLONE_BRIDGE"
        )
        self.energy = 100.0
        self.fatigue = 0.0
        self.last_state = "IDLE"

        # Rejestracja hooków w OS Kernel
        if self.os_kernel:
            self._register_kernel_hooks()

    def _register_kernel_hooks(self):
        if hasattr(self.os_kernel, 'register_agent'):
            self.os_kernel.register_agent("STALLONE_AGENT", self.stallone.scheduler.get_current_priority())

    def map_environment(self, env: Dict[str, Any]) -> Dict[str, Any]:
        ctx = EnvironmentContext(
            threat_level=env.get("threat", 0.0),
            chaos_level=env.get("chaos", 0.0),
            emotional_pressure=env.get("emotional", 0.0),
            entropy=env.get("entropy", 5.0),
            terrain=env.get("terrain", "urban"),
            social_pressure=env.get("social", 0.0),
            resource_availability=env.get("resources", 100.0),
            time_active=env.get("time_active", 0.0),
        )
        return ctx.__dict__

    def map_challenge(self, ch: Dict[str, Any]) -> Dict[str, Any]:
        return {
            "impact": ch.get("impact", 10.0),
            "difficulty": ch.get("difficulty", 5.0),
            "long_term": ch.get("long_term", False),
            "emotional_weight": ch.get("emotional_weight", 0.5),
        }

    def process(self, env: Dict[str, Any], ch: Dict[str, Any]) -> Dict[str, Any]:
        context = self.map_environment(env)
        challenge = self.map_challenge(ch)

        # Jeśli mamy zadanie od TEAM_CORE, dodaj je do kontekstu
        if self.team_core and self.stallone.team.has_task():
            task = self.stallone.team.get_current_task()
            context["team_task"] = task

        stallone_out = self.stallone.process_cycle(context, challenge)

        self.energy = stallone_out["metrics"]["energy"]
        self.fatigue = stallone_out["metrics"]["fatigue"]
        self.last_state = stallone_out["state"]

        self.heilong.receive_shadow_vector({
            "stealth": self.stallone.rambo.stealth_charge,
            "fatigue": self.fatigue,
            "state": self.last_state
        })

        self.osmiornica.route({
            "rocky_resilience": self.stallone.rocky.internal_resilience,
            "rambo_precision": self.stallone.rambo.precision_factor,
            "fractal": stallone_out.get("fractal_pulse", {})
        })

        self.trunk.update_meta_state({
            "stallone_state": self.last_state,
            "sri": stallone_out["metrics"]["sri"],
            "momentum": stallone_out["metrics"]["momentum"],
            "energy": self.energy,
            "fatigue": self.fatigue
        })

        # Raport do TEAM_CORE
        if self.team_core:
            self.stallone.team.report_completion({
                "status": stallone_out["state"],
                "score": stallone_out["metrics"]["score"]
            })

        return {
            "stallone_state": self.last_state,
            "stallone_output": stallone_out,
            "energy": self.energy,
            "fatigue": self.fatigue,
            "memory_resonance": stallone_out["metrics"]["memory_resonance"]
        }

