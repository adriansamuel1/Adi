class InstinctPredictor:
    def __init__(self):
        self.confidence_threshold = 0.8
        self.last_prediction = None

    def predict(self, history: List[Dict], context: Dict) -> Tuple[Optional[str], float]:
        if len(history) < 3:
            return None, 0.0
        recent_scores = [h.get("score", 50) for h in history[-5:]]
        if len(recent_scores) >= 3:
            trend = recent_scores[-1] - recent_scores[-3]
            last_state = history[-1].get("state", "")
            if trend > 10 and last_state in ["PRIME_MODE", "ULTRA_PRIME_FLOW"]:
                confidence = min(0.9, 0.6 + trend / 100)
                return last_state, confidence
            if trend < -10:
                return "SHADOW_MODE", 0.75
        terrain = context.get("terrain", "urban")
        if terrain == "cyber" and context.get("threat_level", 0) > 60:
            return "RAMBO_MODE", 0.85
        if terrain == "wilderness" and context.get("chaos_level", 0) < 30:
            return "ROCKY_MODE", 0.82
        return None, 0.0

