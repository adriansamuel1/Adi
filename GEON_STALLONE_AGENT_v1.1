class TeamCoreCommunicator:
    """
    Komunikacja z TEAM_CORE (77). Wymiana stanów, koordynacja, zadania.
    """
    def __init__(self, agent_id: str = "STALLONE_AGENT"):
        self.agent_id = agent_id
        self.team_state: Dict[str, Any] = {}
        self.assigned_task: Optional[Dict] = None
        self.shared_intent: Dict[str, float] = {}
        self.communication_log: List[Dict] = []

    def sync_state(self, state: Dict[str, Any]) -> None:
        """Wysyła stan agenta do TEAM_CORE."""
        self.team_state.update(state)
        log(f"[TEAM] Stan zsynchronizowany: {state.get('state', 'IDLE')}", "INFO")
        self.communication_log.append({"type": "sync", "state": state, "time": time.time()})

    def receive_task(self, task: Dict[str, Any]) -> None:
        """Odbiera zadanie od TEAM_CORE."""
        self.assigned_task = task
        log(f"[TEAM] Otrzymano zadanie: {task.get('name', 'UNKNOWN')}", "INFO")
        self.communication_log.append({"type": "task", "task": task, "time": time.time()})

    def report_completion(self, result: Dict[str, Any]) -> None:
        """Raportuje ukończenie zadania do TEAM_CORE."""
        log(f"[TEAM] Zadanie ukończone: {result.get('status', 'DONE')}", "INFO")
        self.communication_log.append({"type": "completion", "result": result, "time": time.time()})
        self.assigned_task = None

    def get_team_intent(self) -> Dict[str, float]:
        """Pobiera intencję zespołu (np. współczynniki koordynacji)."""
        return self.shared_intent

    def update_intent(self, intent: Dict[str, float]) -> None:
        """Aktualizuje intencję agenta dla zespołu."""
        self.shared_intent.update(intent)

    def has_task(self) -> bool:
        return self.assigned_task is not None

    def get_current_task(self) -> Optional[Dict]:
        return self.assigned_task

