class LongTermMemory:
    def __init__(self, max_patterns: int = 50):
        self.history: List[Dict[str, Any]] = []
        self.patterns: List[Dict[str, Any]] = []
        self.bias: Dict[str, float] = {"rocky": 0.0, "rambo": 0.0}
        self.max_patterns = max_patterns
        self.last_trend = 0.0

    def update(self, cycle_data: Dict[str, Any]) -> None:
        self.history.append(cycle_data)
        if len(self.history) > self.max_patterns:
            self.history.pop(0)
        self._extract_patterns()
        self._update_bias()

    def _extract_patterns(self) -> None:
        if len(self.history) < 5:
            return
        recent = self.history[-10:]
        states = [h.get("state", "") for h in recent]
        rocky_count = sum(1 for s in states if "ROCKY" in s)
        rambo_count = sum(1 for s in states if "RAMBO" in s)
        if rocky_count > rambo_count + 2:
            self.patterns.append({"trend": "rocky_dominant", "strength": rocky_count / len(states)})
        elif rambo_count > rocky_count + 2:
            self.patterns.append({"trend": "rambo_dominant", "strength": rambo_count / len(states)})
        if len(self.patterns) > 10:
            self.patterns.pop(0)

    def _update_bias(self) -> None:
        rocky_patterns = [p for p in self.patterns if p.get("trend") == "rocky_dominant"]
        rambo_patterns = [p for p in self.patterns if p.get("trend") == "rambo_dominant"]
        if rocky_patterns:
            avg = sum(p["strength"] for p in rocky_patterns) / len(rocky_patterns)
            self.bias["rocky"] = min(0.3, avg * 0.15)
        if rambo_patterns:
            avg = sum(p["strength"] for p in rambo_patterns) / len(rambo_patterns)
            self.bias["rambo"] = min(0.3, avg * 0.15)
        if len(self.history) >= 3:
            scores = [h.get("score", 50) for h in self.history[-3:]]
            self.last_trend = scores[-1] - scores[0]

    def get_adaptive_weight(self, base_weight: float) -> float:
        correction = self.bias["rocky"] - self.bias["rambo"]
        return max(0.0, min(1.0, base_weight + correction))

