class MemOmegaIntegrator:
    """
    Pełna integracja z GEON_MEM_Ω (45). Kwintesencja pamięci, rezonans.
    """
    def __init__(self, agent_id: str = "STALLONE_AGENT"):
        self.agent_id = agent_id
        self.quintessence: Dict[str, Any] = {}  # kwintesencja – wzorce kluczowe
        self.memory_resonance: float = 0.0
        self.last_recall: Optional[Dict] = None

    def store_pattern(self, pattern_id: str, data: Dict[str, Any]) -> None:
        """
        Zapisuje wzorzec w pamięci kwintesencji.
        """
        self.quintessence[pattern_id] = {
            "data": data,
            "timestamp": time.time(),
            "agent": self.agent_id
        }
        log(f"[MEM_Ω] Zapisano wzorzec: {pattern_id}", "INFO")

    def recall_pattern(self, pattern_id: str) -> Optional[Dict]:
        """
        Odczytuje wzorzec z pamięci kwintesencji.
        """
        if pattern_id in self.quintessence:
            self.last_recall = self.quintessence[pattern_id]
            self._update_resonance(self.quintessence[pattern_id])
            return self.quintessence[pattern_id]["data"]
        return None

    def find_similar_pattern(self, context: Dict[str, Any]) -> Optional[Tuple[str, float]]:
        """
        Szuka podobnego wzorca w pamięci kwintesencji (rezonans).
        Zwraca (pattern_id, similarity_score).
        """
        best_match = None
        best_score = 0.0

        for pid, entry in self.quintessence.items():
            data = entry["data"]
            # Prosta heurystyka podobieństwa – można rozbudować
            score = self._calculate_similarity(context, data)
            if score > best_score:
                best_score = score
                best_match = pid

        if best_match and best_score > 0.3:
            self.memory_resonance = best_score
            return best_match, best_score
        return None

    def _calculate_similarity(self, context: Dict, stored: Dict) -> float:
        """
        Oblicza podobieństwo między kontekstem a przechowywanym wzorcem.
        """
        # Podstawowa heurystyka – porównanie typów i wag
        score = 0.0
        for key in ["threat_level", "chaos_level", "terrain"]:
            if key in context and key in stored:
                if context[key] == stored[key]:
                    score += 0.5
                else:
                    # Im mniejsza różnica, tym wyższy wynik
                    try:
                        diff = abs(context[key] - stored[key])
                        score += max(0, 1.0 - diff / 100.0) * 0.5
                    except TypeError:
                        pass
        return min(1.0, score)

    def _update_resonance(self, entry: Dict) -> None:
        """
        Aktualizuje rezonans pamięci na podstawie odczytanego wzorca.
        """
        # Rezonans rośnie z czasem od ostatniego odczytu
        elapsed = time.time() - entry.get("timestamp", time.time())
        decay = math.exp(-elapsed / 3600.0)  # 1 godzina półtrwania
        self.memory_resonance = max(0.0, min(1.0, 0.5 + 0.5 * decay))

    def get_quintessence(self) -> Dict[str, Any]:
        return self.quintessence

    def get_resonance(self) -> float:
        return self.memory_resonance

    def clear(self) -> None:
        self.quintessence.clear()
        self.memory_resonance = 0.0

