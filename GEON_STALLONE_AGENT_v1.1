class RockyCore:
    def __init__(self, rebound_factor: float = 1.25):
        self.rebound_factor = rebound_factor
        self.internal_resilience = 0.0
        self.heart_drive_bonus = 0.0

    def execute(self, challenge: Dict[str, Any], micro_tactics: Dict[str, Any] = None) -> Dict[str, Any]:
        impact = challenge.get("impact", 10.0)
        difficulty = challenge.get("difficulty", 5.0)
        emotional_weight = challenge.get("emotional_weight", 0.5)
        absorbed_energy = (impact * self.rebound_factor + difficulty * 0.5) * (1 + self.heart_drive_bonus * 0.1)
        self.internal_resilience += absorbed_energy * 0.1
        return {
            "core": "ROCKY",
            "action": "Absorb & Endure",
            "resilience": f"Absorbed impact {impact:.1f}, difficulty {difficulty:.1f}. Fortitude built.",
            "heart_drive": f"Heart Engine active (bonus {self.heart_drive_bonus:.2f}). Long-term focus locked.",
