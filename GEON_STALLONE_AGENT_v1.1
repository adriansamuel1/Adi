class GEONStalloneModule:
    """
    Główny moduł operacyjny z pełną integracją v3.1.
    Rozszerzony o KERNEL, TEAM i MEM_Ω.
    """
    def __init__(self, legacy_config: Dict[str, Any] = None, agent_id: str = "STALLONE_AGENT"):
        # Rdzenie (bez zmian)
        self.rocky = RockyCore(rebound_factor=1.25)
        self.rambo = RamboCore(precision_factor=0.9)
        self.integrator = IntegratorStallone()
        self.fractal = FractalEngine()
        self.memory = LongTermMemory()
        self.instinct = InstinctPredictor()

        self.profile = StalloneProfile()
        if legacy_config:
            self.profile.legacy_config = legacy_config
            if "heilong" in legacy_config:
                self.profile.adaptive_bias["rambo"] += 0.1
            if "osmiornica" in legacy_config:
                self.profile.adaptive_bias["rocky"] += 0.05
            if "rings" in legacy_config:
                self.profile.adaptive_bias["rocky"] += 0.02
            if "olsii" in legacy_config:
                self.rocky.heart_drive_bonus = 0.2
            if "beny" in legacy_config:
                self.rambo.precision_boost = 0.15

        self.energy = 100.0
        self.fatigue = 0.0
        self.current_state = "IDLE"
        self.cycle_count = 0
        self.history: List[Dict[str, Any]] = []
        self.heilong_suggestion = {"strategy": "balanced_offensive", "priority": "medium"}

        # --- NOWE INTEGRACJE v1.1 ---
        self.agent_id = agent_id
        # Kernel
        self.kernel_hook = KernelHookManager(agent_id)
        self.interrupt_handler = SystemInterruptHandler()
        self.scheduler = PriorityScheduler(agent_id)
        # Rejestracja domyślnych przerwań
        self.kernel_hook.register_interrupt_handler("EMERGENCY_STOP", self.interrupt_handler.emergency_stop)
        self.kernel_hook.register_interrupt_handler("RECONFIGURE", self.interrupt_handler.reconfigure)
        self.kernel_hook.register_interrupt_handler("SOFT_RESET", self.interrupt_handler.soft_reset)
        # Team
        self.team = TeamCoreCommunicator(agent_id)
        # MemΩ
        self.mem_omega = MemOmegaIntegrator(agent_id)

        log(f"🐉 GEON_STALLONE_AGENT_v1.1 załadowany – ID: {agent_id}", "INFO")

    def calc_momentum(self) -> float:
        if len(self.history) < 2:
            return 50.0
        scores = [h.get("score", 50) for h in self.history[-3:]]
        avg_score = sum(scores) / len(scores)
        trend = scores[-1] - scores[0] if len(scores) > 1 else 0
        momentum = (avg_score * 0.6) + (trend * 0.4) + (self.energy * 0.1) - (self.fatigue * 0.2)
        return max(0.0, min(100.0, momentum))

    def calc_sri(self) -> float:
        heart = self.profile.heart
        shadow = self.profile.shadow
        resilience = self.rocky.internal_resilience / 100.0
        awareness = self.rambo.stealth_charge / 100.0
        fatigue_penalty = self.fatigue * 0.3 / 100.0
        sri = (heart * resilience + shadow * awareness) - fatigue_penalty
        if "heilong" in self.profile.legacy_config:
            sri += 0.1
        if self.profile.momentum > 70:
            sri *= 1.2
        return max(0.0, min(100.0, sri * 100))

    def update_fatigue(self, entropy: float) -> float:
        increment = (entropy * 0.1) + (2.0 if self.energy < 30.0 else 0.5)
        increment = math.log(1 + increment) * 1.5
        self.fatigue = min(100.0, self.fatigue + increment)
        return self.fatigue

    def adjust_energy(self, delta: float) -> None:
        terrain = self.profile.terrain_profile
        cost_mod = 1.0
        if terrain == "wilderness":
            cost_mod = 0.8
        elif terrain == "cyber":
            cost_mod = 1.2
        regen_factor = 0.5 + self.profile.heart * 0.3
        if delta < 0:
            self.energy = max(0.0, self.energy + delta * cost_mod)
        else:
            self.energy = min(100.0, self.energy + delta * regen_factor)

    def dispatch(self, state: str, context: Dict, challenge: Dict) -> Dict:
        output = {"state": state, "cycle": self.cycle_count}

        # Przerwania systemowe – sprawdzenie przed wykonaniem
        if self.kernel_hook.handle_interrupt("EMERGENCY_STOP", {}).get("status") == "HALTED":
            return {"state": "HALTED", "result": {"status": "EMERGENCY_STOP"}}

        # Wybór stanu
        if state == "ROCKY_MODE":
            micro = self.fractal.run(self.rambo, "A_Micro_Tactics", context)
            result = self.rocky.execute(challenge, micro)
            self.adjust_energy(result.get("absorbed_energy", 0) * 0.2)
            output["result"] = result

        elif state == "RAMBO_MODE":
            micro = self.fractal.run(self.rocky, "B_Micro_Stamina", context)
            result = self.rambo.execute(context, micro)
            self.adjust_energy(-8.0)
            output["result"] = result

        elif state == "BALANCE_MODE":
            rocky_out = self.rocky.execute(challenge)
            rambo_out = self.rambo.execute(context)
            chaos = context.get("chaos_level", 50)
            base_weight = 0.5 + 0.004 * (chaos - 50)
            adapted_weight = self.memory.get_adaptive_weight(base_weight)
            merged = self.integrator.merge(rocky_out, rambo_out, adapted_weight)
            self.adjust_energy(-3.0)
            output["result"] = merged

        elif state == "SHADOW_MODE":
            rambo_silent = self.rambo.shadow_ops(context)
            rocky_stab = self.rocky.stabilize()
            merged = self.integrator.merge_shadow(rambo_silent, rocky_stab, self.fatigue)
            self.fatigue = max(0.0, self.fatigue - 15.0)
            output["result"] = merged

        elif state == "PRIME_MODE":
            rocky_grow = self.rocky.growth(challenge)
            rambo_anal = self.rambo.analysis(context)
            merged = self.integrator.merge_prime(rocky_grow, rambo_anal, self.energy)
            self.adjust_energy(-5.0)
            output["result"] = merged

        elif state == "ULTRA_PRIME_FLOW":
            rocky_out = self.rocky.execute(challenge)
            rambo_out = self.rambo.execute(context)
            merged = self.integrator.merge(rocky_out, rambo_out, 0.4)
            self.adjust_energy(-2.0)
            output["result"] = merged
            output["ultra_bonus"] = {"speed": "+30%", "cost": "-20%", "score": "+15%"}

        elif state == "HYBRID_DRAGON_MODE":
            rocky_out = self.rocky.stabilize()
            rambo_out = self.rambo.analysis(context)
            merged = self.integrator.merge_dragon(rocky_out, rambo_out, self.heilong_suggestion)
            self.adjust_energy(-1.0)
            output["result"] = merged

        elif state == "MENTOR_OVERRIDE":
            result = self.rocky.mentor_override(context)
            self.adjust_energy(-2.0)
            output["result"] = result

        elif state == "OPERATOR_OVERRIDE":
            result = self.rambo.operator_override(context)
            self.adjust_energy(-10.0)
            output["result"] = result

        elif state == "PHOENIX_RECOVERY":
            phase1 = {"phase": "1/3", "action": "Emotional stabilization"}
            phase2 = {"phase": "2/3", "action": "Micro-noise clearing"}
            phase3 = {"phase": "3/3", "action": "Priority reconstruction"}
            self.energy = 80.0
            self.fatigue = 0.0
            self.rocky.internal_resilience = max(10.0, self.rocky.internal_resilience * 0.5)
            output["result"] = {
                "action": "PHOENIX_RECOVERY_2.0",
                "phases": [phase1, phase2, phase3],
                "status": "Energy restored to 80%, fatigue cleared, core stabilized."
            }

        elif state == "GLADIATOR":
            rocky_raw = self.rocky.execute(challenge)
            rambo_raw = self.rambo.execute(context)
            output["result"] = {
                "action": "GLADIATOR",
                "rocky_raw": rocky_raw,
                "rambo_raw": rambo_raw,
                "status": "Total force deployed. No filters. Reboot required."
            }
            self.energy = 5.0
            self.fatigue = 99.0

        else:
            output["result"] = {"status": "IDLE", "message": "No valid state executed"}

        # Post-hook – zapisz w pamięci kwintesencji
        self.mem_omega.store_pattern(f"cycle_{self.cycle_count}", {
            "state": state,
            "energy": self.energy,
            "fatigue": self.fatigue,
            "score": output.get("result", {}).get("score", 0)
        })

        return output

    def process_cycle(self, context: Dict[str, Any], challenge: Dict[str, Any]) -> Dict[str, Any]:
        self.cycle_count += 1
        entropy = context.get("entropy", 5.0)

        # --- HOOK PRE-CYCLE ---
        context = self.kernel_hook.trigger_pre_hooks(context)

        # --- SCHEDULER – sprawdzenie, czy agent może kontynuować ---
        urgency = max(context.get("threat_level", 0.0) / 100.0,
                      context.get("chaos_level", 0.0) / 100.0)
        self.scheduler.raise_priority(urgency)
        if not self.scheduler.request_processing_time(urgency):
            log("Agent oddaje kontrolę – kwantum wyczerpane", "INFO")
            return {"state": "PAUSED", "metrics": self.get_metrics()}

        # --- AKTUALIZACJA ---
        self.update_fatigue(entropy)
        self.profile.terrain_profile = context.get("terrain", "urban")

        # --- INSTINCT ---
        inst_state, inst_conf = self.instinct.predict(self.history, context)
        self.profile.instinct_confidence = inst_conf

        if inst_state and inst_conf > 0.8:
            state = inst_state
        else:
            state = self.integrator.select_state(
                context, challenge, self.profile, self.memory, self.energy, self.fatigue
            )

        # --- WYKONANIE ---
        self.profile.momentum = self.calc_momentum()
        self.profile.sri = self.calc_sri()

        output = self.dispatch(state, context, challenge)
        self.current_state = state

        # --- OCENA SKUTECZNOŚCI ---
        base_score = 100.0 - (self.fatigue * 0.4) + (self.energy * 0.3)
        sri_bonus = self.profile.sri * 0.2
        momentum_bonus = self.profile.momentum * 0.1
        score = min(100.0, max(0.0, base_score + sri_bonus + momentum_bonus))

        cycle_data = {
            "cycle": self.cycle_count,
            "state": state,
            "energy": round(self.energy, 2),
            "fatigue": round(self.fatigue, 2),
            "score": round(score, 2),
            "sri": round(self.profile.sri, 2),
            "momentum": round(self.profile.momentum, 2)
        }
        self.history.append(cycle_data)
        if len(self.history) > 20:
            self.history.pop(0)
        self.memory.update(cycle_data)

        # --- TEAM CORE – synchronizacja stanu ---
        self.team.sync_state(cycle_data)

        # --- MEM_Ω – rezonans i zapis ---
        # Szukamy podobnego wzorca
        similar = self.mem_omega.find_similar_pattern(context)
        if similar:
            pattern_id, score = similar
            log(f"[MEM_Ω] Znaleziono rezonans: {pattern_id} (score: {score:.2f})", "INFO")
            # Zastosuj rezonans – modyfikacja decyzji
            if score > 0.7:
                output["resonance_boost"] = True

        # --- METRYKI ---
        output["metrics"] = self.get_metrics()

        # --- HOOK POST-CYCLE ---
        output = self.kernel_hook.trigger_post_hooks(output)

        # Obniżenie priorytetu po cyklu
        self.scheduler.lower_priority()

        return output

    def get_metrics(self) -> Dict[str, float]:
        return {
            "energy": round(self.energy, 2),
            "fatigue": round(self.fatigue, 2),
            "score": round(self.history[-1]["score"], 2) if self.history else 50.0,
            "sri": round(self.profile.sri, 2),
            "momentum": round(self.profile.momentum, 2),
            "instinct_confidence": round(self.profile.instinct_confidence, 2),
            "memory_resonance": round(self.mem_omega.get_resonance(), 2)
        }

    def handle_system_interrupt(self, interrupt_type: str, data: Dict) -> Dict:
        return self.kernel_hook.handle_interrupt(interrupt_type, data)

    def get_team_state(self) -> Dict:
        return self.team.team_state

    def get_quintessence(self) -> Dict:
        return self.mem_omega.get_quintessence()

