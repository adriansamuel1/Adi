class IntegratorStallone:
    def __init__(self):
        self.terrain_mods = {
            "urban": {"threat_offset": 0, "chaos_offset": 0, "weight_rambo": 0.1},
            "wilderness": {"threat_offset": -10, "chaos_offset": -10, "weight_rambo": -0.1},
            "cyber": {"threat_offset": 10, "chaos_offset": 5, "weight_rambo": 0.15},
            "social": {"threat_offset": -5, "chaos_offset": 15, "weight_rambo": -0.05}
        }

    def select_state(self, context: Dict[str, Any], challenge: Dict[str, Any],
                     profile: StalloneProfile, memory: LongTermMemory,
                     energy: float, fatigue: float) -> str:
        if energy < 10.0 and fatigue > 90.0 and context.get("threat_level", 0) > 90.0:
            return "GLADIATOR"
        if energy < 15.0 or fatigue > 85.0:
            return "PHOENIX_RECOVERY"
        if energy > 90.0 and fatigue < 20.0 and context.get("chaos_level", 50) < 40.0:
            return "ULTRA_PRIME_FLOW"

        threat = context.get("threat_level", 0.0)
        chaos = context.get("chaos_level", 0.0)
        emotional = context.get("emotional_pressure", 0.0)
        long_term = challenge.get("long_term", False)

        if chaos < 30 and threat < 20 and long_term:
            return "MENTOR_OVERRIDE"
        if chaos > 70 and threat > 60 and emotional > 50:
            return "OPERATOR_OVERRIDE"

        terrain = context.get("terrain", "urban")
        mods = self.terrain_mods.get(terrain, self.terrain_mods["urban"])
        threat_threshold = 70 + mods["threat_offset"]
        chaos_threshold = 50 + mods["chaos_offset"]

        base_weight_rambo = 0.5
        adapted_weight = memory.get_adaptive_weight(base_weight_rambo)
        bias_adjust = (adapted_weight - 0.5) * 20
        threat_threshold += bias_adjust

        if threat > threat_threshold:
            return "RAMBO_MODE"
        if long_term and chaos < 60.0:
            return "ROCKY_MODE"
        if chaos > chaos_threshold:
            return "BALANCE_MODE"
        if emotional > 60.0:
            return "SHADOW_MODE"
        if threat < 40 and chaos < 30 and energy > 70 and fatigue < 40:
            return "HYBRID_DRAGON_MODE"
        return "PRIME_MODE"

    def merge(self, rocky_res: Dict, rambo_res: Dict, weight_rambo: float) -> Dict:
        w_rocky = 1.0 - weight_rambo
        return {
            "merged_mode": "BALANCE",
            "weights": {"rocky": round(w_rocky, 2), "rambo": round(weight_rambo, 2)},
            "rocky_component": rocky_res,
            "rambo_component": rambo_res
        }

    def merge_shadow(self, rambo_res: Dict, rocky_res: Dict, fatigue: float) -> Dict:
        w_rambo = max(0.3, min(0.7, 0.7 - fatigue * 0.004))
        w_rocky = 1.0 - w_rambo
        return {
            "merged_mode": "SHADOW",
            "weights": {"rocky": round(w_rocky, 2), "rambo": round(w_rambo, 2)},
            "fatigue_mitigation": f"Fatigue {fatigue:.1f} suppressed.",
            "primary_shadow": rambo_res,
            "secondary_anchor": rocky_res
        }

    def merge_prime(self, rocky_res: Dict, rambo_res: Dict, energy: float) -> Dict:
        w_rocky = max(0.4, min(0.8, 0.6 + (100 - energy) * 0.002))
        w_rambo = 1.0 - w_rocky
        return {
            "merged_mode": "PRIME",
            "weights": {"rocky": round(w_rocky, 2), "rambo": round(w_rambo, 2)},
            "system_efficiency": f"Prime capacity at energy {energy:.1f}.",
            "growth_expansion": rocky_res,
            "tactical_overview": rambo_res
        }

    def merge_dragon(self, rocky_res: Dict, rambo_res: Dict, heilong_suggestion: Dict) -> Dict:
        return {
            "merged_mode": "HYBRID_DRAGON",
            "status": "Stallone + HEILONG synergy active.",
            "stability_score": 95,
            "precision_score": 97,
            "energy_cost": "minimal",
            "rocky_foundation": rocky_res,
            "rambo_tactics": rambo_res,
            "heilong_strategy": heilong_suggestion
