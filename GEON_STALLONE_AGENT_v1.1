            "internal_resilience": round(self.internal_resilience, 2),
            "micro_tactics": micro_tactics or {},
            "emotional_influence": round(emotional_weight, 2)
        }

    def stabilize(self) -> Dict[str, Any]:
        self.internal_resilience = max(0.0, self.internal_resilience - 5.0)
        return {
            "core": "ROCKY",
            "action": "Stabilize",
            "status": "Emotional core anchored. Zero-point noise cancellation active.",
            "resilience_after_stabilization": round(self.internal_resilience, 2)
        }

    def growth(self, challenge: Dict[str, Any]) -> Dict[str, Any]:
        difficulty = challenge.get("difficulty", 5.0)
        growth_delta = difficulty * 1.5 * (1 + self.heart_drive_bonus * 0.05)
        self.internal_resilience += growth_delta * 0.2
        return {
            "core": "ROCKY",
            "action": "Growth Loop",
            "growth_delta": round(growth_delta, 2),
            "status": "Structural capabilities expanded under pressure.",
            "resilience_after_growth": round(self.internal_resilience, 2)
        }

    def mentor_override(self, context: Dict[str, Any]) -> Dict[str, Any]:
        return {
