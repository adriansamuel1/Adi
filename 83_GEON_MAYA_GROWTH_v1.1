class GeonMayaGrowth:
    """
    🌱 ALGORYTM WZROSTU KAROLA MAYA
    Przeprowadza system przez 7 etapów ewolucyjnych rzeczywistości.
    ULEPSZENIA v1.1: zoptymalizowany auto-pilot, clamp safety.
    """

    def __init__(self, cube=None, config: Optional[Dict] = None):
        # Inicjalizacja kostki
        self.cube = cube or MockCube()
        self.config = config or {}
        
        # Stan
        self.current_stage = EtapWzrostu.INIT
        self.history: List[Dict[str, Any]] = []
        self.resonance_base = 168.0
        self.current_drift = 0.000000
        self.cycle_id = generate_context_hash({"init": time.time()})
        
        # Integracje (mocki)
        self.kroniki = MockSamaelHeilong
        self.egregor = MockEgregor
        
        # Ustawienia
        self.auto_pilot = self.config.get("auto_pilot", False)
        self.validate_stages = self.config.get("validate_stages", True)
        self.log_to_egregor = self.config.get("log_to_egregor", True)
        
        log("🐉 GEON_MAYA_GROWTH v1.1 aktywowany | " + FRACTAL_SIGNATURE)
        log(f"   ETAPY: {len(STAGE_CONFIGS)} | AUTO-PILOT: {self.auto_pilot}")

    def _log(self, event: str, data: Dict[str, Any]) -> None:
        """Logowanie do Kronik Samaela."""
        self.kroniki.log_event(f"MAYA_{event}", data)

    def _calculate_drift(self) -> float:
        """Kalkuluje odchylenie (dryf) na podstawie dyspersji osi A, B, C."""
        st = self.cube.state()
        a_sum = sum(st["A"])
        b_sum = sum(st["B"])
        c_sum = sum(st["C"])
        var = (abs(a_sum - b_sum) + abs(b_sum - c_sum) + abs(c_sum - a_sum)) / 300.0
        return round(var, 6)

    def _check_stage_validation(self, stage: EtapWzrostu, eval_result: Dict[str, Any]) -> bool:
        """Sprawdza czy etap osiągnął pożądany stan."""
        if not self.validate_stages:
            return True
        cfg = STAGE_CONFIGS.get(stage)
        if not cfg or not cfg.target_states:
            return True
        current_stan = eval_result.get("stan", "")
        for target in cfg.target_states:
            if target in current_stan:
                return True
        return False

    # =========================================================================
    # ULEPSZONY AUTO-PILOT – PRECYZYJNA REAKCJA NA STANY I PRESJĘ
    # =========================================================================

    def _get_auto_pilot_moves(self, eval_result: Dict[str, Any]) -> List[str]:
        """
        Zoptymalizowany Auto-pilot – precyzyjnie reaguje na presję i stany,
        zapobiegając gwałtownym skokom dryfu.
        """
        konsekwencja = eval_result.get("konsekwencja", 0.5)
        stan = str(eval_result.get("stan", "")).upper()
        
        if "STABILNY" in stan or "NOMINAL" in stan:
            if konsekwencja < 0.35:
                return ["A+", "B+"]
            elif konsekwencja > 0.75:
                return ["A-", "B-"]
            else:
                return ["C+", "C-"]
        elif "KRYTYCZNY" in stan or "WARNING" in stan:
            return ["A2", "B2"] if konsekwencja > 0.6 else ["C2", "A+"]
        elif "AWARIA" in stan or "CRITICAL" in stan:
            # Dławienie fali – sekwencja równoważąca
            return ["A-", "B-", "C2"]
        else:
            # Stan domyślny / nieznany – łagodny balans
            return ["A+", "C-"]

    # =========================================================================
    # CLAMP SAFETY – ZABEZPIECZENIE INDEKSÓW POZYCJI
    # =========================================================================

    def evaluate_current_state(self, posA: int = 8, posB: int = 8, posC: int = 8) -> Dict[str, Any]:
        """Ewaluacja rezonansu z klamrowaniem indeksów pozycji (Clamp Safety)."""
        pA = clamp(posA, 0, 14)
        pB = clamp(posB, 0, 14)
        pC = clamp(posC, 0, 14)
        return self.cube.eval(int(pA), int(pB), int(pC), log=False)

    def step(self, posA: int = 8, posB: int = 8, posC: int = 8) -> Dict[str, Any]:
        """Wykonanie pojedynczego taktu ewolucyjnego."""
        before_state = self.cube.state()
        before_eval = self.evaluate_current_state(posA, posB, posC)

        # Wybór ruchów
        cfg = STAGE_CONFIGS.get(self.current_stage)
        if self.auto_pilot:
            moves = self._get_auto_pilot_moves(before_eval)
        else:
            moves = cfg.moves if cfg else []

        if moves:
            self.cube.apply_moves(moves)

        after_eval = self.evaluate_current_state(posA, posB, posC)
        self.current_drift = self._calculate_drift()
        
        # Rezonans dynamiczny
        step_resonance = round(self.resonance_base * (1.0 + (after_eval["konsekwencja"] - 0.5) * 0.1), 2)

        # Waloryzacja etapu
        validation_passed = self._check_stage_validation(self.current_stage, after_eval)

        step_report = {
            "stage": self.current_stage.value,
            "stage_index": list(EtapWzrostu).index(self.current_stage) + 1,
            "moves_applied": moves,
            "before_state": before_state,
            "after_state": self.cube.state(),
            "before_eval": before_eval,
            "after_eval": after_eval,
            "resonance": step_resonance,
            "drift": self.current_drift,
            "validation_passed": validation_passed,
            "timestamp": datetime.now().isoformat()
        }
        
        self.history.append(step_report)
        self._log("STEP_COMPLETE", {
            "Etap": step_report["stage"],
            "StanPrzed": before_eval["stan"],
            "StanPo": after_eval["stan"],
            "Presja": f"{after_eval['konsekwencja']:.4f}",
            "Dryf": f"{self.current_drift:.6f}",
            "Walidacja": validation_passed
        })

        # Zapis do Egregora
        if self.log_to_egregor:
            entry = {
                "type": "MAYA_GROWTH_STEP",
                "stage": step_report["stage"],
                "cube_state": step_report["after_state"],
                "evaluation": after_eval,
                "drift": self.current_drift,
                "validation": validation_passed,
                "cycle_id": self.cycle_id,
                "timestamp": step_report["timestamp"]
            }
            self.egregor.commit(entry, node_id="GEON_MAYA")

        # Przejście do następnego etapu
        if self.current_stage != EtapWzrostu.END:
            stages = list(EtapWzrostu)
            idx = stages.index(self.current_stage)
            if idx + 1 < len(stages):
                self.current_stage = stages[idx + 1]

        return step_report

    def full_cycle(self, start_pos: Tuple[int, int, int] = (8, 8, 8)) -> List[Dict[str, Any]]:
        """Uruchomienie pełnego, 7-etapowego rytuału przejścia rzeczywistości."""
        self.current_stage = EtapWzrostu.INIT
        self.history = []
        self.cycle_id = generate_context_hash({"start": time.time()})
        
        self._log("CYCLE_START", {"punkt_skupienia": start_pos, "cycle_id": self.cycle_id})

        for _ in range(len(EtapWzrostu)):
            self.step(*start_pos)

        self._log("CYCLE_END", {
            "status": "ZAKOŃCZONY",
            "koncowy_stan_osi": self.cube.state(),
            "final_drift": self.current_drift,
            "cycle_id": self.cycle_id
        })
        
        return self.history

    def reset(self) -> None:
        """Przywrócenie pierwotnej geometrii układu."""
        self.cube = MockCube()
        self.current_stage = EtapWzrostu.INIT
        self.history = []
        self.current_drift = 0.000000
        self.cycle_id = generate_context_hash({"reset": time.time()})
        self._log("RESET", {"status": "PRZYWRÓCONO_STAN_ZERO"})

    def summary(self) -> Dict[str, Any]:
        last = self.history[-1] if self.history else None
        avg_res = sum(h["resonance"] for h in self.history) / len(self.history) if self.history else 168.0
        return {
            "current_stage": self.current_stage.value,
            "cycles_completed": 1 if (last and last["stage"] == "END") else 0,
            "final_cube_state": self.cube.state(),
            "final_evaluation": last["after_eval"] if last else None,
            "final_drift": self.current_drift,
            "avg_resonance": round(avg_res, 2),
            "total_steps": len(self.history),
            "validation_summary": {
                "passed": sum(1 for h in self.history if h.get("validation_passed", True)),
                "total": len(self.history)
            },
            "cycle_id": self.cycle_id
        }

    def get_status(self) -> Dict[str, Any]:
        return {
            "system": "GEON_MAYA_GROWTH_v1.1",
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "vibe": VIBE,
            "current_stage": self.current_stage.value,
            "drift": self.current_drift,
            "history_len": len(self.history),
            "auto_pilot": self.auto_pilot,
            "validate_stages": self.validate_stages,
            "cycle_id": self.cycle_id
        }

