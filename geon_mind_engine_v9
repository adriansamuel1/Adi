import math
from dataclasses import dataclass, field
from typing import Dict, Any, List


def LOG(module: str, event: str, msg: str) -> None:
    print(f"[MIND9][{module}][{event}] -> {msg}")


# ============================================================
# STRUKTURA WYJŚCIOWA MIND v9
# ============================================================

@dataclass
class MindStatusV9:
    classification: str
    weighted_sum: float
    core: Dict[str, int]
    archetype: str
    cognitive_vector_d2: List[float]
    harmony_vector_d3: List[float]
    correction_vector_d4: List[float]
    recommendations: List[str]
    meta: Dict[str, Any] = field(default_factory=dict)


# ============================================================
# ARCHETYPY POZNAWCZE v9
# ============================================================

class MindArchetypeV9:
    """Archetypy poznawcze GEON v9 — meta-warstwa psychologiczna."""

    def classify(self, core: Dict[str, int], total: float) -> str:
        o = core.get("odpowiedzialnosc", 0)
        e = core.get("empatia", 0)
        g = core.get("granice", 0)
        s = core.get("stabilnosc", 0)

        if o >= 4 and e >= 4 and s >= 4:
            return "ARCHETYPE_GUARDIAN"
        if g >= 4 and s >= 4:
            return "ARCHETYPE_STRATEGIST"
        if e >= 4 and o <= 2:
            return "ARCHETYPE_EMPATH"
        if total >= 55:
            return "ARCHETYPE_INTEGRATED"
        if total <= 25:
            return "ARCHETYPE_FRAGMENTED"
        return "ARCHETYPE_NEUTRAL"


# ============================================================
# MIND ENGINE v9 — GŁÓWNY SILNIK POZNAWCZY
# ============================================================

class FMPCMindEngineV9:
    """
    MIND v9 — kora przedczołowa GEON:
    - ocena człowieka
    - rdzeń psychologiczny
    - archetyp poznawczy
    - generowanie D2 (dynamika)
    - generowanie D3 (harmonia)
    - generowanie D4 (korekcja)
    """

    def __init__(self):
        self.archetype_engine = MindArchetypeV9()
        LOG("MIND_V9", "INIT", "🧠 Mind Engine v9 aktywowany")

    # --------------------------------------------------------
    # FUNKCJE POMOCNICZE
    # --------------------------------------------------------

    @staticmethod
    def avg(values: List[float]) -> float:
        return sum(values) / len(values) if values else 0.0

    @staticmethod
    def normalize(value: float) -> float:
        return max(0.0, min(1.0, value))

    # --------------------------------------------------------
    # GŁÓWNA FUNKCJA MIND v9
    # --------------------------------------------------------

    def compute(self, dane: Dict[str, int]) -> MindStatusV9:
        # 1. Suma poznawcza
        total = sum(int(v) for v in dane.values())

        # 2. Klasyfikacja FMPC
        if total >= 55:
            cls = "stabilny"
        elif total >= 40:
            cls = "konstruktywny"
        elif total >= 25:
            cls = "chaotyczny"
        else:
            cls = "wysokie_ryzyko"

        # 3. Rdzeń psychologiczny
        core_keys = ["odpowiedzialnosc", "empatia", "granice", "stabilnosc"]
        core = {k: dane.get(k, 0) for k in core_keys}

        # 4. Archetyp poznawczy
        archetype = self.archetype_engine.classify(core, total)

        # 5. D2 — dynamika poznawcza
        #    bazuje na sumie + rdzeniu
        base = total or 1.0
        core_sum = sum(core.values()) or 1.0
        cognitive_vector_d2 = [
            self.normalize(((base * (i + 1)) + core_sum) % 168 / 168.0)
            for i in range(9)
        ]

        # 6. D3 — harmonia poznawcza
        harmony_vector_d3 = [
            self.normalize((core_sum * (i + 1)) % 168 / 168.0)
            for i in range(9)
        ]

        # 7. D4 — korekcja poznawcza
        correction_vector_d4 = [
            self.normalize((total / 100.0) * (i + 1) / 9.0)
            for i in range(9)
        ]

        # 8. Rekomendacje
        rec = []
        for k, v in dane.items():
            if v <= 2:
                rec.append(f"wzmocnij: {k}")
            elif v >= 4:
                rec.append(f"utrzymaj: {k}")

        # 9. Meta
        meta_out = {
            "total": total,
            "archetype": archetype,
            "core": core,
            "d2_energy": sum(cognitive_vector_d2),
            "d3_energy": sum(harmony_vector_d3),
            "d4_energy": sum(correction_vector_d4),
        }

        return MindStatusV9(
            classification=cls,
            weighted_sum=float(total),
            core=core,
            archetype=archetype,
            cognitive_vector_d2=cognitive_vector_d2,
            harmony_vector_d3=harmony_vector_d3,
            correction_vector_d4=correction_vector_d4,
            recommendations=rec[:8],
            meta=meta_out,
        )