        self.magilla = getattr(self.node, 'magilla', MockMagilla())
        self.kroniki = getattr(self.node, 'kroniki', MockSamaelHeilong)
        self.zwierciadlo = getattr(self.node, 'zwierciadlo', MockMirror())
        self.gadget = getattr(self.node.core, 'gadget', MockGadget())
        self.monterey = getattr(self.node.core, 'monterey', MockMonterey())
        self.dzet = getattr(self.node.core, 'dzet', MockDzet())
        
        # Egregor
        self.egregor = getattr(self.node, 'egregor', MockEgregor())
        
        # Genetic pool
        self.genetic_pool = getattr(self.node, '_shared_genetic_pool', MockGeneticPool())
        
        # Rejestr i inicjalizacja archetypów
        self.archetypes: Dict[str, Archetype] = {}
        self.config = EduBeastConfig()
        
        # Thread-safe lock dla operacji zbiorczych
        self._lock = threading.Lock()
        
        # Rejestracja archetypów
        self._register_default_archetypes()
        
        log("🐉 GEON_EDU_BEAST v1.1 aktywowany | " + FRACTAL_SIGNATURE)
        log(f"   ARCHETYPY: {len(self.archetypes)} | KERNEL: {self.node.node_id}")

    def _register_default_archetypes(self) -> None:
        """Rejestruje domyślne archetypy edukacyjne."""
        self.register_archetype("Noddy", self._spark)
        self.register_archetype("Karolek", self._chaos_with_retry)
        self.register_archetype("Andzia", self._mirror)
        self.register_archetype("Franklin", self._lesson)
        self.register_archetype("Bob", self._construct)
        self.register_archetype("Sam", self._secure)
        self.register_archetype("Abbe", self._journey)
        self.register_archetype("Puchatek", self._wisdom)
        self.register_archetype("Krzys", self._meta)

    def register_archetype(self, name: str, function: Callable) -> None:
        """Rejestruje nowy archetyp."""
        self.archetypes[name] = Archetype(name, function)

    # =========================================================================
    # ULEPSZENIE: Deterministic Randomness – seed z context_hash
    # =========================================================================

    def _get_deterministic_rng(self, seed: int) -> random.Random:
        """Zwraca instancję RNG z zadanym ziarnem."""
        return random.Random(seed)

    # =========================================================================
    # ULEPSZENIE: run_edu_cycle z izolacją błędów i typowanym strumieniem
    # =========================================================================

    def run_edu_cycle(self, stimulus: Dict[str, Any], dragon_index: int = 0) -> EduBeastReport:
        """
        Uruchamia pełny cykl edukacyjny przez wszystkie archetypy.
        ULEPSZENIA:
        - Izolacja błędów (try-except dla każdego archetypu)
        - Typowanie strumienia (EduContextPayload)
        - Deterministic Randomness (seed z context_hash)
        - Adaptive XP Scaling
        - Egregor Query
        """
        # Kanoniczny hash kontekstu
        context_hash = generate_context_hash(stimulus)
        cycle_id = str(uuid.uuid4())[:8].upper()
        
        # Inicjalizacja kontekstu
        ctx = EduContextPayload(
            cycle_id=cycle_id,
            context_hash=context_hash,
            stimulus=stimulus
        )
        
        # Deterministic RNG – ziarno z hasha kontekstu
        seed = int(context_hash[:8], 16) if context_hash else 0
        rng = self._get_deterministic_rng(seed)
        
        # Aktualizacja RNG dla komponentów (jeśli obsługują)
        if hasattr(self.magilla, '_rng'):
            self.magilla._rng = rng
        if hasattr(self.gadget, '_rng'):
            self.gadget._rng = rng
        if hasattr(self.dzet, '_rng'):
            self.dzet._rng = rng

        # Wybór smoka z Hordy
        if self.horde and hasattr(self.horde, 'dragons') and self.horde.dragons:
            smok = self.horde.dragons[dragon_index % len(self.horde.dragons)]
        else:
            smok = MockYoungDragon("Edu_Temp")

        order = self.config.archetype_order
        outputs = {}

        # Sekwencyjne wykonanie archetypów z izolacją błędów
        for name in order:
            if name not in self.archetypes:
                continue
            
            archetype = self.archetypes[name]
            
            # ULEPSZENIE: try-except dla każdego archetypu
            try:
                out = archetype.execute(ctx)
                ctx.add_output(name, out)
                outputs[name] = out
                # Aktualizacja danych dla następnego archetypu
                if isinstance(out, dict):
                    ctx.current_data.update(out)
                else:
                    ctx.current_data["_last_raw"] = out
                    
            except Exception as e:
                error_msg = f"Archetyp {name} failed: {str(e)}"
                log(error_msg, "ERROR")
                ctx.add_output(name, None, error=error_msg)
                
                if self.config.enable_fallback:
                    # Fallback – przekaż niezmodyfikowane dane
                    fallback_data = ctx.current_data.copy()
                    fallback_data["_fallback"] = True
                    fallback_data["_failed_archetype"] = name
                    ctx.current_data = fallback_data
                    outputs[name] = {"status": "FALLBACK", "reason": str(e)}
                    # Kontynuuj potok
                    continue
                else:
                    # Rzuć wyjątek – przerwij potok
                    raise

        # =====================================================================
        # ULEPSZENIE: Adaptive XP Scaling
        # =====================================================================
        difficulty = stimulus.get("difficulty", 0.5)
        stability = ctx.current_data.get("stability", 0.5)
        
        xp_base = self.config.xp_per_cycle
        xp_difficulty_bonus = int(difficulty * 100 * self.config.xp_difficulty_weight)
        xp_stability_bonus = int(stability * 100 * self.config.xp_stability_weight)
        xp_level_bonus = self.archetypes.get("Krzys", Archetype("Krzys", lambda x: x)).level * 5
        
        xp_gain = xp_base + xp_difficulty_bonus + xp_stability_bonus + xp_level_bonus
        
        if self.config.enable_xp:
            smok.gain_experience(
                xp_gain, 
                f"EDU_BEAST_FLOW_{stimulus.get('type', 'GENERIC')}_DIFF_{difficulty:.2f}"
            )

        # =====================================================================
        # ULEPSZENIE: Egregor Query przed zapisem
        # =====================================================================
        if self.config.enable_egregor:
            # Sprawdź, czy podobna lekcja już istnieje
            existing = self.egregor.query(context_hash)
            if not existing:
                # Nowy wpis – zapisz
                entry = {
                    "context_hash": context_hash,
                    "resolved_path": ctx.current_data.get("concept", "Edu_Concept_Fallback"),
                    "efficiency": stability,
                    "uses": 1,
                    "clue": {"module": "GEON_EDU_BEAST", "difficulty": difficulty}
                }
                self.egregor.commit(entry, node_id=self.node.node_id)

        # Certyfikacja
        signature = self.kroniki.certyfikuj_ruch_optimusa(
            f"EDU_BEAST_CYCLE_NODE_{self.node.node_id}_OK"
        )

        # Logowanie końcowe
        if self.config.enable_logging:
            self.kroniki.log_event("EDU_BEAST_COMPLETE", {
                "node": self.node.node_id,
                "cycle_id": cycle_id,
                "xp_gain": xp_gain,
                "errors": ctx.errors,
                "execution_path": ctx.execution_path
            })

        return EduBeastReport(
            status="EDU_BEAST_COMPLETE",
            outputs=outputs,
            dragon=smok.name,
            xp_gain=xp_gain,
            signature=signature,
            context_hash=context_hash,
            execution_path=ctx.execution_path,
            errors=ctx.errors,
            stability=stability,
            difficulty=difficulty
        )

    # =========================================================================
    # PODMODUŁY ARCHETYPÓW (ZSYNCHRONIZOWANE Z TYPOWANYM STRUMIENIEM)
    # =========================================================================

    def _spark(self, ctx: EduContextPayload) -> Dict:
        """Noddy – iskra ciekawości. ULEPSZENIE: odczyt z Egregora."""
        # ULEPSZENIE: Egregor Query – sprawdź, czy podobna lekcja już istnieje
        if self.config.enable_egregor:
            existing = self.egregor.query(ctx.context_hash)
            if existing:
                return {
                    "curiosity": f"Spark_{ctx.stimulus.get('type', 'Unknown')}_CACHED",
                    "origin_stimulus": ctx.stimulus,
                    "cached_lesson": existing[0].get("resolved_path"),
                    "efficiency": existing[0].get("efficiency", 0.8)
                }
        
        return {
            "curiosity": f"Spark_{ctx.stimulus.get('type', 'Unknown')}",
            "origin_stimulus": ctx.stimulus
        }

    def _chaos_with_retry(self, ctx: EduContextPayload, retries: int = 3) -> Dict:
        """Karolek – chaos z retry."""
        curiosity = ctx.current_data.get("curiosity", "Unknown")
        out = {"stability_delta": 0}
        for i in range(retries):
            out = self.magilla.activate_magilla({"task": curiosity})
            if out.get("stability_delta", 0) > 0.05:
                return out
            # Wzmocnienie siły
            ctx.current_data["force"] = ctx.current_data.get("force", 0) + 0.3
        return out

    def _mirror(self, ctx: EduContextPayload) -> Dict:
        """Andzia – zwierciadło."""
        chaos_output = ctx.current_data
        cycle_mock = {
            "path": chaos_output.get("action_taken", "Magilla_Path"),
            "stability": chaos_output.get("stability_delta", 0.5),
            "context_hash": ctx.context_hash,
            "warnings": [chaos_output.get("comment", "")]
        }
        return self.zwierciadlo.reflect(cycle_mock, self.genetic_pool)

    def _lesson(self, ctx: EduContextPayload) -> Dict:
        """Franklin – lekcja z certyfikacją."""
        reflection = ctx.current_data
        reflection["lesson_certified"] = True
        reflection["franklin_seal"] = self.kroniki.certyfikuj_ruch_optimusa(
            "FRANKLIN_LESSON_INTEGRITY"
        )
        return reflection

    def _construct(self, ctx: EduContextPayload) -> Dict:
        """Bob – konstrukcja z Gadget."""
        lesson = ctx.current_data
        return self.gadget.spark_invention({
            "task": "build_from_lesson",
            "lesson_seal": lesson.get("franklin_seal")
        })

    def _secure(self, ctx: EduContextPayload) -> Dict:
        """Sam – zabezpieczenie przez Monterey."""
        solution = ctx.current_data
        self.monterey.stabilize_core(
            kernel_mode=getattr(self.node, 'GLOBAL_STATE', {}).get("mode", "PRIME")
        )
        solution["secured"] = True
        solution["protection_power"] = self.monterey.output_power
        return solution

    def _journey(self, ctx: EduContextPayload) -> Dict:
        """Abbe – podróż i zapis do Egregora."""
        safe_solution = ctx.current_data
        c_hash = ctx.context_hash
        
        # ULEPSZENIE: Egregor Query przed zapisem (już zrobione w run_edu_cycle)
        entry = {
            "context_hash": c_hash,
            "resolved_path": safe_solution.get("concept", "Edu_Concept_Fallback"),
            "efficiency": safe_solution.get("stability", 0.8),
            "uses": 1,
            "clue": {"module": "GEON_EDU_BEAST"}
        }
        # Egregor commit jest już wykonany w run_edu_cycle dla całego cyklu
        # Tu tylko przygotowujemy dane dla następnych archetypów
        return {
            "transition": "level_up",
            "artifact": safe_solution,
            "computed_hash": c_hash
        }

    def _wisdom(self, ctx: EduContextPayload) -> Dict:
        """Puchatek – mądrość."""
        transition = ctx.current_data
        return {
            "wisdom": f"Puchatek_OK_{hash(str(transition.get('computed_hash')))}"
        }

    def _meta(self, ctx: EduContextPayload) -> Dict:
        """Krzys – meta-integracja."""
        wisdom = ctx.current_data
        return {
            "meta": f"Krzys_Integracja_Wymiaru_{hash(str(wisdom.get('wisdom')))}"
        }

    # =========================================================================
    # METODY POMOCNICZE
    # =========================================================================

    def get_archetype_status(self) -> Dict[str, Dict]:
        """Zwraca status wszystkich archetypów."""
        with self._lock:
            return {
                name: a.get_state()
                for name, a in self.archetypes.items()
            }

    def get_report(self) -> Dict[str, Any]:
        """Zwraca pełny raport edukacyjny."""
        return {
            "system": "GEON_EDU_BEAST_v1.1",
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "archetypes": self.get_archetype_status(),
            "config": {
                "enable_xp": self.config.enable_xp,
                "enable_egregor": self.config.enable_egregor,
                "enable_fallback": self.config.enable_fallback,
                "archetype_order": self.config.archetype_order
            },
            "node_id": self.node.node_id
        }

    def __str__(self) -> str:
        return f"GEON_EDU_BEAST_v1.1 | Archetypy: {len(self.archetypes)}"

# =============================================================================
# MOST INTEGRACYJNY — EDU_BEAST_BRIDGE (Z DYNAMICZNYMI METRYKAMI)
# =============================================================================

class EduBeastBridge:
    """
    Most integracyjny między GEON_EDU_BEAST a resztą architektury.
    ULEPSZENIE: dynamiczne metryki z raportu cyklu.
    """

    def __init__(self, edu_beast: GeonEduBeast):
        self.edu_beast = edu_beast
        self._last_report: Optional[EduBeastReport] = None

    def update_last_report(self, report: EduBeastReport) -> None:
        """Aktualizuje ostatni raport dla dynamicznych metryk."""
        self._last_report = report

    def get_archetype_context(self) -> Dict[str, Any]:
        return {
            "tryb": "EDU_BEAST_v1.1",
            "archetypy": list(self.edu_beast.archetypes.keys()),
            "statusy": self.edu_beast.get_archetype_status()
        }

    def get_autopilot_state(self) -> Dict[str, Any]:
        """ULEPSZENIE: dynamiczne metryki z ostatniego raportu."""
        if self._last_report:
            stability = self._last_report.stability
            difficulty = self._last_report.difficulty
            errors_count = len(self._last_report.errors)
            
            # Oblicz pressure na podstawie błędów i trudności
            pressure = min(1.0, (difficulty * 0.5) + (errors_count * 0.1))
            energy = 0.7 + (stability * 0.2)
            
            return {
                "mode": "EDU_BEAST_v1.1",
                "stability": stability,
                "energy": clamp(energy, 0.1, 1.0),
                "pressure": clamp(pressure, 0.0, 1.0),
                "resilience": 0.7 + (stability * 0.2),
                "archetypes_active": len(self.edu_beast.archetypes),
                "last_xp_gain": self._last_report.xp_gain,
                "execution_path": self._last_report.execution_path
            }
        
        # Fallback – statyczne wartości
        return {
            "mode": "EDU_BEAST_v1.1",
            "stability": 0.8,
            "energy": 0.7,
            "pressure": 0.2,
            "resilience": 0.9,
            "archetypes_active": len(self.edu_beast.archetypes)
        }

    def get_governor_context(self) -> Dict[str, Any]:
        return {
            "intent": "EDUCATIONAL_LEARNING",
            "confidence": 0.9,
            "entropy": 0.1,
            "edu_ready": True
        }

    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        if self._last_report:
            return [{
                "source": "EDU_BEAST_v1.1",
                "content": f"Edu cycle: {self._last_report.execution_path[-3:]}",
                "energy": 0.8,
                "xp_gain": self._last_report.xp_gain,
                "stability": self._last_report.stability
            }]
        return [{"source": "EDU_BEAST_v1.1", "content": "Edu cycle completed", "energy": 0.8}]

    def get_trio_state(self) -> Dict[str, str]:
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": "EDU_BEAST_v1.1",
            "edu": "AKTYWNY"
        }

