def demo():
    """Demonstracja GEON_EDU_BEAST_v1.1 z ulepszeniami."""
    print("\n" + "=" * 80)
    print("📚 GEON_EDU_BEAST_v1.1 — DEMONSTRACJA Z ULEPSZENIAMI")
    print("IZOLACJA BŁĘDÓW | TYPOWANIE | THREAD-SAFETY | DETERMINISTYCZNY CHAOS")
    print("=" * 80 + "\n")

    # 1. Inicjalizacja
    edu = GeonEduBeast()
    bridge = EduBeastBridge(edu)

    print("🔮 CYKL EDUKACYJNY (z deterministycznym ziarnem):\n")

    # 2. Cykl 1 – normalny
    stimulus1 = {"type": "infrastructure_learning", "target": "Tauron_Grid", "difficulty": 0.7}
    report1 = edu.run_edu_cycle(stimulus1)
    bridge.update_last_report(report1)

    print(f"   Status: {report1.status}")
    print(f"   Smok: {report1.dragon} (+{report1.xp_gain} XP)")
    print(f"   Stabilność: {report1.stability:.2f}")
    print(f"   Trudność: {report1.difficulty:.2f}")
    print(f"   Ścieżka: {' → '.join(report1.execution_path[:5])}...")

    # 3. Cykl 2 – z tym samym bodźcem (deterministyczny chaos – ta sama ścieżka)
    print("\n📌 CYKL 2: Ten sam bodziec (deterministyczny chaos – identyczna ścieżka)")
    stimulus2 = {"type": "infrastructure_learning", "target": "Tauron_Grid", "difficulty": 0.7}
    report2 = edu.run_edu_cycle(stimulus2)
    bridge.update_last_report(report2)
    
    print(f"   Stabilność: {report2.stability:.2f}")
    print(f"   Ścieżka: {' → '.join(report2.execution_path[:5])}...")
    
    # Sprawdzenie determinizmu
    same_path = report1.execution_path == report2.execution_path
    print(f"   Determinizm: {'✅ TAKA SAMA ŚCIEŻKA' if same_path else '❌ RÓŻNE ŚCIEŻKI'}")

    # 4. Cykl 3 – z błędem w archetypie (test fallback)
    print("\n📌 CYKL 3: Test fallback – symulacja błędu w Karolku")
    
    # Zepsujemy Karolka na chwilę
    original_karolek = edu.archetypes["Karolek"].function
    def broken_function(ctx):
        raise ValueError("Symulowany błąd w Karolku!")
    edu.archetypes["Karolek"].function = broken_function
    
    stimulus3 = {"type": "test_error", "difficulty": 0.9}
    report3 = edu.run_edu_cycle(stimulus3)
    bridge.update_last_report(report3)
    
    print(f"   Status: {report3.status}")
    print(f"   Błędy: {len(report3.errors)}")
    if report3.errors:
        print(f"   Błąd: {report3.errors[0]['archetype']} → {report3.errors[0]['error'][:50]}...")
    print(f"   Ścieżka: {' → '.join(report3.execution_path)}")
    
    # Przywróć Karolka
    edu.archetypes["Karolek"].function = original_karolek

    # 5. Wyniki archetypów
    print("\n📌 WYNIKI ARCHETYPÓW (z report1):")
    for name in ["Noddy", "Karolek", "Franklin", "Krzys"]:
        if name in report1.outputs:
            out = report1.outputs[name]
            if isinstance(out, dict):
                print(f"   {name}: {str(out)[:60]}...")
            else:
                print(f"   {name}: {str(out)[:60]}")

    # 6. Status archetypów
    print("\n📊 STATUS ARCHETYPÓW:")
    for name, status in edu.get_archetype_status().items():
        print(f"   {name}: lvl {status['level']}, XP {status['xp']}")

    # 7. Mosty integracyjne z dynamicznymi metrykami
    print("\n🔗 MOSTY INTEGRACYJNE (DYNAMICZNE METRYKI):")
    print(f"   GEX Context: {bridge.get_archetype_context()}")
    print(f"   G_CORE State: {bridge.get_autopilot_state()}")
    print(f"   NARRATIVE: {bridge.get_narrative_fragments(2)}")
    print(f"   TRIO State: {bridge.get_trio_state()}")

    print("\n" + "=" * 80)
    print("📚 GEON_EDU_BEAST_v1.1 — GOTOWY DO WDROŻENIA")
    print(HASLO)
    print("=" * 80)

if __name__ == "__main__":
    demo()