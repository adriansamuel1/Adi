            "xp_gain": self.xp_gain,
            "signature": self.signature,
            "context_hash": self.context_hash,
            "execution_path": self.execution_path,
            "errors": self.errors,
            "stability": self.stability,
            "difficulty": self.difficulty,
            "timestamp": self.timestamp
        }

