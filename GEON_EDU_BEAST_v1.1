@dataclass
class EduContextPayload:
    """
    Standaryzowana koperta przekazywania danych między archetypami.
    ULEPSZENIE: typowanie strumienia – każdy archetyp operuje na tej samej strukturze.
    """
    # Metadane
    cycle_id: str
    context_hash: str
    stimulus: Dict[str, Any]
    timestamp: float = field(default_factory=time.time)
    
    # Artefakty akumulowane
    artifacts: Dict[str, Any] = field(default_factory=dict)
    
    # Ostatni zwrot każdego archetypu (dla przejrzystości)
    last_outputs: Dict[str, Any] = field(default_factory=dict)
    
    # Bieżący stan przepływu (aktualizowany przez każdy archetyp)
    current_data: Dict[str, Any] = field(default_factory=dict)
    
    # Ścieżka wykonania
    execution_path: List[str] = field(default_factory=list)
    errors: List[Dict[str, Any]] = field(default_factory=list)

    def add_output(self, archetype_name: str, output: Any, error: Optional[str] = None) -> None:
        """Dodaje output archetypu do kontekstu."""
        self.last_outputs[archetype_name] = output
        self.execution_path.append(archetype_name)
        if error:
            self.errors.append({"archetype": archetype_name, "error": error})
        # Aktualizacja current_data – ostatni output staje się bieżącym stanem
        if isinstance(output, dict):
            self.current_data.update(output)
        else:
            self.current_data["_last_raw"] = output

    def get_last_output(self, archetype_name: str) -> Optional[Any]:
        return self.last_outputs.get(archetype_name)

    def to_dict(self) -> Dict[str, Any]:
        return {
            "cycle_id": self.cycle_id,
            "context_hash": self.context_hash,
            "stimulus": self.stimulus,
            "artifacts": self.artifacts,
            "last_outputs": self.last_outputs,
            "current_data": self.current_data,
            "execution_path": self.execution_path,
            "errors": self.errors,
            "timestamp": self.timestamp
        }


@dataclass
class Archetype:
    """
    Archetyp edukacyjny – agent z XP i poziomami.
    ULEPSZENIE: Thread-Safety dla XP i poziomów.
    """
    name: str
    function: Callable
    xp: int = 0
    level: int = 1
    last_output: Any = None
    _lock: threading.Lock = field(default_factory=threading.Lock, init=False)

    def execute(self, input_data: Any) -> Any:
        """Wykonuje archetyp z zabezpieczeniem thread-safe dla XP/level."""
        self.last_output = self.function(input_data)
        
        # Thread-safe aktualizacja XP i poziomu
        with self._lock:
            self.xp += 1
            if self.xp >= self.level * 10:
                self.level += 1
        
        return self.last_output

    def get_state(self) -> Dict[str, Any]:
        with self._lock:
            return {"xp": self.xp, "level": self.level}


