@dataclass
class FleetCell:
    """10.0A — FLEET_CELL: Pojedynczy dron jako komórka organizmu z fizyką wektorową."""
    id: str
    role: FleetRole
    status: FleetStatus = FleetStatus.IDLE
    position: Tuple[float, float, float] = (0.0, 0.0, 0.0)
    velocity: Tuple[float, float, float] = (0.0, 0.0, 0.0)
    energy: float = 100.0
    max_energy: float = 100.0
    health: float = 100.0
    max_health: float = 100.0
    sensors: Dict[str, float] = field(default_factory=dict)
    connections: List[str] = field(default_factory=list)
    last_update: float = field(default_factory=time.time)
    metadata: Dict[str, Any] = field(default_factory=dict)
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "id": self.id,
            "role": self.role.value,
            "status": self.status.value,
            "position": [round(p, 2) for p in self.position],
            "velocity": [round(v, 2) for v in self.velocity],
            "energy": round(self.energy, 2),
            "max_energy": self.max_energy,
            "health": round(self.health, 2),
            "max_health": self.max_health,
            "sensors": self.sensors,
            "connections": self.connections,
            "last_update": self.last_update,
            "metadata": self.metadata
        }
    
    def is_alive(self) -> bool:
        return self.health > 0 and self.status != FleetStatus.OFFLINE
    
    def is_ready(self) -> bool:
        return self.is_alive() and self.energy > 20 and self.status == FleetStatus.IDLE

    def apply_vector_motion(self, target_pos: Tuple[float, float, float], speed: float = 1.0) -> None:
        """Przesuwa komórkę płynnie w stronę docelowej pozycji (fizyka roju)."""
        dx = target_pos[0] - self.position[0]
        dy = target_pos[1] - self.position[1]
        dz = target_pos[2] - self.position[2]
        dist = math.sqrt(dx*dx + dy*dy + dz*dz)
        
        if dist > 0.1:
            vx = (dx / dist) * speed
            vy = (dy / dist) * speed
            vz = (dz / dist) * speed
            
            self.velocity = (vx, vy, vz)
            self.position = (
                self.position[0] + vx,
                self.position[1] + vy,
                self.position[2] + vz
            )
            self.status = FleetStatus.MOVING
        else:
            self.velocity = (0.0, 0.0, 0.0)
            if self.status == FleetStatus.MOVING:
                self.status = FleetStatus.IDLE


@dataclass
class FleetTissue:
    """10.0B — FLEET_TISSUE: Grupa komórek tworząca tkankę."""
    id: str
    formation: FleetFormation
    cells: List[str]  # ID komórek
    leader: Optional[str] = None
    status: FleetStatus = FleetStatus.IDLE
    position: Tuple[float, float, float] = (0.0, 0.0, 0.0)
    velocity: Tuple[float, float, float] = (0.0, 0.0, 0.0)
    cohesion: float = 1.0  # Dynamicznie przeliczana spójność (0.0 - 1.0)
    created_at: float = field(default_factory=time.time)
    metadata: Dict[str, Any] = field(default_factory=dict)
    
    def update_cohesion(self, cells_map: Dict[str, FleetCell]) -> float:
        """Wylicza realną spójność tkanki na podstawie odchylenia komórek od środka."""
        valid_positions = [cells_map[cid].position for cid in self.cells if cid in cells_map]
        if len(valid_positions) <= 1:
            self.cohesion = 1.0
            return 1.0
        
        total_dist = 0.0
        for pos in valid_positions:
            dist = math.sqrt(sum((pos[i] - self.position[i])**2 for i in range(3)))
            total_dist += dist
            
        avg_dist = total_dist / len(valid_positions)
        # Spójność maleje wykładniczo wraz ze wzrostem rozrzutu przestrzennego
        self.cohesion = max(0.0, min(1.0, 1.0 / (1.0 + (avg_dist / 20.0))))
        return self.cohesion

    def to_dict(self) -> Dict[str, Any]:
        return {
            "id": self.id,
            "formation": self.formation.value,
            "cells": self.cells,
            "leader": self.leader,
            "status": self.status.value,
            "position": [round(p, 2) for p in self.position],
            "velocity": [round(v, 2) for v in self.velocity],
            "cohesion": round(self.cohesion, 4),
            "created_at": self.created_at,
            "metadata": self.metadata
        }


