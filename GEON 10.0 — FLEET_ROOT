class GEON_10_FleetRoot:
    """
    GEON 10.0 — FLEET_ROOT v1.1.
    Pierwsza gałąź drzewa GEON — autoadaptacyjny organizm roju.
    """
    
    def __init__(self, geon_connection: Optional[Any] = None):
        # 10.0A — FLEET_CELL
        self.cells: Dict[str, FleetCell] = {}
        self.cell_counter = 0
        
        # 10.0B — FLEET_TISSUE
        self.tissues: Dict[str, FleetTissue] = {}
        self.tissue_counter = 0
        
        # 10.0C — FLEET_NERVOUS
        self.signals: List[FleetSignal] = []
        self.signal_counter = 0
        self.signal_history: List[Dict[str, Any]] = []
        
        # 10.0D — FLEET_MIND
        self.mind = FleetMind()
        self.geon_connection = geon_connection
        
        # Statystyki operacyjne
        self.stats = {
            "cells_created": 0,
            "cells_destroyed": 0,
            "tissues_formed": 0,
            "tissues_dissolved": 0,
            "signals_sent": 0,
            "signals_received": 0,
            "decisions_made": 0,
            "energy_consumed": 0.0,
            "repairs_initiated": 0
        }
        
        self.history: List[Dict[str, Any]] = []
        self.active = False
        
        LOG("GEON_10_FLEET_ROOT", "🐉 GEON 10.0 — FLEET_ROOT v1.1 ZAINICJOWANY")
        LOG("GEON_10_FLEET_ROOT", f"   Sygnatura: {FRACTAL_SIGNATURE}")
        LOG("GEON_10_FLEET_ROOT", "   Podsystemy: CELL (Fizyka) → TISSUE (Cohesion) → NERVOUS (Routing) → MIND (GEON)")

    # =========================================================================
    # 10.0A — FLEET_CELL (ZARZĄDZANIE KOMÓRKAMI)
    # =========================================================================
    
    def create_cell(
        self,
        role: FleetRole = FleetRole.SCOUT,
        position: Tuple[float, float, float] = (0.0, 0.0, 0.0),
        energy: float = 100.0,
        health: float = 100.0,
        sensors: Optional[Dict[str, float]] = None
    ) -> FleetCell:
        self.cell_counter += 1
        cell_id = f"CELL_{self.cell_counter:04d}"
        
        cell = FleetCell(
            id=cell_id,
            role=role,
            position=position,
            energy=energy,
            max_energy=energy,
            health=health,
            max_health=health,
            sensors=sensors or {},
            status=FleetStatus.IDLE
        )
        
        self.cells[cell_id] = cell
        self.stats["cells_created"] += 1
        self._log("CELL_CREATED", cell.to_dict())
        
        LOG("GEON_10_FLEET_ROOT", f"🧬 Komórka utworzona: {cell_id} ({role.value}) na poz: {position}")
        return cell
    
    def destroy_cell(self, cell_id: str) -> bool:
        if cell_id not in self.cells:
            return False
        
        # Usuń references z tkanek
        for tissue in self.tissues.values():
            if cell_id in tissue.cells:
                tissue.cells.remove(cell_id)
        
        del self.cells[cell_id]
        self.stats["cells_destroyed"] += 1
        self._log("CELL_DESTROYED", {"id": cell_id})
        
        LOG("GEON_10_FLEET_ROOT", f"💥 Komórka zniszczona/usunięta: {cell_id}")
        return True
    
    def update_cell(
        self,
        cell_id: str,
        position: Optional[Tuple[float, float, float]] = None,
        velocity: Optional[Tuple[float, float, float]] = None,
        energy: Optional[float] = None,
        health: Optional[float] = None,
        status: Optional[FleetStatus] = None
    ) -> bool:
        if cell_id not in self.cells:
            return False
        
        cell = self.cells[cell_id]
        if position is not None: cell.position = position
        if velocity is not None: cell.velocity = velocity
        if energy is not None: cell.energy = max(0.0, min(cell.max_energy, energy))
        if health is not None: cell.health = max(0.0, min(cell.max_health, health))
        if status is not None: cell.status = status
        
        cell.last_update = time.time()
        return True

    def get_cell(self, cell_id: str) -> Optional[FleetCell]:
        return self.cells.get(cell_id)
    
    def get_all_cells(self) -> List[FleetCell]:
        return list(self.cells.values())
    
    def get_active_cells(self) -> List[FleetCell]:
        return [c for c in self.cells.values() if c.is_alive()]
    
    def get_ready_cells(self) -> List[FleetCell]:
        return [c for c in self.cells.values() if c.is_ready()]
    
    def get_cells_by_role(self, role: FleetRole) -> List[FleetCell]:
        return [c for c in self.cells.values() if c.role == role and c.is_alive()]

    # =========================================================================
    # 10.0B — FLEET_TISSUE (FORMACJE I SPÓJNOŚĆ)
    # =========================================================================
    
    def form_tissue(
        self,
        cell_ids: List[str],
        formation: FleetFormation = FleetFormation.LINE,
        leader: Optional[str] = None
    ) -> Optional[FleetTissue]:
        if len(cell_ids) < 2:
            LOG("GEON_10_FLEET_ROOT", "⚠️ Wymagane minimum 2 komórki do utworzenia tkanki")
            return None
        
        for cell_id in cell_ids:
            if cell_id not in self.cells:
                LOG("GEON_10_FLEET_ROOT", f"⚠️ Błąd tworzenia tkanki — brak komórki: {cell_id}")
                return None
        
        self.tissue_counter += 1
        tissue_id = f"TISSUE_{self.tissue_counter:04d}"
        
        positions = [self.cells[cid].position for cid in cell_ids]
        center = (
            sum(p[0] for p in positions) / len(positions),
            sum(p[1] for p in positions) / len(positions),
            sum(p[2] for p in positions) / len(positions)
        )
        
        tissue = FleetTissue(
            id=tissue_id,
            formation=formation,
            cells=cell_ids,
            leader=leader or cell_ids[0],
            position=center,
            status=FleetStatus.IDLE
        )
        tissue.update_cohesion(self.cells)
        
        self.tissues[tissue_id] = tissue
        self.stats["tissues_formed"] += 1
        self._log("TISSUE_FORMED", tissue.to_dict())
        
        LOG("GEON_10_FLEET_ROOT", f"🧫 Tkanka utworzona: {tissue_id} ({formation.value}) | Komórki: {len(cell_ids)}")
        return tissue
    
    def dissolve_tissue(self, tissue_id: str) -> bool:
        if tissue_id not in self.tissues:
            return False
        
        del self.tissues[tissue_id]
        self.stats["tissues_dissolved"] += 1
        self._log("TISSUE_DISSOLVED", {"id": tissue_id})
        
        LOG("GEON_10_FLEET_ROOT", f"🧫 Tkanka rozpuszczona: {tissue_id}")
        return True

    def get_tissue(self, tissue_id: str) -> Optional[FleetTissue]:
        return self.tissues.get(tissue_id)
    
    def get_all_tissues(self) -> List[FleetTissue]:
        return list(self.tissues.values())

    # =========================================================================
    # 10.0C — FLEET_NERVOUS (KOMUNIKACJA NERWOWA)
    # =========================================================================
    
    def send_signal(
        self,
        source: str,
        target: str,
        signal_type: str,
        payload: Dict[str, Any],
        priority: int = 5
    ) -> FleetSignal:
        self.signal_counter += 1
        signal_id = f"SIG_{self.signal_counter:04d}"
        
        signal = FleetSignal(
            id=signal_id,
            source=source,
            target=target,
            type=signal_type,
            payload=payload,
            priority=priority
        )
        
        self.signals.append(signal)
        self.stats["signals_sent"] += 1
        self._log("SIGNAL_SENT", signal.to_dict())
        
        LOG("GEON_10_FLEET_ROOT", f"⚡ Sygnał wysłany: {signal_id} ({source} → {target}) | Typ: {signal_type}")
        return signal
    
    def receive_signal(self, signal_id: str) -> Optional[FleetSignal]:
        for signal in self.signals:
            if signal.id == signal_id and not signal.acknowledged:
                signal.acknowledged = True
                self.stats["signals_received"] += 1
                self.signal_history.append(signal.to_dict())
                LOG("GEON_10_FLEET_ROOT", f"📡 Sygnał przetworzony: {signal_id}")
                return signal
        return None
    
    def get_pending_signals(self) -> List[FleetSignal]:
        return [s for s in self.signals if not s.acknowledged]

    # =========================================================================
    # 10.0D — FLEET_MIND (INTEGRACJA Z GEON)
    # =========================================================================
    
    def connect_to_geon(self, geon_instance: Any) -> None:
        self.geon_connection = geon_instance
        self.mind.geon_connected = True
        self.mind.last_sync = time.time()
        LOG("GEON_10_FLEET_ROOT", "🧠 Flota połączona z rdzeniem GEON")
    
    def set_directive(self, directive: Dict[str, Any]) -> None:
        self.mind.directive = directive
        self.mind.last_sync = time.time()
        self._log("DIRECTIVE_SET", directive)
        LOG("GEON_10_FLEET_ROOT", f"📋 Nowa dyrektywa GEON: {directive.get('type', 'GENERAL')}")
    
    def make_decision(self, context: Dict[str, Any]) -> Dict[str, Any]:
        self.stats["decisions_made"] += 1
        
        decision = {
            "id": f"DEC_{self.stats['decisions_made']:04d}",
            "timestamp": time.time(),
            "context": context,
            "source": "GEON_CORE" if self.mind.geon_connected else "AUTONOMOUS_MIND"
        }
        
        if self.mind.geon_connected and self.geon_connection:
            try:
                if hasattr(self.geon_connection, "process"):
                    geon_result = self.geon_connection.process(context)
                    decision["geon_result"] = geon_result
                    decision["directive"] = self.mind.directive
            except Exception as e:
                LOG("GEON_10_FLEET_ROOT", f"⚠️ Wyjątek podczas zapytania do GEON: {e}")
                decision["error"] = str(e)
        else:
            decision["autonomous"] = self._autonomous_decision(context)
        
        self.mind.decisions.append(decision)
        if len(self.mind.decisions) > 100:
            self.mind.decisions = self.mind.decisions[-100:]
        
        self._log("DECISION_MADE", decision)
        return decision
    
    def _autonomous_decision(self, context: Dict[str, Any]) -> Dict[str, Any]:
        action = "maintain_structure"
        priority = 5
        
        low_cohesion_tissues = context.get("low_cohesion_tissues", 0)
        unhandled_repairs = context.get("unhandled_repairs", 0)
        
        if unhandled_repairs > 0:
            action = "dispatch_repairs"
            priority = 1
        elif low_cohesion_tissues > 0:
            action = "regroup_tissues"
            priority = 2
        
        return {
            "action": action,
            "priority": priority,
            "autonomous": True
        }

    # =========================================================================
    # ADVANCED CYCLE TICK (SILNIK BIOCYBERNETYCZNY)
    # =========================================================================
    
    def activate(self) -> None:
        self.active = True
        self.mind.state = "ACTIVE"
        self._log("FLEET_ACTIVATED", {"timestamp": time.time()})
        LOG("GEON_10_FLEET_ROOT", "🔥 Flota aktywowana — tryb operacyjny RUNNING")
    
    def deactivate(self) -> None:
        self.active = False
        self.mind.state = "IDLE"
        self._log("FLEET_DEACTIVATED", {"timestamp": time.time()})
        LOG("GEON_10_FLEET_ROOT", "💤 Flota dezaktywowana")

    def tick(self) -> Dict[str, Any]:
        """Główna pętla taktu floty v1.1 (Zarządzanie stanem, samoleczeniem i fizyką)."""
        if not self.active:
            return {"status": "INACTIVE"}
        
        current_tick = len(self.history) + 1
        LOG("GEON_10_FLEET_ROOT", f"🔄 CYKL TIK #{current_tick}")
        
        # 1. Czyszczenie zniszczonych komórek & Drenaż energii
        dead_cells = []
        for cell_id, cell in list(self.cells.items()):
            if not cell.is_alive():
                dead_cells.append(cell_id)
                continue
            
            if cell.status != FleetStatus.OFFLINE:
                drain = 0.2 if cell.status == FleetStatus.ENGAGED else 0.05
                cell.energy = max(0.0, cell.energy - drain)
                self.stats["energy_consumed"] += drain
                
                if cell.energy == 0:
                    cell.status = FleetStatus.OFFLINE
                    LOG("FLEET_CELL", f"⚠️ Komórka {cell.id} wyczerpała energię i przeszła w OFFLINE")

        for d_id in dead_cells:
            self.destroy_cell(d_id)

        # 2. Aktualizacja Tkanek, Liderów, Spójności i Autonomicznego Ruchu
        low_cohesion_count = 0
        unhandled_repairs = 0

        for tissue_id, tissue in list(self.tissues.items()):
            # Usunięcie zniszczonych jednostek z tkanki
            tissue.cells = [cid for cid in tissue.cells if cid in self.cells]
            
            if len(tissue.cells) < 2:
                LOG("FLEET_TISSUE", f"🧫 Tkanka {tissue_id} uległa rozpadowi (za mało żywych komórek).")
                self.dissolve_tissue(tissue_id)
                continue
            
            # Weryfikacja obecności Lidera
            if not tissue.leader or tissue.leader not in self.cells:
                tissue.leader = tissue.cells[0]
                LOG("FLEET_TISSUE", f"👑 Wyznaczono nowego lidera tkanki {tissue_id}: {tissue.leader}")
            
            # Obliczenie środka ciężkości tkanki
            positions = [self.cells[cid].position for cid in tissue.cells]
            tissue.position = (
                sum(p[0] for p in positions) / len(positions),
                sum(p[1] for p in positions) / len(positions),
                sum(p[2] for p in positions) / len(positions)
            )
            
            # Przeliczenie spójności
            coh = tissue.update_cohesion(self.cells)
            if coh < 0.6:
                low_cohesion_count += 1

            # Ruch wektorowy komórek (Dążenie do środka tkanki lub pozycji lidera)
            leader_pos = self.cells[tissue.leader].position
            for cid in tissue.cells:
                cell = self.cells[cid]
                if cid != tissue.leader:
                    cell.apply_vector_motion(leader_pos, speed=1.5)

            # Auto-Repair Protocol: Wykrywanie uszkodzeń
            for cid in tissue.cells:
                cell = self.cells[cid]
                if cell.health < 40.0 and cell.status != FleetStatus.RECOVERING:
                    repair_cells = self.get_cells_by_role(FleetRole.REPAIR)
                    if repair_cells:
                        self.send_signal(
                            source=cell.id,
                            target=repair_cells[0].id,
                            signal_type="MEDIC_REQUEST",
                            payload={"patient": cell.id, "pos": cell.position, "hp": cell.health},
                            priority=1
                        )
                        cell.status = FleetStatus.RECOVERING
                        self.stats["repairs_initiated"] += 1
                    else:
                        unhandled_repairs += 1

        # 3. Odczyt sygnałów z układu nerwowego
        pending_sigs = self.get_pending_signals()
        for sig in pending_sigs:
            self.receive_signal(sig.id)

        # 4. Decyzja i synapsa z Umysłem
        context = {
            "tick": current_tick,
            "total_cells": len(self.cells),
            "active_cells": len(self.get_active_cells()),
            "tissues": len(self.tissues),
            "low_cohesion_tissues": low_cohesion_count,
            "unhandled_repairs": unhandled_repairs,
            "energy_avg": sum(c.energy for c in self.cells.values()) / max(1, len(self.cells))
        }
        
        decision = self.make_decision(context)
        
        return {
            "status": "TICK_COMPLETE",
            "tick": current_tick,
            "active_cells": len(self.get_active_cells()),
            "tissues": len(self.tissues),
            "processed_signals": len(pending_sigs),
            "decision": decision
        }

    # =========================================================================
    # RAPORTOWANIE I REJESTRACJA
    # =========================================================================
    
    def get_status(self) -> Dict[str, Any]:
        return {
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "active": self.active,
            "stats": self.stats,
            "cells": {
                "total": len(self.cells),
                "active": len(self.get_active_cells()),
                "ready": len(self.get_ready_cells())
            },
            "tissues": {
                "total": len(self.tissues),
                "formations": {f.value: len([t for t in self.tissues.values() if t.formation == f]) for f in FleetFormation}
            },
            "nervous": {
                "pending": len(self.get_pending_signals()),
                "total": len(self.signals)
            },
            "mind": self.mind.to_dict()
        }

