        return report

    def _log(self, event: str, data: Dict[str, Any]) -> None:
        entry = {
            "timestamp": datetime.now().isoformat(),
            "event": event,
            "data": data
        }
        self.history.append(entry)
        if len(self.history) > 1000:
            self.history = self.history[-1000:]

    def reset(self) -> None:
        self.cells = {}
        self.cell_counter = 0
        self.tissues = {}
        self.tissue_counter = 0
        self.signals = []
        self.signal_counter = 0
        self.signal_history = []
        self.mind = FleetMind()
        self.stats = {
            "cells_created": 0,
            "cells_destroyed": 0,
            "tissues_formed": 0,
            "tissues_dissolved": 0,
            "signals_sent": 0,
            "signals_received": 0,
            "decisions_made": 0,
            "energy_consumed": 0.0,
            "repairs_initiated": 0
        }
        self.history = []
        self.active = False
        LOG("GEON_10_FLEET_ROOT", "🔄 Pełny reset floty wykonany")


