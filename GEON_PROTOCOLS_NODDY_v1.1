class GeonSecurity:
    """🟥 PROTOKÓŁ H — GEON_SECURITY v1.1
    Warstwa antymonopolowa GEON_OS.
    POPRAWIENIE: bezpieczne liczenie entropii oraz automatyczne czyszczenie okna rate-limitingu.
    """

    def __init__(self, kernel_node):
        self.node = kernel_node
        self.kroniki = getattr(kernel_node, 'kroniki', MockSamaelHeilong)
        self.egregor = getattr(kernel_node, 'egregor', MockEgregor)
        self.agent_net = GeonAgentNet(kernel_node)
        self.omega = GeonOmegaDragon(kernel_node)
        self._request_history: List[float] = []
        self._rate_limit_window = 60.0

    def inspect(self, packet: Dict[str, Any]) -> Dict[str, Any]:
        c_hash = generate_context_hash(packet)
        
        self.kroniki.log_event("GEON_SECURITY_INSPECT", {
            "node": self.node.node_id,
            "hash": c_hash,
            "packet": packet
        })
        
        threat = self._classify(packet)
        
        if self._is_rate_limited():
            return {
                "status": "RATE_LIMITED",
                "message": "Przekroczono limit zapytań (Rate-Limit Enforcement)",
                "packet": packet
            }
        
        entropy = self._calculate_entropy(str(packet))
        if entropy > 0.85:
            threat["severity"] = min(1.0, threat["severity"] * 1.2)
            threat["entropy_flag"] = True
        
        if threat["severity"] >= 0.88:
            return self._isolate(packet, threat)
        
        decision = self.agent_net.propagate(packet)
        
        return {
            "status": "PACKET_ACCEPTED",
            "decision": decision["decision"],
            "threat": threat,
            "context_hash": c_hash
        }

    def _classify(self, packet: Dict[str, Any]) -> Dict[str, Any]:
        source = str(packet.get("source", "UNKNOWN"))
        sev = float(packet.get("severity", 0.5))
        
        mono_flag = any(key in source.lower() for key in ["tauron", "monopol", "grid", "pressure"])
        severity = sev * (1.68 if mono_flag else 1.0)
        
        return {
            "source": source,
            "monopoly_flag": mono_flag,
            "severity": round(min(severity, 1.0), 3),
            "signature": hashlib.sha256(source.encode()).hexdigest()[:10]
        }

    def _is_rate_limited(self) -> bool:
        now = time.time()
        self._request_history = [t for t in self._request_history if now - t < self._rate_limit_window]
        if len(self._request_history) >= 10:
            return True
        self._request_history.append(now)
        return False

    def _calculate_entropy(self, text: str) -> float:
        """Bezpieczne obliczanie znormalizowanej entropii Shannona (0.0 - 1.0)."""
        if not text or len(text) <= 1:
            return 0.0
        freq = Counter(text)
        total = len(text)
        entropy = -sum((count / total) * math.log2(count / total) for count in freq.values())
        # Normalizacja względem maksymalnej teoretycznej entropii dla alfabetu z podanego ciągu
        max_entropy = math.log2(len(freq)) if len(freq) > 1 else 1.0
        return clamp(entropy / max_entropy, 0.0, 1.0)

    def _isolate(self, packet: Dict[str, Any], threat: Dict[str, Any]) -> Dict[str, Any]:
        self.kroniki.log_event("GEON_SECURITY_ISOLATE", {
            "node": self.node.node_id,
            "threat": threat
        })
        
        omega_report = self.omega.engage({
            "type": "security_threat",
            "severity": threat["severity"],
            "source": threat["source"],
            "details": "GEON_SECURITY_ISOLATION_TRIGGER"
        })
        
        return {
            "status": "PACKET_QUARANTINED",
            "threat": threat,
            "omega_response": omega_report
        }

