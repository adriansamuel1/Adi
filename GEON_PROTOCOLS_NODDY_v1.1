class MockEgregor:
    _ledger: List[Dict[str, Any]] = []
    
    @classmethod
    def commit(cls, entry: Dict[str, Any], node_id: str) -> None:
        entry["node_id"] = node_id
        entry["timestamp"] = datetime.now().isoformat()
        cls._ledger.append(entry)
    
    @classmethod
    def query(cls, context_hash: str) -> List[Dict[str, Any]]:
        return [e for e in cls._ledger if e.get("context_hash") == context_hash]
    
    @classmethod
    def get_ledger(cls) -> List[Dict[str, Any]]:
        """Zwraca płytką kopię listy dla zachowania enkapsulacji."""
        return cls._ledger.copy()

    @classmethod
    def clear_ledger(cls) -> None:
        """Bezpieczne API do czyszczenia pamięci egregora."""
        cls._ledger.clear()

