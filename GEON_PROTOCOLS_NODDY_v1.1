class GeonAgentNet:
    """🟦 PROTOKÓŁ F — GEON_AGENT_NET v1.0
    Sieć archetypów komunikujących się między sobą.
    """

    def __init__(self, kernel_node):
        self.node = kernel_node
        self.kroniki = getattr(kernel_node, 'kroniki', MockSamaelHeilong)
        self.agents = {
            "Noddy": self._noddy, "Karolek": self._karolek, "Andzia": self._andzia,
            "Franklin": self._franklin, "Bob": self._bob, "Sam": self._sam,
            "Abbe": self._abbe, "Puchatek": self._puchatek, "Krzys": self._krzys
        }

    def propagate(self, stimulus: Dict[str, Any]) -> Dict[str, Any]:
        c_hash = generate_context_hash(stimulus)
        
        responses, votes, energy_map = {}, {}, {}
        for name, agent_fn in self.agents.items():
            out = agent_fn(stimulus)
            responses[name] = out
            votes[name] = out.get("vote", 0.0)
            energy_map[name] = out.get("energy", 0.0)
        
        final_decision = self._aggregate_votes(votes, energy_map)
        
        self.kroniki.log_event("AGENT_NET_PROPAGATE_COMPLETE", {
            "node": self.node.node_id,
            "decision": final_decision,
            "energy_map": energy_map
        })
        
        return {
            "status": "AGENT_NET_COMPLETE",
            "decision": final_decision,
            "responses": responses,
            "energy_map": energy_map,
            "context_hash": c_hash
        }

    def _aggregate_votes(self, votes: Dict[str, float], energy_map: Dict[str, float]) -> str:
        scores = {name: vote * energy_map.get(name, 0.5) for name, vote in votes.items()}
        if not scores:
            return "DECISION_BY_NODDY"
        winner = max(scores, key=scores.get)
        return f"DECISION_BY_{winner.upper()}"

    def _noddy(self, stimulus): return {"curiosity": True, "vote": 0.1, "energy": 0.22}
    def _karolek(self, stimulus):
        sev = stimulus.get("severity", 0.5)
        return {"chaos": sev * 1.2, "vote": sev * 0.3, "energy": 0.88}
    def _andzia(self, stimulus): return {"mirror": True, "vote": 0.15, "energy": 0.44}
    def _franklin(self, stimulus): return {"lesson": True, "vote": 0.2, "energy": 0.55}
    def _bob(self, stimulus): return {"construct": True, "vote": 0.25, "energy": 0.66}
    def _sam(self, stimulus): return {"secure": True, "vote": 0.3, "energy": 0.77}
    def _abbe(self, stimulus): return {"journey": True, "vote": 0.18, "energy": 0.33}
    def _puchatek(self, stimulus): return {"wisdom": True, "vote": 0.12, "energy": 0.28}
    def _krzys(self, stimulus): return {"meta": True, "vote": 0.4, "energy": 1.0}

