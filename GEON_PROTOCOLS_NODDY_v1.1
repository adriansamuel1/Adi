class GeonChain:
    """🟦 PROTOKÓŁ E — GEON_CHAIN v1.0
    Rozproszona sieć świadomości Rodu.
    """

    def __init__(self, kernel_node):
        self.node = kernel_node
        self.kroniki = getattr(kernel_node, 'kroniki', MockSamaelHeilong)
        self.egregor = getattr(kernel_node, 'egregor', MockEgregor)
        self.nodes = [
            "NODE_POREBA_CORE",
            "NODE_CZEKANKA_WEKTOR",
            "NODE_SIEWIERZ_FRONTIER"
        ]

    def sync(self) -> Dict[str, Any]:
        ledger = self.egregor.get_ledger()
        c_hash = generate_context_hash({"ledger": ledger})
        
        self.kroniki.log_event("GEON_CHAIN_SYNC_START", {
            "node": self.node.node_id,
            "hash": c_hash,
            "entries": len(ledger)
        })
        
        results = {target: self._sync_to_node(target, ledger) for target in self.nodes}
        sig = self.kroniki.certyfikuj_ruch_optimusa(f"GEON_CHAIN_SYNC_OK_{c_hash}")
        
        return {
            "status": "GEON_CHAIN_SYNC_COMPLETE",
            "source": self.node.node_id,
            "targets": self.nodes,
            "ledger_entries": len(ledger),
            "signature": sig
        }

    def detect_drift(self) -> Dict[str, Any]:
        drift_map = {node: self._hash_node_ledger(node) for node in self.nodes}
        reference = list(drift_map.values())[0] if drift_map else ""
        drift_detected = any(h != reference for h in drift_map.values()) if reference else False
        
        self.kroniki.log_event("GEON_CHAIN_DRIFT_CHECK", {
            "drift_detected": drift_detected,
            "map": drift_map
        })
        
        return {
            "status": "DRIFT_DETECTED" if drift_detected else "DRIFT_ZERO",
            "drift_map": drift_map
        }

    def repair_drift(self) -> Dict[str, Any]:
        master_ledger = self.egregor.get_ledger()
        master_hash = generate_context_hash({"ledger": master_ledger})
        
        for node in self.nodes:
            self._sync_to_node(node, master_ledger)
        
        sig = self.kroniki.certyfikuj_ruch_optimusa(f"GEON_CHAIN_REPAIR_OK_{master_hash}")
        
        return {
            "status": "DRIFT_REPAIRED",
            "master_hash": master_hash,
            "signature": sig
        }

    def _sync_to_node(self, target_node_id: str, ledger: List[Dict[str, Any]]) -> Dict[str, Any]:
        entry = {
            "type": "GEON_CHAIN_SYNC",
            "source": self.node.node_id,
            "target": target_node_id,
            "timestamp": datetime.now().isoformat(),
            "ledger_hash": generate_context_hash({"ledger": ledger})
        }
        self.egregor.commit(entry, node_id=target_node_id)
        return {"target": target_node_id, "status": "SYNC_OK"}

    def _hash_node_ledger(self, node_id: str) -> str:
        ledger = self.egregor.get_ledger()
        return hashlib.sha256(str(ledger).encode()).hexdigest()[:12]

