class GeonQuantum:
    """🟪 PROTOKÓŁ I — GEON_QUANTUM v1.0
    Logika kwantowa archetypów. Superpozycja i kolaps.
    """

    def __init__(self, kernel_node):
        self.node = kernel_node
        self.kroniki = getattr(kernel_node, 'kroniki', MockSamaelHeilong)
        self.egregor = getattr(kernel_node, 'egregor', MockEgregor)
        self.quantum_states = {
            "Noddy": 0.11, "Karolek": 0.22, "Andzia": 0.33,
            "Franklin": 0.44, "Bob": 0.55, "Sam": 0.66,
            "Abbe": 0.77, "Puchatek": 0.88, "Krzys": 0.99
        }

    def collapse(self, stimulus: Dict[str, Any]) -> Dict[str, Any]:
        c_hash = generate_context_hash(stimulus)
        
        amplitudes = self._compute_amplitudes(stimulus)
        normalized = self._normalize(amplitudes)
        chosen = self._quantum_choice(normalized)
        
        entry = {
            "type": "GEON_QUANTUM_COLLAPSE",
            "node": self.node.node_id,
            "timestamp": datetime.now().isoformat(),
            "chosen_archetype": chosen,
            "context_hash": c_hash
        }
        self.egregor.commit(entry, node_id=self.node.node_id)
        
        return {
            "status": "QUANTUM_COLLAPSE_COMPLETE",
            "chosen_archetype": chosen,
            "normalized_distribution": normalized,
            "context_hash": c_hash
        }

    def _compute_amplitudes(self, stimulus):
        sev = stimulus.get("severity", 0.5)
        return {name: base * (1 + sev * random.uniform(0.1, 0.9)) for name, base in self.quantum_states.items()}

    def _normalize(self, amplitudes):
        total = sum(amplitudes.values())
        return {name: round(val / total, 5) for name, val in amplitudes.items()}

    def _quantum_choice(self, distribution):
        names = list(distribution.keys())
        weights = list(distribution.values())
        return random.choices(names, weights=weights, k=1)[0]

