class GeonPoligonD:
    """🟫 PROTOKÓŁ D — POLIGON DLA GORYLA
    Test presji, siły, odporności i instynktu.
    """

    def __init__(self, kernel_node):
        self.node = kernel_node
        self.kroniki = getattr(kernel_node, 'kroniki', MockSamaelHeilong)
        self.egregor = getattr(kernel_node, 'egregor', MockEgregor)
        self.magilla = getattr(kernel_node, 'magilla', MockMagilla())
        self.goryl = getattr(kernel_node, "gorilla", None)
        if self.goryl is None:
            self.goryl = YoungGorilla("GORILLA_TEMP")

    def run(self, stimulus: Dict[str, Any]) -> Dict[str, Any]:
        c_hash = generate_context_hash(stimulus)
        
        self.kroniki.log_event("POLIGON_D_START", {
            "node": self.node.node_id,
            "stimulus": stimulus,
            "hash": c_hash
        })
        
        instinct = self._instinct(stimulus)
        force = self._force(instinct)
        pressure = self._pressure(force)
        calm = self._calm(pressure)
        
        xp_gain = int((pressure.get("resilience", 0.5) * 100))
        self.goryl.gain_experience(xp_gain, f"POLIGON_D_{stimulus.get('type')}")
        
        entry = {
            "type": "POLIGON_D_GORILLA",
            "node": self.node.node_id,
            "timestamp": datetime.now().isoformat(),
            "instinct": instinct,
            "force": force,
            "pressure": pressure,
            "calm": calm,
            "xp_gain": xp_gain,
            "context_hash": c_hash
        }
        self.egregor.commit(entry, node_id=self.node.node_id)
        
        sig = self.kroniki.certyfikuj_ruch_optimusa(f"POLIGON_D_OK_{c_hash}")
        
        return {
            "status": "POLIGON_D_COMPLETE",
            "gorilla": self.goryl.name,
            "xp_gain": xp_gain,
            "instinct": instinct,
            "force": force,
            "pressure": pressure,
            "calm": calm,
            "signature": sig
        }

    def _instinct(self, stimulus: Dict) -> Dict:
        return {
            "reaction": "ALERT",
            "trigger": stimulus.get("type", "UNKNOWN"),
            "intensity": min(1.0, stimulus.get("severity", 0.5) * 1.2)
        }

    def _force(self, instinct: Dict) -> Dict:
        return {
            "impact": instinct["intensity"] * 1.68,
            "mode": "BREAK_OR_PUSH",
            "raw": True
        }

    def _pressure(self, force: Dict) -> Dict:
        raw_resilience = 1.0 - force["impact"] / 3.0
        resilience = max(0.05, sigmoid(raw_resilience * 2.0 - 1.0) * 0.95)
        return {
            "resilience": round(resilience, 3),
            "status": "HOLDING" if resilience > 0.4 else "STRUGGLE"
        }

    def _calm(self, pressure: Dict) -> Dict:
        return {
            "calm_level": round(pressure["resilience"] * 0.88, 3),
            "state": "STABLE" if pressure["resilience"] > 0.4 else "RECOVERING"
        }

