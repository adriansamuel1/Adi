class GeonAutonomy:
    """🟩 PROTOKÓŁ J — GEON_AUTONOMY v1.1
    Samosterowność systemu GEON_OS.
    """

    def __init__(self, kernel_node):
        self.node = kernel_node
        self.kroniki = getattr(kernel_node, 'kroniki', MockSamaelHeilong)
        self.egregor = getattr(kernel_node, 'egregor', MockEgregor)
        self.security = GeonSecurity(kernel_node)
        self.chain = GeonChain(kernel_node)
        self.visualizer = GeonOSVisualizer(kernel_node)
        self.quantum = GeonQuantum(kernel_node)

    def cycle(self) -> Dict[str, Any]:
        c_hash = generate_context_hash(self.node.GLOBAL_STATE)
        
        core_state = self.node.GLOBAL_STATE
        drift_state = self.chain.detect_drift()
        memory_state = {"density": len(self.egregor.get_ledger()) / 42}
        energy_state = {"power": getattr(self.node.core.monterey, 'output_power', 8), "mode": core_state.get("mode")}
        quantum_signal = self.quantum.collapse({"severity": 0.42})
        
        decision = self._autonomous_decision(core_state, drift_state, memory_state, energy_state, quantum_signal)
        action_result = self._execute(decision)
        topology = self.visualizer.snapshot()
        
        entry = {
            "type": "GEON_AUTONOMY_CYCLE",
            "node": self.node.node_id,
            "timestamp": datetime.now().isoformat(),
            "decision": decision,
            "action_result": action_result,
            "context_hash": c_hash
        }
        self.egregor.commit(entry, node_id=self.node.node_id)
        
        return {
            "status": "AUTONOMY_CYCLE_COMPLETE",
            "decision": decision,
            "action_result": action_result,
            "topology": topology
        }

    def _autonomous_decision(self, core, drift, memory, energy, quantum) -> str:
        if drift["status"] != "DRIFT_ZERO":
            return "SYNC_CHAIN"
        if memory["density"] > 1.2:
            return "MEMORY_PURGE"
        if energy["mode"] == "OMEGA":
            return "STABILIZE"
        if quantum["chosen_archetype"] in ["Krzys", "Sam"]:
            return "EXPAND"
        return "IDLE"

    def _execute(self, decision: str) -> Dict[str, Any]:
        if decision == "SYNC_CHAIN":
            return self.chain.repair_drift()
        elif decision == "MEMORY_PURGE":
            if hasattr(self.node, 'memory') and self.node.memory:
                purged = self.node.memory.purge("volatile")
                return {"purged": purged}
            # Użycie oficjalnego API czyszczącego Egregora (Enkapsulacja)
            if hasattr(self.egregor, 'clear_ledger'):
                self.egregor.clear_ledger()
            return {"purged": True, "method": "egregor_api_clear"}
        elif decision == "STABILIZE":
            omega = GeonOmegaDragon(self.node)
            return omega.release()
        elif decision == "EXPAND":
            return {"expansion": "NEW_ARCHETYPE_PATH"}
        return {"idle": True}

