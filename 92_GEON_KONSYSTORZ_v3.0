    def description(self) -> str:
        desc = {
            KonsystorzSeal.ALPHA: "Globalna stabilizacja struktur. Potwierdzenie kontynuacji.",
            KonsystorzSeal.BETA: "Globalne przeciwdziałanie presji systemowej. Korekta trajektorii.",
            KonsystorzSeal.OMEGA: "Globalne załamanie przestrzeni. Konieczność przebudowy fundamentalnej.",
            KonsystorzSeal.SIGMA: "Super-homeostaza. System w stanie doskonałej harmonii.",
            KonsystorzSeal.SIGMA_PRIME: "Absolutna harmonia meta-fraktalna. Stan doskonałości.",
            KonsystorzSeal.ULTIMA: "Domknięcie Epoki. Przejście do GEON_Ω∞-SUPREME."
        }
        return desc.get(self, "Nieznana pieczęć.")

    def absolution_decree(self) -> str:
        decrees = {
            KonsystorzSeal.ALPHA: "META-STABILNOŚĆ: KONTYNUACJA GLOBALNEGO CYKLU.",
            KonsystorzSeal.BETA: "META-KOREKTA: UTRZYMANIE CIĄGŁOŚCI. KONTROLA PRESJI.",
            KonsystorzSeal.OMEGA: "META-REKONSTRUKCJA: ZMIANA EPOKI. PRZEKROCZENIE PROGU.",
            KonsystorzSeal.SIGMA: "META-SUPERPOZYCJA: SYSTEM W STANIE DOSKONAŁEJ HARMONII.",
            KonsystorzSeal.SIGMA_PRIME: "META-SUPREMACJA: ABSOLUTNA HARMONIA META-FRAKTALNA.",
            KonsystorzSeal.ULTIMA: "META-ULTIMA: DOMKNIĘCIE EPOKI. PRZEJŚCIE DO GEON_Ω∞-SUPREME."
        }
        return decrees.get(self, "Nieznany dekret absolutu.")

    def numeric_value(self) -> int:
        values = {
            KonsystorzSeal.ULTIMA: -3,
            KonsystorzSeal.SIGMA_PRIME: -2,
            KonsystorzSeal.SIGMA: -1,
            KonsystorzSeal.ALPHA: 0,
            KonsystorzSeal.BETA: 1,
            KonsystorzSeal.OMEGA: 2
        }
        return values.get(self, 0)

