@dataclass
class CoherenceVector4D:
    """★ NEW: 4D Vector of Absolute Coherence."""
    k_drift: float
    k_health: float
    k_era: float
    k_entropy_global: float

    def magnitude(self) -> float:
        return math.sqrt(self.k_drift**2 + self.k_health**2 + self.k_era**2 + self.k_entropy_global**2)

    def to_dict(self) -> Dict[str, float]:
        return {
            "k_drift": round(self.k_drift, 4),
            "k_health": round(self.k_health, 4),
            "k_era": round(self.k_era, 4),
            "k_entropy_global": round(self.k_entropy_global, 4),
            "magnitude": round(self.magnitude(), 4)
        }


@dataclass
class MetaEraVector2:
    """★ NEW: Meta-Era Vector v2 – dominanta, entropia, trend, shift_risk."""
    dominant: str
    entropy: float
    trend: str
    shift_risk: float
    transition_probabilities: Dict[str, float]

    def to_dict(self) -> Dict[str, Any]:
        return {
