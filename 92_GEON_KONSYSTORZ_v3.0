# =============================================================================
# EGREGOR I KRONIKI
# =============================================================================

class Egregor:
    _ledger: deque = deque(maxlen=MEMORY_LIMIT)
    _index_by_type: Dict[str, List[int]] = {}
    _lock: threading.Lock = threading.Lock()
    
    @classmethod
    def commit(cls, entry: Dict[str, Any], node_id: str) -> None:
        entry["node_id"] = node_id
        entry["timestamp"] = datetime.now().isoformat()
        with cls._lock:
            idx = len(cls._ledger)
            cls._ledger.append(entry)
            entry_type = entry.get("type", "UNKNOWN")
            cls._index_by_type.setdefault(entry_type, []).append(idx)
    
    @classmethod
    def query(cls, type_filter: Optional[str] = None) -> List[Dict[str, Any]]:
        with cls._lock:
            if type_filter:
                indices = cls._index_by_type.get(type_filter, [])
                return [cls._ledger[i] for i in indices if i < len(cls._ledger)]
            return list(cls._ledger)

class SamaelHeilong:
    @staticmethod
    def certyfikuj_konsystorz(action: str, synod_signatures: List[str], gss: str) -> str:
        timestamp = datetime.now().isoformat()
        combined = "".join(synod_signatures) if synod_signatures else action
        combined_hash = hashlib.sha256(combined.encode("utf-8")).hexdigest()[:16]
        payload = f"{timestamp}-{action}-{combined_hash}-{gss[:12]}-1-6-8. ∞. SIEMA!"
        h = hashlib.sha256(payload.encode("utf-8")).hexdigest()[:16].upper()
        return f"🔒 [KONSYSTORZ-CERT-{h}-{combined_hash[:8]}]"

    @staticmethod
    def log_event(event_type: str, payload: Dict[str, Any]) -> None:
        ts = datetime.now().isoformat()
        log(f"[KRONIKI SAMAELA] {ts} | {event_type} -> {payload}", "INFO")

# =============================================================================
# GŁÓWNY MODUŁ: GEON_KONSYSTORZ v3.1
# =============================================================================

class GeonKonsystorz:
    """
    🜀 GEON_KONSYSTORZ v3.1 – META-ABSOLUT SUPREME z integracją AFC.
    """

    def __init__(self, config: Optional[Dict[str, Any]] = None):
        self.config = config or {}
        self.memory_limit = self.config.get("memory_limit", MEMORY_LIMIT)
        self.history: deque = deque(maxlen=self.memory_limit)
        self.meta_memory: List[Dict] = []
        self.kroniki = SamaelHeilong
        self.egregor = Egregor
        self._lock = threading.Lock()
        
        # Progi
        self.omega_required = self.config.get("omega_required", 2)
        self.beta_required = self.config.get("beta_required", 2)
        
        # SIGMA PRIME
        self.sigma_prime_coherence = self.config.get("sigma_prime_coherence", SIGMA_PRIME_COHERENCE_THRESHOLD)
        self.sigma_prime_resonance = self.config.get("sigma_prime_resonance", SIGMA_PRIME_RESONANCE_THRESHOLD)
        self.sigma_prime_entropy = self.config.get("sigma_prime_entropy", SIGMA_PRIME_ENTROPY_THRESHOLD)
        
        # ULTIMA
        self.ultima_coherence = self.config.get("ultima_coherence", ULTIMA_COHERENCE_THRESHOLD)
        self.ultima_resonance = self.config.get("ultima_resonance", ULTIMA_RESONANCE_THRESHOLD)
        self.ultima_entropy = self.config.get("ultima_entropy", ULTIMA_ENTROPY_THRESHOLD)
        
        # ===== NOWE PROGI AFC =====
        self.afc_crisis_stability_threshold = self.config.get("afc_crisis_stability_threshold", AFC_CRISIS_STABILITY_THRESHOLD)
        self.afc_entropy_boost = self.config.get("afc_entropy_boost", AFC_ENTROPY_BOOST)
        self.afc_coherence_penalty = self.config.get("afc_coherence_penalty", AFC_COHERENCE_PENALTY)
        self.afc_seal_omega_boost = self.config.get("afc_seal_omega_boost", AFC_SEAL_OMEGA_BOOST)
        
        # Adaptive mode
        self.adaptive_mode = self.config.get("adaptive_mode", True)
        
        log(f"🐉 {VERSION} aktywowany | {FRACTAL_SIGNATURE}")
        log(f"   ULTIMA: COH>{self.ultima_coherence} | RES<{self.ultima_resonance} | ENT<{self.ultima_entropy}")
        log(f"   AFC INTEGRACJA: AKTYWNA | AFC_ENTROPY_BOOST: {self.afc_entropy_boost}")

    # -------------------------------------------------------------------------
    # GŁÓWNA METODA – ZWOŁANIE KONSYSTORZA
    # -------------------------------------------------------------------------

    def convene(self, synod_inputs: List[Dict[str, Any]]) -> KonsystorzReport:
        if not synod_inputs:
            raise ValueError("Konsystorz wymaga co najmniej jednego wejścia z Synodu.")

        # 1. Parsowanie i walidacja (z AFC)
        parsed_inputs, meta_decrees, drifts, healths, eras, sigs, afc_stabilities, afc_decisions = self._parse_inputs_enhanced(synod_inputs)

        # ===== AGRAGACJA AFC =====
        afc_avg_stability = sum(afc_stabilities) / len(afc_stabilities) if afc_stabilities else 0.0
        afc_dominant_decision = max(set(afc_decisions), key=afc_decisions.count) if afc_decisions else None
        afc_dominant_policy = None  # można dodać jeśli potrzebne

        # 2. Meta-Entropy Global (z AFC)
        meta_entropy_global = self._compute_meta_entropy_global(eras, drifts, healths, afc_avg_stability, afc_dominant_decision)

        # 3. 4D Coherence (z AFC)
        coherence_4d = self._compute_coherence_4d(drifts, healths, eras, meta_entropy_global, afc_avg_stability)

        # 4. Meta-Era v2
        meta_era = self._compute_meta_era_v2(eras, drifts, healths)

        # 5. Resonance Matrix
        resonance_matrix = self._compute_resonance_matrix(parsed_inputs)

        # 6. System Stability Indices
        stability_indices = self._compute_stability_indices(parsed_inputs)

        # 7. Influence Graph
        influence_graph = self._compute_influence_graph(parsed_inputs)

        # 8. Global Seal Signature (GSS-Prime)
        gss = self._compute_gss_prime(parsed_inputs, meta_decrees, drifts, healths, eras, meta_entropy_global, afc_avg_stability)

        # 9. Auto-Corrections (ACE)
        seal_prelim = self._determine_seal_preliminary(meta_decrees, drifts, healths, coherence_4d, resonance_matrix)
        auto_corrections = self._generate_auto_corrections_enhanced(seal_prelim, parsed_inputs)

        # 10. Epoch Prediction v2 (z AFC)
        epoch_predictions = self._predict_epochs_v2(drifts, healths, eras, meta_entropy_global, resonance_matrix, afc_avg_stability)

        # 11. Global State Map
        global_state_map = self._generate_global_state_map_enhanced(parsed_inputs)

        # 12. Wybór Pieczęci (z ULTIMA, SIGMA PRIME i AFC)
        seal = self._determine_seal_supreme(
            meta_decrees, drifts, healths, eras,
            coherence_4d, resonance_matrix, meta_entropy_global,
            meta_era, afc_avg_stability, afc_dominant_decision
        )

        # 13. Dekret
        absolution_decree = seal.absolution_decree()

        # 14. Certyfikacja
        cert = self.kroniki.certyfikuj_konsystorz(f"SEAL_{seal.value}", sigs, gss)

        # 15. Zapisz do meta-memory
        self.meta_memory.append({
            "seal": seal.value,
            "coherence": coherence_4d.magnitude(),
            "resonance": resonance_matrix.global_index,
            "entropy": meta_entropy_global,
            "afc_stability": afc_avg_stability,
            "afc_decision": afc_dominant_decision,
            "timestamp": time.time()
        })
        if len(self.meta_memory) > 100:
            self.meta_memory.pop(0)

        report = KonsystorzReport(
            seal=seal,
            synod_inputs=parsed_inputs,
            meta_decree_summary=self._summarize_decrees(meta_decrees),
            absolution_decree=absolution_decree,
            coherence_4d=coherence_4d,
            meta_era=meta_era,
            resonance_matrix=resonance_matrix,
            global_seal_signature=gss,
            auto_corrections=auto_corrections,
            epoch_predictions=epoch_predictions,
            global_state_map=global_state_map,
            meta_entropy_global=meta_entropy_global,
            system_stability_indices=stability_indices,
            influence_graph=influence_graph,
            certificate=cert,
            # ===== NOWE POLA AFC =====
            afc_average_stability=afc_avg_stability,
            afc_dominant_decision=afc_dominant_decision,
            afc_dominant_policy=afc_dominant_policy
        )

        with self._lock:
            self.history.append(report.to_dict())

        if seal in [KonsystorzSeal.OMEGA, KonsystorzSeal.BETA, KonsystorzSeal.ULTIMA] or len(self.history) % 5 == 0:
            entry = {
                "type": "KONSYSTORZ_SEAL_AFC",
                "report": report.to_dict(),
                "certificate": cert,
                "seal": seal.value,
                "gss": gss,
                "afc_avg_stability": afc_avg_stability,
                "afc_dominant_decision": afc_dominant_decision,
                "timestamp": datetime.now().isoformat()
            }
            self.egregor.commit(entry, node_id="GEON_KONSYSTORZ_AFC")

        self.kroniki.log_event("KONSYSTORZ_CONVENED_AFC", {
            "seal": seal.value,
            "coherence": coherence_4d.magnitude(),
            "resonance": resonance_matrix.global_index,
            "entropy": meta_entropy_global,
            "afc_avg_stability": round(afc_avg_stability, 4),
            "afc_dominant_decision": afc_dominant_decision
        })

        return report

    # -------------------------------------------------------------------------
    # PARSOWANIE WEJŚĆ Z AFC
    # -------------------------------------------------------------------------

    def _parse_inputs_enhanced(self, inputs: List[Dict]) -> Tuple[List[SynodInput], List[str], List[float], List[float], List[str], List[str], List[float], List[str]]:
        parsed, decrees, drifts, healths, eras, sigs, afc_stabilities, afc_decisions = [], [], [], [], [], [], [], []
        for inp in inputs:
            synod_id = inp.get("synod_id", "UNKNOWN")
            meta_decree = inp.get("meta_decree", "META_ALPHA")
            avg_drift = inp.get("average_drift", 0.0)
            avg_health = inp.get("average_health", 0.5)
            sys_count = inp.get("system_count", 1)
            oracle_era = inp.get("oracle_era", "ERA_NIEOKRESLONA")
            signatures = inp.get("signatures", [f"SIG_{synod_id}"])
            
            # ===== EKSTRAKCJA AFC =====
            afc_stability = inp.get("afc_stability", 0.0)
            afc_decision = inp.get("afc_decision")
            afc_policy = inp.get("afc_policy")
            
            # Oblicz entropię systemu na podstawie health/drift/AFC
            afc_penalty = 0.0
            if afc_stability < self.afc_crisis_stability_threshold:
                afc_penalty = 0.1
            if afc_decision in ["ALERT", "HARD_ALERT"]:
                afc_penalty += 0.1
            entropy = clamp((1 - avg_health) + avg_drift * 0.5 + afc_penalty, 0.0, 1.0)
            stability_index = clamp(avg_health * (1 - avg_drift) * (0.8 + 0.2 * afc_stability), 0.0, 1.0)
            
            parsed.append(SynodInput(
                synod_id, meta_decree, avg_drift, avg_health, sys_count,
                oracle_era, signatures, entropy, stability_index,
                afc_stability, afc_decision, afc_policy
            ))
            decrees.append(meta_decree)
            drifts.append(avg_drift)
            healths.append(avg_health)
            eras.append(oracle_era)
            sigs.extend(signatures)
            afc_stabilities.append(afc_stability)
            if afc_decision:
                afc_decisions.append(afc_decision)
        
        return parsed, decrees, drifts, healths, eras, sigs, afc_stabilities, afc_decisions

    def _summarize_decrees(self, decrees: List[str]) -> Dict[str, int]:
        summary = {}
        for d in decrees:
            summary[d] = summary.get(d, 0) + 1
        return summary

    # -------------------------------------------------------------------------
    # META-ENTROPY GLOBAL (Z AFC)
    # -------------------------------------------------------------------------

    def _compute_meta_entropy_global(self, eras: List[str], drifts: List[float],
                                      healths: List[float], afc_avg_stability: float = 0.0,
                                      afc_dominant_decision: Optional[str] = None) -> float:
        # Entropia epok
        era_counts = {}
        for e in eras:
            era_counts[e] = era_counts.get(e, 0) + 1
        total = len(eras)
        era_entropy = -sum((c/total) * math.log((c/total) + 1e-9) for c in era_counts.values()) if total > 0 else 0.0
        era_entropy = clamp(era_entropy / math.log(len(era_counts) + 1e-9), 0.0, 1.0)
        
        # Entropia dryfów
        avg_drift = sum(drifts) / len(drifts) if drifts else 0.0
        drift_variance = sum((d - avg_drift) ** 2 for d in drifts) / len(drifts) if drifts else 0.0
        drift_entropy = clamp(drift_variance * 2.0, 0.0, 1.0)
        
        # Entropia zdrowia
        avg_health = sum(healths) / len(healths) if healths else 0.0
        health_variance = sum((h - avg_health) ** 2 for h in healths) / len(healths) if healths else 0.0
        health_entropy = clamp(health_variance * 2.0, 0.0, 1.0)
        
        # ===== ENTROPIA AFC =====
        afc_entropy = 0.0
        if afc_avg_stability < self.afc_crisis_stability_threshold:
            afc_entropy += self.afc_entropy_boost
        if afc_dominant_decision in ["ALERT", "HARD_ALERT"]:
            afc_entropy += self.afc_entropy_boost
        afc_entropy = clamp(afc_entropy, 0.0, 0.5)
        
        return clamp((era_entropy * 0.3 + drift_entropy * 0.25 + health_entropy * 0.25 + afc_entropy * 0.2), 0.0, 1.0)

    # -------------------------------------------------------------------------
    # 4D KOHERENCJA (Z AFC)
    # -------------------------------------------------------------------------

    def _compute_coherence_4d(self, drifts: List[float], healths: List[float],
                               eras: List[str], meta_entropy: float,
                               afc_avg_stability: float = 0.0) -> CoherenceVector4D:
        avg_drift = sum(drifts) / len(drifts) if drifts else 0.0
        avg_health = sum(healths) / len(healths) if healths else 0.0
        
        era_counts = {}
        for e in eras:
            era_counts[e] = era_counts.get(e, 0) + 1
        max_count = max(era_counts.values()) if era_counts else 0
        k_era = max_count / len(eras) if eras else 0.0
        
        k_drift = 1.0 - clamp(avg_drift, 0.0, 1.0)
        
        # ===== KOREKTA ZDROWIA O AFC =====
        afc_penalty = 0.0
        if afc_avg_stability < self.afc_crisis_stability_threshold:
            afc_penalty = self.afc_coherence_penalty
        k_health = clamp(avg_health - afc_penalty, 0.0, 1.0)
        
        k_entropy_global = 1.0 - meta_entropy
        
        return CoherenceVector4D(k_drift, k_health, k_era, k_entropy_global)

    # -------------------------------------------------------------------------
    # META-ERA v2 (BEZ ZMIAN)
    # -------------------------------------------------------------------------

    def _compute_meta_era_v2(self, eras: List[str], drifts: List[float], healths: List[float]) -> MetaEraVector2:
        counts = {}
        for e in eras:
            counts[e] = counts.get(e, 0) + 1
        dominant = max(counts.items(), key=lambda x: x[1])[0] if counts else "ERA_NIEOKRESLONA"
        
        total = len(eras)
        entropy = -sum((c/total) * math.log((c/total) + 1e-9) for c in counts.values()) if total > 0 else 0.0
        entropy = clamp(entropy / math.log(len(counts) + 1e-9), 0.0, 1.0)
        
        era_order = {"ERA_STABILNOŚCI": 0, "ERA_TRANSFORMACJI": 1, "ERA_KRYZYSU": 2}
        values = [era_order.get(e, 1) for e in eras]
        avg_value = sum(values) / len(values) if values else 1.0
        if avg_value < 0.5:
            trend = "STABILIZACJA"
        elif avg_value < 1.2:
            trend = "TRANSFORMACJA"
        else:
            trend = "KRYZYS"
        
        shift_risk = clamp(entropy + (1 - sum(healths) / len(healths) if healths else 0) * 0.5, 0.0, 1.0)
        
        probs = {}
        for era in ["ERA_STABILNOŚCI", "ERA_TRANSFORMACJI", "ERA_KRYZYSU"]:
            if era == dominant:
                probs[era] = clamp(1.0 - entropy, 0.0, 1.0)
            else:
                probs[era] = clamp(entropy / 2, 0.0, 1.0)
        
        return MetaEraVector2(dominant, entropy, trend, shift_risk, probs)

    # -------------------------------------------------------------------------
    # RESONANCE MATRIX (BEZ ZMIAN)
    # -------------------------------------------------------------------------

    def _compute_resonance_matrix(self, inputs: List[SynodInput]) -> ResonanceMatrix:
        n = len(inputs)
        matrix = []
        systems = [inp.synod_id for inp in inputs]
        
        for i, inp_i in enumerate(inputs):
            row = []
            for j, inp_j in enumerate(inputs):
                if i == j:
                    row.append(1.0)
                else:
                    drift_diff = abs(inp_i.average_drift - inp_j.average_drift)
                    health_diff = abs(inp_i.average_health - inp_j.average_health)
                    era_same = 1.0 if inp_i.oracle_era == inp_j.oracle_era else 0.0
                    afc_diff = abs(inp_i.afc_stability - inp_j.afc_stability) * 0.5
                    resonance = (1.0 - drift_diff) * 0.35 + health_diff * 0.25 + era_same * 0.25 + (1.0 - afc_diff) * 0.15
                    row.append(clamp(resonance, 0.0, 1.0))
            matrix.append(row)
        
        total = 0
        count = 0
        for i in range(n):
            for j in range(n):
                if i != j:
                    total += matrix[i][j]
                    count += 1
        global_index = total / count if count > 0 else 0.0
        
        gradient = 0.0
        if n > 1:
            first_col = sum(matrix[i][0] for i in range(n)) / n
            last_col = sum(matrix[i][-1] for i in range(n)) / n
            gradient = last_col - first_col
        
        return ResonanceMatrix(matrix, global_index, gradient, systems)

    # -------------------------------------------------------------------------
    # SYSTEM STABILITY INDICES (BEZ ZMIAN)
    # -------------------------------------------------------------------------

    def _compute_stability_indices(self, inputs: List[SynodInput]) -> Dict[str, float]:
        return {inp.synod_id: inp.stability_index for inp in inputs}

    # -------------------------------------------------------------------------
    # INFLUENCE GRAPH (BEZ ZMIAN)
    # -------------------------------------------------------------------------

    def _compute_influence_graph(self, inputs: List[SynodInput]) -> Dict[str, List[str]]:
        graph = {}
        for inp in inputs:
            graph[inp.synod_id] = []
            for other in inputs:
                if other.synod_id != inp.synod_id:
                    if abs(inp.average_drift - other.average_drift) < 0.2:
                        graph[inp.synod_id].append(other.synod_id)
        return graph

    # -------------------------------------------------------------------------
    # GSS-PRIME (Z AFC)
    # -------------------------------------------------------------------------

    def _compute_gss_prime(self, inputs: List[SynodInput], decrees: List[str],
                            drifts: List[float], healths: List[float],
                            eras: List[str], meta_entropy: float,
                            afc_avg_stability: float) -> str:
        payload = {
            "synods": [inp.synod_id for inp in inputs],
            "decrees": decrees,
            "avg_drift": sum(drifts) / len(drifts) if drifts else 0.0,
            "avg_health": sum(healths) / len(healths) if healths else 0.0,
            "eras": eras,
            "meta_entropy": meta_entropy,
            "afc_avg_stability": afc_avg_stability,
            "timestamp": time.time()
        }
        return generate_context_hash(payload)

    # -------------------------------------------------------------------------
    # AUTO-CORRECTIONS ENHANCED (BEZ ZMIAN)
    # -------------------------------------------------------------------------

    def _determine_seal_preliminary(self, decrees: List[str], drifts: List[float],
                                    healths: List[float], coherence: CoherenceVector4D,
                                    resonance: ResonanceMatrix) -> KonsystorzSeal:
        omega = decrees.count("META_OMEGA")
        beta = decrees.count("META_BETA")
        avg_drift = sum(drifts) / len(drifts) if drifts else 0.0
        avg_health = sum(healths) / len(healths) if healths else 0.0
        
        if omega >= 2:
            return KonsystorzSeal.OMEGA
        if avg_drift > 0.65:
            return KonsystorzSeal.OMEGA
        if beta >= 2:
            return KonsystorzSeal.BETA
        if avg_health < 0.4:
            return KonsystorzSeal.BETA
        return KonsystorzSeal.ALPHA

    def _generate_auto_corrections_enhanced(self, seal: KonsystorzSeal, inputs: List[SynodInput]) -> List[Dict[str, Any]]:
        corrections = []
        if seal in [KonsystorzSeal.ALPHA, KonsystorzSeal.SIGMA, KonsystorzSeal.SIGMA_PRIME, KonsystorzSeal.ULTIMA]:
            return corrections
        
        target_drift = 0.3 if seal == KonsystorzSeal.BETA else 0.15
        target_health = 0.7 if seal == KonsystorzSeal.BETA else 0.85
        
        for inp in inputs:
            corr = {"synod": inp.synod_id}
            if inp.average_drift > target_drift:
                corr["drift_reduction"] = round(inp.average_drift - target_drift, 4)
            if inp.average_health < target_health:
                corr["health_increase"] = round(target_health - inp.average_health, 4)
            if inp.afc_stability < self.afc_crisis_stability_threshold:
                corr["afc_stabilization_required"] = round(self.afc_crisis_stability_threshold - inp.afc_stability, 4)
            if len(corr) > 1:
                corrections.append(corr)
        return corrections

    # -------------------------------------------------------------------------
    # EPOCH PREDICTION v2 (Z AFC)
    # -------------------------------------------------------------------------

    def _predict_epochs_v2(self, drifts: List[float], healths: List[float],
                           eras: List[str], meta_entropy: float,
                           resonance: ResonanceMatrix,
                           afc_avg_stability: float = 0.0) -> EpochPredictionV2:
        avg_drift = sum(drifts) / len(drifts) if drifts else 0.0
        avg_health = sum(healths) / len(healths) if healths else 0.0
        
        era_order = {"ERA_STABILNOŚCI": 0, "ERA_TRANSFORMACJI": 1, "ERA_KRYZYSU": 2}
        era_values = [era_order.get(e, 1) for e in eras]
        trend = sum(era_values) / len(era_values) if era_values else 1.0
        
        # Korekta trendu o AFC
        if afc_avg_stability < self.afc_crisis_stability_threshold:
            trend += 0.3
        
        if trend < 0.6:
            next_epoch = "ERA_STABILNOŚCI"
            confidence = 0.85 - avg_drift
        elif trend < 1.2:
            next_epoch = "ERA_TRANSFORMACJI"
            confidence = 0.75 - avg_drift * 0.5
        else:
            next_epoch = "ERA_KRYZYSU"
            confidence = 0.7 - avg_drift * 0.5
        
        shift_risk = clamp(meta_entropy + (1 - avg_health) * 0.5, 0.0, 1.0)
        
        base = 0 if next_epoch == "ERA_STABILNOŚCI" else 1 if next_epoch == "ERA_TRANSFORMACJI" else 2
        shift_vector = []
        for i in range(7):
            val = base + int(i * 0.3)
            shift_vector.append(clamp(val, 0, 2))
        
        forecasts = ["ERA_STABILNOŚCI", "ERA_TRANSFORMACJI", "ERA_KRYZYSU"]
        forecast_3 = forecasts[(base + 1) % 3]
        forecast_7 = forecasts[(base + 2) % 3]
        forecast_21 = forecasts[(base + 0) % 3]
        
        crisis_prob = clamp(avg_drift * 0.4 + (1 - avg_health) * 0.25 + meta_entropy * 0.2 + (1 - afc_avg_stability) * 0.15, 0.0, 1.0)
        
        return EpochPredictionV2(
            next_epoch=next_epoch,
            next_epoch_confidence=clamp(confidence, 0.0, 1.0),
            epoch_shift_risk=shift_risk,
            epoch_shift_vector=shift_vector,
            forecast_3=forecast_3,
            forecast_7=forecast_7,
            forecast_21=forecast_21,
            crisis_probability=crisis_prob
        )

    # -------------------------------------------------------------------------
    # GLOBAL STATE MAP ENHANCED (Z AFC)
    # -------------------------------------------------------------------------

    def _generate_global_state_map_enhanced(self, inputs: List[SynodInput]) -> Dict[str, Any]:
        systems = []
        for inp in inputs:
            systems.append({
                "id": inp.synod_id,
                "decree": inp.meta_decree,
                "drift": round(inp.average_drift, 4),
                "health": round(inp.average_health, 4),
                "era": inp.oracle_era,
                "entropy": round(inp.entropy, 4),
                "stability": round(inp.stability_index, 4),
                "afc_stability": round(inp.afc_stability, 4),
                "afc_decision": inp.afc_decision,
                "systems": inp.system_count,
                "status": "KRYTYCZNY" if inp.average_drift > 0.6 or inp.average_health < 0.4 or inp.afc_stability < 0.2 else "STABILNY"
            })
        
        return {
            "systems": systems,
            "summary": {
                "total": len(inputs),
                "avg_drift": round(sum(inp.average_drift for inp in inputs) / len(inputs), 4),
                "avg_health": round(sum(inp.average_health for inp in inputs) / len(inputs), 4),
                "avg_afc_stability": round(sum(inp.afc_stability for inp in inputs) / len(inputs), 4),
                "critical_count": sum(1 for s in systems if s["status"] == "KRYTYCZNY"),
                "dominant_era": max(set(inp.oracle_era for inp in inputs), key=lambda e: sum(1 for i in inputs if i.oracle_era == e)) if inputs else "UNKNOWN"
            }
        }

    # -------------------------------------------------------------------------
    # SUPREME SEAL DETERMINATION (Z AFC)
    # -------------------------------------------------------------------------

    def _determine_seal_supreme(self, decrees: List[str], drifts: List[float],
                                healths: List[float], eras: List[str],
                                coherence: CoherenceVector4D,
                                resonance: ResonanceMatrix,
                                meta_entropy: float,
                                meta_era: MetaEraVector2,
                                afc_avg_stability: float = 0.0,
                                afc_dominant_decision: Optional[str] = None) -> KonsystorzSeal:
        omega = decrees.count("META_OMEGA")
        beta = decrees.count("META_BETA")
        alpha = decrees.count("META_ALPHA")
        total = len(decrees)
        
        avg_drift = sum(drifts) / len(drifts) if drifts else 0.0
        avg_health = sum(healths) / len(healths) if healths else 0.0
        coherence_mag = coherence.magnitude()
        resonance_global = resonance.global_index
        
        # ===== AFC BOOST =====
        afc_omega_boost = 0.0
        if afc_avg_stability < self.afc_crisis_stability_threshold:
            afc_omega_boost += self.afc_seal_omega_boost
        if afc_dominant_decision in ["ALERT", "HARD_ALERT"]:
            afc_omega_boost += self.afc_seal_omega_boost
        
        # 1. ULTIMA – absolutne domknięcie (wymaga stabilnego AFC)
        if (coherence_mag > self.ultima_coherence and
            resonance_global < self.ultima_resonance and
            meta_entropy < self.ultima_entropy and
            afc_avg_stability > 0.8 and
            meta_era.trend == "STABILIZACJA" and
            omega == 0 and beta == 0):
            return KonsystorzSeal.ULTIMA

        # 2. SIGMA PRIME – absolutna harmonia (wymaga stabilnego AFC)
        if (coherence_mag > self.sigma_prime_coherence and
            resonance_global < self.sigma_prime_resonance and
            meta_entropy < self.sigma_prime_entropy and
            afc_avg_stability > 0.7 and
            meta_era.trend == "STABILIZACJA" and
            omega == 0 and beta == 0):
            return KonsystorzSeal.SIGMA_PRIME

        # 3. SIGMA – super-stabilność
        if (omega == 0 and beta == 0 and alpha == total and
            coherence_mag > 0.85 and avg_drift < 0.25 and
            afc_avg_stability > 0.6):
            return KonsystorzSeal.SIGMA

        # 4. OMEGA – z AFC boost
        if omega >= 2 or avg_drift > 0.65 or afc_omega_boost >= 0.5:
            return KonsystorzSeal.OMEGA

        # 5. BETA – z AFC boost
        if beta >= 2 or avg_health < 0.4 or afc_omega_boost >= 0.3:
            return KonsystorzSeal.BETA

        # 6. ALPHA – domyślnie
        return KonsystorzSeal.ALPHA

    # -------------------------------------------------------------------------
    # METODY POMOCNICZE
    # -------------------------------------------------------------------------

    def get_history(self, n: Optional[int] = None) -> List[Dict[str, Any]]:
        with self._lock:
            snapshot = list(self.history)
        if n is not None and n > 0:
            return snapshot[-n:]
        return snapshot

    def get_meta_memory(self, n: Optional[int] = None) -> List[Dict]:
        if n is not None and n > 0:
            return self.meta_memory[-n:]
        return self.meta_memory.copy()

    def reset(self) -> None:
        with self._lock:
            self.history.clear()
            self.meta_memory.clear()
        self.kroniki.log_event("KONSYSTORZ_RESET", {"status": "CLEARED"})

    def get_status(self) -> Dict[str, Any]:
        with self._lock:
            hist_size = len(self.history)
        return {
            "system": "GEON_KONSYSTORZ",
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "vibe": VIBE,
            "history_size": hist_size,
            "memory_limit": self.memory_limit,
            "meta_memory_size": len(self.meta_memory),
            "seals": [s.value for s in KonsystorzSeal],
            "features": {
                "coherence_4d": True,
                "meta_era_v2": True,
                "sigma_prime": True,
                "resonance_matrix": True,
                "gss_prime": True,
                "ace_enhanced": True,
                "epe_v2": True,
                "gsm_enhanced": True,
                "ultima": True,
                "meta_entropy": True,
                "stability_indices": True,
                "influence_graph": True,
                "afc_integration": True
            },
            "afc_thresholds": {
                "crisis_stability": self.afc_crisis_stability_threshold,
                "entropy_boost": self.afc_entropy_boost,
                "coherence_penalty": self.afc_coherence_penalty,
                "seal_omega_boost": self.afc_seal_omega_boost
            }
        }

# =============================================================================
# MOST INTEGRACYJNY — KONSYSTORZ_BRIDGE (ROZSZERZONY)
# =============================================================================

class KonsystorzBridge:
    def __init__(self, konsystorz: GeonKonsystorz):
        self.konsystorz = konsystorz

    # ===== ORYGINALNE METODY (ZACHOWANE) =====
    
    def get_archetype_context(self) -> Dict[str, Any]:
        status = self.konsystorz.get_status()
        return {
            "tryb": VERSION,
            "historia": status["history_size"],
            "features": status["features"],
            "seals": status["seals"],
            "afc_thresholds": status.get("afc_thresholds", {})
        }

    def get_autopilot_state(self) -> Dict[str, Any]:
        history = self.konsystorz.get_history(1)
        if history:
            last = history[-1]
            return {
                "mode": VERSION,
                "seal": last.get("seal", "UNKNOWN"),
                "coherence": last.get("coherence_4d", {}).get("magnitude", 0.0),
                "resonance": last.get("resonance_matrix", {}).get("global_index", 0.0),
                "entropy": last.get("meta_entropy_global", 0.0),
                "gss": last.get("global_seal_signature", "")[:16],
                "afc_avg_stability": last.get("afc_average_stability", 0.0),
                "afc_dominant_decision": last.get("afc_dominant_decision", "UNKNOWN"),
                "konsystorz_ready": True
            }
        return {"mode": VERSION, "seal": "NO_DATA", "konsystorz_ready": True}

    def get_governor_context(self) -> Dict[str, Any]:
        history = self.konsystorz.get_history(1)
        if history:
            last = history[-1]
            return {
                "intent": "KONSYSTORZ_ABSOLUTION",
                "confidence": 1.0 - last.get("meta_entropy_global", 0.5),
                "seal": last.get("seal", "UNKNOWN"),
                "gss": last.get("global_seal_signature", ""),
                "coherence": last.get("coherence_4d", {}).get("magnitude", 0.0),
                "afc_avg_stability": last.get("afc_average_stability", 0.0),
                "konsystorz_ready": True
            }
        return {"intent": "KONSYSTORZ_ABSOLUTION", "confidence": 0.5, "konsystorz_ready": True}

    def get_trio_state(self) -> Dict[str, str]:
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": VERSION,
            "konsystorz": "META-ABSOLUT_AFC"
        }

    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        history = self.konsystorz.get_history(n)
        fragments = []
        for entry in history:
            fragments.append({
                "source": VERSION,
                "content": f"Konsystorz: {entry.get('seal', 'UNKNOWN')} | coh: {entry.get('coherence_4d', {}).get('magnitude', 0):.3f} | afc_stab: {entry.get('afc_average_stability', 0):.3f}",
                "seal": entry.get("seal", "UNKNOWN"),
                "decree": entry.get("absolution_decree", "UNKNOWN")[:60],
                "afc_stability": entry.get("afc_average_stability", 0.0)
            })
        return fragments

    # ===== NOWE METODY AFC =====

    def get_afc_context(self) -> Dict[str, Any]:
        """Zwraca kontekst AFC z ostatniego posiedzenia Konsystorza."""
        history = self.konsystorz.get_history(1)
        if history:
            last = history[-1]
            return {
                "afc_average_stability": last.get("afc_average_stability", 0.0),
                "afc_dominant_decision": last.get("afc_dominant_decision", "UNKNOWN"),
                "afc_dominant_policy": last.get("afc_dominant_policy", "UNKNOWN"),
                "seal": last.get("seal", "UNKNOWN"),
                "coherence": last.get("coherence_4d", {}).get("magnitude", 0.0)
            }
        return {"afc_average_stability": 0.0, "afc_dominant_decision": "UNKNOWN"}

    def get_full_status(self) -> Dict[str, Any]:
        """Zwraca pełny status – Konsystorz + AFC."""
        return {
            "konsystorz": self.konsystorz.get_status(),
            "afc_context": self.get_afc_context(),
            "last_report": self.konsystorz.get_history(1)[0] if self.konsystorz.get_history(1) else None,
            "meta_memory": self.konsystorz.get_meta_memory(5)
        }

# =============================================================================
# GEON_Ω∞ SUPREME — ORGANIZM META-ABSOLUT (z AFC)
# =============================================================================

class GeonOmegaInfinitySupreme:
    """
    🜀 GEON_Ω∞ SUPREME – Najwyższa instancja organizmu meta-fraktalnego z AFC.
    """

    def __init__(self, konsystorz: GeonKonsystorz):
        self.konsystorz = konsystorz
        self.kroniki = SamaelHeilong
        self.egregor = Egregor
        self.history: List[Dict] = []
        self.pulse_count = 0

    def execute_supreme_pulse(self, synod_reports: List[Dict[str, Any]]) -> Dict[str, Any]:
        self.pulse_count += 1
        self.kroniki.log_event("SUPREME_PULSE_AFC", {"pulse": self.pulse_count, "synods": len(synod_reports)})

        report = self.konsystorz.convene(synod_reports)

        entry = {
            "type": "SUPREME_PULSE_AFC",
            "pulse": self.pulse_count,
            "seal": report.seal.value,
            "absolution_decree": report.absolution_decree,
            "gss": report.global_seal_signature,
            "coherence": report.coherence_4d.magnitude(),
            "resonance": report.resonance_matrix.global_index,
            "entropy": report.meta_entropy_global,
            "afc_avg_stability": report.afc_average_stability,
            "afc_dominant_decision": report.afc_dominant_decision,
            "timestamp": datetime.now().isoformat()
        }
        self.history.append(entry)
        self.egregor.commit(entry, node_id="GEON_OMEGA_INFINITY_SUPREME_AFC")

        return {
            "status": "SUPREME_PULSE_COMPLETE",
            "pulse": self.pulse_count,
            "seal": report.seal.value,
            "absolution_decree": report.absolution_decree,
            "gss": report.global_seal_signature,
            "coherence": report.coherence_4d.magnitude(),
            "resonance": report.resonance_matrix.global_index,
            "entropy": report.meta_entropy_global,
            "afc_avg_stability": report.afc_average_stability,
            "afc_dominant_decision": report.afc_dominant_decision,
            "corrections": len(report.auto_corrections),
            "certificate": report.certificate,
            "epoch_forecast": report.epoch_predictions.next_epoch
        }

    def get_supreme_status(self) -> Dict[str, Any]:
        return {
            "system": "GEON_Ω∞ SUPREME",
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "vibe": VIBE,
            "pulse_count": self.pulse_count,
            "history_len": len(self.history),
            "features": self.konsystorz.get_status()["features"]
        }

# =============================================================================
# DEMONSTRACJA
# =============================================================================

def demo():
    print("\n" + "=" * 80)
    print(f"🜀 {VERSION} — DEMONSTRACJA META-ABSOLUT SUPREME Z AFC")
    print("4D COHERENCE | SIGMA PRIME | ULTIMA | AFC INTEGRATION")
    print("=" * 80 + "\n")

    konsystorz = GeonKonsystorz(adaptive_mode=True)
    bridge = KonsystorzBridge(konsystorz)
    supreme = GeonOmegaInfinitySupreme(konsystorz)

    # Symulacja wejść z Synodów z AFC
    def create_synod_input(synod_id, decree, drift, health, era, afc_stab=0.0, afc_dec=None):
        return {
            "synod_id": synod_id,
            "meta_decree": decree,
            "average_drift": drift,
            "average_health": health,
            "system_count": 5,
            "oracle_era": era,
            "signatures": [f"SIG_{synod_id}_01"],
            "afc_stability": afc_stab,
            "afc_decision": afc_dec,
            "afc_policy": "MAINTAIN"
        }

    print("🔍 TEST 1: WSZYSTKIE STABILNE + AFC STABILNY → ULTIMA")
    inputs1 = [
        create_synod_input("EUROPE", "META_ALPHA", 0.05, 0.95, "ERA_STABILNOŚCI", 0.85, "NORMAL"),
        create_synod_input("AFRICA", "META_ALPHA", 0.08, 0.93, "ERA_STABILNOŚCI", 0.82, "NORMAL"),
        create_synod_input("AMERICA", "META_ALPHA", 0.06, 0.94, "ERA_STABILNOŚCI", 0.88, "NORMAL")
    ]
    report1 = konsystorz.convene(inputs1)
    print(f"   Pieczęć: {report1.seal.value} | Coherence: {report1.coherence_4d.magnitude():.3f}")
    print(f"   AFC avg stability: {report1.afc_average_stability:.3f}")

    print("\n🔍 TEST 2: WSZYSTKIE STABILNE + AFC NIESTABILNY (ALERT) → BETA/OMEGA")
    inputs2 = [
        create_synod_input("EUROPE", "META_ALPHA", 0.05, 0.95, "ERA_STABILNOŚCI", 0.2, "ALERT"),
        create_synod_input("AFRICA", "META_ALPHA", 0.08, 0.93, "ERA_STABILNOŚCI", 0.15, "HARD_ALERT"),
        create_synod_input("AMERICA", "META_ALPHA", 0.06, 0.94, "ERA_STABILNOŚCI", 0.25, "ALERT")
    ]
    report2 = konsystorz.convene(inputs2)
    print(f"   Pieczęć: {report2.seal.value} | Entropy: {report2.meta_entropy_global:.3f}")
    print(f"   AFC avg stability: {report2.afc_average_stability:.3f}")

    print("\n🔍 TEST 3: SYSTEMY MIESZANE + AFC MIESZANE")
    inputs3 = [
        create_synod_input("EUROPE", "META_ALPHA", 0.05, 0.95, "ERA_STABILNOŚCI", 0.7, "NORMAL"),
        create_synod_input("AFRICA", "META_BETA", 0.35, 0.65, "ERA_TRANSFORMACJI", 0.4, "NORMAL"),
        create_synod_input("AMERICA", "META_OMEGA", 0.55, 0.45, "ERA_KRYZYSU", 0.2, "ALERT")
    ]
    report3 = konsystorz.convene(inputs3)
    print(f"   Pieczęć: {report3.seal.value}")
    print(f"   Coherence: {report3.coherence_4d.magnitude():.3f}")
    print(f"   AFC avg stability: {report3.afc_average_stability:.3f}")
    print(f"   Epoch forecast: {report3.epoch_predictions.next_epoch}")

    print("\n🔍 TEST SUPREME PULSE:")
    pulse = supreme.execute_supreme_pulse(inputs3)
    print(f"   Pulse #{pulse['pulse']}: {pulse['seal']}")
    print(f"   Coherence: {pulse['coherence']:.3f} | AFC stab: {pulse['afc_avg_stability']:.3f}")

    print("\n🔗 MOSTY INTEGRACYJNE (AFC):")
    print(f"   AFC Context: {bridge.get_afc_context()}")
    print(f"   Autopilot: {bridge.get_autopilot_state()}")
    print(f"   Governor: {bridge.get_governor_context()}")

    print("\n" + "=" * 80)
    print(f"🜀 {VERSION} — META-ABSOLUT SUPREME GOTOWY DO WDROŻENIA")
    print(HASLO)
    print("=" * 80)

if __name__ == "__main__":
    demo()