class MemOmegaBridge:
    """
    Most integracyjny między GEON_MEM_Ω a resztą architektury.
    Łączy: CymaticMemory, GraphMemory, MetaGovernor, ArchetypeRing, G_CORE
    """
    
    def __init__(self, mem_omega: GEON_MEM_OMEGA):
        self.mem = mem_omega
        
    # ========================================================================
    # MOST DO CYMATIC MEMORY
    # ========================================================================
    
    def get_embedding_for_content(self, content: Any) -> List[float]:
        """Zwraca embedding treści z pajęczyny"""
        return self.mem._simple_embedding(content)
    
    def find_similar_nodes(self, content: Any, threshold: float = 0.7) -> List[Node]:
        """Znajduje podobne węzły na podstawie embeddingu"""
        emb = self.mem._simple_embedding(content)
        results = []
        for node in self.mem._nodes.values():
            if node.embedding:
                sim = self.mem._cosine_similarity(emb, node.embedding)
                if sim > threshold:
                    results.append((node, sim))
        results.sort(key=lambda x: x[1], reverse=True)
        return [node for node, _ in results[:10]]
    
    # ========================================================================
    # MOST DO GRAPH MEMORY (Relacje rodowe)
    # ========================================================================
    
    def get_archai_relations(self) -> Dict[str, List[str]]:
        """Zwraca relacje między węzłami ARCHAI"""
        relations = {t: [] for t in Constants.ARCHAI_TYPES}
        for node in self.mem._nodes.values():
            if node.archai_type:
                # Znajdź sąsiadów z tym samym typem ARCHAI
                for edge in self.mem._get_neighbors(node.id):
                    neighbor = self.mem._nodes.get(edge.to_id)
                    if neighbor and neighbor.archai_type == node.archai_type:
                        relations[node.archai_type].append(neighbor.content)
        return relations
    
    # ========================================================================
    # MOST DO META-GOVERNOR (Sonar)
    # ========================================================================
    
    def sonar_recall(self, cues: List[Any]) -> Dict[str, Any]:
        """Wywołanie sonaru – recall z dodatkowymi metadanymi"""
        result = self.mem.recall(cues)
        return {
            "result": result.to_dict(),
            "operational_state": self.mem.get_operational_state().to_dict() if self.mem.get_operational_state() else None,
            "archai_alignment": self.mem.get_archai_alignment(),
            "archai_vector": self.mem.get_archai_vector()
        }
    
    # ========================================================================
    # MOST DO ARCHETYPE RING (ARCHAI jako kierunek)
    # ========================================================================
    
    def get_archai_guidance(self) -> Dict[str, float]:
        """
        Zwraca wskazówki ARCHAI dla Archetype Ring.
        Wyższa wartość = silniejsze przyciąganie w stronę danego archetypu.
        """
        archai_vec = self.mem.get_archai_vector()
        # Mapowanie ARCHAI na archetypy
        archai_to_archetype = {
            "HEILONG": ["SMOK", "TERMINATOR_TC2000"],
            "ARCHITEKT": ["SUN_TZU", "PAMIEC_ABSOLUTNA"],
            "OLSII": ["TYGRYS", "PREDATOR"],
            "BENY": ["SHAOLIN", "TAO"]
        }
        
        guidance = {}
        for arch_type, weight in archai_vec.items():
            for archetype in archai_to_archetype.get(arch_type, []):
                guidance[archetype] = max(guidance.get(archetype, 0.0), weight)
        
        return guidance
    
    # ========================================================================
    # MOST DO G_CORE (Stan operacyjny dla autopilota)
    # ========================================================================
    
    def get_autopilot_state(self) -> Dict[str, Any]:
        """Zwraca stan dla autopilota G_CORE"""
        state = self.mem.get_operational_state()
        if not state:
            return {"mode": "UNKNOWN", "stability": 0.5}
        
        return {
            "mode": state.overall_state.upper(),
            "stability": state.trajectory_stability,
            "meta_stability": state.meta_stability,
            "energy": state.energy_balance,
            "archai": state.archai_alignment
        }
    
    # ========================================================================
    # MOST DO SHERLOCK (Rezonans jako detekcja anomalii)
    # ========================================================================
    
    def detect_anomaly(self, cues: List[Any]) -> Dict[str, Any]:
        """Używa rezonansu do detekcji anomalii"""
        result = self.mem.recall(cues)
        
        # Anomalia = niska pewność przy silnym bodźcu + niestabilny stan
        is_anomaly = (
            result.confidence < 0.3 and
            len(cues) > 0 and
            self.mem.get_operational_state() and
            self.mem.get_operational_state().meta_meta_stability > 0.5
        )
        
        return {
            "is_anomaly": is_anomaly,
            "confidence": result.confidence,
            "core": result.core.content if result.core else None,
            "context": [n.content for n in result.context[:3]],
            "operational_state": self.mem.get_operational_state().to_dict() if self.mem.get_operational_state() else None
        }
    
    # ========================================================================
    # MOST DO NARRATIVE (Rezonanse jako źródło opowieści)
    # ========================================================================
    
    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        """Zwraca fragmenty narracyjne z logu rezonansów"""
        log = self.mem.get_resonance_log()
        fragments = []
        for entry in log[-n:]:
            fragments.append({
                "cue": entry.get("cues", []),
                "core": entry.get("core"),
                "confidence": entry.get("confidence", 0.0),
                "context": entry.get("context", []),
                "state": entry.get("state", "unknown")
            })
        return fragments
    
    # ========================================================================
    # MOST DO REFLECTION (Trajektorie jako samoświadomość)
    # ========================================================================
    
    def get_trajectory_snapshot(self, node_id: str = None) -> Dict[str, Any]:
        """Zwraca snapshot trajektorii dla refleksji"""
        if node_id:
            node = self.mem._nodes.get(node_id)
            if node:
                return {
                    "id": node.id,
                    "content": node.content,
                    "trajectory": node.trajectory[-10:],
                    "meta_trajectory": node.meta_trajectory[-10:],
                    "meta_meta_trajectory": node.meta_meta_trajectory[-10:],
                    "energy": node.energy,
                    "archai_weight": node.archai_weight
                }
        
        # Zwróć agregację wszystkich węzłów
        trajectories = []
        for node in list(self.mem._nodes.values())[:20]:
            if node.trajectory:
                trajectories.append({
                    "id": node.id,
                    "content": str(node.content)[:30],
                    "trajectory": node.trajectory[-5:],
                    "energy": node.energy
                })
        
        return {
            "total_nodes": len(self.mem._nodes),
            "trajectories": trajectories
        }

