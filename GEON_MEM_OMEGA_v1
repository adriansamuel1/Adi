    def _init_strategic_nodes(self) -> None:
        """Inicjalizuje węzły strategiczne z tagami ARCHAI"""
        for name, arch_type in Constants.ARCHAI_MAP.items():
            node = self._create_or_get_node(name)
            node.archai_type = arch_type
            node.archai_weight = Constants.ARCHAI_MAP[arch_type] / 1.0
            node.energy = 0.9

    def _generate_id(self) -> str:
        self._next_id += 1
        return f"MEM_{self._next_id:04d}"

    def _simple_embedding(self, content: Any) -> List[float]:
        """Generuje embedding dla treści (168D)"""
        s = str(content).encode()
        h = hashlib.md5(s).digest()
        return [(h[i % 16] + i) / 255.0 for i in range(self._embedding_dim)]

    def _cosine_similarity(self, a: List[float], b: List[float]) -> float:
        """Oblicza podobieństwo kosinusowe dwóch wektorów"""
        if not a or not b:
            return 0.0
        dot = sum(ai * bi for ai, bi in zip(a, b))
        n1 = math.sqrt(sum(ai * ai for ai in a))
        n2 = math.sqrt(sum(bi * bi for bi in b))
        return dot / (n1 * n2 + 1e-9)

    def _create_or_get_node(self, content: Any, tags: List[str] = None) -> Node:
        """Tworzy nowy węzeł lub zwraca istniejący"""
        # Sprawdź czy już istnieje
        for node in self._nodes.values():
            if node.content == content:
                node.last_accessed = time.time()
                return node
        
        # Utwórz nowy węzeł
        node_id = self._generate_id()
        node = Node(
            id=node_id,
            content=content,
            tags=tags or [],
            embedding=self._simple_embedding(content),
            energy=1.0,
            emo_weight=0.5,
            base_frequency=440.0 + (hash(str(content)) % 100) / 10.0
        )
        self._nodes[node_id] = node
        self._adjacency[node_id] = []
        return node

    def _add_edge(self, from_node: Node, to_node: Node, strength: float = 0.5) -> None:
        """Dodaje lub wzmacnia krawędź między węzłami"""
        key = (from_node.id, to_node.id)
        
        if key in self._edges:
            edge = self._edges[key]
            edge.strength = min(1.0, edge.strength + strength * 0.2)
            edge.resonance_factor = min(1.0, edge.resonance_factor + 0.05)
            edge.last_activated = time.time()
        else:
            edge = Edge(
                from_id=from_node.id,
                to_id=to_node.id,
                strength=strength
            )
            self._edges[key] = edge
            self._adjacency[from_node.id].append(edge)
        
        # Krawędź zwrotna (słabsza)
        rev_key = (to_node.id, from_node.id)
        if rev_key not in self._edges:
            rev_edge = Edge(
                from_id=to_node.id,
                to_id=from_node.id,
                strength=strength * 0.8
            )
            self._edges[rev_key] = rev_edge
            self._adjacency[to_node.id].append(rev_edge)

    # ========================================================================
    # PRIVATE – WARSTWY L2–L8 (wewnętrzne)
    # ========================================================================

    def _decay_energy(self) -> None:
        """L2 – Naturalny zanik energii wszystkich węzłów"""
        for node in self._nodes.values():
            node.energy = max(Constants.ENERGY_FLOOR, node.energy - Constants.ENERGY_DECAY)

    def _apply_emo_weight(self, wave: Wave, node: Node) -> float:
        """L3 – Modulacja amplitudy fali przez emo_weight węzła"""
        return wave.amplitude * (0.5 + node.emo_weight * 0.5)

    def _update_trajectory(self, node: Node, score: float) -> None:
        """L4 – Aktualizacja trajektorii węzła"""
        node.prev_trajectory = node.trajectory.copy()
        node.trajectory.append(score)
        if len(node.trajectory) > 20:
            node.trajectory = node.trajectory[-20:]

    def _update_meta_trajectory(self, node: Node) -> None:
        """L5 – Aktualizacja meta‑trajektorii (pochodna trajektorii)"""
        if len(node.trajectory) < 2:
            return
        node.prev_meta_trajectory = node.meta_trajectory.copy()
        meta = node.trajectory[-1] - node.trajectory[-2]
        node.meta_trajectory.append(meta)
        if len(node.meta_trajectory) > 20:
            node.meta_trajectory = node.meta_trajectory[-20:]

    def _update_meta_meta_trajectory(self, node: Node) -> None:
        """L6 – Aktualizacja meta‑meta‑trajektorii (druga pochodna)"""
        if len(node.meta_trajectory) < 2:
            return
        meta_meta = node.meta_trajectory[-1] - node.meta_trajectory[-2]
        node.meta_meta_trajectory.append(meta_meta)
        if len(node.meta_meta_trajectory) > 20:
            node.meta_meta_trajectory = node.meta_meta_trajectory[-20:]

    def _homeostasis(self, node: Node) -> None:
        """L7 – Stabilizacja trajektorii węzła (wygładzanie)"""
        if len(node.trajectory) < 5:
            return
        recent = node.trajectory[-5:]
        mean = sum(recent) / 5
        smoothed = mean * Constants.HOMEOSTASIS_ALPHA + node.trajectory[-1] * (1 - Constants.HOMEOSTASIS_ALPHA)
        node.trajectory[-1] = smoothed

    def _update_archai(self, node: Node) -> None:
        """L8 – Aktualizacja alignment ARCHAI węzła"""
        if not node.archai_type:
            return
        
        if len(node.trajectory) > 5:
            recent = node.trajectory[-5:]
            stability = 1.0 - min(1.0, (max(recent) - min(recent)))
        else:
            stability = 0.5
        
        node.archai_weight = (node.energy * 0.6 + stability * 0.4)

    def _archai_gravity(self) -> float:
        """Oblicza globalne przyciąganie ARCHAI (alignment całego systemu)"""
        archai_nodes = [n for n in self._nodes.values() if n.archai_type]
        if not archai_nodes:
            return 0.5
        return sum(n.archai_weight for n in archai_nodes) / len(archai_nodes)

    # ========================================================================
    # PRIVATE – L9 OPERATIONAL AWARENESS
    # ========================================================================

    def _evaluate_operational_state(self) -> OperationalState:
        """L9 – Ocena stanu operacyjnego systemu"""
        traj_vals, meta_vals, meta_meta_vals = [], [], []
        
        for node in self._nodes.values():
            if node.trajectory:
                traj_vals.append(abs(node.trajectory[-1]) if node.trajectory else 0.5)
            if node.meta_trajectory:
                meta_vals.append(abs(node.meta_trajectory[-1]) if node.meta_trajectory else 0.1)
            if node.meta_meta_trajectory:
                meta_meta_vals.append(abs(node.meta_meta_trajectory[-1]) if node.meta_meta_trajectory else 0.05)
        
        traj_stab = 1.0 - (sum(traj_vals) / max(1, len(traj_vals))) if traj_vals else 0.7
        meta_stab = 1.0 - (sum(meta_vals) / max(1, len(meta_vals))) if meta_vals else 0.6
        meta_meta_stab = 1.0 - (sum(meta_meta_vals) / max(1, len(meta_meta_vals))) if meta_meta_vals else 0.7
        
        archai_align = self._archai_gravity()
        energy_balance = sum(n.energy for n in self._nodes.values()) / max(1, len(self._nodes))
        
        # Określenie stanu ogólnego
        if meta_meta_stab > Constants.META_META_ALERT:
            overall = "unstable"
        elif archai_align < Constants.MIN_ARCHAI:
            overall = "misaligned"
        elif energy_balance < Constants.MIN_ENERGY:
            overall = "recovering"
        else:
            overall = "stable"
        
        return OperationalState(
            trajectory_stability=traj_stab,
            meta_stability=meta_stab,
            meta_meta_stability=meta_meta_stab,
            archai_alignment=archai_align,
            energy_balance=energy_balance,
            overall_state=overall
        )

    def _operational_correction(self, state: OperationalState) -> None:
        """L9 – Autopilot fraktalny – koryguje zachowanie systemu"""
        # Meta-meta za wysokie → tłumimy
        if state.meta_meta_stability > Constants.MAX_META_META:
            for node in self._nodes.values():
                node.energy = max(0.3, node.energy * 0.95)
        
        # Archai za słabe → wzmacniamy węzły rodowe
        if state.archai_alignment < Constants.MIN_ARCHAI:
            for node in self._nodes.values():
                if node.archai_type:
                    node.energy = min(1.5, node.energy * 1.05)
        
        # Energia za niska → podbijamy
        if state.energy_balance < Constants.MIN_ENERGY:
            for node in self._nodes.values():
                node.energy = min(1.5, node.energy * 1.03)

    # ========================================================================
    # PRIVATE – L10 SELF-ADAPT
    # ========================================================================

    def _self_adapt(self, state: OperationalState) -> None:
        """L10 – Samo-aktualizacja parametrów na podstawie historii stanów"""
        if len(self._state_history) < Constants.ADAPTATION_WINDOW:
            return
        
        last_n = list(self._state_history)[-Constants.ADAPTATION_WINDOW:]
        
        # 1. Jeśli często "unstable" → zwiększ DAMPING_FACTOR
        unstable = sum(1 for s in last_n if s.overall_state == "unstable")
        if unstable >= Constants.INSTABILITY_THRESHOLD_FOR_DAMP and Constants.DAMPING_FACTOR < 0.93:
            old = Constants.DAMPING_FACTOR
            Constants.DAMPING_FACTOR += Constants.DAMPING_INCREMENT
            rule = AdaptationRule(
                name="STABILIZE_DAMPING",
                trigger_state="unstable",
                param="DAMPING_FACTOR",
                direction="up",
                step=Constants.DAMPING_INCREMENT
            )
            self._adaptation_history.append(rule)
            self._on_adaptation(rule)
            if self._verbose:
                print(f"[L10] DAMPING: {old:.3f} → {Constants.DAMPING_FACTOR:.3f}")
        
        # 2. Jeśli długo "stable" → zmniejsz ENERGY_DECAY
        stable = sum(1 for s in last_n if s.overall_state == "stable")
        if stable >= Constants.STABILITY_THRESHOLD_FOR_RELAX and Constants.ENERGY_DECAY > 0.08:
            old = Constants.ENERGY_DECAY
            Constants.ENERGY_DECAY -= Constants.DECAY_DECREMENT
            rule = AdaptationRule(
                name="REVIVE_WEB",
                trigger_state="stable",
                param="ENERGY_DECAY",
                direction="down",
                step=Constants.DECAY_DECREMENT
            )
            self._adaptation_history.append(rule)
            self._on_adaptation(rule)
            if self._verbose:
                print(f"[L10] ENERGY_DECAY: {old:.3f} → {Constants.ENERGY_DECAY:.3f}")

    # ========================================================================
    # PRIVATE – L11 META-ADAPT
    # ========================================================================

    def _meta_adapt(self) -> None:
        """L11 – Adaptacja zasad adaptacji (meta-regulator nad L10)"""
        if len(self._adaptation_history) < Constants.META_WINDOW:
            return
        
        last = list(self._adaptation_history)[-Constants.META_WINDOW:]
        
        # 1. Jeśli L10 za często podbija damping → zmniejsz jego czułość
        damping_changes = [a for a in last if a.param == "DAMPING_FACTOR" and a.direction == "up"]
        if len(damping_changes) > Constants.MAX_DAMPING_CHANGES:
            old = Constants.DAMPING_INCREMENT
            Constants.DAMPING_INCREMENT = max(0.005, Constants.DAMPING_INCREMENT * 0.8)
            rule = MetaAdaptationRule(
                name="REDUCE_DAMPING_SENSITIVITY",
                affected_param="DAMPING_INCREMENT",
                adjustment=Constants.DAMPING_INCREMENT - old,
                reason=f"too_many ({len(damping_changes)})"
            )
            self._meta_adaptation_history.append(rule)
            self._on_meta_adaptation(rule)
            if self._verbose:
                print(f"[L11] DAMPING_INCREMENT: {old:.4f} → {Constants.DAMPING_INCREMENT:.4f}")
        
        # 2. Jeśli decay był zmieniany zbyt często → ogranicz jego zakres
        decay_changes = [a for a in last if a.param == "ENERGY_DECAY"]
        if len(decay_changes) > Constants.MAX_DECAY_CHANGES:
            old = Constants.DECAY_DECREMENT
            Constants.DECAY_DECREMENT = max(0.002, Constants.DECAY_DECREMENT * 0.7)
            rule = MetaAdaptationRule(
                name="LIMIT_DECAY_ADAPTATION",
                affected_param="DECAY_DECREMENT",
                adjustment=Constants.DECAY_DECREMENT - old,
                reason=f"too_many ({len(decay_changes)})"
            )
            self._meta_adaptation_history.append(rule)
            self._on_meta_adaptation(rule)
            if self._verbose:
                print(f"[L11] DECAY_DECREMENT: {old:.4f} → {Constants.DECAY_DECREMENT:.4f}")

    # ========================================================================
    # PRIVATE – GŁÓWNA FUNKCJA RECALL (L1–L11)
    # ========================================================================

    def _find_best_matching_node(self, cue: Any) -> Optional[Node]:
        """Znajduje węzeł najlepiej pasujący do bodźca"""
        if not self._nodes:
            return None
        
        cue_emb = self._simple_embedding(cue)
        best, best_score = None, -1.0
        
        for node in self._nodes.values():
            if node.embedding:
                score = self._cosine_similarity(cue_emb, node.embedding)
                # Bonus za tagi
                if isinstance(cue, str) and node.tags:
                    for tag in node.tags:
                        if tag.lower() in cue.lower():
                            score += 0.2
                if score > best_score:
                    best_score, best = score, node
        
        return best if best_score > 0.2 else None

    def _get_neighbors(self, node_id: str) -> List[Edge]:
        """Zwraca wszystkie krawędzie wychodzące z węzła"""
        return self._adjacency.get(node_id, [])

    def _propagate_waves(self, waves: List[Wave]) -> ResonancePattern:
        """L1–L3 – Propagacja fal po pajęczynie"""
        scores: Dict[str, float] = {}
        paths: List[List[str]] = []
        visited: Set[str] = set()
        queue: List[Wave] = []
        
        for w in waves:
            w.path = [w.node_id]
            heapq.heappush(queue, w)
        
        while queue:
            w = heapq.heappop(queue)
            
            if w.depth >= Constants.MAX_WAVE_DEPTH:
                continue
            if w.amplitude < Constants.PROPAGATION_THRESHOLD:
                continue
            
            # Akumulacja wyniku
            scores[w.node_id] = scores.get(w.node_id, 0.0) + w.amplitude
            
            # Zapisz ścieżkę
            if w.depth > 0 and w.node_id not in visited:
                paths.append(w.path.copy())
                visited.add(w.node_id)
            
            # Propaguj do sąsiadów
            for edge in self._get_neighbors(w.node_id):
                target = self._nodes.get(edge.to_id)
                if not target:
                    continue
                
                # Oblicz nową amplitudę
                new_amp = w.amplitude * edge.strength * edge.resonance_factor
                new_amp *= Constants.DAMPING_FACTOR * target.energy
                new_amp = self._apply_emo_weight(w, target)
                
                # Oblicz nową częstotliwość
                new_freq = (w.frequency + target.base_frequency) / 2
                new_phase = w.phase + edge.latency
                
                new_wave = Wave(
                    node_id=edge.to_id,
                    amplitude=new_amp,
                    frequency=new_freq,
                    phase=new_phase,
                    depth=w.depth + 1,
                    path=w.path + [edge.to_id]
                )
                heapq.heappush(queue, new_wave)
        
        return ResonancePattern(node_scores=scores, wave_paths=paths)

    def _get_core_memory(self, resonance: ResonancePattern) -> Optional[Node]:
        """Wybierz węzeł z najwyższym wynikiem rezonansu (rdzeń wspomnienia)"""
        if not resonance.node_scores:
            return None
        
        best_id = max(resonance.node_scores.items(), key=lambda x: x[1])[0]
        best_score = resonance.node_scores[best_id]
        
        if best_score < Constants.CORE_SCORE_THRESHOLD:
            return None
        
        return self._nodes.get(best_id)

    def _expand_context(self, core: Node, resonance: ResonancePattern, top_n: int = 5) -> List[Node]:
        """Rozwija kontekst wokół rdzenia wspomnienia"""
        neighbors = self._get_neighbors(core.id)
        scored = [
            (edge.to_id, resonance.node_scores.get(edge.to_id, 0.0) * edge.strength)
            for edge in neighbors
        ]
        scored.sort(key=lambda x: x[1], reverse=True)
        
        context = []
        for nid, _ in scored[:top_n]:
            node = self._nodes.get(nid)
            if node and node.id != core.id:
                context.append(node)
        
        return context

    def _recall_full(self, cues: List[Any]) -> MemoryResult:
        """Pełny cykl przypominania L1–L11"""
        # 1. Znajdź węzły startowe
        start_nodes = []
        for cue in cues:
            node = self._find_best_matching_node(cue)
            if node:
                start_nodes.append(node)
        
        if not start_nodes:
            return MemoryResult(confidence=0.0)
        
        # 2. Utwórz fale
        waves = [
            Wave(
                node_id=n.id,
                amplitude=1.0,
                frequency=n.base_frequency,
                phase=0.0
            )
            for n in start_nodes
        ]
        
        # 3. Propaguj fale (L1–L3)
        resonance = self._propagate_waves(waves)
        resonance.cue = cues
        
        # 4. Wybierz rdzeń
        core = self._get_core_memory(resonance)
        if not core:
            core = start_nodes[0]
        
        # 5. Rozwiń kontekst
        context = self._expand_context(core, resonance)
        
        # 6. Aktualizuj trajektorie (L4–L6)
        for node_id, score in resonance.node_scores.items():
            node = self._nodes.get(node_id)
            if node:
                self._update_trajectory(node, score)
        
        for node in self._nodes.values():
            self._update_meta_trajectory(node)
            self._update_meta_meta_trajectory(node)
        
        # 7. Homeostaza (L7)
        for node in self._nodes.values():
            self._homeostasis(node)
        
        # 8. Archai (L8)
        for node in self._nodes.values():
            self._update_archai(node)
        
        # 9. L2 – Decay energii
        self._decay_energy()
        
        # 10. L9 – Świadomość operacyjna
        state = self._evaluate_operational_state()
        self._operational_correction(state)
        self._current_operational_state = state
        self._state_history.append(state)
        
        # 11. L10 – Samo-aktualizacja
        self._self_adapt(state)
        
        # 12. L11 – Meta-adaptacja
        self._meta_adapt()
        
        # 13. Wynik
        confidence = min(1.0, resonance.node_scores.get(core.id, 0.0))
        result = MemoryResult(
            core=core,
            context=context,
            resonance=resonance,
            confidence=confidence
        )
        
        # 14. Logowanie
        self._resonance_log.append({
            "timestamp": time.time(),
            "cues": cues,
            "core": core.content,
            "confidence": confidence,
            "state": state.overall_state,
            "context": [n.content for n in context[:3]]
        })
        
        return result

