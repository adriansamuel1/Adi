@dataclass
class Node:
    """Węzeł pamięci – element pajęczyny znaczeń"""
    id: str
    content: Any
    tags: List[str] = field(default_factory=list)
    base_frequency: float = 440.0
    energy: float = 1.0
    embedding: Optional[List[float]] = None
    created_at: float = field(default_factory=time.time)
    last_accessed: float = field(default_factory=time.time)
    
    # L3: EMO_WEIGHT
    emo_weight: float = 0.5
    
    # L4-L6: TRAJECTORY
    trajectory: List[float] = field(default_factory=list)
    prev_trajectory: List[float] = field(default_factory=list)
    meta_trajectory: List[float] = field(default_factory=list)
    prev_meta_trajectory: List[float] = field(default_factory=list)
    meta_meta_trajectory: List[float] = field(default_factory=list)
    
    # L8: ARCHAI
    archai_type: Optional[str] = None
    archai_weight: float = 0.5
    
    def __hash__(self):
        return hash(self.id)

@dataclass
class Edge:
    """Krawędź pajęczyny – połączenie między węzłami"""
    from_id: str
    to_id: str
    strength: float = 0.5
    latency: float = 0.1
    resonance_factor: float = Constants.DEFAULT_RESONANCE_FACTOR
    created_at: float = field(default_factory=time.time)
    last_activated: float = field(default_factory=time.time)
    
    def decay(self, factor: float = 0.995) -> None:
        """Naturalne wygaszanie krawędzi w czasie"""
        self.strength = max(0.1, self.strength * factor)
        self.resonance_factor = max(0.3, self.resonance_factor * factor)

@dataclass
class Wave:
    """Fala propagująca po pajęczynie"""
    node_id: str
    amplitude: float
    frequency: float
    phase: float
    depth: int = 0
    path: List[str] = field(default_factory=list)
    
    def __lt__(self, other):
        return self.amplitude > other.amplitude

@dataclass
class ResonancePattern:
    """Wzór rezonansu – mapa wzmocnień węzłów po propagacji"""
    node_scores: Dict[str, float] = field(default_factory=dict)
    wave_paths: List[List[str]] = field(default_factory=list)
    timestamp: float = field(default_factory=time.time)
    cue: Any = None
    
    def get_top_nodes(self, n: int = 10) -> List[Tuple[str, float]]:
        """Zwraca n węzłów z najwyższym wynikiem rezonansu"""
        return sorted(self.node_scores.items(), key=lambda x: x[1], reverse=True)[:n]

