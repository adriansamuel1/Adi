def _buduj_wzor(idx: int) -> Wzor:
    """Tworzy wzór matematyczny z zabezpieczeniami numerycznymi."""
    if idx == 1:
        return Wzor("Hydrostatyka (p = ρgh)", 
                    lambda p: (clamp(p.get("glebokosc", 0), 0, 1000) * 9.81 * clamp(p.get("gestosc", 0), 0, 5000)) / 100000.0, 
                    ["glebokosc", "gestosc"])
    elif idx == 2:
        return Wzor("Prawo Ohma (I = U/R)", 
                    lambda p: p.get("napiecie", 0) / max(p.get("opornosc", 1.0), 0.001), 
                    ["napiecie", "opornosc"])
    elif idx == 3:
        return Wzor("Wzrost Wykładniczy (e^(k*t))", 
                    lambda p: math.exp(clamp(p.get("czas", 0) * p.get("wsp", 0.1), -10, 10)), 
                    ["czas", "wsp"])
    elif idx == 4:
        return Wzor("Energia Potencjalna (E = mgh)", 
                    lambda p: (p.get("masa", 0) * 9.81 * p.get("wysokosc", 0)) / 1000.0, 
                    ["masa", "wysokosc"])
    elif idx == 5:
        return Wzor("Równanie Logistyczne", 
                    lambda p: 1.0 / (1.0 + math.exp(-clamp(p.get("czas", 0), -10, 10))), 
                    ["czas"])
    elif idx == 6:
        return Wzor("Czynnik Rezonansu 168", 
                    lambda p: (p.get("rezonans_bazowy", 168.0) / 100.0) * p.get("wsp", 0.1), 
                    ["rezonans_bazowy", "wsp"])
    elif idx == 7:
        return Wzor("Entropia Boltzmanna", 
                    lambda p: 1.38 * safe_log(max(p.get("pojemnosc", 2.0), 1.0001)), 
                    ["pojemnosc"])
    elif idx == 8:
        return Wzor("Dylatacja Czasu", 
                    lambda p: 1.0 / math.sqrt(max(1.0 - (clamp(p.get("wsp", 0.01), 0.0, 0.9999)**2), 0.0001)), 
                    ["wsp"])
    elif idx == 9:
        return Wzor("Praca Termodynamiczna", 
                    lambda p: (p.get("pojemnosc", 0) * 8.31 * p.get("temp_pocz", 0)) / 1000.0, 
                    ["pojemnosc", "temp_pocz"])
    elif idx == 10:
        return Wzor("Długość Wektora 2D", 
                    lambda p: math.sqrt(p.get("wysokosc", 0)**2 + p.get("glebokosc", 0)**2) / 10.0, 
                    ["wysokosc", "glebokosc"])
    else:
        return Wzor(f"Fraktal_Mod{idx}", 
                    lambda p, i=idx: (p.get("pojemnosc", 10.0) * i) / (max(p.get("temp_pocz", 20.0), 0.1) * 1.68), 
                    ["pojemnosc", "temp_pocz"])

def utworz_modele() -> List[Model]:
    modele = []
    typy = ["Zamknięty", "Otwarty", "Scentralizowany", "Rozproszony", "Dynamiczny"]
    for i in range(1, 16):
        typ = typy[(i - 1) % len(typy)]
        prog_stab = 0.3 + (i % 4) * 0.1
        prog_kryt = prog_stab + 0.25
        parametry = {
            "glebokosc": 10.0 * i,
            "gestosc": 1000.0 + (i * 50),
            "napiecie": 12.0 * i,
            "opornosc": 1.5 * i,
            "czas": 1.0 + (i * 0.5),
            "wsp": 0.05 + (i * 0.01),
            "masa": 50.0 * i,
            "wysokosc": 5.0 * i,
            "pojemnosc": 100.0 + i * 10.0,
            "temp_pocz": 20.0 + i,
            "rezonans_bazowy": 168.0
        }
        modele.append(Model(f"Model_{i:02d}", f"Architektura {typ} – ID_{i:02d}",
                            prog_stab, prog_kryt, parametry))
    return modele

def utworz_warstwy() -> List[Warstwa]:
    warstwy = []
    funkcje = ["Ryzyko", "Naprężenie", "Przepływ", "Energia", "Entropia",
               "Sterowanie", "Adaptacja", "Rezonans", "Dryf", "Stabilność",
               "Fraktalność", "Informacja", "Substancja", "Wektor", "Ciągłość"]
    for i, nazwa in enumerate(funkcje, 1):
        if i % 3 == 0:
            trans = lambda p, f=i/10: p * f
        elif i % 3 == 1:
            trans = lambda p, f=i/5: math.exp(min(p * f, 20)) - 1
        else:
            trans = lambda p, f=i/2: p ** f if p >= 0 else 0.0
        warstwy.append(Warstwa(f"Warstwa_{i:02d}_{nazwa}", 
                               f"Przetwarzanie_{nazwa.lower()}", trans))
    return warstwy

def utworz_wzory() -> List[Wzor]:
    return [_buduj_wzor(i) for i in range(1, 16)]

MODELE = utworz_modele()
WARSTWY = utworz_warstwy()
WZORY = utworz_wzory()

def NAVIGATOR_15x15(A: int, B: int, C: int) -> Dict[str, Any]:
    if not (1 <= A <= 15 and 1 <= B <= 15 and 1 <= C <= 15):
        raise ValueError("Indeksy Matrixa GEON muszą zawierać się w przedziale [1-15]")
    model = MODELE[A-1]
    warstwa = WARSTWY[B-1]
    wzor = WZORY[C-1]
    
    parametry_kontekstu = {zm: model.parametry.get(zm, 0.5) for zm in wzor.zmienne}
    try:
        presja = float(wzor.rownanie(parametry_kontekstu))
    except Exception:
        presja = 0.0
    konsekwencja = float(warstwa.transformacja(presja))
    
    if konsekwencja < model.prog_stabilny:
        stan = "STABILNY (NOMINAL)"
    elif konsekwencja < model.prog_krytyczny:
        stan = "KRYTYCZNY (WARNING)"
    else:
        stan = "AWARIA (CRITICAL_DRIFT)"
    
    regula = f"GEON::[M_{A:02d}][W_{B:02d}][WZ_{C:02d}] -> {warstwa.funkcja}(Presja: {presja:.4f}) => Trans: {konsekwencja:.4f}"
    return {
        "model": model.nazwa,
        "warstwa": warstwa.nazwa,
        "wzor": wzor.nazwa,
        "presja_pierwotna": presja,
        "konsekwencja": konsekwencja,
        "stan": stan,
        "regula": regula
    }

