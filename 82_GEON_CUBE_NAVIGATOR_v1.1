class FlowStep:
    def __init__(self, name: str, moves: List[str], eval_point: Tuple[int, int, int],
                 on_stable: str, on_warning: str, on_critical: str):
        self.name = name
        self.moves = moves
        self.eval_point = eval_point
        self.on_stable = on_stable
        self.on_warning = on_warning
        self.on_critical = on_critical

class FlowEngine:
    def __init__(self, cube: GEON_Cube):
        self.cube = cube
        self.steps: Dict[str, FlowStep] = {}
        self.current_step: Optional[str] = None
        self.history: List[Dict[str, Any]] = []

    def add_step(self, step: FlowStep) -> None:
        self.steps[step.name] = step

    def set_start(self, name: str) -> None:
        if name not in self.steps:
            raise ValueError(f"Krok startowy '{name}' nie istnieje.")
        self.current_step = name

    def tick(self) -> Optional[Dict[str, Any]]:
        if self.current_step is None:
            return None
        step = self.steps[self.current_step]
        if step.moves:
            self.cube.apply_moves(step.moves)
        a, b, c = step.eval_point
        res = self.cube.eval(a, b, c, log=False)
        stan = res["stan"]
        if "STABILNY" in stan:
            nxt = step.on_stable
        elif "KRYTYCZNY" in stan:
            nxt = step.on_warning
        else:
            nxt = step.on_critical
        record = {
            "step": step.name,
            "moves": step.moves,
            "eval_point": step.eval_point,
            "stan": stan,
            "konsekwencja": res["konsekwencja"],
            "next": nxt,
            "timestamp": datetime.now().isoformat()
        }
        self.history.append(record)
        SamaelHeilong.log_event("FLOW_TICK", {
            "Krok": step.name,
            "StanKostki": stan,
            "Konsekwencja": f"{res['konsekwencja']:.4f}",
            "Wektor_Kolejny": nxt
        })
        self.current_step = nxt if nxt != "END" else None
        return res

