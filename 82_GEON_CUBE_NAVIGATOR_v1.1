class Model:
    """Model Verne'a – opis systemu, progi stabilności, parametry wewnętrzne"""
    def __init__(self, nazwa: str, opis: str, prog_stabilny: float, 
                 prog_krytyczny: float, parametry: Dict[str, float]):
