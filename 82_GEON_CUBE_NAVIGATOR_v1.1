class GEON_Cube:
    """SZEŚCIAN GEON 15×15×15 – oś X = MODELE (A), Y = WARSTWY (B), Z = WZORY (C)"""
    
    def __init__(self) -> None:
        self.axis_A: List[int] = list(range(1, 16))
        self.axis_B: List[int] = list(range(1, 16))
        self.axis_C: List[int] = list(range(1, 16))
        self.kroniki = SamaelHeilong
        self.egregor = Egregor

    # Rotacje osi
    def rotate_A(self, shift: int = 1) -> None:
        shift %= 15
        self.axis_A = self.axis_A[shift:] + self.axis_A[:shift]

    def rotate_B(self, shift: int = 1) -> None:
        shift %= 15
        self.axis_B = self.axis_B[shift:] + self.axis_B[:shift]

    def rotate_C(self, shift: int = 1) -> None:
        shift %= 15
        self.axis_C = self.axis_C[shift:] + self.axis_C[:shift]

    # Interfejs symboliczny (notacja Rubika – obsługuje "+", "-", "2")
    def move(self, code: str) -> None:
        """Obsługuje ruchy: A+, A-, A2, B+, B-, B2, C+, C-, C2"""
        if len(code) < 2:
            raise ValueError(f"Nieprawidłowy kod ruchu: {code}")
        axis = code[0].upper()
        suffix = code[1:]
        if suffix == '+':
            shift = 1
        elif suffix == '-':
            shift = -1
        elif suffix == '2':
            shift = 2
        else:
            try:
                shift = int(suffix)
            except ValueError:
                raise ValueError(f"Nieprawidłowy sufiks ruchu: {suffix}")
        if axis == 'A':
            self.rotate_A(shift)
        elif axis == 'B':
            self.rotate_B(shift)
        elif axis == 'C':
            self.rotate_C(shift)
        else:
            raise ValueError(f"Nieznana oś ruchu: {axis}")

    def apply_moves(self, moves: List[str]) -> None:
        for m in moves:
            self.move(m)

    def apply_sequence(self, moves: List[Tuple[str, int]]) -> None:
        for axis, shift in moves:
            if axis == 'A':
                self.rotate_A(shift)
            elif axis == 'B':
                self.rotate_B(shift)
            elif axis == 'C':
                self.rotate_C(shift)

    # Ewaluacja
    def eval(self, posA: int, posB: int, posC: int, log: bool = False) -> Dict[str, Any]:
        if not (1 <= posA <= 15 and 1 <= posB <= 15 and 1 <= posC <= 15):
            raise ValueError("Pozycje muszą być w zakresie 1-15")
        A = self.axis_A[posA - 1]
        B = self.axis_B[posB - 1]
        C = self.axis_C[posC - 1]
        result = NAVIGATOR_15x15(A, B, C)
        if log:
            self.kroniki.log_event("CUBE_EVAL", {
                "pos": (posA, posB, posC),
                "indices": (A, B, C),
                "stan": result["stan"],
                "konsekwencja": result["konsekwencja"]
            })
        return result

    # Stan
    def state(self) -> Dict[str, List[int]]:
        return {"A": self.axis_A.copy(), "B": self.axis_B.copy(), "C": self.axis_C.copy()}

    def from_state(self, state: Dict[str, List[int]]) -> None:
        self.axis_A = state["A"].copy()
        self.axis_B = state["B"].copy()
        self.axis_C = state["C"].copy()

    # Zapis/odczyt Egregor
    def save_state(self, label: str) -> None:
        entry = {
            "type": "CUBE_STATE",
            "label": label,
            "state": self.state(),
            "timestamp": datetime.now().isoformat()
        }
        self.egregor.commit(entry, node_id="GEON_CUBE")

    def load_state(self, label: str) -> bool:
        for e in self.egregor.query():
            if e.get("type") == "CUBE_STATE" and e.get("label") == label:
                self.from_state(e["state"])
                return True
        return False

    # Wyświetlanie
    def show(self, max_display: int = 5) -> None:
        print(f"Oś A (modele): {self.axis_A[:max_display]}... (łącznie {len(self.axis_A)})")
        print(f"Oś B (warstwy): {self.axis_B[:max_display]}...")
        print(f"Oś C (wzory) : {self.axis_C[:max_display]}...")

    # Ewaluacja warstwy / przekątnej
    def eval_layer(self, fixed_axis: str, fixed_pos: int) -> List[Dict[str, Any]]:
        results = []
        if fixed_axis == 'A':
            for b in range(1, 16):
                for c in range(1, 16):
                    results.append(self.eval(fixed_pos, b, c, log=False))
        elif fixed_axis == 'B':
            for a in range(1, 16):
                for c in range(1, 16):
                    results.append(self.eval(a, fixed_pos, c, log=False))
        elif fixed_axis == 'C':
            for a in range(1, 16):
                for b in range(1, 16):
                    results.append(self.eval(a, b, fixed_pos, log=False))
        else:
            raise ValueError("fixed_axis musi być 'A', 'B' lub 'C'")
        return results

