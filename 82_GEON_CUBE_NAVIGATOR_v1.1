class Warstwa:
    """Warstwa GEON-OS – funkcja operacyjna i transformacja presji"""
    def __init__(self, nazwa: str, funkcja: str, transformacja: Callable[[float], float]):
        self.nazwa = nazwa
        self.funkcja = funkcja
        self.transformacja = transformacja

class Wzor:
    """Wzór matematyczny – nazwa, równanie dynamiczne, wymagane zmienne"""
    def __init__(self, nazwa: str, rownanie: Callable[[Dict[str, float]], float], 
                 zmienne: List[str]):
        self.nazwa = nazwa
        self.rownanie = rownanie
        self.zmienne = zmienne

