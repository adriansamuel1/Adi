class GeonCubeNavigatorModule:
    """Główny orchestrator nawigacji – agreguje Cube, Navigator, FlowEngine."""
    
    def __init__(self):
        self.cube = GEON_Cube()
        self.navigator = GeonCubeNavigator(self.cube)
        self.flow = FlowEngine(self.cube)
        self.kroniki = SamaelHeilong
        self.egregor = Egregor
        
        log("🐉 GEON_CUBE_NAVIGATOR_v1.1 aktywowany | " + FRACTAL_SIGNATURE)
        log(f"   KOSTKA: 15×15×15 | REZONANS: {VIBE} | RUCHY: +, -, 2")

    def eval_point(self, a: int, b: int, c: int, log: bool = False) -> Dict[str, Any]:
        return self.cube.eval(a, b, c, log)

    def apply_moves(self, moves: List[str]) -> None:
        self.cube.apply_moves(moves)

    def find_path(self, target_stan: str, target_konsekwencja: float,
                  eval_point: Tuple[int, int, int] = (1, 1, 1),
                  tolerance: float = 0.05, max_moves: int = 5) -> Optional[List[str]]:
        return self.navigator.find_path_to_target(target_stan, target_konsekwencja,
                                                   eval_point, tolerance, max_moves)

    def run_flow(self, start_step: str) -> List[Dict[str, Any]]:
        self.flow.set_start(start_step)
        while self.flow.current_step is not None:
            self.flow.tick()
        return self.flow.history

    def snapshot(self) -> Dict[str, Any]:
        return {
            "status": "CUBE_NAVIGATOR_ACTIVE",
            "state": self.cube.state(),
            "egregor_size": len(self.egregor.get_ledger()),
            "history_len": len(self.flow.history)
        }

    def get_status(self) -> Dict[str, Any]:
        return {
            "system": "GEON_CUBE_NAVIGATOR_v1.1",
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "vibe": VIBE,
            "cube_state": self.cube.state(),
            "flow_history_len": len(self.flow.history)
        }

class CubeNavigatorBridge:
    """Most integracyjny dla GEON_CUBE_NAVIGATOR."""
    
    def __init__(self, module: GeonCubeNavigatorModule):
        self.module = module

    def get_archetype_context(self) -> Dict[str, Any]:
        return {
            "tryb": "CUBE_NAVIGATOR_v1.1",
            "cube_state": self.module.cube.state(),
            "flow_steps": len(self.module.flow.steps)
        }

    def get_autopilot_state(self) -> Dict[str, Any]:
        return {
            "mode": "CUBE_NAVIGATOR_v1.1",
            "stability": 0.85,
            "energy": 0.7,
            "pressure": 0.2,
            "resilience": 0.9,
            "cube_ready": True
        }

    def get_governor_context(self) -> Dict[str, Any]:
        return {
            "intent": "CUBE_NAVIGATION",
            "confidence": 0.95,
            "entropy": 0.1,
            "navigator_ready": True
        }

    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        return [{
            "source": "CUBE_NAVIGATOR_v1.1",
            "content": f"Kostka: {self.module.cube.state()}",
            "energy": 0.8
        }]

    def get_trio_state(self) -> Dict[str, str]:
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": "CUBE_NAVIGATOR_v1.1",
            "navigator": "AKTYWNY"
        }

