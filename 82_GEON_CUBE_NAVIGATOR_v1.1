# =============================================================================

def demo():
    print("\n" + "=" * 80)
    print("🧭 GEON_CUBE_NAVIGATOR_v1.1 — DEMONSTRACJA")
    print("ZABEZPIECZONE WZORY | UNIWERSALNY NAVIGATOR | RUCH '2'")
    print("=" * 80 + "\n")

    module = GeonCubeNavigatorModule()
    bridge = CubeNavigatorBridge(module)

    # 1. Ewaluacja punktu
    print("📌 EWALUACJA PUNKTU (2,1,1):")
    res = module.eval_point(2, 1, 1, log=True)
    print(f"   Stan: {res['stan']}")
    print(f"   Konsekwencja: {res['konsekwencja']:.4f}")

    # 2. Ruchy kostką z "2"
    print("\n🔄 RUCHY KOSTKĄ (A+, A2, B-, C2, A-):")
    moves = ["A+", "A2", "B-", "C2", "A-"]
    module.apply_moves(moves)
    module.cube.show()
    res2 = module.eval_point(2, 1, 1, log=False)
    print(f"   Nowy stan: {res2['stan']}, konsekwencja: {res2['konsekwencja']:.4f}")

    # 3. Szukanie ścieżki w punkcie (2,1,1)
    print("\n🔍 SZUKANIE ŚCIEŻKI W PUNKCIE (2,1,1) DO STANU STABILNY:")
    path = module.find_path("STABILNY", 0.2, eval_point=(2, 1, 1), tolerance=0.8, max_moves=4)
    print(f"   Znaleziona ścieżka: {path}")

    # 4. FlowEngine – scenariusz
    print("\n⚙️ URUCHOMIENIE FLOW_ENGINE:")
    flow = module.flow
    flow.add_step(FlowStep("INIT", ["A+", "B+", "C+"], (2, 1, 1),
                           "OPERATE", "OPERATE", "RECOVERY"))
    flow.add_step(FlowStep("OPERATE", ["A2", "C-"], (3, 2, 1),
                           "STABILIZE", "STABILIZE", "RECOVERY"))
    flow.add_step(FlowStep("STABILIZE", ["B-", "C2"], (2, 1, 2),
                           "END", "END", "RECOVERY"))
    flow.add_step(FlowStep("RECOVERY", ["A-", "B-", "C-"], (1, 1, 1),
                           "END", "END", "END"))
    history = module.run_flow("INIT")
    print("   Historia wykonania:")
    for entry in history:
        print(f"   • {entry['step']}: {entry['stan']} -> {entry['next']}")

    # 5. Stan końcowy
    print("\n📊 STAN KOŃCOWY:")
    status = module.get_status()
    print(f"   System: {status['system']}")
    print(f"   Vibe: {status['vibe']}")

    # 6. Mosty
    print("\n🔗 MOSTY INTEGRACYJNE:")
    print(f"   GEX Context: {bridge.get_archetype_context()}")
    print(f"   G_CORE State: {bridge.get_autopilot_state()}")

    print("\n" + "=" * 80)
    print("🧭 GEON_CUBE_NAVIGATOR_v1.1 — GOTOWY DO WDROŻENIA")
    print(HASLO)
    print("=" * 80)

if __name__ == "__main__":
    demo()