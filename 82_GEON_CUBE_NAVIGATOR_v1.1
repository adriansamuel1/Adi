# CZĘŚĆ 3: GeonCubeNavigator (UNIWERSALNY – DOWOLNY PUNKT + RUCH "2")
# =============================================================================

class GeonCubeNavigator:
    def __init__(self, cube: GEON_Cube):
        self.cube = cube

    def find_path_to_target(self, target_stan: str, target_konsekwencja: float,
                            eval_point: Tuple[int, int, int] = (1, 1, 1),
                            tolerance: float = 0.05, max_moves: int = 5) -> Optional[List[str]]:
        """
        Wyszukuje optymalną sekwencję rotacji dla wybranego punktu ewaluacyjnego.
        Obsługuje ruchy: +, -, 2.
        """
        start_state = self.cube.state()
        
        def state_key(s: Dict[str, List[int]]):
            return (tuple(s["A"]), tuple(s["B"]), tuple(s["C"]))
        
        queue = deque([(start_state, [], 0)])
        visited = {state_key(start_state)}
        
        while queue:
            current_state, path, depth = queue.popleft()
            self.cube.from_state(current_state)
            
            # Ewaluacja wskazanego punktu w kostce
            res = self.cube.eval(eval_point[0], eval_point[1], eval_point[2], log=False)
            
            if target_stan in res["stan"] and abs(res["konsekwencja"] - target_konsekwencja) <= tolerance:
                self.cube.from_state(start_state)
                return path
                
            if depth >= max_moves:
                continue
                
            # Generowanie ruchów Notacji Rubika dla GEON (A, B, C x +, -, 2)
            for axis in ['A', 'B', 'C']:
                for move_type in ['+', '-', '2']:
                    move_code = f"{axis}{move_type}"
                    test_cube = GEON_Cube()
                    test_cube.from_state(current_state)
                    test_cube.move(move_code)
                    
                    next_state = test_cube.state()
                    key = state_key(next_state)
                    if key not in visited:
                        visited.add(key)
                        queue.append((next_state, path + [move_code], depth + 1))
                        
        self.cube.from_state(start_state)
        return None

