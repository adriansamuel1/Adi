class A1_Czucie_Sygnalu:
    """A1 – Pierścień czucia pierwotnego z uwzględnieniem AFC"""
    def __init__(self):
        self.simba = "PURE_INSTINCT"
        self.boo = "INNOCENT_FEELING"
        self.kot = "INTUITIVE_TOUCH"
        self.nazwa = "CZUCIE_SYGNALU"
        self.historia: List[Dict] = []
        self.afc_stability_threshold = AFC_CRISIS_STABILITY_THRESHOLD
    
    def execute(self, pole: Dict) -> Dict:
        # Ekstrakcja danych AFC
        afc_data = pole.get("afc_data", {})
        afc_stability = afc_data.get("stability", 0.5)
        afc_decision = afc_data.get("decision")
        afc_policy = afc_data.get("policy")
        
        # Czucie pierwotne z uwzględnieniem AFC
        czucie = self._simba_touch(pole, afc_stability)
        oczyszczone = self._boo_filter(czucie)
        intuicja = self._kot_instinct(oczyszczone, afc_stability, afc_decision)
        
        # Dodanie sygnatury AFC do wyniku
        wynik = {
            "czucie_pierwotne": intuicja,
            "afc_stability": afc_stability,
            "afc_decision": afc_decision,
            "afc_policy": afc_policy
        }
        self.historia.append({"timestamp": time.time(), "wynik": wynik})
        if len(self.historia) > 50:
            self.historia = self.historia[-30:]
        return wynik
    
    def _simba_touch(self, pole: Dict, afc_stability: float) -> Dict:
        emocje = pole.get("emocje", {})
        # AFC stabilny → czucie czystsze
        # AFC niestabilny → czucie bardziej zamglone
        czystosc = 0.5 + 0.5 * afc_stability
        if emocje:
            return {k: v * czystosc for k, v in emocje.items()}
        return {"domyslna": 0.5 * czystosc}
    
    def _boo_filter(self, czucie: Dict) -> Dict:
        if not isinstance(czucie, dict):
            return {}
        return {k: float(v) for k, v in czucie.items()}
    
    def _kot_instinct(self, czucie: Dict, afc_stability: float, afc_decision: Optional[str]) -> Dict:
        if not czucie:
            return {"reakcja": "nie_wiem", "intensywnosc": 0.0, "afc_boost": 0.0}
        
        intens = sum(czucie.values()) / len(czucie)
        
        # Korekta AFC – decyzja ALERT zwiększa czujność
        afc_boost = 0.0
        if afc_decision in ["ALERT", "HARD_ALERT"]:
            afc_boost = 0.2
        if afc_stability < self.afc_stability_threshold:
            afc_boost += 0.1
        
        intens_korekta = min(1.0, intens + afc_boost)
        
        if intens_korekta > 0.6:
            return {"reakcja": "tak", "intensywnosc": intens_korekta, "afc_boost": afc_boost}
        if intens_korekta < 0.3:
            return {"reakcja": "nie", "intensywnosc": intens_korekta, "afc_boost": afc_boost}
        return {"reakcja": "nie_wiem", "intensywnosc": intens_korekta, "afc_boost": afc_boost}


