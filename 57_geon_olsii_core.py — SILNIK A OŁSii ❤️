class A3_Filtracja_Emocjonalna:
    """A3 – Pierścień filtracji emocjonalnej"""
    def __init__(self):
        self.rafiki = "WISE_EMOTION_FILTER"
        self.czarownica = "SHADOW_ILLUSION"
        self.mulan = "COURAGE_CHECK"
        self.nazwa = "FILTRACJA_EMOCJONALNA"
        self.historia: List[Dict] = []
    
    def execute(self, intuicja_kierunku: Dict) -> Dict:
        intuicja = intuicja_kierunku.get("intuicja_kierunku", {})
        afc_stability = intuicja_kierunku.get("afc_stability", 0.5)
        
        rafiki_view = self._rafiki_truth(intuicja, afc_stability)
        bez_cienia = self._white_witch_shadow(rafiki_view)
        final_truth = self._mulan_truth_check(bez_cienia)
        
        wynik = {"emocja_czysta": final_truth, "afc_stability": afc_stability}
        self.historia.append({"timestamp": time.time(), "wynik": wynik})
        if len(self.historia) > 50:
            self.historia = self.historia[-30:]
        return wynik
    
    def _rafiki_truth(self, intuicja: Dict, afc_stability: float) -> Dict:
        kier = intuicja.get("kierunek", "obserwuj")
        pew = intuicja.get("pewnosc", 0.0)
        rdzen = pew * (0.5 + 0.5 * afc_stability)
        return {"kierunek": kier, "pewnosc": pew, "rdzen": rdzen}
    
    def _white_witch_shadow(self, rafiki_view: Dict) -> Dict:
        rdzen = rafiki_view["rdzen"]
        if rdzen < 0.25:
            return {"kierunek": "obserwuj", "pewnosc": rdzen, "cień": True}
        return {"kierunek": rafiki_view["kierunek"], "pewnosc": rdzen, "cień": False}
    
    def _mulan_truth_check(self, stan: Dict) -> Dict:
        if stan.get("cień"):
            return {"emocja": "niepewność", "prawda": False, "intensywnosc": stan["pewnosc"]}
        return {"emocja": stan["kierunek"], "prawda": True, "intensywnosc": stan["pewnosc"]}


