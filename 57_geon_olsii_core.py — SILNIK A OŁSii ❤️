class A9_Integracja_Emocjonalna:
    """A9 – Pierścień integracji emocjonalnej — Wektor Serca z AFC"""
    def __init__(self):
        self.aslan = "HEART_TRUTH"
        self.tefiti = "HEALING_FIELD"
        self.elinor = "WISE_INTEGRATION"
        self.nazwa = "INTEGRACJA_EMOCJONALNA"
        self.historia: List[Dict] = []
        self.ostatni_wektor: Optional[Dict] = None
    
    def execute(self, meta_sens: Dict) -> Dict:
        sens = meta_sens.get("meta_sens", {})
        afc_stability = meta_sens.get("afc_stability", 0.5)
        afc_decision = meta_sens.get("afc_decision")
        afc_policy = meta_sens.get("afc_policy")
        
        prawda = self._aslan_truth(sens)
        uzdrowienie = self._tefiti_heal(prawda, afc_stability)
        final = self._elinor_integrate(uzdrowienie, afc_stability, afc_decision)
        
        # Dodanie sygnatury AFC do wektora
        final["afc_stability"] = afc_stability
        final["afc_decision"] = afc_decision
        final["afc_policy"] = afc_policy
        
        self.ostatni_wektor = final
        wynik = {"wektor_serca": final}
        self.historia.append({"timestamp": time.time(), "wynik": wynik})
        if len(self.historia) > 50:
            self.historia = self.historia[-30:]
        return wynik
    
    def _aslan_truth(self, sens: Dict) -> Dict:
        intens = sens.get("intensywnosc_sensu", 0.0)
        kier = sens.get("kierunek", "obserwuj")
        return {"prawda_serca": kier, "moc": intens, "powolanie": sens.get("powolanie", "delikatne")}
    
    def _tefiti_heal(self, stan: Dict, afc_stability: float) -> Dict:
        moc = stan["moc"] * (0.5 + 0.5 * afc_stability)
        harmonia = "wysoka" if moc > 0.7 else "średnia" if moc > 0.4 else "niska"
        return {"prawda_serca": stan["prawda_serca"], "harmonia": harmonia, "moc": moc}
    
    def _elinor_integrate(self, stan: Dict, afc_stability: float, afc_decision: Optional[str]) -> Dict:
        moc = stan["moc"]
        harmonia = stan["harmonia"]
        stabilnosc = moc * 0.6 + (1.0 if harmonia == "wysoka" else 0.6 if harmonia == "średnia" else 0.3) * 0.4
        stabilnosc = min(1.0, stabilnosc * (0.7 + 0.3 * afc_stability))
        
        # AFC ALERT → zwiększa czujność, ale nie zmienia kierunku
        kierunek = stan["prawda_serca"]
        if afc_decision in ["ALERT", "HARD_ALERT"] and kierunek == "idź":
            kierunek = "obserwuj"  # ostrożność
        
        return {
            "kierunek": kierunek,
            "stabilnosc": stabilnosc,
            "harmonia": harmonia,
            "moc": moc,
            "timestamp": time.time()
        }


