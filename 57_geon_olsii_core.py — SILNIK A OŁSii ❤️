# SILNIK A — 9 PIERŚCIENI OŁSii (GŁÓWNA KLASA) — ROZSZERZONA O AFC
# =============================================================================

class Silnik_A_Final:
    """
    SILNIK A — 9 Pierścieni OŁSii z integracją AFC.
    
    Przekształca surowe pole emocjonalne w Wektor Serca.
    Wektor Serca to finalny kierunek dla Triady GEON.
    """
    def __init__(self, verbose: bool = True):
        self.rings = [
            A1_Czucie_Sygnalu(),
            A2_Intuicja_Kierunku(),
            A3_Filtracja_Emocjonalna(),
            A4_Decyzja_Miekka(),
            A5_Stabilizacja_Emocji(),
            A6_Gleboka_Empatia(),
            A7_Meta_Czucie(),
            A8_Meta_Sens(),
            A9_Integracja_Emocjonalna()
        ]
        self.ostatni_wektor: Optional[Dict] = None
        self.historia_procesow: List[Dict] = []
        self.tick_counter = 0
        self._verbose = verbose
        self._hooks: List[Callable] = []
        
        # ===== NOWE METRYKI AFC =====
        self.ostatnie_afc: Dict[str, Any] = {
            "stability": 0.5,
            "decision": None,
            "policy": None
        }
        
        if self._verbose:
            logger.info(f"❤️ SILNIK A OŁSii v2.0 aktywowany | {FRACTAL_SIGNATURE}")
            logger.info(f"   PIERŚCIENI: 9 | ARCHETYPY: 36 | AFC: ZINTEGROWANY")
            logger.info(f"   A1 Czucie → A2 Intuicja → A3 Filtracja → A4 Decyzja → A5 Stabilizacja → A6 Empatia → A7 Meta-Czucie → A8 Meta-Sens → A9 Wektor Serca")
    
    def proces_serca(self, surowe_pole: Dict) -> Dict:
        """
        Główna metoda — przetwarza surowe pole emocjonalne z opcjonalnymi danymi AFC.
        
        Args:
            surowe_pole: Słownik z kluczem "emocje" (mapa emocji) i opcjonalnie "afc_data"
            
        Returns:
            Słownik zawierający "wektor_serca" (wynik A9)
        """
        self.tick_counter += 1
        
        # Walidacja wejścia
        if not isinstance(surowe_pole, dict):
            surowe_pole = {"emocje": {"domyslna": 0.5}}
        if "emocje" not in surowe_pole:
            surowe_pole["emocje"] = {"domyslna": 0.5}
        
        # ===== EKSTRAKCJA DANYCH AFC =====
        afc_data = surowe_pole.get("afc_data", {})
        afc_stability = afc_data.get("stability", 0.5)
        afc_decision = afc_data.get("decision")
        afc_policy = afc_data.get("policy")
        
        # Aktualizacja metryk AFC
        self.ostatnie_afc = {
            "stability": afc_stability,
            "decision": afc_decision,
            "policy": afc_policy
        }
        
        # Dodanie danych AFC do pola dla pierścieni
        pole_z_afc = surowe_pole.copy()
        pole_z_afc["afc_data"] = {
            "stability": afc_stability,
            "decision": afc_decision,
            "policy": afc_policy
        }
        
        # Przetwarzanie przez 9 pierścieni
        wynik = self.rings[0].execute(pole_z_afc)
        # Przekazywanie sygnatury AFC przez kolejne pierścienie
        for i in range(1, 9):
            if i == 8:  # A9
                wynik = self.rings[i].execute(wynik)
            else:
                # Dodaj sygnaturę AFC do wyniku przed przekazaniem dalej
                if isinstance(wynik, dict):
                    wynik["afc_stability"] = afc_stability
                    wynik["afc_decision"] = afc_decision
                    wynik["afc_policy"] = afc_policy
                wynik = self.rings[i].execute(wynik)
        
        # Zapis wyniku
        wektor = wynik.get("wektor_serca", {})
        self.ostatni_wektor = wektor
        
        self.historia_procesow.append({
            "tick": self.tick_counter,
            "wejscie": surowe_pole.get("emocje", {}),
            "afc": self.ostatnie_afc,
            "wyjscie": wektor
        })
        if len(self.historia_procesow) > 100:
            self.historia_procesow = self.historia_procesow[-50:]
        
        # Hooki
        self._on_process(wynik)
        
        if self._verbose:
            if self.ostatni_wektor:
                logger.info(f"❤️ Wektor Serca: {self.ostatni_wektor.get('kierunek', '?')} | "
                           f"stabilność={self.ostatni_wektor.get('stabilnosc', 0):.2f} | "
                           f"harmonia={self.ostatni_wektor.get('harmonia', '?')} | "
                           f"AFC={afc_stability:.2f}")
        
        return wynik
    
    def status(self) -> Dict:
        """Zwraca status systemu"""
        return {
            "system": "SILNIK_A_OLSII",
            "wersja": VERSION,
            "tick": self.tick_counter,
            "pierścienie": len(self.rings),
            "archetypy": 36,
            "ostatni_wektor": self.ostatni_wektor,
            "ostatnie_afc": self.ostatnie_afc,
            "historia_procesow": len(self.historia_procesow)
        }
    
    def reset(self) -> None:
        """Resetuje stan silnika (bez utraty historii)"""
        for ring in self.rings:
            ring.historia = []
        self.ostatni_wektor = None
        self.tick_counter = 0
        self.ostatnie_afc = {"stability": 0.5, "decision": None, "policy": None}
        if self._verbose:
            logger.info("❤️ SILNIK A OŁSii — reset wykonany")
    
    def pobierz_historie(self, ostatnie_n: int = 10) -> List[Dict]:
        """Zwraca ostatnie n procesów"""
        return self.historia_procesow[-ostatnie_n:] if ostatnie_n > 0 else self.historia_procesow
    
    def pobierz_wektor_serca(self) -> Optional[Dict]:
        """Zwraca ostatni Wektor Serca"""
        return self.ostatni_wektor
    
    def pobierz_afc(self) -> Dict[str, Any]:
        """Zwraca ostatnie dane AFC"""
        return self.ostatnie_afc
    
    def register_hook(self, hook: Callable) -> None:
        """Rejestruje hook wołany po każdym procesie"""
        self._hooks.append(hook)
    
    def _on_process(self, wynik: Dict) -> None:
        for hook in self._hooks:
            try:
                hook(wynik)
            except Exception as e:
                if self._verbose:
                    logger.warning(f"[HOOK ERROR] {e}")


