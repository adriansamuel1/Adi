            return {"wektor": "ciągnie", "moc": intens}
        if intens < 0.3:
            return {"wektor": "odpycha", "moc": intens}
        return {"wektor": "neutralne", "moc": intens}
    
    def _elsa_call(self, instynkt: Dict) -> Dict:
        wektor = instynkt["wektor"]
        moc = instynkt["moc"]
        if wektor == "ciągnie" and moc > 0.7:
            return {"call": "silne_przyciąganie", "moc": moc}
        if wektor == "odpycha" and moc > 0.5:
            return {"call": "silne_odrzucenie", "moc": moc}
        return {"call": "delikatne", "moc": moc}
    
    def _moana_wayfinder(self, glos: Dict) -> Dict:
        call = glos["call"]
        moc = glos["moc"]
        if call == "silne_przyciąganie":
            return {"kierunek": "idź", "pewnosc": moc}
        if call == "silne_odrzucenie":
            return {"kierunek": "nie_idź", "pewnosc": moc}
        return {"kierunek": "obserwuj", "pewnosc": moc}


