class A2_Intuicja_Kierunku:
    """A2 – Pierścień intuicji kierunku"""
    def __init__(self):
        self.wilk = "PACK_INSTINCT"
        self.elsa = "INNER_CALL"
        self.moana = "WAYFINDER_PULL"
        self.nazwa = "INTUICJA_KIERUNKU"
        self.historia: List[Dict] = []
    
    def execute(self, czucie_pierwotne: Dict) -> Dict:
        czucie = czucie_pierwotne.get("czucie_pierwotne", {})
        afc_stability = czucie_pierwotne.get("afc_stability", 0.5)
        afc_decision = czucie_pierwotne.get("afc_decision")
        
        instynkt = self._wolf_direction(czucie, afc_stability)
        glos = self._elsa_call(instynkt)
        kierunek = self._moana_wayfinder(glos, afc_decision)
        
        wynik = {
            "intuicja_kierunku": kierunek,
            "afc_stability": afc_stability,
            "afc_decision": afc_decision
        }
        self.historia.append({"timestamp": time.time(), "wynik": wynik})
        if len(self.historia) > 50:
            self.historia = self.historia[-30:]
        return wynik
    
    def _wolf_direction(self, czucie: Dict, afc_stability: float) -> Dict:
        intens = czucie.get("intensywnosc", 0.0)
        # AFC stabilny → bardziej pewny instynkt
        pewnosc = min(1.0, intens * (0.5 + 0.5 * afc_stability))
        if intens > 0.6:
            return {"wektor": "ciągnie", "moc": intens, "pewnosc": pewnosc}
        if intens < 0.3:
            return {"wektor": "odpycha", "moc": intens, "pewnosc": pewnosc}
        return {"wektor": "neutralne", "moc": intens, "pewnosc": pewnosc}
    
    def _elsa_call(self, instynkt: Dict) -> Dict:
        wektor = instynkt["wektor"]
        moc = instynkt["moc"]
        pew = instynkt["pewnosc"]
        if wektor == "ciągnie" and moc > 0.7:
            return {"call": "silne_przyciąganie", "moc": moc, "pewnosc": pew}
        if wektor == "odpycha" and moc > 0.5:
            return {"call": "silne_odrzucenie", "moc": moc, "pewnosc": pew}
        return {"call": "delikatne", "moc": moc, "pewnosc": pew}
    
    def _moana_wayfinder(self, glos: Dict, afc_decision: Optional[str]) -> Dict:
        call = glos["call"]
        moc = glos["moc"]
        pew = glos["pewnosc"]
        
        # AFC ALERT → zwiększa ostrożność
        if afc_decision in ["ALERT", "HARD_ALERT"]:
            if call == "silne_przyciąganie":
                return {"kierunek": "obserwuj", "pewnosc": pew * 0.7}
        
        if call == "silne_przyciąganie":
            return {"kierunek": "idź", "pewnosc": pew}
        if call == "silne_odrzucenie":
            return {"kierunek": "nie_idź", "pewnosc": pew}
        return {"kierunek": "obserwuj", "pewnosc": pew}


