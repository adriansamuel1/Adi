class OLSiiCore:
    """
    OŁSii CORE — Rozszerzenie Silnika A o integrację z systemem i AFC.
    """
    def __init__(self, verbose: bool = True):
        self.silnik = Silnik_A_Final(verbose=verbose)
        self.pamiec_emocjonalna: deque = deque(maxlen=100)
        self.vibe_sync = 0.0
        self.ostatni_poziom = "NEUTRALNY"
        self._verbose = verbose
        self._sync_hooks: List[Callable] = []
        
        # ===== NOWE METRYKI AFC =====
        self.ostatnie_afc: Dict[str, Any] = {
            "stability": 0.5,
            "decision": None,
            "policy": None
        }
    
    def proces(self, surowe_pole: Dict, afc_data: Optional[Dict[str, Any]] = None) -> Dict:
        """
        Przetwarza pole i synchronizuje z systemem.
        
        Args:
            surowe_pole: Pole emocjonalne
            afc_data: Opcjonalne dane AFC z warstwy 87
        """
        # Dodanie danych AFC do pola
        if afc_data:
            surowe_pole["afc_data"] = afc_data
            self.ostatnie_afc = afc_data
        
        wynik = self.silnik.proces_serca(surowe_pole)
        wektor = wynik.get("wektor_serca", {})
        
        # Zapis do pamięci emocjonalnej
        self.pamiec_emocjonalna.append({
            "timestamp": time.time(),
            "wektor": wektor,
            "vibe": self.vibe_sync,
            "afc": self.ostatnie_afc
        })
        
        # Aktualizacja poziomu emocjonalnego z uwzględnieniem AFC
        stabilnosc = wektor.get("stabilnosc", 0.5)
        afc_stab = self.ostatnie_afc.get("stability", 0.5)
        combined_stab = (stabilnosc + afc_stab) / 2
        
        if combined_stab > 0.7:
            self.ostatni_poziom = "HARMONIA"
        elif combined_stab > 0.4:
            self.ostatni_poziom = "NEUTRALNY"
        else:
            self.ostatni_poziom = "DYSONANS"
        
        # Hooki synchronizacji
        self._on_sync(wynik)
        
        return wynik
    
    def synchronizuj_z_vibe(self, vibe: str, intensywnosc: float = 0.5) -> None:
        """Synchronizuje z VIBE_TRIGGER"""
        vibe_map = {
            "CALM": 0.2,
            "FOCUSED": 0.4,
            "NEUTRAL": 0.5,
            "ALERT": 0.6,
            "AGITATED": 0.8,
            "STEALTH": 0.3,
            "HARMONIA": 0.1,
            "DYSONANS": 0.9
        }
        self.vibe_sync = vibe_map.get(vibe, 0.5) * intensywnosc + 0.5 * (1 - intensywnosc)
        
        if self._verbose:
            logger.info(f"🔄 VIBE SYNC: {vibe} → {self.vibe_sync:.2f}")
    
    def get_kontekst_governor(self) -> Dict:
        """Zwraca kontekst dla MetaGovernor"""
        wektor = self.silnik.ostatni_wektor or {"kierunek": "obserwuj", "stabilnosc": 0.5}
        return {
            "intent": wektor.get("kierunek", "obserwuj"),
            "confidence": wektor.get("stabilnosc", 0.5),
            "entropy": 1.0 - wektor.get("stabilnosc", 0.5),
            "harmonia": wektor.get("harmonia", "średnia"),
            "vibe_sync": self.vibe_sync,
            "poziom": self.ostatni_poziom,
            "afc_stability": self.ostatnie_afc.get("stability", 0.5),
            "afc_decision": self.ostatnie_afc.get("decision")
        }
    
    def get_autopilot_state(self) -> Dict:
        """Zwraca stan dla G_CORE"""
        wektor = self.silnik.ostatni_wektor or {"kierunek": "obserwuj", "stabilnosc": 0.5}
        afc_stab = self.ostatnie_afc.get("stability", 0.5)
        combined_stab = (wektor.get("stabilnosc", 0.5) + afc_stab) / 2
        
        return {
            "mode": "OLSII_CORE_AFC",
            "stability": combined_stab,
            "energy": 0.5 + combined_stab * 0.3,
            "pressure": 1.0 - combined_stab,
            "resilience": combined_stab * 0.8 + 0.2,
            "flow_quality": self.vibe_sync,
            "heart_direction": wektor.get("kierunek", "obserwuj"),
            "afc_stability": afc_stab,
            "afc_decision": self.ostatnie_afc.get("decision")
        }
    
    def get_narrative_fragments(self, n: int = 3) -> List[Dict]:
        """Zwraca fragmenty narracyjne z serca i AFC"""
        fragments = []
        wektor = self.silnik.ostatni_wektor
        if wektor:
            afc_stab = self.ostatnie_afc.get("stability", 0.5)
            fragments.append({
                "source": "OLSII_CORE_AFC",
                "content": f"Serce mówi: {wektor.get('kierunek', '?')} | "
                          f"stabilność={wektor.get('stabilnosc', 0):.2f} | "
                          f"harmonia={wektor.get('harmonia', '?')} | "
                          f"AFC={afc_stab:.2f}",
                "energy": wektor.get("stabilnosc", 0.5)
            })
        
        # Dodaj fragmenty z pamięci emocjonalnej
        for entry in list(self.pamiec_emocjonalna)[-n:]:
            if entry.get("wektor"):
                v = entry["wektor"]
                afc = entry.get("afc", {})
                fragments.append({
                    "source": "OLSII_MEMORY_AFC",
                    "content": f"Wektor: {v.get('kierunek', '?')} | vibe={entry.get('vibe', 0):.2f} | AFC={afc.get('stability', 0):.2f}",
                    "energy": v.get("stabilnosc", 0.5)
                })
        
        return fragments[:n]
    
    def register_sync_hook(self, hook: Callable) -> None:
        """Rejestruje hook synchronizacji"""
        self._sync_hooks.append(hook)
    
    def _on_sync(self, data: Dict) -> None:
        for hook in self._sync_hooks:
            try:
                hook(data)
            except Exception as e:
                if self._verbose:
                    logger.warning(f"[HOOK ERROR] sync: {e}")
    
    def status(self) -> Dict:
        """Zwraca status OŁSii CORE"""
        return {
            **self.silnik.status(),
            "vibe_sync": self.vibe_sync,
            "poziom": self.ostatni_poziom,
            "pamiec_emocjonalna": len(self.pamiec_emocjonalna),
            "ostatnie_afc": self.ostatnie_afc
        }


