        self.nazwa = "INTUICJA_KIERUNKU"
        self.historia: List[Dict] = []
    
    def execute(self, czucie_pierwotne: Dict) -> Dict:
        instynkt = self._wolf_direction(czucie_pierwotne)
        glos = self._elsa_call(instynkt)
        kierunek = self._moana_wayfinder(glos)
        
        wynik = {"intuicja_kierunku": kierunek}
        self.historia.append({"timestamp": time.time(), "wynik": wynik})
        if len(self.historia) > 50:
