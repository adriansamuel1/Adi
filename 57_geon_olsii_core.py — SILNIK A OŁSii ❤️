class A5_Stabilizacja_Emocji:
    """A5 – Pierścień stabilizacji emocjonalnej"""
    def __init__(self):
        self.dab = "ROOTED_STABILITY"
        self.baloo = "RELAXED_FLOW"
        self.groot = "WARM_SOLIDITY"
        self.nazwa = "STABILIZACJA_EMOCJI"
        self.historia: List[Dict] = []
    
    def execute(self, postawa_serca: Dict) -> Dict:
        postawa = postawa_serca.get("postawa_serca", {})
        
        grounded = self._oak_root(postawa)
        relaxed = self._baloo_relax(grounded)
        stable = self._groot_solid(relaxed)
        
        wynik = {"stan_stabilny": stable}
        self.historia.append({"timestamp": time.time(), "wynik": wynik})
        if len(self.historia) > 50:
            self.historia = self.historia[-30:]
        return wynik
    
    def _oak_root(self, stan: Dict) -> Dict:
        pew = stan.get("pewnosc", 0.0)
        return {"postawa": stan["postawa"], "pewnosc": pew, "ugruntowanie": min(1.0, pew + 0.2)}
    
    def _baloo_relax(self, stan: Dict) -> Dict:
        return {
            "postawa": stan["postawa"],
            "pewnosc": stan["pewnosc"],
            "ugruntowanie": stan["ugruntowanie"],
            "napiecie": max(0.0, 1.0 - stan["ugruntowanie"])
        }
    
    def _groot_solid(self, stan: Dict) -> Dict:
        stabilnosc = (stan["ugruntowanie"] + (1.0 - stan["napiecie"])) / 2
        return {"postawa": stan["postawa"], "stabilnosc": stabilnosc, "cieplo": stabilnosc * 0.8}


