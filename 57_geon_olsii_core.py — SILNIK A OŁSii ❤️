        pieczec = "AKTYWNA" if combined > 0.4 else "NIEAKTYWNA"
        perfekcja = "AKTYWNA" if combined > 0.7 else "NIEAKTYWNA"
        
        return {
            "ISKRA": iskra,
            "PIECZĘĆ": pieczec,
            "PERFEKCJA": perfekcja,
            "tryb": "OLSII_CORE_AFC",
            "kierunek_serca": wektor.get("kierunek", "obserwuj"),
            "harmonia": wektor.get("harmonia", "średnia"),
            "afc_stability": afc_stab
        }
    
    # ========================================================================
    # MOST DO HEILONG_22_ORGANISM (Tryby emocjonalne)
    # ========================================================================
    
    def get_organizm_tryb(self) -> str:
        """Zwraca tryb emocjonalny dla HEILONG_22_ORGANISM z AFC"""
        wektor = self.olsii.silnik.ostatni_wektor or {}
        afc = self.olsii.ostatnie_afc
        kierunek = wektor.get("kierunek", "obserwuj")
        stabilnosc = wektor.get("stabilnosc", 0.5)
        afc_stab = afc.get("stability", 0.5)
        combined = (stabilnosc + afc_stab) / 2
        
        if kierunek == "otwórz" and combined > 0.6:
            return "KRUK"  # strategia, wizja
        elif kierunek == "zamknij" and combined < 0.4:
            return "SZCZUR"  # operacja, przetrwanie
        elif kierunek == "obserwuj" or combined > 0.5:
            return "WRONA"  # synchronia
        return "NEUTRALNY"
    
    # ========================================================================
    # NOWE METODY AFC
    # ========================================================================
    
    def get_afc_context(self) -> Dict[str, Any]:
        """Zwraca kontekst AFC z ostatniego procesu"""
        return {
            "afc_stability": self.olsii.ostatnie_afc.get("stability", 0.5),
            "afc_decision": self.olsii.ostatnie_afc.get("decision"),
            "afc_policy": self.olsii.ostatnie_afc.get("policy"),
            "heart_direction": self.olsii.silnik.ostatni_wektor.get("kierunek") if self.olsii.silnik.ostatni_wektor else None
        }
    
    def process_with_afc(self, emocje: Dict[str, float], afc_data: Dict[str, Any]) -> Dict[str, Any]:
        """Przetwarza pole emocjonalne z danymi AFC"""
        return self.olsii.proces({"emocje": emocje}, afc_data=afc_data)
    
    def get_full_status(self) -> Dict[str, Any]:
        """Zwraca pełny status – OŁSii + AFC"""
        return {
            "olsii": self.olsii.status(),
            "afc": self.get_afc_context(),
            "organizm_tryb": self.get_organizm_tryb(),
            "trio": self.get_trio_state()
        }


