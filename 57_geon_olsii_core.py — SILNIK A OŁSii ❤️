class A1_Czucie_Sygnalu:
    """A1 – Pierścień czucia pierwotnego"""
    def __init__(self):
        self.simba = "PURE_INSTINCT"
        self.boo = "INNOCENT_FEELING"
        self.kot = "INTUITIVE_TOUCH"
        self.nazwa = "CZUCIE_SYGNALU"
        self.historia: List[Dict] = []
    
    def execute(self, pole: Dict) -> Dict:
        czucie = self._simba_touch(pole)
        oczyszczone = self._boo_filter(czucie)
        intuicja = self._kot_instinct(oczyszczone)
        
        wynik = {"czucie_pierwotne": intuicja}
        self.historia.append({"timestamp": time.time(), "wynik": wynik})
        if len(self.historia) > 50:
            self.historia = self.historia[-30:]
        return wynik
    
    def _simba_touch(self, pole: Dict) -> Dict:
        return pole.get("emocje", {})
    
    def _boo_filter(self, czucie: Dict) -> Dict:
        if not isinstance(czucie, dict):
            return {}
        return {k: float(v) for k, v in czucie.items()}
    
    def _kot_instinct(self, czucie: Dict) -> Dict:
        if not czucie:
            return {"reakcja": "nie_wiem", "intensywnosc": 0.0}
        intens = sum(czucie.values()) / len(czucie)
        if intens > 0.6:
            return {"reakcja": "tak", "intensywnosc": intens}
        if intens < 0.3:
            return {"reakcja": "nie", "intensywnosc": intens}
        return {"reakcja": "nie_wiem", "intensywnosc": intens}


