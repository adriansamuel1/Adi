        "dominion_substance_index": 0.72,
        "dominion_status": "KONSOLIDACJA_NOMINALNA",
        "crisis_vectors_count": 0,
        "signatures": ["SIG_PLZ_01"]
    }

    system_2 = {
        "system_id": "DOMINION_UGANDA_ZERO",
        "council_decree": "DEKRET_BETA",
        "council_confidence": 0.70,
        "council_drift": 0.38,
        "grid_health": 0.65,
        "anomaly_score": 0.35,
        "oracle_era": "ERA_TRANSFORMACJI",
        "maya_phase": 5,
        "dominion_substance_index": 0.45,
        "dominion_status": "DEFICYT_SUBSTANCJI",
        "crisis_vectors_count": 1,
        "signatures": ["SIG_UGA_01"]
    }

    system_3 = {
        "system_id": "DOMINION_CRISTAL_GLOBAL",
        "council_decree": "DEKRET_OMEGA",
        "council_confidence": 0.60,
        "council_drift": 0.55,
        "grid_health": 0.40,
        "anomaly_score": 0.78,
        "oracle_era": "ERA_KRYZYSU",
        "maya_phase": 6,
        "dominion_substance_index": 0.28,
        "dominion_status": "KRYZYS_ZASOBOWY",
        "crisis_vectors_count": 3,
        "signatures": ["SIG_CRI_01", "SIG_CRI_02"]
    }

    print("🔍 SYMULACJA 3 SYSTEMÓW:")
    print("   System 1 (PLZ): ALPHA – stabilny")
    print("   System 2 (Uganda): BETA – transformacja")
    print("   System 3 (Cristal): OMEGA – kryzys\n")

    report = synod.convene([system_1, system_2, system_3])

    print(f"📊 META‑DEKRET: {report.meta_decree.value}")
    print(f"   SPI: {report.spi:.3f}")
    print(f"   Pressure Index: {report.pressure_index:.3f}")
    print(f"   Drift Map: min={report.drift_map['min']:.3f}, max={report.drift_map['max']:.3f}, median={report.drift_map['median']:.3f}")
    print(f"   Era Vector: ({report.era_vector[0]:.3f}, {report.era_vector[1]:.3f}, {report.era_vector[2]:.3f})")
    print(f"   Fraktalny konsensus: {report.fractal_consensus['global']['decisive_factor']}")
    print(f"   Certyfikat: {report.certificate[:50]}...")

    print("\n🔍 TEST DRY-RUN:")
    dry = synod._simulate([system_1, system_2, system_3])
    print(f"   Status: {dry['status']}")
    print(f"   Predykcja: {dry['meta_decree']} | SPI: {dry['spi']:.3f}")

    print("\n🔗 MOSTY INTEGRACYJNE:")
    print(f"   Autopilot: {bridge.get_autopilot_state()}")
    print(f"   Governor: {bridge.get_governor_context()}")

    print("\n" + "=" * 80)
    print(f"🜀 {VERSION} — GOTOWY DO KONSYSTORZA (92)")
    print(HASLO)
    print("=" * 80)

if __name__ == "__main__":
    demo()