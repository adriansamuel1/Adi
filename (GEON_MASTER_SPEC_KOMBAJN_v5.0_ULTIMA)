class HeartbeatState(Enum):
    ACTIVE = "ACTIVE"
    PAUSED = "PAUSED"
    STOPPED = "STOPPED"
    ADAPTING = "ADAPTING"


class HeartbeatEngine:
    """Generuje puls systemowy. Monitoruje odpowiedzi i adaptuje częstotliwość."""
    
    def __init__(self, base_frequency: float = 1.0):
        self.base_frequency = base_frequency
        self.current_frequency = base_frequency
        self.state = HeartbeatState.STOPPED
        self.pulse_count = 0
        self.responses: List[Dict[str, Any]] = []
        self.history: List[Dict[str, Any]] = []
        self._running = False
        self._thread: Optional[threading.Thread] = None
        
        LOG_INFO("HEARTBEAT", f"💓 HeartbeatEngine aktywowany (częstotliwość: {base_frequency}Hz)")
    
    def start(self) -> None:
        if self._running:
            LOG_WARN("HEARTBEAT", "Puls już działa")
            return
        
        self._running = True
        self.state = HeartbeatState.ACTIVE
        self._thread = threading.Thread(target=self._heartbeat_loop, daemon=True)
        self._thread.start()
        
        LOG_INFO("HEARTBEAT", "💓 Puls systemowy uruchomiony")
    
    def stop(self) -> None:
        self._running = False
        self.state = HeartbeatState.STOPPED
        if self._thread:
            self._thread.join(timeout=1.0)
        LOG_INFO("HEARTBEAT", "🔄 Puls systemowy zatrzymany")
    
    def pause(self) -> None:
        self.state = HeartbeatState.PAUSED
        LOG_INFO("HEARTBEAT", "⏸️ Puls wstrzymany")
    
    def resume(self) -> None:
        self.state = HeartbeatState.ACTIVE
        LOG_INFO("HEARTBEAT", "▶️ Puls wznowiony")
    
    def _heartbeat_loop(self) -> None:
        while self._running:
            if self.state == HeartbeatState.PAUSED:
                time.sleep(0.1)
                continue
            
            pulse = self._generate_pulse()
            self._distribute_pulse(pulse)
            response = self._monitor_response()
            self.responses.append(response)
            self._adapt_frequency(response)
            self._stabilize_rhythm()
            
            self.history.append({"pulse": self.pulse_count, "frequency": self.current_frequency, "response": response})
            self.pulse_count += 1
            
            time.sleep(1.0 / self.current_frequency)
    
    def _generate_pulse(self) -> Dict[str, Any]:
        return {"pulse_id": self.pulse_count, "timestamp": datetime.now().isoformat(), "frequency": self.current_frequency}
    
    def _distribute_pulse(self, pulse: Dict[str, Any]) -> None:
        LOG_DEBUG("HEARTBEAT", f"💓 Puls {pulse['pulse_id']} (f: {pulse['frequency']:.2f}Hz)")
    
    def _monitor_response(self) -> Dict[str, Any]:
        response_time = 0.1 + (0.3 * (1.0 - self.current_frequency / 2.0))
        return {"status": "OK", "response_time": round(response_time, 4), "modules_responding": ["GEON_168", "GEON_169", "MASTER_SPEC", "BENY"]}
    
    def _adapt_frequency(self, response: Dict[str, Any]) -> None:
        if response["response_time"] > 0.3:
            self.current_frequency = max(0.5, self.current_frequency - 0.05)
            self.state = HeartbeatState.ADAPTING
        elif response["response_time"] < 0.15 and self.current_frequency < 2.0:
            self.current_frequency = min(2.0, self.current_frequency + 0.05)
        else:
            self.state = HeartbeatState.ACTIVE
        self.current_frequency = round(self.current_frequency, 3)
    
    def _stabilize_rhythm(self) -> None:
        if len(self.history) > 5:
            recent = self.history[-5:]
            avg_freq = sum(h["frequency"] for h in recent) / len(recent)
            if abs(avg_freq - self.current_frequency) < 0.01:
                self.current_frequency = avg_freq
    
    def get_status(self) -> Dict[str, Any]:
        return {
            "state": self.state.value,
            "frequency": round(self.current_frequency, 3),
            "base_frequency": self.base_frequency,
            "pulse_count": self.pulse_count,
            "response_count": len(self.responses),
            "history_size": len(self.history),
            "running": self._running
        }
    
    def reset(self) -> None:
        self.stop()
        self.current_frequency = self.base_frequency
        self.pulse_count = 0
        self.responses = []
        self.history = []
        self.state = HeartbeatState.STOPPED
        LOG_INFO("HEARTBEAT", "🔄 Zresetowano")


