        return self.matrix.get_registers_status()
    
    def set_register(self, name: str, value: Any) -> None:
        self.matrix.set_register(name, value)
        if name == "R_BENY":
            self.matrix.set_register("R_BENY", self.beny.get_status())
    
    def clear_buffer(self) -> None:
        self.matrix.clear_buffer()
    
    # =========================================================================
    # FUNKCJA 8: BENY_SYSTEM
    # =========================================================================
    
    def run_beny(self, target: str = "autoanaliza", **kwargs) -> Dict[str, Any]:
        self.stats["function_calls"] += 1
        self.stats["last_function"] = "BENY"
        LOG_INFO("KOMBAJN", "🐉 Uruchamianie BENY_SYSTEM")
        result = self.beny.analyze(target, kwargs if kwargs else None)
        self.matrix.set_register("R_BENY", self.beny.get_status())
        return result
    
