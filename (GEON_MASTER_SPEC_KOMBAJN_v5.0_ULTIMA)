class SyncEngine:
    """Globalny synchronizator cykli 168, 169, MASTER_SPEC."""
    
    def __init__(self):
        self.cycles = {"GEON_168": 0, "GEON_169": 0, "MASTER_SPEC": 0}
        self.global_clock = 0
        self.sync_state = "UNSYNCED"
        self.history: List[Dict[str, Any]] = []
        self.locked = False
        
        LOG_INFO("SYNC_ENGINE", "🔄 SyncEngine aktywowany")
    
    def register_cycle(self, name: str, cycle: int) -> None:
        if name in self.cycles:
            self.cycles[name] = cycle
    
    def align_all(self) -> Dict[str, Any]:
        LOG_INFO("SYNC_ENGINE", "🚀 Rozpoczynanie synchronizacji")
        
        inputs = self._capture_all_inputs()
        normalized = self._normalize_all_signals(inputs)
        merged = self._merge_logic_meta_supervision(normalized)
        aligned = self._align_cycles(merged)
        timing = self._set_global_timing(aligned)
        stabilized = self._stabilize_synchronization(timing)
        locked = self._lock_synchronicity(stabilized)
        confirmation = self._confirm_global_sync(locked)
        
        self.sync_state = "SYNCED"
        self.locked = True
        
        return {
            "status": "SYNCED",
            "global_clock": self.global_clock,
            "cycles": self.cycles,
            "timestamp": datetime.now().isoformat()
        }
    
    def _capture_all_inputs(self) -> Dict[str, Any]:
        return {"GEON_168": {"cycle": self.cycles["GEON_168"]}, "GEON_169": {"cycle": self.cycles["GEON_169"]}, "MASTER_SPEC": {"cycle": self.cycles["MASTER_SPEC"]}}
    
    def _normalize_all_signals(self, inputs: Dict) -> Dict:
        return {k: {"cycle": v["cycle"], "normalized": True} for k, v in inputs.items()}
    
    def _merge_logic_meta_supervision(self, normalized: Dict) -> Dict:
        return {"merged": True, "logic": normalized["GEON_168"], "meta_logic": normalized["GEON_169"], "supervision": normalized["MASTER_SPEC"]}
    
    def _align_cycles(self, merged: Dict) -> Dict:
        max_cycle = max(self.cycles.values())
        for name in self.cycles:
            self.cycles[name] = max_cycle
        return {**merged, "aligned": True, "target_cycle": max_cycle}
    
    def _set_global_timing(self, aligned: Dict) -> Dict:
        self.global_clock = int(time.time())
        return {**aligned, "global_clock": self.global_clock}
    
    def _stabilize_synchronization(self, timing: Dict) -> Dict:
        return {**timing, "stabilized": True}
    
    def _lock_synchronicity(self, stabilized: Dict) -> Dict:
        self.locked = True
        return {**stabilized, "locked": True}
    
    def _confirm_global_sync(self, locked: Dict) -> Dict:
        return {"status": "CONFIRMED", "global_clock": self.global_clock, "sync_state": self.sync_state}
    
    def get_status(self) -> Dict[str, Any]:
        return {"sync_state": self.sync_state, "global_clock": self.global_clock, "cycles": self.cycles, "locked": self.locked}
    
    def reset(self) -> None:
        for name in self.cycles:
            self.cycles[name] = 0
        self.global_clock = 0
        self.sync_state = "UNSYNCED"
        self.locked = False
        LOG_INFO("SYNC_ENGINE", "🔄 Zresetowano")


