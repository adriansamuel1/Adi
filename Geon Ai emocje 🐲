@dataclass
class FlowVector9D:
    """9-wymiarowy wektor przepływu po przejściu przez AFC-9."""
    D1: List[float]
    D2: List[float]
    D3: List[float]
    D4: List[float]
    D5: List[float]
    D6: List[float]
    D7: List[float]
    D8: List[float]
    D9: List[float]

    def to_dict(self) -> Dict[str, List[float]]:
        return {
            "D1": self.D1,
            "D2": self.D2,
            "D3": self.D3,
            "D4": self.D4,
            "D5": self.D5,
            "D6": self.D6,
            "D7": self.D7,
            "D8": self.D8,
            "D9": self.D9
        }

    def get_core(self) -> float:
        return sum(self.D9) / len(self.D9) if self.D9 else 0.0

    def get_variance(self) -> float:
        if not self.D9:
            return 0.0
        core = self.get_core()
        return sum((v - core) ** 2 for v in self.D9) / len(self.D9)

    def get_stability(self) -> float:
        variance = self.get_variance()
        return max(0.0, min(1.0, 1.0 - variance * 10.0))

    @staticmethod
    def empty(size: int = 9) -> 'FlowVector9D':
        zeros = [0.0] * size
        return FlowVector9D(
            D1=zeros.copy(), D2=zeros.copy(), D3=zeros.copy(), D4=zeros.copy(),
            D5=zeros.copy(), D6=zeros.copy(), D7=zeros.copy(), D8=zeros.copy(), D9=zeros.copy()
        )


