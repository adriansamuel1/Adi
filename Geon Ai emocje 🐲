# 2. KOMBAJN_ALARM (RYZYKO CENIA) Z PROFILAMI
# ============================================================
class KombajnAlarm:
    """Układ odpornościowy — ocena ryzyka cienia z profilami wag."""

    def __init__(self, profile: ShadowProfile = ShadowProfile.PROFILE_OMEGA):
        self.profile = profile
        self.history: List[Dict[str, Any]] = []
        self.stats = {"scans": 0, "green": 0, "yellow": 0, "red": 0}
        LOG("FLOW_KOMBAJN_ALARM", "INIT", f"🛡️ KombajnAlarm (Flow) aktywowany, profile={self.profile.value}")

    def _weights(self) -> Dict[str, int]:
        if self.profile == ShadowProfile.PROFILE_SOFT:
            return {
                "empathy": 1, "reflexion": 1,
                "uses_people": 2, "breaks_promises": 1,
                "avoids_care": 2, "cold_procedural": 1
            }
        if self.profile == ShadowProfile.PROFILE_STRICT:
            return {
                "empathy": 3, "reflexion": 3,
                "uses_people": 3, "breaks_promises": 2,
                "avoids_care": 3, "cold_procedural": 2
            }
        # PROFILE_OMEGA (domyślny – zbalansowany)
        return {
            "empathy": 2, "reflexion": 2,
            "uses_people": 2, "breaks_promises": 1,
            "avoids_care": 2, "cold_procedural": 1
        }

    def _calculate_shadow_score(self, signal: EmotionalSignal) -> int:
        w = self._weights()
        score = 0
        if not signal.empathy: score += w["empathy"]
        if not signal.reflexion: score += w["reflexion"]
        if signal.uses_people_as_resource: score += w["uses_people"]
        if signal.breaks_promises_for_gain: score += w["breaks_promises"]
        if signal.avoids_care_in_crisis: score += w["avoids_care"]
        if signal.cold_procedural_in_family: score += w["cold_procedural"]
        return min(10, score)

    def _classify_risk_level(self, score: int) -> FlowRiskLevel:
        if score <= 1:
            return FlowRiskLevel.GREEN
        elif score <= 4:
            return FlowRiskLevel.YELLOW
        return FlowRiskLevel.RED

    def scan(self, signal: EmotionalSignal) -> Dict[str, Any]:
        self.stats["scans"] += 1
        score = self._calculate_shadow_score(signal)
        level = self._classify_risk_level(score)
        self.stats[level.value.lower()] += 1

        messages = {
            FlowRiskLevel.GREEN: "Bezpieczna integracja.",
            FlowRiskLevel.YELLOW: "Ostrożnie. Obserwuj.",
            FlowRiskLevel.RED: "Dystans. Zero oczekiwań."
        }

        icons = {
            FlowRiskLevel.GREEN: "🟢",
            FlowRiskLevel.YELLOW: "🟡",
            FlowRiskLevel.RED: "🔴"
        }

        result = {
            "STATUS": level,
            "SCORE": score,
            "ICON": icons[level],
            "MESSAGE": messages[level],
            "PROFILE": self.profile.value
        }

        self.history.append({
            "timestamp": time.time(),
            "score": score,
            "level": level.value,
            "profile": self.profile.value
        })
        if len(self.history) > 100:
            self.history.pop(0)

        LOG("FLOW_KOMBAJN_ALARM", "SCAN", f"Level={level.value}, Score={score}, Profile={self.profile.value}")
        return result

    def get_stats(self) -> Dict[str, Any]:
        total = self.stats["scans"]
        return {
            "scans": total,
            "green": self.stats["green"],
            "yellow": self.stats["yellow"],
            "red": self.stats["red"],
            "green_rate": self.stats["green"] / total if total > 0 else 0,
            "history_size": len(self.history),
            "profile": self.profile.value
        }


