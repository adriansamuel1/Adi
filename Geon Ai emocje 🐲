# 3. FLOW_INTEGRITY_SHIELD (PRZEPŁYW RELACYJNY)
# ============================================================
class FlowIntegrityShield:
    """Ocena przepływu — nie osoby, tylko wzorca interakcji."""

    def __init__(self):
        self.history: List[Dict[str, Any]] = []
        self.stats = {"evaluations": 0, "green": 0, "yellow": 0, "red": 0}
        LOG("FLOW_SHIELD", "INIT", "🛡️ FlowIntegrityShield v3.0 aktywowany")

    def evaluate(self, signal: EmotionalSignal) -> Dict[str, Any]:
        self.stats["evaluations"] += 1

        thresholds = {
            "warmth_level": 0.3,
            "clarity_level": 0.3,
            "reciprocity_level": 0.3,
            "stability_level": 0.3,
            "presence_level": 0.3
        }

        score = 0
        details = {}
        for key, threshold in thresholds.items():
            value = getattr(signal, key, 0.5)
            passed = value >= threshold
            details[key] = {"value": value, "threshold": threshold, "passed": passed}
            if not passed:
                score += 1

        if score <= 1:
            level, boundary = FlowRiskLevel.GREEN, "OPEN"
            message = "Przepływ stabilny."
        elif score <= 3:
            level, boundary = FlowRiskLevel.YELLOW, "MEDIUM"
            message = "Zachować czujność. Regulować dystans."
        else:
            level, boundary = FlowRiskLevel.RED, "CLOSED"
            message = "Przepływ zaburzony. Chronić rdzeń."

        self.stats[level.value.lower()] += 1

        icons = {
            FlowRiskLevel.GREEN: "🟢",
            FlowRiskLevel.YELLOW: "🟡",
            FlowRiskLevel.RED: "🔴"
        }

        result = {
            "STATUS": level,
            "SCORE": score,
            "BOUNDARY": boundary,
            "MESSAGE": message,
            "ICON": icons[level],
            "DETAILS": details
        }

        self.history.append(result)
        if len(self.history) > 100:
            self.history.pop(0)

        LOG("FLOW_SHIELD", "EVAL", f"Flow={level.value}, Score={score}")
        return result

    def get_stats(self) -> Dict[str, Any]:
        total = self.stats["evaluations"]
        return {
            "evaluations": total,
            "green": self.stats["green"],
            "yellow": self.stats["yellow"],
            "red": self.stats["red"],
            "green_rate": self.stats["green"] / total if total > 0 else 0
        }


