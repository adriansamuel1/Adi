# 7. GŁÓWNY SILNIK — GEON_AI_EMOTIONAL_FLOW_ENGINE v3.0 OMEGA
# ============================================================
class GEON_AI_EmotionalFlowEngine:
    """
    Główny organ przepływu emocjonalno-relacyjnego dla GEON_AI.
    Wejście: EmotionalSignal (pojedynczy) lub lista (batch).
    Wyjście: FlowStatus + DecisionMap dla GEON_AI_DECISION_ENGINE_ULTIMA v3.0 OMEGA.
    """

    def __init__(self, config: Optional[Dict[str, Any]] = None):
        self.config = config or {}
        self.tick = 0
        self.last_stability = 0.5

        profile = self.config.get("shadow_profile", ShadowProfile.PROFILE_OMEGA)
        if isinstance(profile, str):
            profile = ShadowProfile(profile)

        self.kombajn_alarm = KombajnAlarm(profile=profile)
        self.flow_shield = FlowIntegrityShield()
        self.entropy_filter = FlowEntropyFilter(self.config.get("noise_threshold", 0.06))
        self.afc9 = AFC9Attractor()
        self.core_stabilizer = FlowCoreStabilizer()

        self.history: List[FlowStatus] = []
        self.stats = {
            "evaluations": 0,
            "safe": 0,
            "caution": 0,
            "blocked": 0
        }

        LOG("FLOW_ENGINE", "INIT", f"🐉 GEON_AI_EMOTIONAL_FLOW_ENGINE v{VERSION} aktywowany")
        LOG("FLOW_ENGINE", "INIT", f"   Sygnatura: {FRACTAL_SIGNATURE}")

    def _build_base_vectors(self, signal: EmotionalSignal) -> FlowVector9D:
        D1 = [
            float(signal.warmth_level),
            float(signal.clarity_level),
            float(signal.reciprocity_level),
            float(signal.stability_level),
            float(signal.presence_level),
            1.0 if signal.empathy else 0.0,
            1.0 if signal.reflexion else 0.0,
            1.0 - float(signal.noise),
            1.0 if signal.symmetry else 0.0,
        ]
        D2 = [min(1.0, v * 0.9) for v in D1]
        D3 = [min(1.0, v * 1.1) for v in D1]
        D4 = [self.last_stability for _ in range(len(D1))]
        return self.afc9.compute(D1, D2, D3, D4)

    def _decision_from_levels(self, risk: FlowRiskLevel, flow: FlowRiskLevel, stability: float) -> FlowDecision:
        if risk == FlowRiskLevel.RED or flow == FlowRiskLevel.RED or stability < 0.3:
            return FlowDecision.BLOCK
        if risk == FlowRiskLevel.YELLOW or flow == FlowRiskLevel.YELLOW or stability < 0.6:
            return FlowDecision.CAUTION
        return FlowDecision.ALLOW

    def evaluate_flow(self, signal: EmotionalSignal) -> FlowStatus:
        self.tick += 1
        self.stats["evaluations"] += 1
        LOG("FLOW_ENGINE", "START", f"Rozpoczynam ocenę przepływu #{self.tick}", self.tick)

        meta = {
            "tick": self.tick,
            "signal": signal.to_dict()
        }

        filtered = self.entropy_filter.filter(signal)
        if filtered is None:
            empty_vector = FlowVector9D.empty()
            diagnostics = self.core_stabilizer.stabilize(empty_vector, self.last_stability)
            self.last_stability = diagnostics.stability
            decision = FlowDecision.BLOCK
            self.stats["blocked"] += 1

            status = FlowStatus(
                risk_level=FlowRiskLevel.RED,
                flow_level=FlowRiskLevel.RED,
                decision=decision,
                entropy_filtered=False,
                symmetry_ok=signal.symmetry,
                afc9_vector=empty_vector,
                diagnostics=diagnostics,
                message="Sygnał odrzucony przez filtr entropii.",
                meta={**meta, "rejection_reason": "entropy_filter"}
            )
            self.history.append(status)
            return status

        kombajn_result = self.kombajn_alarm.scan(filtered)
        risk_level = kombajn_result["STATUS"]

        flow_result = self.flow_shield.evaluate(filtered)
        flow_level = flow_result["STATUS"]

        vector_9d = self._build_base_vectors(filtered)
        diagnostics = self.core_stabilizer.stabilize(vector_9d, self.last_stability)
        self.last_stability = diagnostics.stability

        decision = self._decision_from_levels(risk_level, flow_level, diagnostics.stability)
        if decision == FlowDecision.BLOCK:
            msg = "Przepływ zaburzony lub cień wysoki — chronić rdzeń."
            self.stats["blocked"] += 1
        elif decision == FlowDecision.CAUTION:
            msg = "Przepływ częściowo stabilny — zalecana czujność i regulacja dystansu."
            self.stats["caution"] += 1
        else:
            msg = "Przepływ stabilny, cień niski — bezpieczna integracja z rdzeniem."
            self.stats["safe"] += 1

        status = FlowStatus(
            risk_level=risk_level,
            flow_level=flow_level,
            decision=decision,
            entropy_filtered=True,
            symmetry_ok=True,
            afc9_vector=vector_9d,
            diagnostics=diagnostics,
            message=msg,
            meta={
                **meta,
                "kombajn": kombajn_result,
                "flow_shield": flow_result,
                "afc9_core": vector_9d.get_core(),
                "afc9_stability": vector_9d.get_stability()
            }
        )

        self.history.append(status)
        if len(self.history) > 300:
            self.history = self.history[-300:]

        LOG("FLOW_ENGINE", "COMPLETE",
            f"Flow={flow_level.value}, Risk={risk_level.value}, Decision={decision.value}, Stability={diagnostics.stability:.4f}",
            self.tick)

        return status

    # ============================================================
    # 8. BATCH API
    # ============================================================
    def evaluate_batch(self, signals: List[EmotionalSignal]) -> List[FlowStatus]:
        results: List[FlowStatus] = []
        for sig in signals:
            results.append(self.evaluate_flow(sig))
        return results

    # ============================================================
    # 9. METODY POMOCNICZE
    # ============================================================
    def get_status(self) -> Dict[str, Any]:
        return {
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "tick": self.tick,
            "last_stability": self.last_stability,
            "stats": self.stats,
            "history_size": len(self.history),
            "components": {
                "kombajn_alarm": self.kombajn_alarm.get_stats(),
                "flow_shield": self.flow_shield.get_stats(),
                "entropy_filter": self.entropy_filter.get_stats(),
                "core_stabilizer": self.core_stabilizer.get_stats(),
                "afc9_core": self.afc9.get_last_core()
            }
        }

    def get_last_status(self) -> Optional[FlowStatus]:
        return self.history[-1] if self.history else None

    def get_history(self, limit: int = 10) -> List[FlowStatus]:
        return self.history[-limit:]

    def get_summary(self) -> Dict[str, Any]:
        if not self.history:
            return {"message": "Brak danych"}
        total = len(self.history)
        safe = sum(1 for s in self.history if s.is_safe())
        caution = sum(1 for s in self.history if s.is_caution())
        blocked = sum(1 for s in self.history if s.is_blocked())
        return {
            "total": total,
            "safe": safe,
            "caution": caution,
            "blocked": blocked,
            "safe_rate": safe / total if total > 0 else 0,
            "avg_stability": sum(s.diagnostics.stability for s in self.history) / total if total > 0 else 0,
            "last_status": self.history[-1].to_dict() if self.history else None
        }

    def reset(self) -> None:
        self.tick = 0
        self.last_stability = 0.5
        self.history = []
        self.stats = {"evaluations": 0, "safe": 0, "caution": 0, "blocked": 0}
        LOG("FLOW_ENGINE", "RESET", "🔄 Silnik v3.0 OMEGA zresetowany")


