# 5. AFC‑9 — ATRAKTOR 9D PRZEPŁYWU (ELASTYCZNA DŁUGOŚĆ)
# ============================================================
class AFC9Attractor:
    """Implementacja AFC‑9 jako stabilizator przepływu 9D."""

    def __init__(self):
        self.history: List[FlowVector9D] = []
        LOG("AFC9_ATTRACTOR", "INIT", "AFC‑9 Flow Attractor v3.0 aktywowany")

    @staticmethod
    def _avg(values: List[float]) -> float:
        return sum(values) / len(values) if values else 0.0

    def compute(self, D1: List[float], D2: List[float], D3: List[float], D4: List[float]) -> FlowVector9D:
        size = len(D1)
        D5 = [self._avg([D1[i], D2[i], D3[i], D4[i]]) for i in range(size)]
        D6 = [self._avg([D1[i], D3[i], D5[i]]) for i in range(size)]
        D7 = [self._avg([D2[i], D4[i], D6[i]]) for i in range(size)]
        D8 = [self._avg([D1[i], D3[i], D5[i], D7[i]]) for i in range(size)]
        D9 = [self._avg([D1[i], D8[i]]) for i in range(size)]

        vector = FlowVector9D(D1=D1, D2=D2, D3=D3, D4=D4, D5=D5, D6=D6, D7=D7, D8=D8, D9=D9)
        self.history.append(vector)
        if len(self.history) > 100:
            self.history.pop(0)

        return vector

    def get_last_core(self) -> float:
        if not self.history:
            return 0.0
        return self.history[-1].get_core()


