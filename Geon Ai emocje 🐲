# 6. FLOW_CORE_STABILIZER (STABILIZACJA RDZENIA + DRIFT)
# ============================================================
class FlowCoreStabilizer:
    """Minimalna wersja GEON_168 dla przepływu — stabilizacja rdzenia + drift."""

    def __init__(self):
        self.core_history: List[float] = []
        self.stability_history: List[float] = []
        LOG("FLOW_CORE_STABILIZER", "INIT", "GEON_168 (Flow) v3.0 aktywowany")

    def stabilize(self, vector_9d: FlowVector9D, previous_stability: float = 0.5) -> FlowDiagnostics:
        core = vector_9d.get_core()
        variance = vector_9d.get_variance()
        stability_raw = max(0.0, min(1.0, 1.0 - variance * 2.5))

        self.core_history.append(core)
        if len(self.core_history) > 100:
            self.core_history = self.core_history[-100:]

        if len(self.core_history) < 3:
            stability = 0.8
            drift = 0.0
            volatility = 0.0
        else:
            window = self.core_history[-10:]
            mean = sum(window) / len(window)
            drift = core - mean
            volatility = max(window) - min(window)
            stability = stability_raw * 0.7 + previous_stability * 0.3

        self.stability_history.append(stability)
        if len(self.stability_history) > 100:
            self.stability_history = self.stability_history[-100:]

        LOG("FLOW_CORE_STABILIZER", "STABILITY",
            f"Core={core:.4f}, Var={variance:.4f}, Drift={drift:.44f}, Vol={volatility:.4f}, Stability={stability:.4f}")

        return FlowDiagnostics(
            core=core,
            stability=stability,
            variance=variance,
            drift=drift,
            volatility=volatility
        )

    def get_stats(self) -> Dict[str, Any]:
        if not self.core_history:
            return {"avg_core": 0.0, "avg_stability": 0.0, "history_size": 0}
        return {
            "avg_core": sum(self.core_history[-20:]) / min(20, len(self.core_history)),
            "avg_stability": sum(self.stability_history[-20:]) / min(20, len(self.stability_history)) if self.stability_history else 0.0,
            "history_size": len(self.core_history)
        }


