# 4. FLOW_ENTROPY_FILTER (FILTR ENTROPII)
# ============================================================
class FlowEntropyFilter:
    """Filtruje sygnał na podstawie symetrii i szumu."""

    def __init__(self, noise_threshold: float = 0.06):
        self.noise_threshold = noise_threshold
        self.filtered_count = 0
        self.rejected_count = 0
        self.rejection_reasons: Dict[str, int] = {"asymmetry": 0, "noise": 0}
        LOG("FLOW_ENTROPY_FILTER", "INIT", f"NoiseThreshold={noise_threshold}")

    def filter(self, signal: EmotionalSignal) -> Optional[EmotionalSignal]:
        if not signal.symmetry:
            self.rejected_count += 1
            self.rejection_reasons["asymmetry"] += 1
            LOG("FLOW_ENTROPY_FILTER", "REJECT", "Asymmetry detected")
            return None

        if signal.noise > self.noise_threshold:
            self.rejected_count += 1
            self.rejection_reasons["noise"] += 1
            LOG("FLOW_ENTROPY_FILTER", "REJECT", f"Noise={signal.noise:.4f} > {self.noise_threshold}")
            return None

        self.filtered_count += 1
        LOG("FLOW_ENTROPY_FILTER", "PASS", "Signal accepted")
        return signal

    def get_stats(self) -> Dict[str, Any]:
        total = self.filtered_count + self.rejected_count
        return {
            "filtered": self.filtered_count,
            "rejected": self.rejected_count,
            "acceptance_rate": self.filtered_count / total if total > 0 else 0.0,
            "noise_threshold": self.noise_threshold,
            "rejection_reasons": self.rejection_reasons
        }


