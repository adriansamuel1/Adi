class GeonArchontCouncil:
    """
    ⚖️ GEON_ARCHONT_COUNCIL v2.0 – Pełna Rada Archontów z integracją AFC.
    """

    def __init__(self, config: Optional[Dict[str, Any]] = None):
        self.config = config or {}
        self.memory_limit = self.config.get("memory_limit", MEMORY_LIMIT)
        self.history: deque = deque(maxlen=self.memory_limit)
        self.kroniki = SamaelHeilong
        self.egregor = Egregor
        self._lock = threading.Lock()
        
        self.weighted_voting = self.config.get("weighted_voting", True)
        self.weight_threshold = self.config.get("weight_threshold", 0.6)
        
        # Progi ulepszeń
        self.drift_omega_threshold = self.config.get("drift_omega_threshold", DRIFT_OMEGA_THRESHOLD)
        self.drift_beta_threshold = self.config.get("drift_beta_threshold", DRIFT_BETA_THRESHOLD)
        self.phase_alignment_alpha_threshold = self.config.get("phase_alignment_alpha_threshold", PHASE_ALIGNMENT_ALPHA_THRESHOLD)
        self.council_drift_omega_threshold = self.config.get("council_drift_omega_threshold", COUNCIL_DRIFT_OMEGA_THRESHOLD)
        self.council_drift_beta_threshold = self.config.get("council_drift_beta_threshold", COUNCIL_DRIFT_BETA_THRESHOLD)
        self.crisis_bias = self.config.get("crisis_bias", CRISIS_BIAS)
        self.oracle_crisis_bias = self.config.get("oracle_crisis_bias", ORACLE_CRISIS_BIAS)
        
        # ===== NOWE PROGI AFC =====
        self.afc_crisis_stability_threshold = self.config.get("afc_crisis_stability_threshold", AFC_CRISIS_STABILITY_THRESHOLD)
        self.afc_alert_score_boost = self.config.get("afc_alert_score_boost", AFC_ALERT_SCORE_BOOST)
        
        log(f"🐉 {VERSION} aktywowany | {FRACTAL_SIGNATURE}")
        log(f"   GŁOSOWANIE: {'WAŻONE' if self.weighted_voting else 'TWARDE'}")
        log(f"   CRISIS_BIAS: {self.crisis_bias} | DRIFT_OMEGA: {self.drift_omega_threshold}")
        log(f"   AFC INTEGRACJA: AKTYWNA")

    # -------------------------------------------------------------------------
    # GŁÓWNA METODA – PRZYJMUJE PAYLOAD Z GRIDU (ROZSZERZONA O AFC)
    # -------------------------------------------------------------------------

    def convene(self, council_payload: Dict[str, Any],
                oracle_era: Optional[str] = None,
                maya_phase: int = 0,
                anomaly_score: float = 0.0,
                # ===== NOWE PARAMETRY AFC (opcjonalne) =====
                afc_global_stability: Optional[float] = None,
                afc_global_decision: Optional[str] = None,
                afc_global_policy: Optional[str] = None) -> CouncilReport:
        """
        Zbiera Radę Archontów z pełnymi metrykami v2.0 + AFC.
        """
        # 1. Ekstrakcja danych z payloadu
        votes_raw = council_payload.get("votes", [])
        confidence_list = council_payload.get("confidence", [])
        influence_list = council_payload.get("influence", [])
        drifts = council_payload.get("drifts", [])
        phase_alignments = council_payload.get("phase_alignments", [])
        signatures = council_payload.get("signatures", [])
        archont_names = ["SAMAEL", "ENKI", "RA", "OPTIMUS", "HEILONG"]
        
        # Pobierz AFC z payloadu (jeśli nie podano wprost)
        if afc_global_stability is None:
            afc_global_stability = council_payload.get("afc_global_stability", 0.0)
        if afc_global_decision is None:
            afc_global_decision = council_payload.get("afc_global_decision")
        if afc_global_policy is None:
            afc_global_policy = council_payload.get("afc_global_policy")
        
        # Uzupełnienie brakujących danych
        def pad_list(lst, default, size):
            if len(lst) < size:
                return lst + [default] * (size - len(lst))
            return lst[:size]
        
        votes_raw = pad_list(votes_raw, "NIEZNANY", len(archont_names))
        confidence_list = pad_list(confidence_list, 0.5, len(archont_names))
        influence_list = pad_list(influence_list, 0.5, len(archont_names))
        drifts = pad_list(drifts, 0.0, len(archont_names))
        phase_alignments = pad_list(phase_alignments, 0.5, len(archont_names))
        signatures = pad_list(signatures, "BRAK_SYGNAtURY", len(archont_names))

        # Crisis Vectors z payloadu
        archont_vectors = council_payload.get("archont_vectors", [])
        crisis_vectors = []
        for v in archont_vectors:
            if len(v) >= 5 and v[4] >= 4:
                crisis_vectors.append(v[:4])

        # 2. Tworzenie obiektów głosów z pełnymi metrykami + AFC
        votes = []
        for i, name in enumerate(archont_names):
            cv = crisis_vectors[i] if i < len(crisis_vectors) else None
            votes.append(CouncilVote(
                archont_name=name,
                status=votes_raw[i],
                confidence=confidence_list[i],
                influence=influence_list[i],
                drift=drifts[i],
                phase_alignment=phase_alignments[i],
                signature=signatures[i],
                crisis_vector=cv,
                # ===== NOWE POLA AFC =====
                afc_stability=afc_global_stability,
                afc_decision=afc_global_decision,
                afc_policy=afc_global_policy
            ))

        # 3. Głosowanie z ulepszeniami + AFC
        decree = self._vote_weighted_enhanced(votes, oracle_era, anomaly_score, afc_global_stability, afc_global_decision)

        # 4. Podsumowanie głosów
        vote_summary = {}
        for v in votes:
            vote_summary[v.status] = vote_summary.get(v.status, 0) + 1

        # 5. Średnie
        conf_avg = sum(v.confidence for v in votes) / len(votes) if votes else 0.0
        inf_avg = sum(v.influence for v in votes) / len(votes) if votes else 0.0
        council_drift = sum(v.drift for v in votes) / len(votes) if votes else 0.0

        # 6. Crisis Vectors w raporcie
        crisis_vectors_report = [v.crisis_vector for v in votes if v.crisis_vector is not None]

        # 7. Certyfikacja z podpisami Archontów
        signatures_list = [v.signature for v in votes if v.signature != "BRAK_SYGNAtURY"]
        cert = self.kroniki.certyfikuj_council(f"DECREE_{decree.value}", signatures_list)

        # 8. Raport z AFC
        report = CouncilReport(
            decree=decree,
            votes=votes,
            vote_summary=vote_summary,
            confidence_avg=conf_avg,
            influence_avg=inf_avg,
            council_drift=council_drift,
            crisis_vectors=crisis_vectors_report,
            weighted_voting=self.weighted_voting,
            oracle_era=oracle_era,
            maya_phase=maya_phase,
            anomaly_score=anomaly_score,
            certificate=cert,
            # ===== NOWE POLA AFC =====
            afc_global_stability=afc_global_stability,
            afc_global_decision=afc_global_decision,
            afc_global_policy=afc_global_policy
        )

        # 9. Zapis do historii
        with self._lock:
            self.history.append(report.to_dict())

        # 10. Zapis do Egregora
        if decree in [CouncilDecree.OMEGA, CouncilDecree.BETA] or len(self.history) % 5 == 0:
            entry = {
                "type": "COUNCIL_DECREE_AFC",
                "report": report.to_dict(),
                "certificate": cert,
                "council_drift": council_drift,
                "crisis_vectors_count": len(crisis_vectors_report),
                "afc_stability": afc_global_stability,
                "afc_decision": afc_global_decision,
                "timestamp": datetime.now().isoformat()
            }
            self.egregor.commit(entry, node_id="GEON_ARCHONT_COUNCIL_AFC")

        self.kroniki.log_event("COUNCIL_CONVENED_AFC", {
            "decree": decree.value,
            "summary": vote_summary,
            "council_drift": council_drift,
            "crisis_vectors": len(crisis_vectors_report),
            "afc_stability": afc_global_stability,
            "afc_decision": afc_global_decision
        })

        return report

    # -------------------------------------------------------------------------
    # ULEPSZONE GŁOSOWANIE – v2.0 (z AFC)
    # -------------------------------------------------------------------------

    def _vote_weighted_enhanced(self, votes: List[CouncilVote],
                                 oracle_era: Optional[str] = None,
                                 anomaly_score: float = 0.0,
                                 afc_global_stability: float = 0.0,
                                 afc_global_decision: Optional[str] = None) -> CouncilDecree:
        """
        Ważone głosowanie z ulepszeniami v2.0 + AFC.
        """
        if not self.weighted_voting:
            return self._vote_twarde_enhanced(votes, afc_global_stability, afc_global_decision)

        total_weight = 0.0
        weighted_score = 0.0
        drifts = []
        crisis_count = 0

        status_numeric = {
            "APOTEOSIS": 0, "STABILNOŚĆ": 0,
            "PRESJA": 1,
            "NIESTABILNOŚĆ": 2,
            "KRYZYS": 3,
            "NIEZNANY": 1
        }

        for v in votes:
            # 1. Waga bazowa
            weight = v.influence if v.influence > 0 else v.confidence
            
            # 2. Korekta dryfem
            weight *= (1.0 - v.drift * 0.5)
            
            # 3. Crisis Bias
            crisis_bias = 1.0
            if v.status == "KRYZYS":
                crisis_bias = self.crisis_bias
                crisis_count += 1
            
            # ===== 4. NOWA KOREKTA AFC =====
            afc_bias = 1.0
            if afc_global_stability < self.afc_crisis_stability_threshold:
                # Niska stabilność AFC – zwiększamy wagę kryzysu
                afc_bias *= 1.3
            if afc_global_decision in ["ALERT", "HARD_ALERT"]:
                afc_bias *= (1.0 + self.afc_alert_score_boost)
            
            # 5. Numeric status
            numeric = status_numeric.get(v.status, 1)
            
            # 6. Phase Alignment
            if v.phase_alignment > self.phase_alignment_alpha_threshold:
                numeric = max(0, numeric - 0.5)
            
            weighted_score += weight * numeric * crisis_bias * afc_bias
            total_weight += weight
            drifts.append(v.drift)

        if total_weight == 0:
            return CouncilDecree.ALPHA

        avg_score = weighted_score / total_weight
        council_drift = sum(drifts) / len(drifts) if drifts else 0.0

        # 7. Oracle Bias
        if oracle_era == "ERA_KRYZYSU":
            avg_score *= self.oracle_crisis_bias

        # 8. Anomaly Bias
        if anomaly_score > 0.7:
            avg_score *= (1.0 + anomaly_score * 0.3)

        # 9. Council Drift Index
        if council_drift > self.council_drift_omega_threshold:
            return CouncilDecree.OMEGA
        if council_drift > self.council_drift_beta_threshold:
            return CouncilDecree.BETA

        # 10. Individual Drift Threshold
        for v in votes:
            if v.drift > self.drift_omega_threshold:
                return CouncilDecree.OMEGA
            if v.drift > self.drift_beta_threshold and avg_score > 0.5:
                return CouncilDecree.BETA

        # 11. Decyzja końcowa
        if avg_score > self.weight_threshold * 2.5:
            return CouncilDecree.OMEGA
        if avg_score > self.weight_threshold:
            return CouncilDecree.BETA
        return CouncilDecree.ALPHA

    def _vote_twarde_enhanced(self, votes: List[CouncilVote],
                               afc_global_stability: float = 0.0,
                               afc_global_decision: Optional[str] = None) -> CouncilDecree:
        """
        Twarde głosowanie z ulepszeniami v2.0 + AFC.
        """
        statuses = [v.status for v in votes]
        drifts = [v.drift for v in votes]
        
        niestab_count = statuses.count("NIESTABILNOŚĆ")
        presja_count = statuses.count("PRESJA")
        kryzys_count = statuses.count("KRYZYS")
        total_niestab = niestab_count + kryzys_count
        
        council_drift = sum(drifts) / len(drifts) if drifts else 0.0
        
        # ===== AFC Boost =====
        afc_boost = 0
        if afc_global_stability < self.afc_crisis_stability_threshold:
            afc_boost += 1
        if afc_global_decision in ["ALERT", "HARD_ALERT"]:
            afc_boost += 1
        
        # 1. Council Drift Index
        if council_drift > self.council_drift_omega_threshold:
            return CouncilDecree.OMEGA
        if council_drift > self.council_drift_beta_threshold:
            return CouncilDecree.BETA
        
        # 2. Individual Drift
        for v in votes:
            if v.drift > self.drift_omega_threshold:
                return CouncilDecree.OMEGA
            if v.drift > self.drift_beta_threshold:
                return CouncilDecree.BETA
        
        # 3. Standardowe reguły + AFC
        if total_niestab >= 2 or afc_boost >= 2:
            return CouncilDecree.OMEGA
        if presja_count >= 3 or afc_boost >= 1:
            return CouncilDecree.BETA
        return CouncilDecree.ALPHA

    # -------------------------------------------------------------------------
    # METODY POMOCNICZE
    # -------------------------------------------------------------------------

    def get_history(self, n: Optional[int] = None) -> List[Dict[str, Any]]:
        with self._lock:
            snapshot = list(self.history)
        if n is not None and n > 0:
            return snapshot[-n:]
        return snapshot

    def reset(self) -> None:
        with self._lock:
            self.history.clear()
        self.kroniki.log_event("COUNCIL_RESET", {"status": "CLEARED"})

    def get_status(self) -> Dict[str, Any]:
        with self._lock:
            hist_size = len(self.history)
        return {
            "system": "GEON_ARCHONT_COUNCIL",
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "vibe": VIBE,
            "history_size": hist_size,
            "memory_limit": self.memory_limit,
            "weighted_voting": self.weighted_voting,
            "weight_threshold": self.weight_threshold,
            "features": {
                "crisis_bias": self.crisis_bias,
                "drift_omega_threshold": self.drift_omega_threshold,
                "council_drift_omega": self.council_drift_omega_threshold,
                "phase_alignment_alpha": self.phase_alignment_alpha_threshold,
                "oracle_crisis_bias": self.oracle_crisis_bias,
                "afc_crisis_stability_threshold": self.afc_crisis_stability_threshold,
                "afc_alert_score_boost": self.afc_alert_score_boost
            },
            "integration": {
                "AFC": True,
                "ORACLE": True,
                "GRID": True
            }
        }

