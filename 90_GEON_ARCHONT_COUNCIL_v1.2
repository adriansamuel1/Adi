class CouncilDecree(Enum):
    ALPHA = "DEKRET_ALPHA"
    BETA = "DEKRET_BETA"
    OMEGA = "DEKRET_OMEGA"

    def description(self) -> str:
        desc = {
            CouncilDecree.ALPHA: "Zatwierdzenie Ładu – kontynuacja cyklu.",
            CouncilDecree.BETA: "Wymuszona Korekta – korekta trajektorii.",
            CouncilDecree.OMEGA: "Globalny Reset – rekonstrukcja struktury."
        }
        return desc.get(self, "Nieznany dekret.")

    def numeric_value(self) -> int:
        values = {CouncilDecree.ALPHA: 0, CouncilDecree.BETA: 1, CouncilDecree.OMEGA: 2}
        return values.get(self, 0)


