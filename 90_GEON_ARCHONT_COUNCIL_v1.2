class CouncilBridge:
    def __init__(self, council: GeonArchontCouncil):
        self.council = council

    # ===== ORYGINALNE METODY (ZACHOWANE) =====
    
    def get_archetype_context(self) -> Dict[str, Any]:
        status = self.council.get_status()
        return {
            "tryb": VERSION,
            "historia": status["history_size"],
            "features": status["features"],
            "weighted": status["weighted_voting"],
            "integration": status["integration"]
        }

    def get_autopilot_state(self) -> Dict[str, Any]:
        history = self.council.get_history(1)
        if history:
            last = history[-1]
            return {
                "mode": VERSION,
                "decree": last.get("decree", "UNKNOWN"),
                "council_drift": last.get("council_drift", 0.0),
                "crisis_vectors": last.get("crisis_vectors_count", 0),
                "afc_stability": last.get("afc_global_stability", 0.0),
                "afc_decision": last.get("afc_global_decision", "UNKNOWN"),
                "council_ready": True
            }
        return {"mode": VERSION, "decree": "NO_DATA", "council_ready": True}

    def get_governor_context(self) -> Dict[str, Any]:
        history = self.council.get_history(1)
        if history:
            last = history[-1]
            return {
                "intent": "COUNCIL_DECISION",
                "confidence": last.get("confidence_avg", 0.5),
                "decree": last.get("decree", "UNKNOWN"),
                "council_drift": last.get("council_drift", 0.0),
                "afc_stability": last.get("afc_global_stability", 0.0),
                "council_ready": True
            }
        return {"intent": "COUNCIL_DECISION", "confidence": 0.5, "council_ready": True}

    def get_trio_state(self) -> Dict[str, str]:
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": VERSION,
            "council": "AKTYWNY_V2.0_AFC"
        }

    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        history = self.council.get_history(n)
        fragments = []
        for entry in history:
            fragments.append({
                "source": VERSION,
                "content": f"Rada: {entry.get('decree', 'UNKNOWN')} | drift: {entry.get('council_drift', 0):.3f} | afc_stab: {entry.get('afc_global_stability', 0):.3f}",
                "decree": entry.get("decree", "UNKNOWN"),
                "crisis_vectors": entry.get("crisis_vectors_count", 0),
                "afc_stability": entry.get("afc_global_stability", 0.0)
            })
        return fragments

    # ===== NOWE METODY AFC =====

    def get_afc_context(self) -> Dict[str, Any]:
        """Zwraca kontekst AFC z ostatniej decyzji Rady."""
        history = self.council.get_history(1)
        if history:
            last = history[-1]
            return {
                "afc_global_stability": last.get("afc_global_stability", 0.0),
                "afc_global_decision": last.get("afc_global_decision", "UNKNOWN"),
                "afc_global_policy": last.get("afc_global_policy", "UNKNOWN"),
                "decree": last.get("decree", "UNKNOWN")
            }
        return {"afc_global_stability": 0.0, "afc_global_decision": "UNKNOWN"}

    def get_full_status(self) -> Dict[str, Any]:
        """Zwraca pełny status – Rada + AFC."""
        return {
            "council": self.council.get_status(),
            "afc_context": self.get_afc_context(),
            "last_report": self.council.get_history(1)[0] if self.council.get_history(1) else None
        }

