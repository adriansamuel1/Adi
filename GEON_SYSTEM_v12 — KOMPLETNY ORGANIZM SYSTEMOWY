class DragonSealLedger:
    """
    DRAGON_SEAL_LEDGER — Meta-Rejestr Decyzji.
    "Jeśli czegoś nie ma w Ledgerze — nie istnieje w systemie."
    """
    
    SEAL_SIGNATURE = "DRAGON_SEAL_INFINITY"
    
    def __init__(self):
        self.header = {
            "id": "DRAGON_SEAL_LEDGER",
            "version": "1.0",
            "owner": "DRAGON_OS_INFINITY",
            "signature": self.SEAL_SIGNATURE
        }
        self.records: List[Dict[str, Any]] = []
        self.backup: List[Dict[str, Any]] = []
    
    def write(self, entry: Dict[str, Any]) -> Dict[str, Any]:
        """Zapisuje wpis do Ledgera."""
        record = {
            "entry_id": f"ENTRY_{len(self.records)+1:04d}",
            "timestamp": datetime.now().isoformat(),
            "signature": self.SEAL_SIGNATURE,
            **entry
        }
        self.records.append(record)
        LOG("LEDGER", f"📝 Wpis #{record['entry_id']}: {entry.get('event', 'unknown')}")
        return record
    
    def read(self, filter: Optional[Dict[str, Any]] = None) -> List[Dict[str, Any]]:
        """Odczytuje wpisy z Ledgera."""
        if not filter:
            return self.records
        results = []
        for record in self.records:
            match = True
            for key, value in filter.items():
                if key not in record or record[key] != value:
                    match = False
                    break
            if match:
                results.append(record)
        return results
    
    def backup_ledger(self) -> None:
        """Tworzy kopię zapasową Ledgera."""
        self.backup = self.records.copy()
        LOG("LEDGER", "💾 Kopia zapasowa utworzona")
    
    def void_reset(self) -> None:
        """Resetuje Ledger (VOID_ENGINE)."""
        if self._detect_corruption():
            self.backup_ledger()
            self.records = []
            LOG("LEDGER", "🧹 Reset wykonany (VOID_ENGINE)")
        else:
            LOG("LEDGER", "✅ Brak korupcji — reset anulowany")
    
    def _detect_corruption(self) -> bool:
        """Wykrywa korupcję w Ledgerze."""
        if len(self.records) > 1000:
            return True
        for record in self.records[-10:]:
            if record.get("signature") != self.SEAL_SIGNATURE:
                return True
        return False
    
    def get_size(self) -> int:
        return len(self.records)
    
    def get_last(self, n: int = 10) -> List[Dict[str, Any]]:
        return self.records[-n:]


