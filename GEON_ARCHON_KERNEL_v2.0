import logging
logger = logging.getLogger("ARCHON_KERNEL_v2.0")
logger.setLevel(logging.INFO)
if not logger.handlers:
    handler = logging.StreamHandler()
    handler.setFormatter(logging.Formatter('👑 [ARCHON] %(message)s'))
    logger.addHandler(handler)

def log(msg: str, level: str = "INFO") -> None:
    if level == "INFO":
        logger.info(msg)
    elif level == "WARN":
        logger.warning(msg)
    elif level == "ERROR":
        logger.error(msg)
    else:
        logger.info(msg)

def clamp(x: float, lo: float, hi: float) -> float:
    return max(lo, min(hi, x))

# =============================================================================
# L0: UTILITIES & KANONICZNE HASZOWANIE (ULEPSZONE)
# =============================================================================

def generate_context_hash(context: Dict[str, Any]) -> str:
    """
    Generuje kanoniczny hash kontekstu – odporny na szum czasowy.
    ULEPSZENIE: json.dumps + SHA-256 (szybszy i bezpieczniejszy od MD5)
    """
    filtered_context = {k: v for k, v in context.items() 
                        if k not in ["timestamp", "request_id", "nonce"]}
    # json.dumps jest szybszy od str(sorted_items)) i daje stabilną reprezentację
    context_str = json.dumps(filtered_context, sort_keys=True, ensure_ascii=False)
    # SHA-256 zamiast MD5 – bezpieczniejszy, nadal szybki
    return hashlib.sha256(context_str.encode("utf-8")).hexdigest()

def generate_fast_hash(context: Dict[str, Any]) -> str:
    """
    Alternatywny, szybszy hash używający BLAKE2b (opcjonalnie).
    """
    filtered_context = {k: v for k, v in context.items() 
                        if k not in ["timestamp", "request_id", "nonce"]}
    context_str = json.dumps(filtered_context, sort_keys=True, ensure_ascii=False)
    return hashlib.blake2b(context_str.encode("utf-8"), digest_size=16).hexdigest()

# =============================================================================
# L30: PAMIĘĆ RODOWA Z SŁOWNIKIEM I DECAY (ULEPSZONA)
# =============================================================================

class GeneticPool:
    """
    Pamięć rodowa z indeksowaniem słownikowym O(1) i wykładniczym wygaszaniem.
    ULEPSZENIA:
    - Słownik lookup O(1) zamiast listy O(N)
    - Memory Decay – wykładnicze wygaszanie starych wzorców
    - Thread-Safe (threading.Lock)
    """
    
    def __init__(self, max_size: int = MAX_GENETIC_POOL):
        self._pool: Dict[str, Dict[str, Any]] = {}  # hash -> entry
        self._lock = threading.Lock()
        self._max_size = max_size
        self._decay_factor = DECAY_FACTOR
        self._last_cleanup = time.time()
        self._cleanup_interval = 60.0  # co 60 sekund
    
    def get(self, context_hash: str) -> Optional[Dict[str, Any]]:
        """Pobiera wzorzec po hashach – O(1)."""
        with self._lock:
            entry = self._pool.get(context_hash)
            if entry:
                # Aktualizacja czasu dostępu (dla decay)
                entry["last_access"] = time.time()
            return entry
    
    def get_path(self, context_hash: str, min_efficiency: float = 0.5) -> Optional[str]:
        """Pobiera ścieżkę dla danego hasha, jeśli wydajność >= min_efficiency."""
        entry = self.get(context_hash)
        if entry and entry.get("efficiency", 0.0) >= min_efficiency:
            return entry.get("resolved_path")
        return None
    
    def put(self, context_hash: str, clue: Dict[str, Any], 
            resolved_path: str, efficiency: float) -> None:
        """Dodaje lub aktualizuje wzorzec w pamięci rodowej."""
        with self._lock:
            # Jeśli już istnieje, aktualizuj
            if context_hash in self._pool:
                entry = self._pool[context_hash]
                entry["uses"] = entry.get("uses", 0) + 1
                entry["efficiency"] = round((entry["efficiency"] + efficiency) / 2, 3)
                entry["last_access"] = time.time()
                return
            
            # Jeśli przekroczono limit, usuń najstarszy (LRU)
            if len(self._pool) >= self._max_size:
                oldest = min(self._pool.items(), 
                           key=lambda x: x[1].get("last_access", 0))
                del self._pool[oldest[0]]
            
            self._pool[context_hash] = {
                "context_hash": context_hash,
                "clue": clue,
                "resolved_path": resolved_path,
                "efficiency": efficiency,
                "uses": 1,
                "last_access": time.time()
            }
    
    def apply_decay(self) -> None:
        """Wykładnicze wygaszanie wydajności starych wzorców."""
        now = time.time()
        if now - self._last_cleanup < self._cleanup_interval:
            return
        
        with self._lock:
            to_remove = []
            for key, entry in self._pool.items():
                age = now - entry.get("last_access", now)
                # Im starszy wpis, tym większy spadek wydajności
                decay_factor = self._decay_factor ** (age / 3600.0)  # 1 godzina półtrwania
                entry["efficiency"] = round(entry["efficiency"] * decay_factor, 3)
                
                # Jeśli wydajność spadła poniżej progu, usuń
                if entry["efficiency"] < 0.1:
                    to_remove.append(key)
            
            for key in to_remove:
                del self._pool[key]
            
            self._last_cleanup = now
    
    def get_size(self) -> int:
        with self._lock:
            return len(self._pool)
    
    def get_all(self) -> List[Dict[str, Any]]:
        with self._lock:
            return list(self._pool.values())
    
    def clear(self) -> None:
        with self._lock:
            self._pool.clear()

