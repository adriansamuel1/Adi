# L70: DRAGON HORDE – RÓWNOLEGŁA ROJOWA INTELIGENCJA (ULEPSZONA)
# =============================================================================

class DragonHorde:
    """🐲 SMOCZA HORDA — równoległa improwizacja wielu smoków."""
    
    def __init__(self, size: int = HORDE_SIZE):
        self.dragons: List[YoungDragon] = [YoungDragon(f"Horde_{i}") for i in range(size)]
        self.swarm_count = 0
        self._executor = concurrent.futures.ThreadPoolExecutor(max_workers=size)

    def _run_dragon(self, _: int, context: Dict[str, Any]) -> Dict[str, Any]:
        """Pojedynczy smok wykonuje akcję (uruchamiane równolegle)."""
        return GeonMagilla.activate_magilla(context)

    def swarm_solve(self, context: Dict[str, Any]) -> Dict[str, Any]:
        """
        Równoległe uruchomienie wszystkich smoków.
        ULEPSZENIE: concurrent.futures.ThreadPoolExecutor
        """
        futures = []
        for i in range(len(self.dragons)):
            future = self._executor.submit(self._run_dragon, i, context)
            futures.append(future)
        
        results = []
        for future in concurrent.futures.as_completed(futures):
            try:
                results.append(future.result())
            except Exception as e:
                log(f"Błąd w Hordzie: {e}", "ERROR")
                results.append({"stability_delta": 0.05, "comment": "Fallback"})
        
        best = max(results, key=lambda x: x.get("stability_delta", 0))
        best["swarm_size"] = len(self.dragons)
        best["comment"] += " | Wybrano najlepszy ruch z Hordy (równoległej)."
        self.swarm_count += 1
        
        return best

    def shutdown(self) -> None:
        self._executor.shutdown(wait=False)

