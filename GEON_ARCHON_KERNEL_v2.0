# L60: FRAKTALNE ZWIERCIADŁO (bez zmian, działa dobrze)
# =============================================================================

class GeonMirror:
    """🪞 GEON_MIRROR — Średnia krocząca i bezpieczna degradacja."""

    @staticmethod
    def reflect(cycle_output: Dict[str, Any], 
                genetic_pool: GeneticPool) -> Dict[str, Any]:
        path = cycle_output.get("path")
        stability = cycle_output.get("stability", 0.0)
        context_hash = cycle_output.get("context_hash")
        
        reflection_log = {
            "path_evaluated": path,
            "resulting_stability": stability,
            "action": "MAINTAINED"
        }
        
        entry = genetic_pool.get(context_hash)
        if entry and entry.get("resolved_path") == path:
            entry["uses"] = entry.get("uses", 0) + 1
            entry["efficiency"] = round((entry["efficiency"] + stability) / 2, 3)
            entry["last_access"] = time.time()
            
            # Smooth degradation – jeśli wzorzec traci na znaczeniu
            if entry["uses"] >= 5 and entry["efficiency"] < 0.4:
                entry["efficiency"] = round(entry["efficiency"] * 0.8, 3)
                reflection_log["action"] = "SMOOTH_DEGRADATION_APPLIED"
        
        # Okresowe czyszczenie pamięci
        genetic_pool.apply_decay()
        
        return {
            "reflection_id": str(uuid.uuid4())[:8].upper(),
            "status": "METRIC_SYNCHRONIZED",
            "log": reflection_log
        }

