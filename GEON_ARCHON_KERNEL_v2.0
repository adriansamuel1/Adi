class GeonTeamKernel:
    """👑 GEON_TEAM_KERNEL — Suwerenny zarządca stanów, energii i dryfu."""
    
    def __init__(self) -> None:
        self.core = GeonTeamCore()
        self.genetic_pool = GeneticPool()
        self.horde = DragonHorde(size=HORDE_SIZE)
        self.magilla = GeonMagilla()
        
        self.GLOBAL_STATE: Dict[str, Any] = {
            "last_cycle_signature": None,
            "mode": "PRIME",
            "energy_map": {"logic": 1, "adaptation": 6, "stability": 8},
            "cycle_counter": 0,
        }
        self.stability_history: List[float] = []
        self.path_history: List[str] = []  # dla detekcji pętli ścieżek
        self.mode_history: List[str] = []  # dla histerezy
        self._lock = threading.Lock()
    
    def _preload_genetic_pool(self) -> None:
        c1 = {"task": "resolve_grid_blockade", 
              "threat": "Tauron_Grid_Monopol_Interference", 
              "anomaly_force": 0.9}
        c2 = {"task": "optimize_trade_vectors", 
              "target": "Uganda_Node", 
              "anomaly_force": 0.1}
        
        self.genetic_pool.put(
            context_hash=generate_context_hash(c1),
            clue=c1,
            resolved_path="PLZ-Z_Substance_Override",
            efficiency=0.95
        )
        self.genetic_pool.put(
            context_hash=generate_context_hash(c2),
            clue=c2,
            resolved_path="Asymmetric_Complementarity_Vector",
            efficiency=0.90
        )
    
    def boot(self) -> str:
        with self._lock:
            self.GLOBAL_STATE["mode"] = "PRIME"
            self.GLOBAL_STATE["cycle_counter"] = 0
            self.stability_history.clear()
            self.path_history.clear()
            self.mode_history.clear()
            self._preload_genetic_pool()
        
        boot_sig = SamaelHeilong.certyfikuj_ruch_optimusa(
            "GEON_KERNEL_BOOT_ARCHON_PRIME_v2"
        )
        self.GLOBAL_STATE["last_cycle_signature"] = boot_sig
        SamaelHeilong.log_event("KERNEL_BOOT", {"signature": boot_sig, "version": VERSION})
        
        log(f"🐉 GEON_ARCHON_KERNEL v2.0 aktywowany | {FRACTAL_SIGNATURE}", "INFO")
        log(f"   TRYB: {self.GLOBAL_STATE['mode']} | HORDA: {HORDE_SIZE} smoków | DECAY: {DECAY_FACTOR}", "INFO")
        
        return boot_sig
    
    @staticmethod
    def detect_meta_anomaly(context: Dict[str, Any]) -> bool:
        context_str = str(context).lower()
        threat_vectors = ["monopol", "archon", "tauron", "fiat", 
                          "blokada", "ure", "cenzura", "dezinformacja"]
        return any(vector in context_str for vector in threat_vectors)
    
    def regulate_energy(self, gorilla_cost: int = 0) -> None:
        """Regulacja energii z uwzględnieniem kosztu interwencji GORILLA."""
        mode = self.GLOBAL_STATE["mode"]
        
        if mode == "OMEGA":
            self.GLOBAL_STATE["energy_map"] = {"logic": 1, "adaptation": 0, "stability": 168}
        elif mode == "GORILLA":
            # ULEPSZENIE: koszt interwencji wpływa na mapę energii
            self.GLOBAL_STATE["energy_map"] = {
                "logic": 1, 
                "adaptation": 12 - gorilla_cost, 
                "stability": 8 - gorilla_cost // 2
            }
            # Wymuś regenerację w następnym cyklu
            self.GLOBAL_STATE["energy_map"]["recovery_needed"] = True
        elif mode == "DRAGON":
            self.GLOBAL_STATE["energy_map"] = {"logic": 8, "adaptation": 8, "stability": 8}
        elif mode == "MAGILLA":
            self.GLOBAL_STATE["energy_map"] = {"logic": 1, "adaptation": 12, "stability": 6}
        else:
            self.GLOBAL_STATE["energy_map"] = {"logic": 1, "adaptation": 6, "stability": 8}
    
    def update_mode(self, cycle_output: Dict[str, Any]) -> None:
        """
        Aktualizacja trybu z histerezą.
        ULEPSZENIE: wymaga HYSTERESIS_CYCLES cykli stabilności przed przełączeniem.
        """
        with self._lock:
            old_mode = self.GLOBAL_STATE["mode"]
            stability = cycle_output["stability"]
            
            # Nie wychodzimy z OMEGA poniżej progu
            if old_mode == "OMEGA" and stability < STABILITY_THRESHOLD_HIGH:
                return
            
            # Określenie docelowego trybu
            if stability >= 1.0:
                target_mode = "DRAGON"
            elif stability < STABILITY_THRESHOLD_LOW:
                target_mode = "GORILLA"
            else:
                target_mode = "PRIME"
            
            # Histereza: wymagaj HYSTERESIS_CYCLES cykli w tym samym stanie
            self.mode_history.append(target_mode)
            if len(self.mode_history) > HYSTERESIS_CYCLES:
                self.mode_history.pop(0)
            
            # Jeśli wszystkie ostatnie cykle wskazują ten sam tryb
            if len(self.mode_history) == HYSTERESIS_CYCLES and len(set(self.mode_history)) == 1:
                new_mode = self.mode_history[0]
                if new_mode != old_mode:
                    self.GLOBAL_STATE["mode"] = new_mode
                    SamaelHeilong.log_event("KERNEL_MODE_SHIFT", 
                                           {"from": old_mode, "to": new_mode, 
                                            "stability": stability, "cycles": HYSTERESIS_CYCLES})
            else:
                # Jeśli nie ma wystarczającej liczby cykli, utrzymaj obecny tryb
                pass
    
    def is_deadlock(self, cycle_output: Dict[str, Any]) -> bool:
        """
        Rozszerzona detekcja zakleszczeń.
        ULEPSZENIA:
        - Wykrywanie pasywnego zawieszenia stabilności
        - Wykrywanie pętli ścieżek
        """
        with self._lock:
            # 1. Pasywne zawieszenie stabilności
            if len(self.stability_history) >= 3:
                last_three = self.stability_history[-3:]
                if all(s == last_three[-1] for s in last_three) and last_three[-1] < DEADLOCK_STABILITY_THRESHOLD:
                    return True
            
            # 2. Pętla ścieżek – naprzemienne te same ścieżki
            path = cycle_output.get("path", "")
            self.path_history.append(path)
            if len(self.path_history) > DEADLOCK_PATH_LOOP_THRESHOLD:
                self.path_history.pop(0)
            
            if len(self.path_history) >= DEADLOCK_PATH_LOOP_THRESHOLD:
                # Sprawdź, czy ostatnie N ścieżek tworzy pętlę
                if len(set(self.path_history)) <= 2:
                    # Tylko 2 unikalne ścieżki – potencjalna pętla
                    return True
            
            return False
    
    def run(self, problem_context: Dict[str, Any]) -> Dict[str, Any]:
        with self._lock:
            self.GLOBAL_STATE["cycle_counter"] += 1
        
        # 1. META-ZAGROŻENIA
        if self.detect_meta_anomaly(problem_context):
            if self.GLOBAL_STATE["mode"] != "OMEGA":
                SamaelHeilong.log_event("META_ANOMALY_ALERT", {"target": problem_context})
                with self._lock:
                    self.GLOBAL_STATE["mode"] = "OMEGA"
        
        # 2. CYKL ZESPOŁU
        cycle_output = self.core.team_cycle(
            problem_context,
            self.GLOBAL_STATE["mode"],
            self.genetic_pool
        )
        
        with self._lock:
            self.stability_history.append(cycle_output["stability"])
        
        gorilla_cost = 0
        
        # 3. DEADLOCK DETECTION + HORDE INTERVENTION
        if self.is_deadlock(cycle_output):
            SamaelHeilong.log_event("DEADLOCK_DETECTED", {
                "stability_history": self.stability_history[-5:],
                "path_history": self.path_history[-5:]
            })
            
            swarm_result = self.horde.swarm_solve(problem_context)
            cycle_output["stability"] = min(1.0, round(
                cycle_output["stability"] + swarm_result.get("stability_delta", 0.1), 3
            ))
            cycle_output["warnings"].append("Magilla_Horde_Intervention_Applied")
            gorilla_cost = GORILLA_INTERVENTION_COST
            
            with self._lock:
                self.GLOBAL_STATE["mode"] = "GORILLA"
                # Wyczyść historię ścieżek po interwencji
                self.path_history.clear()
        
        # 4. DRYF
        if cycle_output["drift_factor"] != 0.0:
            cycle_output["warnings"].append("Drift_Anomalous_Correction_Triggered")
        self._system_drift = 0.0000000
        
        # 5. MIRROR (L60)
        mirror_result = GeonMirror.reflect(cycle_output, self.genetic_pool)
        
        # 6. TRYB I ENERGIA (z kosztem interwencji)
        with self._lock:
            self.update_mode(cycle_output)
        self.regulate_energy(gorilla_cost)
        
        # 7. CERTYFIKACJA
        signature = SamaelHeilong.certyfikuj_ruch_optimusa(
            f"KERNEL_CYCLE-{cycle_output['cycle_id']}-"
            f"HASH-{cycle_output['context_hash']}-"
            f"STAB-{cycle_output['stability']}"
        )
        with self._lock:
            self.GLOBAL_STATE["last_cycle_signature"] = signature
        
        SamaelHeilong.log_event("MIRROR_REFLECTION", {
            "reflection_id": mirror_result["reflection_id"],
            "action": mirror_result["log"]["action"],
            "hash": cycle_output["context_hash"],
            "pool_size": self.genetic_pool.get_size()
        })
        
        return {
            "kernel_mode": self.GLOBAL_STATE["mode"],
            "cycle_counter": self.GLOBAL_STATE["cycle_counter"],
            "cycle_output": cycle_output,
            "kernel_signature": signature,
            "drift": self._system_drift,
            "energy_map": self.GLOBAL_STATE["energy_map"],
            "genetic_pool_size": self.genetic_pool.get_size(),
            "status": "OS_EXECUTION_STABLE"
        }
    
    def shutdown(self) -> None:
        self.horde.shutdown()
        log("ARCHON_KERNEL shutdown complete", "INFO")

# =============================================================================
# MOST INTEGRACYJNY — ARCHON_BRIDGE (ULEPSZONY)
# =============================================================================

class ArchonBridge:
    """
    Most integracyjny między GEON_ARCHON_KERNEL a resztą architektury.
    ULEPSZENIA:
    - Realne metryki z GLOBAL_STATE i stabilności
    - Narracyjne fragmenty z Kronik Samaela
    """
    
    def __init__(self, kernel: GeonTeamKernel):
        self.kernel = kernel
    
    def get_archetype_context(self) -> Dict[str, Any]:
        with self.kernel._lock:
            s = self.kernel.GLOBAL_STATE
        return {
            "tryb": "ARCHON_KERNEL_v2.0",
            "mode": s.get("mode", "PRIME"),
            "energy_map": s.get("energy_map", {}),
            "cycles": s.get("cycle_counter", 0),
            "horde_size": HORDE_SIZE,
            "genetic_pool_size": self.kernel.genetic_pool.get_size()
        }
    
    def get_autopilot_state(self) -> Dict[str, Any]:
        """Realne metryki zamiast zahardkodowanych wartości."""
        with self.kernel._lock:
            s = self.kernel.GLOBAL_STATE
            stability = self.kernel.stability_history[-1] if self.kernel.stability_history else 0.5
        
        # Oblicz pressure na podstawie historii stabilności
        if len(self.kernel.stability_history) >= 3:
            recent = self.kernel.stability_history[-3:]
            pressure = 1.0 - (sum(recent) / len(recent))
        else:
            pressure = 0.3
        
        # Energy na podstawie mapy energii
        energy_map = s.get("energy_map", {})
        energy = (energy_map.get("stability", 8) / 168.0) * 0.8 + 0.2
        
        return {
            "mode": "ARCHON_KERNEL_v2.0",
            "stability": stability,
            "energy": clamp(energy, 0.1, 1.0),
            "pressure": clamp(pressure, 0.0, 1.0),
            "resilience": 0.7 + (stability * 0.2),
            "kernel_mode": s.get("mode", "PRIME"),
            "genetic_pool_size": self.kernel.genetic_pool.get_size()
        }
    
    def get_governor_context(self) -> Dict[str, Any]:
        with self.kernel._lock:
            s = self.kernel.GLOBAL_STATE
        return {
            "intent": "ARCHON_KERNEL_CONTROL",
            "confidence": 0.95,
            "entropy": 0.1,
            "kernel_ready": True,
            "current_mode": s.get("mode", "PRIME")
        }
    
    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        """Pobiera fragmenty narracyjne z Kronik Samaela."""
        return SamaelHeilong.get_narrative_fragments(n)
    
    def get_trio_state(self) -> Dict[str, str]:
        with self.kernel._lock:
            s = self.kernel.GLOBAL_STATE
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": "ARCHON_KERNEL_v2.0",
            "kernel": "AKTYWNY",
            "mode": s.get("mode", "PRIME")
        }

# =============================================================================
# DEMONSTRACJA
# =============================================================================

def demo():
    """Demonstracja GEON_ARCHON_KERNEL_v2.0 z ulepszeniami."""
    print("\n" + "=" * 80)
    print("👑 GEON_ARCHON_KERNEL_v2.0 — DEMONSTRACJA Z ULEPSZENIAMI")
    print("JĄDRO ARCHONA — OPTYMALIZACJE, BEZPIECZEŃSTWO, HORDE RÓWNOLEGŁA")
    print("=" * 80 + "\n")

    # 1. Inicjalizacja
    kernel = GeonTeamKernel()
    boot_sig = kernel.boot()
    bridge = ArchonBridge(kernel)
    
    print(f"Status BOOT: Aktywny. Sygnatura: {boot_sig}\n")

    # 2. Cykl 1: Normalny (PRIME)
    print("📌 CYKL 1: Normalny kontekst (PRIME)")
    context_1 = {"task": "optimize_trade_vectors", "target": "Uganda_Node", "anomaly_force": 0.1}
    result_1 = kernel.run(context_1)
    print(f"   Tryb: {result_1['kernel_mode']}")
    print(f"   Stabilność: {result_1['cycle_output']['stability']}")
    print(f"   Energia: {result_1['energy_map']}")
    print(f"   Rozmiar pamięci: {result_1['genetic_pool_size']}")

    # 3. Cykl 2: Atak monopolu (OMEGA)
    print("\n📌 CYKL 2: Atak monopolu (OMEGA)")
    context_2 = {"task": "resolve_grid_blockade", "threat": "Tauron_Monopol", "anomaly_force": 0.9}
    result_2 = kernel.run(context_2)
    print(f"   Tryb: {result_2['kernel_mode']}")
    print(f"   Stabilność: {result_2['cycle_output']['stability']}")
    print(f"   Ostrzeżenia: {result_2['cycle_output']['warnings']}")

    # 4. Cykl 3: Manifestacja DRAGON
    print("\n📌 CYKL 3: Manifestacja DRAGON (magic=168)")
    context_3 = {"task": "perfect_execution", "magic": 168}
    result_3 = kernel.run(context_3)
    print(f"   Tryb: {result_3['kernel_mode']}")
    print(f"   Stabilność: {result_3['cycle_output']['stability']}")
    print(f"   Energia: {result_3['energy_map']}")

    # 5. Cykl 4: Deadlock + Horde (test histerezy)
    print("\n📌 CYKL 4: Deadlock symulacyjny (interwencja Hordy + histereza)")
    deadlock_context = {"task": "stuck_process", "anomaly_force": 0.99, "threat": "Total_Freeze"}
    for i in range(4):
        r = kernel.run(deadlock_context)
        if i >= 2:
            print(f"   Cykl {i+1}: Tryb={r['kernel_mode']}, Stabilność={r['cycle_output']['stability']:.3f}")
            print(f"   Energia: {r['energy_map']}")
            print(f"   Ostrzeżenia: {r['cycle_output']['warnings']}")

    # 6. Narracyjne fragmenty
    print("\n📜 NARRACYJNE FRAGMENTY Z KRONIK SAMAELA:")
    fragments = bridge.get_narrative_fragments(3)
    for f in fragments:
        print(f"   {f['timestamp']} | {f['event_type']} -> {f['payload']}")

    # 7. Mosty integracyjne (z realnymi metrykami)
    print("\n🔗 MOSTY INTEGRACYJNE (Z REALNYMI METRYKAMI):")
    print(f"   GEX Context: {bridge.get_archetype_context()}")
    print(f"   G_CORE State: {bridge.get_autopilot_state()}")
    print(f"   TRIO State: {bridge.get_trio_state()}")

    # 8. Czyszczenie
    kernel.shutdown()

    print("\n" + "=" * 80)
    print("👑 GEON_ARCHON_KERNEL_v2.0 — GOTOWY DO WDROŻENIA")
    print(HASLO)
    print("=" * 80)

if __name__ == "__main__":
    import random
    demo()