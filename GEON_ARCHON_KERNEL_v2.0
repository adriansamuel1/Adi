class SamaelHeilong:
    """🐉 SAMAEL HEILONG – ARCYPIŚMIENNY STRAŻNIK KRONIK"""
    
    _narrative_history: deque = deque(maxlen=100)
    _lock = threading.Lock()

    @staticmethod
    def certyfikuj_ruch_optimusa(dzialanie: str) -> str:
        timestamp = datetime.now().isoformat()
        payload = f"{timestamp}-{dzialanie}-1-6-8. ∞. SIEMA!"
        hash_signature = hashlib.sha256(payload.encode("utf-8")).hexdigest()[:16].upper()
        return f"🔒 [SAMAELSEALSIG-{hash_signature}-ARCHON-168]"

    @staticmethod
    def log_event(event_type: str, payload: Dict[str, Any]) -> None:
        ts = datetime.now().isoformat()
        log_msg = f"[KRONIKI SAMAELA] {ts} | {event_type} -> {payload}"
        log(log_msg, "INFO")
        
        # Zapis do historii narracyjnej
        with SamaelHeilong._lock:
            SamaelHeilong._narrative_history.append({
                "timestamp": ts,
                "event_type": event_type,
                "payload": payload
            })

    @staticmethod
    def get_narrative_fragments(n: int = 5) -> List[Dict[str, Any]]:
        """Pobiera ostatnie n fragmentów narracyjnych."""
        with SamaelHeilong._lock:
            return list(SamaelHeilong._narrative_history)[-n:]

    @staticmethod
    def clear_narrative() -> None:
        with SamaelHeilong._lock:
            SamaelHeilong._narrative_history.clear()

