class SubStageManagerEnhanced:
    """Precyzyjny zarządca notacji sub-etapów odporny na zniekształcenia komend."""
    
    def __init__(self, parent_stage: int):
        self.parent = parent_stage
        self.sub_level = 1
        self.max_sub = 3

    def next_sub(self) -> bool:
        if self.sub_level < self.max_sub:
            self.sub_level += 1
            return False
        self.sub_level = 1
        return True

    def current_moves(self) -> List[str]:
        base = SIEN_MOVES.get(self.parent, [])
        if not base:
            return []
        
        adjusted_moves = []
        for m in base:
            axis = m[0]
            rest = m[1:]
            
            if self.sub_level == 1:
                # Sub-etap 1: Inicjalizacja / Akcent dodatni
                adjusted_moves.append(f"{axis}+")
            elif self.sub_level == 2:
                # Sub-etap 2: Ruch pełny (nominalny)
                adjusted_moves.append(m)
            else:
                # Sub-etap 3: Domykanie / Konsolidacja
                if "-" in rest:
                    adjusted_moves.append(f"{axis}2")
                else:
                    adjusted_moves.append(f"{axis}-")
                
        return adjusted_moves

    def get_sub_level(self) -> int:
        return self.sub_level

