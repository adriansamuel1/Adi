class GEON_Cube_9_Dynamic_Enhanced(GEON_Cube_15):
    """Kostka z histerazą skali – zapobiega migotaniu rejestrów przy brzegach presji."""
    
    def __init__(self, mode: str = "NORMAL"):
        super().__init__()
        self.mode = mode
        self.current_size = 9
        self._rebuild_axes()
        self.layers = {
            "identity": list(range(1, 10)),
            "lineage": list(range(1, 10)),
            "civilization": list(range(1, 10))
        }
        self._size_history: List[int] = [9]

    def _rebuild_axes(self) -> None:
        self.axis_A = list(range(1, self.current_size + 1))
        self.axis_B = list(range(1, self.current_size + 1))
        self.axis_C = list(range(1, self.current_size + 1))

    def update_size(self, pressure: float) -> None:
        """Histereza: wyjście wyżej wymaga 0.78, powrót wymaga spadku poniżej 0.70/0.38."""
        old_size = self.current_size
        
        if self.mode == "NORMAL" and pressure > 0.78:
            self.mode = "EXPANSION"
            self.current_size = 15
            self._rebuild_axes()
            SamaelHeilong.log_event("CUBE_EXPANSION", {
                "from": old_size, "to": 15, "pressure": round(pressure, 4)
            })
        elif self.mode == "EXPANSION" and pressure < 0.70:
            self.mode = "NORMAL"
            self.current_size = 9
            self._rebuild_axes()
            SamaelHeilong.log_event("CUBE_NORMAL", {
                "from": old_size, "to": 9, "pressure": round(pressure, 4)
            })
        elif self.mode == "NORMAL" and pressure < 0.30:
            self.mode = "CRISIS"
            self.current_size = 6
            self._rebuild_axes()
            SamaelHeilong.log_event("CUBE_CRISIS", {
                "from": old_size, "to": 6, "pressure": round(pressure, 4)
            })
        elif self.mode == "CRISIS" and pressure > 0.38:
            self.mode = "NORMAL"
            self.current_size = 9
            self._rebuild_axes()
            SamaelHeilong.log_event("CUBE_NORMAL", {
                "from": old_size, "to": 9, "pressure": round(pressure, 4)
            })

        if old_size != self.current_size:
            self._size_history.append(self.current_size)

    def move(self, code: str) -> None:
        if len(code) < 2:
            raise ValueError(f"Zły kod ruchu: {code}")
        axis = code[0].upper()
        suffix = code[1:]
        
        if suffix == '+':
            shift = 1
        elif suffix == '-':
            shift = -1
        else:
            try:
                shift = int(suffix)
            except ValueError:
                raise ValueError(f"Nieprawidłowy sufiks: {suffix}")
        
        size = self.current_size
        shift %= size
        
        if axis == 'A':
            self.axis_A = self.axis_A[shift:] + self.axis_A[:shift]
        elif axis == 'B':
            self.axis_B = self.axis_B[shift:] + self.axis_B[:shift]
        elif axis == 'C':
            self.axis_C = self.axis_C[shift:] + self.axis_C[:shift]
        else:
            raise ValueError(f"Nieznana oś wektora: {axis}")

    def apply_moves(self, moves: List[str]) -> None:
        for m in moves:
            self.move(m)

    def eval(self, x: int, y: int, z: int, log: bool = False) -> Dict:
        size = self.current_size
        safe_x = clamp(x, 1, size)
        safe_y = clamp(y, 1, size)
        safe_z = clamp(z, 1, size)
        
        valA = self.axis_A[safe_x - 1]
        valB = self.axis_B[safe_y - 1]
        valC = self.axis_C[safe_z - 1]
        
        scale = 15.0 / size
        scaledA = clamp(int(valA * scale), 1, 15)
        scaledB = clamp(int(valB * scale), 1, 15)
        scaledC = clamp(int(valC * scale), 1, 15)
        
        return super().eval(scaledA, scaledB, scaledC, log=log)

    def get_size_history(self) -> List[int]:
        return self._size_history.copy()

    def get_current_size(self) -> int:
        return self.current_size

    def get_mode(self) -> str:
        return self.mode

