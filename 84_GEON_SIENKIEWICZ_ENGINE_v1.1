class GEON_Cube_15:
    """Implementacja bazy geometrycznej 15×15×15 z zachowaniem stałych pól fizycznych."""
    
    def __init__(self):
        self.axis_A = list(range(1, 16))
        self.axis_B = list(range(1, 16))
        self.axis_C = list(range(1, 16))

    def state(self) -> Dict[str, List[int]]:
        return {"A": self.axis_A.copy(), "B": self.axis_B.copy(), "C": self.axis_C.copy()}
    
    def from_state(self, s: Dict[str, List[int]]) -> None:
        self.axis_A = s["A"].copy()
        self.axis_B = s["B"].copy()
        self.axis_C = s["C"].copy()
    
    def eval(self, a: int, b: int, c: int, log: bool = False) -> Dict[str, Any]:
        a = clamp(a, 1, 15)
        b = clamp(b, 1, 15)
        c = clamp(c, 1, 15)
        
        wspolczynnik = (a * 0.3 + b * 0.4 + c * 0.3) / 15.0
        konsekwencja = clamp(wspolczynnik, 0.0001, 0.9999)
        
        if konsekwencja < 0.4:
            stan = "STABILNY ŁAD"
        elif konsekwencja < 0.75:
            stan = "TRANSFORMACJA"
        else:
            stan = "MASYWNA PRESJA CYWILIZACYJNA"
        
        return {
            "stan": stan,
            "konsekwencja": konsekwencja,
            "presja": konsekwencja * 1.68
        }
    
    def show(self, max_display: int = 5) -> None:
        print(f"Oś A: {self.axis_A[:max_display]}...")
        print(f"Oś B: {self.axis_B[:max_display]}...")
        print(f"Oś C: {self.axis_C[:max_display]}...")

