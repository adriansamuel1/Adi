        self.seed = {
            "final_archetype": last_step.get("archetype"),
            "final_consequence": last_step.get("consequence"),
            "final_state": last_step.get("cube_state")
        }
        SamaelHeilong.log_event("MYTH_SEED_SECURED", {"archetype": self.seed["final_archetype"]})

    def apply_to_next(self, engine) -> bool:
        if self.seed:
            engine.cube.from_state(self.seed["final_state"])
            if self.seed["final_archetype"] == "Przodek":
                engine.resonance += 1
            return True
        return False

