class PressureMap:
    def __init__(self):
        self.grid = [[[0.5 for _ in range(9)] for _ in range(9)] for _ in range(9)]

    def update_from_cube(self, cube: GEON_Cube_9_Dynamic_Enhanced) -> None:
        for i in range(9):
            for j in range(9):
                for k in range(9):
                    res = cube.eval(i+1, j+1, k+1)
                    self.grid[i][j][k] = res.get("konsekwencja", 0.5)

    def critical_points(self, threshold: float = 0.75) -> List[Tuple[int, int, int, float]]:
        points = []
        for i in range(9):
            for j in range(9):
                for k in range(9):
                    if self.grid[i][j][k] > threshold:
                        points.append((i+1, j+1, k+1, self.grid[i][j][k]))
        return sorted(points, key=lambda x: x[3], reverse=True)

class PredictiveLogger:
    def __init__(self, window: int = 5):
        self.window = window
        self.history: List[Dict] = []

    def add(self, stage: int, sub: int, consequence: float, archetype: str) -> None:
        self.history.append({
            "stage": stage,
            "sub": sub,
            "consequence": consequence,
            "archetype": archetype
        })
        if len(self.history) > self.window:
            self.history.pop(0)

    def predict(self) -> Dict:
        if len(self.history) < 2:
            return {"prediction": "INICJACJA", "confidence": 0.0}
        
        cons = [h["consequence"] for h in self.history]
        trend = "WZROST PRESJI" if cons[-1] > cons[0] else "STABILIZACJA"
        
        return {
            "next_probable_stage": min(9, self.history[-1]["stage"] + (1 if trend == "WZROST PRESJI" else 0)),
            "dominant_archetype": self.history[-1]["archetype"],
            "trend": trend,
            "confidence": min(0.95, abs(cons[-1] - cons[0]) * 2.0)
        }

