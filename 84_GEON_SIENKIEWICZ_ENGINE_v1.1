class SienkiewiczEngine:
    """🛡️ RDZEŃ MONOLITU CYWILIZACYJNEGO – Zarządca 27 Pod-etapów (v1.1)."""
    
    def __init__(self, config: Optional[Dict] = None):
        self.config = config or {}
        self.cube = GEON_Cube_9_Dynamic_Enhanced()
        self.stage = 1
        self.sub_manager = SubStageManagerEnhanced(self.stage)
        self.history: List[Dict] = []
        self.resonance = 999
        self.pressure_map = PressureMap()
        self.predictor = PredictiveLogger()
        self.myth = MythRecursion()
        self.lineage = LineageTree()
        self._current_cycle_id: Optional[int] = None
        self.cycle_id = generate_context_hash({"init": time.time()})
        
        self.auto_cycle = self.config.get("auto_cycle", False)
        self.log_to_egregor = self.config.get("log_to_egregor", True)
        self.validate_stages = self.config.get("validate_stages", True)
        
        self.kroniki = SamaelHeilong
        self.egregor = Egregor
        
        log("🐉 GEON_SIENKIEWICZ_ENGINE v1.1 aktywowany | " + FRACTAL_SIGNATURE)
        log(f"   ETAPY: 9 × 3 sub-etapy = 27 | REZONANS: {VIBE} | HISTEREZA: AKTYWNA")

    def _log(self, event: str, data: Dict[str, Any]) -> None:
        self.kroniki.log_event(f"SIEN_{event}", data)

    def _eval_at_stage(self, stage: int) -> Dict:
        pos = SIEN_EVAL[stage]
        return self.cube.eval(*pos)

    def _check_stage_validation(self, stage: int, eval_result: Dict) -> bool:
        if not self.validate_stages:
            return True
        
        konsekwencja = eval_result.get("konsekwencja", 0.5)
        stan = eval_result.get("stan", "")
        
        validation_rules = {
            1: {"min": 0.2, "max": 0.6, "states": ["STABILNY", "TRANSFORMACJA"]},
            2: {"min": 0.3, "max": 0.7, "states": ["STABILNY"]},
            3: {"min": 0.1, "max": 0.5, "states": ["TRANSFORMACJA"]},
            4: {"min": 0.0, "max": 0.3, "states": ["TRANSFORMACJA"]},
            5: {"min": 0.4, "max": 0.8, "states": ["STABILNY"]},
            6: {"min": 0.5, "max": 0.9, "states": ["STABILNY"]},
            7: {"min": 0.3, "max": 0.7, "states": ["STABILNY"]},
            8: {"min": 0.2, "max": 0.6, "states": ["STABILNY"]},
            9: {"min": 0.4, "max": 0.8, "states": ["STABILNY"]}
        }
        
        rule = validation_rules.get(stage)
        if not rule:
            return True
        
        in_range = rule["min"] <= konsekwencja <= rule["max"]
        in_state = any(s in stan for s in rule["states"])
        
        return in_range and in_state

    def step(self) -> Dict:
        stage = self.stage
        sub = self.sub_manager.get_sub_level()
        stage_name = EtapCywilizacji(stage).name
        archetype = ARCHETYPES.get(stage, "Nieznany")
        
        current_eval = self._eval_at_stage(stage)
        consequence = current_eval.get("consequence", 0.5)
        
        # Dynamiczne skalowanie z histerezą
        self.cube.update_size(consequence)
        
        moves = self.sub_manager.current_moves()
        before_state = self.cube.state()
        
        if moves:
            self.cube.apply_moves(moves)
        
        after_state = self.cube.state()
        after_eval = self._eval_at_stage(stage)
        new_consequence = after_eval.get("consequence", 0.5)
        
        validation_passed = self._check_stage_validation(stage, after_eval)
        
        record = {
            "stage": stage,
            "sub_stage": sub,
            "stage_name": stage_name,
            "archetype": archetype,
            "moves": moves,
            "before_state": before_state,
            "after_state": after_state,
            "before_eval": current_eval,
            "after_eval": after_eval,
            "consequence": new_consequence,
            "validation_passed": validation_passed,
            "cube_state": after_state,
            "cube_size": self.cube.get_current_size(),
            "cube_mode": self.cube.get_mode(),
            "timestamp": datetime.now().isoformat()
        }
        
        self.history.append(record)
        
        self._log("STEP_RESOLVED", {
            "lokacja": f"{stage}.{sub}",
            "nazwa": stage_name,
            "arch": archetype,
            "presja": f"{new_consequence:.4f}",
            "walidacja": validation_passed,
            "rozmiar_kostki": self.cube.get_current_size(),
            "tryb_kostki": self.cube.get_mode()
        })
        
        if self.log_to_egregor:
            entry = {
                "type": "SIEN_STEP",
                "stage": f"{stage}.{sub}",
                "archetype": archetype,
                "evaluation": after_eval,
                "validation": validation_passed,
                "cube_size": self.cube.get_current_size(),
                "cube_mode": self.cube.get_mode(),
                "cycle_id": self.cycle_id,
                "timestamp": record["timestamp"]
            }
            self.egregor.commit(entry, node_id="SIEN_ENGINE")
        
        self.predictor.add(stage, sub, new_consequence, archetype)
        
        if self.sub_manager.next_sub():
            self.stage = 1 if stage == 9 else stage + 1
            self.sub_manager = SubStageManagerEnhanced(self.stage)
        
        return record

    def full_cycle(self) -> List[Dict]:
        self.stage = 1
        self.sub_manager = SubStageManagerEnhanced(1)
        self.history = []
        self.cycle_id = generate_context_hash({"start": time.time()})
        
        self._log("EPOCH_INITIALIZED", {"tryb": "MODEL_9_MONOLITH", "cycle_id": self.cycle_id})
        
        for _ in range(27):
            self.step()
        
        self.pressure_map.update_from_cube(self.cube)
        
        if self.history:
            cycle_summary = {
                "final_eval": self.history[-1]["after_eval"],
                "dominant_archetype": ARCHETYPES.get(9, "Przodek"),
                "total_steps": len(self.history),
                "size_history": self.cube.get_size_history()
            }
            self._current_cycle_id = self.lineage.add_cycle(cycle_summary, self._current_cycle_id)
            
            last = self.history[-1]
            self.myth.finalize(last)
        
        self._log("EPOCH_COMPLETE", {
            "steps": len(self.history),
            "final_state": self.cube.state(),
            "final_eval": self.history[-1]["after_eval"] if self.history else None
        })
        
        return self.history

    def next_cycle(self) -> List[Dict]:
        self.myth.apply_to_next(self)
        return self.full_cycle()

    def summary(self) -> Dict[str, Any]:
        last = self.history[-1] if self.history else None
        return {
            "current_stage": self.stage,
            "total_cycles_executed": len(self.lineage.nodes),
            "final_evaluation": last["after_eval"] if last else None,
            "top_critical_nodes": self.pressure_map.critical_points()[:3],
            "size_history": self.cube.get_size_history(),
            "validation_summary": {
                "passed": sum(1 for h in self.history if h.get("validation_passed", True)),
                "total": len(self.history)
            },
            "cycle_id": self.cycle_id
        }

    def get_status(self) -> Dict[str, Any]:
        return {
            "system": "GEON_SIENKIEWICZ_ENGINE_v1.1",
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "vibe": VIBE,
            "stage": self.stage,
            "sub_stage": self.sub_manager.get_sub_level(),
            "resonance": self.resonance,
            "cube_size": self.cube.get_current_size(),
            "cube_mode": self.cube.get_mode(),
            "history_len": len(self.history),
            "lineage_nodes": len(self.lineage.nodes),
            "auto_cycle": self.auto_cycle,
            "cycle_id": self.cycle_id
        }

# =============================================================================
# MOST INTEGRACYJNY — SIENKIEWICZ_BRIDGE
# =============================================================================

class SienkiewiczBridge:
    def __init__(self, engine: SienkiewiczEngine):
        self.engine = engine

    def get_archetype_context(self) -> Dict[str, Any]:
        status = self.engine.get_status()
        summary = self.engine.summary()
        return {
            "tryb": "SIENKIEWICZ_ENGINE_v1.1",
            "etap": status["stage"],
            "sub_etap": status["sub_stage"],
            "architektura": status["cube_size"],
            "tryb_kostki": status["cube_mode"],
            "linia_rodowa": status["lineage_nodes"],
            "walidacja": summary["validation_summary"]
        }

    def get_autopilot_state(self) -> Dict[str, Any]:
        status = self.engine.get_status()
        summary = self.engine.summary()
        last_eval = summary["final_evaluation"]
        stability = 1.0 - (last_eval["konsekwencja"] / 1.0 if last_eval else 0.5)
        return {
            "mode": "SIENKIEWICZ_ENGINE_v1.1",
            "stability": clamp(stability, 0.0, 1.0),
            "energy": status["resonance"] / 999.0,
            "pressure": last_eval["konsekwencja"] if last_eval else 0.5,
            "resilience": summary["validation_summary"]["passed"] / max(1, summary["validation_summary"]["total"]),
            "stage": status["stage"],
            "cube_size": status["cube_size"],
            "cube_mode": status["cube_mode"]
        }

    def get_governor_context(self) -> Dict[str, Any]:
        return {
            "intent": "CIVILIZATION_CYCLE",
            "confidence": 0.9,
            "entropy": 0.1,
            "sien_ready": True,
            "stage": self.engine.stage,
            "lineage": len(self.engine.lineage.nodes)
        }

    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        fragments = []
        for entry in self.engine.history[-n:]:
            fragments.append({
                "source": "SIENKIEWICZ_ENGINE_v1.1",
                "content": f"Etap {entry['stage']}.{entry['sub_stage']}: {entry['archetype']} → {entry['after_eval']['stan']} (kostka: {entry.get('cube_size', '?')})",
                "energy": entry["consequence"],
                "validation": entry.get("validation_passed", True)
            })
        return fragments

    def get_trio_state(self) -> Dict[str, str]:
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": "SIENKIEWICZ_ENGINE_v1.1",
            "sien": "AKTYWNY",
            "etap": str(self.engine.stage),
            "cube_mode": self.engine.cube.get_mode()
        }

