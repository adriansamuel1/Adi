        self.warning_history: List[int] = []
        self.mode_history: List[str] = []
        
        # Blokady trybów ★ NEW
        self._gorilla_lock: bool = False
        self._magilla_lock: bool = False
        self._lock = threading.Lock()
    
    def _preload_genetic_pool(self) -> None:
        """Ładuje początkowe wpisy z Egregora (międzywęzłowa synchronizacja)."""
        # Najpierw dociągnij z Egregora
        known_hashes = {e["context_hash"] for e in self.genetic_pool.get_all()}
        
        for record in Egregor.get_all():
            h = record.get("context_hash")
            if h and h not in known_hashes:
                self.genetic_pool.put(
                    context_hash=h,
                    clue=record.get("clue", {}),
                    resolved_path=record.get("resolved_path", "Asymmetric_Complementarity_Vector"),
                    efficiency=record.get("efficiency", 0.8)
                )
                known_hashes.add(h)
        
        # Jeśli nadal puste, dodaj podstawowe wpisy
        if self.genetic_pool.get_size() == 0:
            c1 = {"task": "resolve_grid_blockade", 
                  "threat": "Tauron_Grid_Monopol_Interference", 
                  "anomaly_force": 0.9}
            c2 = {"task": "optimize_trade_vectors", 
                  "target": "Uganda_Node", 
                  "anomaly_force": 0.1}
            
            entries = [
                {"context_hash": generate_context_hash(c1), "clue": c1, 
                 "resolved_path": "PLZ-Z_Substance_Override", "efficiency": 0.95},
                {"context_hash": generate_context_hash(c2), "clue": c2, 
                 "resolved_path": "Asymmetric_Complementarity_Vector", "efficiency": 0.90}
            ]
            for e in entries:
                self.genetic_pool.put(**e)
                Egregor.commit(e, node_id=self.node_id)
    
    def boot(self) -> str:
        with self._lock:
            self.GLOBAL_STATE["mode"] = "PRIME"
            self.GLOBAL_STATE["cycle_counter"] = 0
            self.stability_history.clear()
            self.path_history.clear()
            self.warning_history.clear()
            self.mode_history.clear()
            self._gorilla_lock = False
            self._magilla_lock = False
            self._preload_genetic_pool()
        
        boot_sig = SamaelHeilong.certyfikuj_ruch_optimusa(
            f"GEON_KERNEL_BOOT_v21_{self.node_id}_OK"
        )
        self.GLOBAL_STATE["last_cycle_signature"] = boot_sig
        SamaelHeilong.log_event("KERNEL_BOOT", {
            "signature": boot_sig, 
            "hierarchy_integrity": "SECURED",
            "node": self.node_id,
            "egregor_size": Egregor.get_size()
        })
        
        log(f"🐉 GEON_ARCHON_KERNEL v2.1 aktywowany | {FRACTAL_SIGNATURE}", "INFO")
        log(f"   WĘZEŁ: {self.node_id} | TRYB: {self.GLOBAL_STATE['mode']}", "INFO")
        log(f"   HORDA: {HORDE_SIZE} smoków | EGREGOR: {Egregor.get_size()} wpisów", "INFO")
        
        return boot_sig
    
    @staticmethod
    def detect_meta_anomaly(context: Dict[str, Any]) -> bool:
        context_str = str(context).lower()
        threat_vectors = ["monopol", "archon", "tauron", "fiat", 
                          "blokada", "ure", "cenzura", "dezinformacja"]
        return any(vector in context_str for vector in threat_vectors)
    
    def regulate_energy(self, gorilla_cost: int = 0) -> None:
        mode = self.GLOBAL_STATE["mode"]
        
        if mode == "OMEGA":
            self.GLOBAL_STATE["energy_map"] = {"logic": 1, "adaptation": 0, "stability": 168}
        elif mode == "MAGILLA":
            self.GLOBAL_STATE["energy_map"] = {"logic": 1, "adaptation": 12, "stability": 6}
        elif mode == "GORILLA":
            self.GLOBAL_STATE["energy_map"] = {
                "logic": 1, 
                "adaptation": 12 - gorilla_cost, 
                "stability": 8 - gorilla_cost // 2
            }
        elif mode == "DRAGON":
            self.GLOBAL_STATE["energy_map"] = {"logic": 8, "adaptation": 8, "stability": 8}
        else:
            self.GLOBAL_STATE["energy_map"] = {"logic": 1, "adaptation": 6, "stability": 8}
    
    def update_mode(self, cycle_output: Dict[str, Any]) -> None:
        with self._lock:
            old_mode = self.GLOBAL_STATE["mode"]
            stability = cycle_output["stability"]
            
            if old_mode == "OMEGA" and stability < STABILITY_THRESHOLD_HIGH:
                return
            
            if stability >= 1.0:
                target_mode = "DRAGON"
            elif stability < STABILITY_THRESHOLD_LOW:
                target_mode = "GORILLA"
            else:
                target_mode = "PRIME"
            
            self.mode_history.append(target_mode)
            if len(self.mode_history) > HYSTERESIS_CYCLES:
                self.mode_history.pop(0)
            
            if len(self.mode_history) == HYSTERESIS_CYCLES and len(set(self.mode_history)) == 1:
                new_mode = self.mode_history[0]
                if new_mode != old_mode:
                    self.GLOBAL_STATE["mode"] = new_mode
                    SamaelHeilong.log_event("KERNEL_MODE_SHIFT", {
                        "from": old_mode, "to": new_mode, 
                        "stability": stability, "cycles": HYSTERESIS_CYCLES,
                        "node": self.node_id
                    })
    
    def is_deadlock(self) -> bool:
        with self._lock:
            if len(self.stability_history) < 3:
                return False
            
            last_three_stab = self.stability_history[-3:]
            last_three_paths = self.path_history[-3:] if len(self.path_history) >= 3 else []
            last_three_warns = self.warning_history[-3:] if len(self.warning_history) >= 3 else [0, 0, 0]
            
            stability_stuck = all(s <= 0.3 for s in last_three_stab) and (max(last_three_stab) - min(last_three_stab) < 0.01)
            path_stuck = len(set(last_three_paths)) == 1 if last_three_paths else False
            warnings_rising = last_three_warns[-1] >= last_three_warns[0]
            
            return stability_stuck and path_stuck and warnings_rising
    
    def run(self, problem_context: Dict[str, Any]) -> Dict[str, Any]:
        with self._lock:
            self.GLOBAL_STATE["cycle_counter"] += 1
        
        gorilla_cost = 0
        
        # --- BLOKADA MAGILLA (najwyższy priorytet) ---
        if self._magilla_lock:
            with self._lock:
                self.GLOBAL_STATE["mode"] = "MAGILLA"
            self.regulate_energy()
            SamaelHeilong.log_event("LOCK_ENGAGED", {
                "type": "MAGILLA_ABSOLUTE_PRIORITY", 
                "node": self.node_id
            })
        
        # --- META-ZAGROŻENIA → OMEGA ---
        if self.detect_meta_anomaly(problem_context):
            if self.GLOBAL_STATE["mode"] != "OMEGA":
                SamaelHeilong.log_event("META_ANOMALY_ALERT", {
                    "target": problem_context, 
                    "node": self.node_id
                })
                with self._lock:
                    self.GLOBAL_STATE["mode"] = "OMEGA"
        
        # --- USER OVERRIDE → MAGILLA ---
        if problem_context.get("user_override") == "MAGILLA" or problem_context.get("smocza_zabawa") == "ACTIVE":
            with self._lock:
                self.GLOBAL_STATE["mode"] = "MAGILLA"
            self._magilla_lock = True
            SamaelHeilong.log_event("USER_OVERRIDE", {
                "action": "MAGILLA_MODE_ENGAGED", 
                "node": self.node_id
            })
        
        # --- CYKL ZESPOŁU ---
        cycle_output = self.core.team_cycle(
            problem_context,
            self.GLOBAL_STATE["mode"],
            self.genetic_pool,
            self.node_id
        )
        
        with self._lock:
            self.stability_history.append(cycle_output["stability"])
            self.path_history.append(cycle_output["path"])
            self.warning_history.append(len(cycle_output["warnings"]))
        
        # --- MAGILLA AKTYWNY ---
        if self.GLOBAL_STATE["mode"] == "MAGILLA":
            magilla_res = GeonMagilla.activate_magilla(problem_context)
            cycle_output["stability"] = min(1.0, round(
                cycle_output["stability"] + magilla_res["stability_delta"], 3
            ))
            cycle_output["warnings"].append(f"Magilla_Active:_{magilla_res['action_taken']}")
            self._magilla_lock = False
        
        # --- DEADLOCK DETECTION + HORDE INTERVENTION ---
        elif self.is_deadlock():
            SamaelHeilong.log_event("DEADLOCK_DETECTED", {
                "history": self.stability_history[-3:],
                "paths": self.path_history[-3:],
                "node": self.node_id
            })
            
            swarm_result = self.horde.swarm_solve(problem_context)
            cycle_output["stability"] = min(1.0, round(
                cycle_output["stability"] + swarm_result.get("stability_delta", 0.1), 3
            ))
            cycle_output["warnings"].append("Magilla_Horde_Intervention_Applied")
            gorilla_cost = GORILLA_INTERVENTION_COST
            
            with self._lock:
                self.GLOBAL_STATE["mode"] = "GORILLA"
                self._gorilla_lock = True
                self.path_history.clear()
        
        # --- DRYF ---
        if cycle_output["drift_factor"] != 0.0:
            cycle_output["warnings"].append("Drift_Anomalous_Correction_Triggered")
        self._system_drift = 0.0000000
        
        # --- BLOKADA GORILLA ---
        if self._gorilla_lock:
            self.regulate_energy(gorilla_cost)
            self._gorilla_lock = False
            SamaelHeilong.log_event("LOCK_RELEASE", {
                "type": "GORILLA_CYCLE_COMPLETED", 
                "node": self.node_id
            })
        elif not self._magilla_lock:
            with self._lock:
                self.update_mode(cycle_output)
            self.regulate_energy(gorilla_cost)
        
        # --- MIRROR (L60) ---
        mirror_result = GeonMirror.reflect(cycle_output, self.genetic_pool)
        
        # --- CERTYFIKACJA ---
        signature = SamaelHeilong.certyfikuj_ruch_optimusa(
            f"KERNEL_v21_CYCLE-{cycle_output['cycle_id']}-"
            f"HASH-{cycle_output['context_hash']}-"
            f"MODE-{self.GLOBAL_STATE['mode']}-"
            f"NODE-{self.node_id}"
        )
        with self._lock:
            self.GLOBAL_STATE["last_cycle_signature"] = signature
        
        SamaelHeilong.log_event("MIRROR_REFLECTION", {
            "reflection_id": mirror_result["reflection_id"],
            "action": mirror_result["log"]["action"],
            "hash": cycle_output["context_hash"],
            "node": self.node_id,
            "pool_size": self.genetic_pool.get_size(),
            "egregor_size": Egregor.get_size()
        })
        
        return {
            "kernel_mode": self.GLOBAL_STATE["mode"],
            "cycle_counter": self.GLOBAL_STATE["cycle_counter"],
            "cycle_output": cycle_output,
            "kernel_signature": signature,
            "drift": self._system_drift,
            "energy_map": self.GLOBAL_STATE["energy_map"],
            "genetic_pool_size": self.genetic_pool.get_size(),
            "egregor_size": Egregor.get_size(),
            "node_id": self.node_id,
            "status": "OS_EXECUTION_STABLE"
        }
    
    def shutdown(self) -> None:
        self.horde.shutdown()
        log("ARCHON_KERNEL v2.1 shutdown complete", "INFO")

