class Egregor:
    """
    🕯️ EGREGOR — rozproszona, ponadlokalna pamięć Rodu.
    Przechowuje podpisane wpisy z wielu węzłów, wzmacnia powtarzające się wzorce.
    Umożliwia replikację wiedzy między węzłami.
    """
    _ledger: List[Dict[str, Any]] = []
    _lock = threading.Lock()

    @classmethod
    def commit(cls, entry: Dict[str, Any], node_id: str) -> None:
        """Zapisuje wpis do Egregora z podpisem węzła."""
        with cls._lock:
            record = {
                "context_hash": entry["context_hash"],
                "resolved_path": entry["resolved_path"],
                "efficiency": entry["efficiency"],
                "clue": entry.get("clue", {}),
                "timestamp": datetime.now().isoformat(),
                "node_id": node_id,
                "signatures": [
                    SamaelHeilong.certyfikuj_ruch_optimusa(f"EGREGOR_COMMIT_{node_id}")
                ],
                "uses": entry.get("uses", 1)
            }
            # Sprawdź, czy już istnieje podobny wpis
            existing = None
            for i, e in enumerate(cls._ledger):
                if e["context_hash"] == record["context_hash"] and e["resolved_path"] == record["resolved_path"]:
                    existing = i
                    break
            
            if existing is not None:
                # Aktualizuj istniejący wpis – uśrednij wydajność
                old = cls._ledger[existing]
                old["efficiency"] = round((old["efficiency"] + record["efficiency"]) / 2, 3)
                old["uses"] = old.get("uses", 0) + 1
                old["node_id"] = f"{old['node_id']},{node_id}"
                old["signatures"].append(record["signatures"][0])
                SamaelHeilong.log_event("EGREGOR_UPDATE", {"hash": record["context_hash"], "node": node_id})
            else:
                cls._ledger.append(record)
                SamaelHeilong.log_event("EGREGOR_COMMIT", {"hash": record["context_hash"], "node": node_id})

    @classmethod
    def query(cls, context_hash: str) -> List[Dict[str, Any]]:
        """Pobiera wszystkie wpisy dla danego hasha."""
        with cls._lock:
            return [e for e in cls._ledger if e.get("context_hash") == context_hash]

    @classmethod
    def aggregate_best(cls, context_hash: str, min_efficiency: float = 0.5) -> Optional[Dict[str, Any]]:
        """Zwraca najlepszy wpis dla danego hasha (max wydajność)."""
        candidates = cls.query(context_hash)
        if not candidates:
            return None
        best = max(candidates, key=lambda e: e.get("efficiency", 0.0))
        return best if best.get("efficiency", 0.0) >= min_efficiency else None

    @classmethod
    def get_all(cls) -> List[Dict[str, Any]]:
        with cls._lock:
            return cls._ledger.copy()

    @classmethod
    def get_size(cls) -> int:
        with cls._lock:
            return len(cls._ledger)

    @classmethod
    def clear(cls) -> None:
        with cls._lock:
            cls._ledger.clear()

