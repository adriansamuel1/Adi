class DragonHorde:
    """🐲 SMOCZA HORDA — zrównoleglona, ucząca się inteligencja rojowa."""
    
    def __init__(self, size: int = HORDE_SIZE):
        self.dragons: List[YoungDragon] = [YoungDragon(f"Horde_Elite_{i}") for i in range(size)]
        self.swarm_count = 0
        self._executor = concurrent.futures.ThreadPoolExecutor(max_workers=size)

    def _run_dragon(self, index: int, context: Dict[str, Any]) -> Dict[str, Any]:
        """Pojedynczy smok wykonuje akcję (uruchamiane równolegle)."""
        res = GeonMagilla.activate_magilla(context)
        # Smok uczy się na podstawie siły swojego uderzenia
        xp_gain = int(res["stability_delta"] * 100)
        self.dragons[index].gain_experience(xp_gain, f"Swarm_solve_{res['action_taken']}")
        res["dragon_name"] = self.dragons[index].name
        return res

    def swarm_solve(self, context: Dict[str, Any]) -> Dict[str, Any]:
        """Równoległe uruchomienie wszystkich smoków z uczeniem."""
        futures = []
        for i in range(len(self.dragons)):
            future = self._executor.submit(self._run_dragon, i, context)
            futures.append(future)
        
        results = []
        for future in concurrent.futures.as_completed(futures):
            try:
                results.append(future.result())
            except Exception as e:
                log(f"Błąd w Hordzie: {e}", "ERROR")
                results.append({"stability_delta": 0.05, "comment": "Fallback"})
        
        best = max(results, key=lambda x: x.get("stability_delta", 0))
        best["swarm_size"] = len(self.dragons)
        best["comment"] += f" [Wyselekcjonowany z manifestacji Hordy przez {best.get('dragon_name', 'unknown')}]"
        self.swarm_count += 1
        
        return best

    def shutdown(self) -> None:
        self._executor.shutdown(wait=False)

