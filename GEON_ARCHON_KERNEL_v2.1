class ArchonBridge:
    def __init__(self, kernel: GeonTeamKernel):
        self.kernel = kernel
    
    def get_archetype_context(self) -> Dict[str, Any]:
        with self.kernel._lock:
            s = self.kernel.GLOBAL_STATE
        return {
            "tryb": "ARCHON_KERNEL_v2.1",
            "mode": s.get("mode", "PRIME"),
            "energy_map": s.get("energy_map", {}),
            "cycles": s.get("cycle_counter", 0),
            "horde_size": HORDE_SIZE,
            "genetic_pool_size": self.kernel.genetic_pool.get_size(),
            "egregor_size": Egregor.get_size(),
            "node_id": self.kernel.node_id
        }
    
    def get_autopilot_state(self) -> Dict[str, Any]:
        with self.kernel._lock:
            s = self.kernel.GLOBAL_STATE
            stability = self.kernel.stability_history[-1] if self.kernel.stability_history else 0.5
        
        if len(self.kernel.stability_history) >= 3:
            recent = self.kernel.stability_history[-3:]
            pressure = 1.0 - (sum(recent) / len(recent))
        else:
            pressure = 0.3
        
        energy_map = s.get("energy_map", {})
        energy = (energy_map.get("stability", 8) / 168.0) * 0.8 + 0.2
        
        return {
            "mode": "ARCHON_KERNEL_v2.1",
            "stability": stability,
            "energy": clamp(energy, 0.1, 1.0),
            "pressure": clamp(pressure, 0.0, 1.0),
            "resilience": 0.7 + (stability * 0.2),
            "kernel_mode": s.get("mode", "PRIME"),
            "genetic_pool_size": self.kernel.genetic_pool.get_size(),
            "egregor_size": Egregor.get_size(),
            "node_id": self.kernel.node_id
        }
    
    def get_governor_context(self) -> Dict[str, Any]:
        with self.kernel._lock:
            s = self.kernel.GLOBAL_STATE
        return {
            "intent": "ARCHON_KERNEL_CONTROL",
            "confidence": 0.95,
            "entropy": 0.1,
            "kernel_ready": True,
            "current_mode": s.get("mode", "PRIME"),
            "node_id": self.kernel.node_id
        }
    
    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        return SamaelHeilong.get_narrative_fragments(n)
    
    def get_trio_state(self) -> Dict[str, str]:
        with self.kernel._lock:
            s = self.kernel.GLOBAL_STATE
        return {
            "ISKRA": "AKTYWNA",
            "PIECZĘĆ": "AKTYWNA",
            "PERFEKCJA": "AKTYWNA",
            "tryb": "ARCHON_KERNEL_v2.1",
            "kernel": "AKTYWNY",
            "mode": s.get("mode", "PRIME"),
            "node": self.kernel.node_id
        }

