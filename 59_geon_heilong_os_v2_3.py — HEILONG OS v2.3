class LONG_TERM_MEMORY:
    """
    Pamięć długoterminowa — przechowuje wydarzenia systemowe.
    """
    def __init__(self):
        self.events: List[Dict] = []
        self.max_events = 500
    
    def store_event(self, label: str, data: Any,
                    truth_value: float, emotion_state: Dict[str, float]) -> None:
        """Przechowuje wydarzenie w pamięci"""
        self.events.append({
            "label": label,
            "data": data,
            "truth_value": truth_value,
            "emotion": emotion_state,
            "time": time.time()
        })
        if len(self.events) > self.max_events:
            self.events = self.events[-250:]
    
    def query(self, label: str) -> List[Dict]:
        """Zwraca wszystkie wydarzenia o danej etykiecie"""
        return [e for e in self.events if e["label"] == label]
    
    def last(self, label: str) -> Optional[Dict]:
        """Zwraca ostatnie wydarzenie o danej etykiecie"""
        matches = self.query(label)
        return matches[-1] if matches else None
    
    def get_all(self) -> List[Dict]:
        return self.events.copy()
    
    def clear(self) -> None:
        self.events = []
    
    def status(self) -> Dict:
        return {
            "events": len(self.events),
            "labels": list(set(e["label"] for e in self.events))
        }


