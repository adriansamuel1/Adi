def TRUTH_INTEGRAL(rdzen: List[Dict[str, Any]]) -> float:
    """
    Całka prawdy — pomiar spójności systemu.
    Im wyższa wartość, tym większa spójność.
    """
    if not rdzen:
        return 0.5
    
    acc = 0.0
    for seg in rdzen:
        source = seg.get("source", 0.0)
        narrative = seg.get("narrative", 0.0)
        mechanism = seg.get("mechanism", 1.0)
        acc += (source - narrative) * mechanism
    
    # Normalizacja do przedziału [0, 1]
    return max(0.0, min(1.0, acc / len(rdzen) + 0.5))


