class PREDICTED_RISK_HANDLER:
    """
    MODUŁ D — predykcja ryzyka i obsługa alertów.
    """
    def __init__(self):
        self.risk_log: List[Dict] = []
        self.threshold = 0.7
        self.alert_count = 0
    
    def predict(self, context: Dict[str, float]) -> float:
        """Predykcja ryzyka na podstawie kontekstu"""
        entropy = context.get("entropy", 0.0)
        load = context.get("load", 0.0)
        divergence = context.get("divergence", 0.0)
        
        risk = entropy * 0.4 + load * 0.3 + divergence * 0.3
        return min(risk, 1.0)
    
    def inject(self, risk_value: float, payload: Optional[Dict] = None) -> None:
        """Wstrzykuje ryzyko do logu"""
        self.risk_log.append({
            "risk": risk_value,
            "payload": payload,
            "time": time.time(),
            "alert_id": self.alert_count
        })
        self.alert_count += 1
        
        if risk_value >= self.threshold:
            BLACK_GOLD_UI.raise_alert(risk_value, payload)
            logger.warning(f"⚠️ ALERT: Ryzyko = {risk_value:.3f}")
    
    def get_last_risk(self) -> Optional[Dict]:
        """Zwraca ostatni wpis ryzyka"""
        return self.risk_log[-1] if self.risk_log else None
    
    def clear_log(self) -> None:
        """Czyści log ryzyka"""
        self.risk_log = []
    
    def status(self) -> Dict:
        return {
            "risk_log_len": len(self.risk_log),
            "alert_count": self.alert_count,
            "threshold": self.threshold
        }


