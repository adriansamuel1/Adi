class GuardianKernel:
    """
    Guardian Kernel — strażnik systemu.
    Monitoruje dryf, prawdę, integralność pamięci.
    """
    def __init__(self, system: Any):
        self.system = system
        self.drift_threshold = 0.05
        self.truth_min = 0.9
        self.last_guard_tick = 0
        self.guard_log: List[Dict] = []
        self.guardian_active = True
    
    def check_memory_integrity(self) -> bool:
        """Sprawdza integralność pamięci TRUTH_HASH_CERT"""
        ok = True
        for record in self.system.pamiec.records:
            if not self.system.pamiec.verify(record):
                ok = False
                logger.warning("⚠️ GUARDIAN_KERNEL: memory tamper detected")
                BLACK_GOLD_UI.raise_alert(0.0, payload={"integrity": "fail"})
                self.guard_log.append({
                    "timestamp": time.time(),
                    "event": "MEMORY_TAMPER",
                    "record": record
                })
        return ok
    
    def compute_drift(self, current_record: Dict, reference: Dict) -> float:
        """Oblicza dryf między aktualnym a referencyjnym rekordem"""
        if not reference:
            return 0.0
        return abs(current_record.get("truth_value", 0.0) - reference.get("truth_value", 0.0))
    
    def enforce_axiom(self) -> None:
        """Wymusza aksjomat systemowy: SYSTEM_DOMKNIETY → 0H_ACTIVE"""
        if self.system.state == "SYSTEM_DOMKNIETY" and self.system.mode != "0H_ACTIVE":
            self.system.mode = "0H_ACTIVE"
            logger.info("✨ GUARDIAN_KERNEL: wymuszono 0H_ACTIVE")
            self.guard_log.append({
                "timestamp": time.time(),
                "event": "AXIOM_ENFORCED",
                "mode": "0H_ACTIVE"
            })
    
    def guard_cycle(self, last_record: Optional[Dict] = None) -> None:
        """
        Pełny cykl strażniczy.
        """
        if not self.guardian_active:
            return
        
        self.last_guard_tick += 1
        
        # Jeśli brak rekordu, pomijamy
        if last_record is None:
            return
        
        # 1. Ustawienie referencji (wzorzec 0H)
        ref = getattr(self.system, "reference_state", None)
        if ref is None:
            if last_record.get("truth_value", 0.0) >= self.truth_min:
                self.system.reference_state = last_record
                logger.info("📌 GUARDIAN_KERNEL: ustawiono reference_state (wzorzec 0H)")
                self.guard_log.append({
                    "timestamp": time.time(),
                    "event": "REFERENCE_SET",
                    "truth_value": last_record.get("truth_value")
                })
            else:
                # Jeśli brak wzorca i prawda za niska — interwencja
                CZARNY_SMOK.stabilize(self.system)
                return
        
        # 2. Obliczenie dryfu
        drift = self.compute_drift(last_record, ref)
        
        # 3. Sprawdzenie dryfu
        if drift > self.drift_threshold:
            logger.warning(f"⚠️ GUARDIAN_KERNEL: drift = {drift:.3f} > threshold")
            CZARNY_SMOK.stabilize(self.system)
            self.guard_log.append({
                "timestamp": time.time(),
                "event": "DRIFT_DETECTED",
                "drift": drift,
                "threshold": self.drift_threshold
            })
            return
        
        # 4. Sprawdzenie prawdy
        if last_record.get("truth_value", 0.0) < self.truth_min:
            logger.warning("⚠️ GUARDIAN_KERNEL: truth_value below minimum")
            CZARNY_SMOK.stabilize(self.system)
            self.guard_log.append({
                "timestamp": time.time(),
                "event": "TRUTH_LOW",
                "truth_value": last_record.get("truth_value"),
                "minimum": self.truth_min
            })
            return
        
        # 5. Sprawdzenie pamięci
        if not self.check_memory_integrity():
            CZARNY_SMOK.stabilize(self.system)
            return
        
        # 6. Wymuszenie aksjomatu
        self.enforce_axiom()
        
        # 7. Raport OK
        if drift <= self.drift_threshold and last_record.get("truth_value", 0.0) >= self.truth_min:
            logger.info(f"✅ GUARDIAN_KERNEL: stan OK (drift={drift:.3f}, truth={last_record['truth_value']:.3f})")
    
    def status(self) -> Dict:
        return {
            "guardian_active": self.guardian_active,
            "last_guard_tick": self.last_guard_tick,
            "drift_threshold": self.drift_threshold,
            "truth_min": self.truth_min,
            "guard_log_len": len(self.guard_log),
            "reference_state": getattr(self.system, "reference_state", None)
        }


