class TRUTH_HASH_CERT:
    """
    Certyfikacja prawdy — hashowanie i weryfikacja.
    """
    def __init__(self):
        self.records: List[Dict] = []
    
    def certify(self, data: Any, truth_value: float) -> str:
        """Certyfikuje dane hashem prawdy"""
        record = {
            "data": data,
            "truth_value": truth_value,
            "timestamp": time.time(),
            "hash": self._compute_hash(data, truth_value)
        }
        self.records.append(record)
        if len(self.records) > 200:
            self.records = self.records[-100:]
        return record["hash"]
    
    def verify(self, record: Dict) -> bool:
        """Weryfikuje poprawność rekordu"""
        expected = self._compute_hash(record["data"], record["truth_value"])
        return expected == record["hash"]
    
    def get_record(self, hash_val: str) -> Optional[Dict]:
        """Znajduje rekord po hashu"""
        for r in self.records:
            if r["hash"] == hash_val:
                return r
        return None
    
    def _compute_hash(self, data: Any, truth: float) -> str:
        raw = f"{data}{truth}{time.time()}"
        return hashlib.sha256(raw.encode()).hexdigest()[:16]
    
    def status(self) -> Dict:
        return {
            "records": len(self.records),
            "last_hash": self.records[-1]["hash"] if self.records else None
        }


