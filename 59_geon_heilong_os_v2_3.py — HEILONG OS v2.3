class EMOTION_ENGINE:
    """
    Silnik emocjonalny — syntetyczne emocje systemu.
    """
    def __init__(self):
        self.last_state: Dict[str, float] = {}
        self.history: List[Dict] = []
    
    def evaluate(self, truth_value: float, risk: float,
                 entropy: float, peace_of_mind: float) -> Dict[str, float]:
        """Ocenia stan emocjonalny systemu"""
        clarity = min(1.0, max(0.0, truth_value / (abs(truth_value) + 1.0)))
        tension = min(1.0, risk * 0.7 + entropy * 0.3)
        calm = min(1.0, peace_of_mind * (1.0 - tension))
        overload = max(0.0, (entropy + risk) / 2.0 - peace_of_mind)
        
        state = {
            "clarity": clarity,
            "tension": tension,
            "calm": calm,
            "overload": overload,
            "vibe": 1.0 - overload
        }
        
        self.last_state = state
        self.history.append({"timestamp": time.time(), "state": state})
        if len(self.history) > 100:
            self.history = self.history[-50:]
        
        return state
    
    def get_last(self) -> Dict:
        return self.last_state
    
    def status(self) -> Dict:
        return {
            "last_state": self.last_state,
            "history_len": len(self.history)
        }


