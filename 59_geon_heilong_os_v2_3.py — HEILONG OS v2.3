class BLACK_GOLD_UI:
    """Czarno-Złoty Interfejs Użytkownika — system alertów"""
    
    _instance = None
    
    def __new__(cls):
        if cls._instance is None:
            cls._instance = super().__new__(cls)
            cls._instance.alert_history: List[Dict] = []
            cls._instance.ok_history: List[str] = []
        return cls._instance
    
    @staticmethod
    def raise_alert(risk: float, payload: Optional[Dict] = None) -> None:
        """Podnosi alert"""
        msg = f"🖤💛 BLACK_GOLD_UI ALERT: Ryzyko = {risk:.3f}"
        if payload:
            msg += f" | {payload}"
        logger.warning(msg)
        BLACK_GOLD_UI._instance.alert_history.append({
            "timestamp": time.time(),
            "risk": risk,
            "payload": payload
        })
    
    @staticmethod
    def log_ok(status: str) -> None:
        """Loguje status OK"""
        msg = f"💚 BLACK_GOLD_UI: {status}"
        logger.info(msg)
        BLACK_GOLD_UI._instance.ok_history.append({
            "timestamp": time.time(),
            "status": status
        })
    
    @staticmethod
    def get_stats() -> Dict:
        """Zwraca statystyki UI"""
        inst = BLACK_GOLD_UI._instance
        return {
            "alerts": len(inst.alert_history),
            "ok_messages": len(inst.ok_history),
            "last_alert": inst.alert_history[-1] if inst.alert_history else None
        }


