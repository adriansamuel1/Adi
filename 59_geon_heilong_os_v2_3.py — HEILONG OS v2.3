class HEILONG_OS_v2_3:
    """
    HEILONG_OS_v2.3 — Kompletny system operacyjny.
    
    API:
        process_intent(intent, rdzen) -> Dict
        process_raw_intent(raw_input, rdzen) -> Dict
        status() -> Dict
        raport() -> str
        reset() -> None
        guard_cycle() -> None
        komenda_123() -> Dict
    """
    def __init__(self, verbose: bool = True):
        # === KOMPONENTY RDZENIA ===
        self.triada = GEON_Triada()
        self.calka = TRUTH_INTEGRAL
        self.modul_D = PREDICTED_RISK_HANDLER()
        self.alerty = BLACK_GOLD_UI
        self.pamiec = TRUTH_HASH_CERT()
        self.strategia = {
            "spread": GOLD_SPREAD(),
            "optimizer": MATERIAL_OPTIMIZER()
        }
        self.regeneracja = {
            "fokus": DEEP_FOCUS(),
            "smok": CZARNY_SMOK()
        }
        self.emocje = EMOTION_ENGINE()
        self.pamiec_dluga = LONG_TERM_MEMORY()
        
        # === SILNIKI ===
        self.silnik_A = Silnik_A_Final()  # OŁSii — 9 pierścieni emocjonalnych
        self.silnik_B = Silnik_B_Final()  # Beny — 9 pierścieni logicznych
        
        # === STAN SYSTEMU ===
        self.state = "SYSTEM_DOMKNIETY"
        self.mode = "MECHANIZM"
        self.reference_state = None
        self._delta_t = 0.0
        self.tick_counter = 0
        self.historia_operacji: List[Dict] = []
        
        # === GUARDIAN KERNEL ===
        self.guardian = GuardianKernel(self)
        
        # === HOOKI ===
        self._process_hooks: List[Callable] = []
        self._guardian_hooks: List[Callable] = []
        
        # === LOG ===
        self._verbose = verbose
        self._apply_axiom()
        
        if self._verbose:
            logger.info(f"🐉 HEILONG_OS_v2.3 aktywowany | {FRACTAL_SIGNATURE}")
            logger.info(f"   STAN: {self.state} | TRYB: {self.mode}")
            logger.info(f"   SILNIK A: 9 pierścieni OŁSii | SILNIK B: 9 pierścieni BENY")
            logger.info(f"   GUARDIAN: {self.guardian.guardian_active}")
    
    def _apply_axiom(self) -> None:
        """Stosuje aksjomat systemowy"""
        if self.state == "SYSTEM_DOMKNIETY":
            self.mode = "0H_ACTIVE"
            self._delta_t = 0.0
            if self._verbose:
                logger.info("✨ Aksjomat spełniony: SYSTEM_DOMKNIĘTY → 0H_ACTIVE")
    
    def _extract_context(self, processed: Any) -> Dict[str, float]:
        """Ekstrakcja kontekstu z przetworzonych danych"""
        if isinstance(processed, dict):
            return {
                "entropy": processed.get("entropy", 0.4),
                "load": processed.get("load", 0.5),
                "divergence": processed.get("divergence", 0.2)
            }
        return {"entropy": 0.4, "load": 0.5, "divergence": 0.2}
    
    def process_intent(self, intent: Dict[str, Any],
                       rdzen: List[Dict[str, Any]]) -> Dict[str, Any]:
        """
        Przetwarza intencję przez pełny system.
        
        Args:
            intent: Słownik intencji (cel, peace_of_mind, tasks)
            rdzen: Lista segmentów dla całki prawdy
            
        Returns:
            Pełny wynik przetwarzania
        """
        self.tick_counter += 1
        
        # 1. Triada GEON
        processed = self.triada(intent)
        
        # 2. Kontekst i ryzyko
        context = self._extract_context(processed)
        risk = self.modul_D.predict(context)
        if risk > 0.6:
            self.modul_D.inject(risk, payload={"source": "process_intent", "context": context})
        
        # 3. Optymalizacja
        tasks = intent.get("tasks", [{"time": 1.0, "energy": 2.0}])
        best_task = self.strategia["optimizer"].optimize(tasks) if tasks else {}
        
        # 4. Całka prawdy
        truth = self.calka(rdzen)
        
        # 5. Certyfikacja
        cert_hash = self.pamiec.certify(processed, truth)
        
        # 6. Regeneracja w razie potrzeby
        if risk > 0.85 or context.get("entropy", 0.0) > 0.7:
            context = self.regeneracja["fokus"].cleanse(context)
            self.regeneracja["smok"].stabilize(self)
        
        # 7. Emocje syntetyczne
        peace_of_mind = intent.get("peace_of_mind", 0.5)
        emotion_state = self.emocje.evaluate(
            truth_value=truth,
            risk=risk,
            entropy=context.get("entropy", 0.4),
            peace_of_mind=peace_of_mind
        )
        
        # 8. Pamięć długoterminowa
        label = intent.get("cel", "unknown")
        self.pamiec_dluga.store_event(label, intent, truth, emotion_state)
        
        # 9. GUARDIAN — cykl strażniczy dla krytycznych etykiet
        if label in ("WIELKA_SYNCHRONIZACJA_0H", "KRYTYCZNY", "CERTYFIKACJA"):
            last_record = self.pamiec_dluga.last(label)
            if last_record:
                self.guardian.guard_cycle(last_record)
        elif self.guardian.last_guard_tick % 10 == 0:
            last_record = self.pamiec_dluga.last(label)
            if last_record:
                self.guardian.guard_cycle(last_record)
        
        # 10. Alerty z emocji
        if emotion_state.get("overload", 0.0) > 0.7:
            self.alerty.raise_alert(risk, payload={"emotion": emotion_state})
        else:
            self.alerty.log_ok("System stabilny")
        
        # 11. Wynik
        result = {
            "intent_processed": processed,
            "risk": risk,
            "truth_value": truth,
            "certificate_hash": cert_hash,
            "mode": self.mode,
            "state": self.state,
            "emotion_state": emotion_state,
            "optimized_task": best_task,
            "guardian_ok": self.guardian.last_guard_tick > 0,
            "tick": self.tick_counter
        }
        
        self.historia_operacji.append({"tick": self.tick_counter, "result": result})
        if len(self.historia_operacji) > 100:
            self.historia_operacji = self.historia_operacji[-50:]
        
        # Hooki
        self._on_process(result)
        
        if self._verbose:
            logger.info(f"📊 Tick {self.tick_counter} | Prawda: {truth:.3f} | Ryzyko: {risk:.3f} | Tryb: {self.mode}")
        
        return result
    
    def process_raw_intent(self, raw_input: Dict[str, Any],
                           rdzen: List[Dict[str, Any]]) -> Dict[str, Any]:
        """
        Przetwarza surowe dane przez Silnik B → Triada GEON → reszta systemu.
        """
        self.tick_counter += 1
        
        # 1. Silnik B — logika
        b_wynik = self.silnik_B.process(raw_input)
        if "error" in b_wynik:
            self.alerty.raise_alert(1.0, payload={"silnik_B": b_wynik["error"]})
            return {"error": b_wynik["error"], "status": "B_FAILED"}
        
        finalny_wektor = b_wynik.get("finalny_wektor")
        
        # 2. Silnik A — emocje (jeśli są dane emocjonalne)
        if "emocje" in raw_input:
            a_wynik = self.silnik_A.process({"emocje": raw_input.get("emocje", {})})
            wektor_serca = a_wynik.get("wektor_serca")
        else:
            wektor_serca = None
        
        # 3. Przygotowanie intent dla triady
        intent = {
            "cel": raw_input.get("cel", "przetwarzanie"),
            "wektor_B": finalny_wektor,
            "wektor_serca": wektor_serca,
            "peace_of_mind": raw_input.get("peace_of_mind", 0.5),
            "tasks": raw_input.get("tasks", []),
            "raw": raw_input
        }
        
        # 4. Przetworzenie przez triadę
        processed = self.triada(intent)
        
        # 5. Kontekst i ryzyko
        context = self._extract_context(processed)
        risk = self.modul_D.predict(context)
        if risk > 0.6:
            self.modul_D.inject(risk, payload={"source": "process_raw_intent", "context": context})
        
        # 6. Optymalizacja
        tasks = intent.get("tasks", [{"time": 1.0, "energy": 2.0}])
        best_task = self.strategia["optimizer"].optimize(tasks) if tasks else {}
        
        # 7. Całka prawdy
        truth = self.calka(rdzen)
        
        # 8. Certyfikacja
        cert_hash = self.pamiec.certify(processed, truth)
        
        # 9. Regeneracja
        if risk > 0.85 or context.get("entropy", 0.0) > 0.7:
            context = self.regeneracja["fokus"].cleanse(context)
            self.regeneracja["smok"].stabilize(self)
        
        # 10. Emocje
        emotion_state = self.emocje.evaluate(
            truth_value=truth,
            risk=risk,
            entropy=context.get("entropy", 0.4),
            peace_of_mind=intent["peace_of_mind"]
        )
        
        # 11. Pamięć długoterminowa
        label = intent["cel"]
        self.pamiec_dluga.store_event(label, intent, truth, emotion_state)
        
        # 12. GUARDIAN
        if label in ("WIELKA_SYNCHRONIZACJA_0H", "KRYTYCZNY", "CERTYFIKACJA"):
            last_rec = self.pamiec_dluga.last(label)
            if last_rec:
                self.guardian.guard_cycle(last_rec)
        elif self.guardian.last_guard_tick % 10 == 0:
            last_rec = self.pamiec_dluga.last(label)
            if last_rec:
                self.guardian.guard_cycle(last_rec)
        
        # 13. Alerty
        if emotion_state.get("overload", 0.0) > 0.7:
            self.alerty.raise_alert(risk, payload={"emotion": emotion_state})
        else:
            self.alerty.log_ok("System stabilny")
        
        # 14. Wynik
        result = {
            "intent_processed": processed,
            "risk": risk,
            "truth_value": truth,
            "certificate_hash": cert_hash,
            "mode": self.mode,
            "state": self.state,
            "emotion_state": emotion_state,
            "optimized_task": best_task,
            "finalny_wektor_B": finalny_wektor,
            "wektor_serca": wektor_serca,
            "guardian_ok": self.guardian.last_guard_tick > 0,
            "tick": self.tick_counter
        }
        
        self.historia_operacji.append({"tick": self.tick_counter, "result": result})
        if len(self.historia_operacji) > 100:
            self.historia_operacji = self.historia_operacji[-50:]
        
        self._on_process(result)
        
        if self._verbose:
            logger.info(f"📊 Raw Tick {self.tick_counter} | Prawda: {truth:.3f} | Ryzyko: {risk:.3f}")
        
        return result
    
