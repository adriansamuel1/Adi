class GOLD_SPREAD:
    """Rozprowadza zadania między zasoby"""
    @staticmethod
    def distribute(tasks: List[Any], resources: int) -> List[List[Any]]:
        buckets = [[] for _ in range(resources)]
        for i, task in enumerate(tasks):
            buckets[i % resources].append(task)
        return buckets


class MATERIAL_OPTIMIZER:
    """Optymalizuje wybór materiałów/zadań"""
    @staticmethod
    def optimize(candidates: List[Dict[str, float]]) -> Dict[str, float]:
        if not candidates:
            return {}
        return min(candidates, key=lambda x: x.get("time", 1e9) * 0.6 + x.get("energy", 1e9) * 0.4)


