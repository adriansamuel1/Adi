║ SILNIK B (BENY): {s['silnik_B_wektor']}                                 ║
║                                                                           ║
║ BLACK_GOLD_UI: alerts={s['black_gold_ui']['alerts']}                     ║
║ HISTORIA OPERACJI: {s['historia_operacji']}                             ║
║                                                                           ║
║ {HASLO}                                                                  ║
║                                                                           ║
╚════════════════════════════════════════════════════════════════════════════╝
"""
    
    def register_process_hook(self, hook: Callable) -> None:
        """Rejestruje hook wołany po każdym procesie"""
        self._process_hooks.append(hook)
    
    def register_guardian_hook(self, hook: Callable) -> None:
        """Rejestruje hook wołany po cyklu strażniczym"""
        self._guardian_hooks.append(hook)
    
    def _on_process(self, data: Dict) -> None:
        for hook in self._process_hooks:
            try:
                hook(data)
            except Exception as e:
                if self._verbose:
                    logger.warning(f"[HOOK ERROR] process: {e}")
    
    def _on_guardian(self, data: Dict) -> None:
        for hook in self._guardian_hooks:
            try:
                hook(data)
            except Exception as e:
                if self._verbose:
                    logger.warning(f"[HOOK ERROR] guardian: {e}")
    
    def __str__(self) -> str:
        return self.raport()


# =============================================================================
# MOST INTEGRACYJNY — POŁĄCZENIE Z ARCHITEKTURĄ
# =============================================================================

class HeilongOSBridge:
    """
    Most integracyjny między HEILONG_OS_v2.3 a resztą architektury.
    Łączy: GEX, G_CORE, MetaGovernor, NARRATIVE, TRIO_ADAPTER
    """
    
    def __init__(self, system: HEILONG_OS_v2_3):
        self.system = system
    
    # ========================================================================
    # MOST DO GEX HEILONG (Archetype Ring)
    # ========================================================================
    
    def get_archetype_context(self) -> Dict[str, Any]:
        """Zwraca kontekst archetypów dla GEX"""
        status = self.system.status()
        return {
            "tryb": "HEILONG_OS_v2.3",
            "mode": status.get("mode"),
            "state": status.get("state"),
            "truth": status.get("pamiec", {}).get("records", 0) / 100,
            "guardian_active": status.get("guardian", {}).get("guardian_active"),
            "silnik_A": status.get("silnik_A_wektor"),
            "silnik_B": status.get("silnik_B_wektor")
        }
    
    # ========================================================================
    # MOST DO G_CORE (Autopilot)
    # ========================================================================
    
    def get_autopilot_state(self) -> Dict[str, Any]:
        """Zwraca stan dla autopilota G_CORE"""
        status = self.system.status()
        emotion = status.get("emocje", {}).get("last_state", {})
        return {
            "mode": "HEILONG_OS_v2.3",
            "stability": 1.0 - emotion.get("tension", 0.5),
            "energy": 1.0 - emotion.get("overload", 0.5),
            "pressure": emotion.get("tension", 0.5),
            "resilience": 1.0 - emotion.get("tension", 0.5) * 0.7,
            "flow_quality": emotion.get("vibe", 0.5),
            "guardian_ok": status.get("guardian", {}).get("last_guard_tick", 0) > 0
        }
    
    # ========================================================================
    # MOST DO META-GOVERNOR (Kontekst decyzyjny)
    # ========================================================================
    
    def get_governor_context(self) -> Dict[str, Any]:
        """Zwraca kontekst dla MetaGovernor"""
        status = self.system.status()
        emotion = status.get("emocje", {}).get("last_state", {})
        return {
            "intent": status.get("mode", "MECHANIZM"),
            "confidence": 1.0 - emotion.get("tension", 0.5),
            "entropy": emotion.get("overload", 0.5),
            "truth_alignment": status.get("pamiec", {}).get("records", 0) / 200,
            "guardian_active": status.get("guardian", {}).get("guardian_active")
        }
    
    # ========================================================================
    # MOST DO NARRATIVE (Źródło opowieści)
    # ========================================================================
    
    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        """Zwraca fragmenty narracyjne z systemu"""
        fragments = []
        
        # Fragment z pamięci długoterminowej
        events = self.system.pamiec_dluga.events[-n:]
        for e in events:
            fragments.append({
                "source": "HEILONG_MEMORY",
                "content": f"{e.get('label', '?')} | truth={e.get('truth_value', 0):.2f}",
                "energy": e.get('truth_value', 0.5)
            })
        
        # Fragment ze stanu
        status = self.system.status()
        fragments.append({
            "source": "HEILONG_STATE",
            "content": f"Mode: {status.get('mode')} | State: {status.get('state')}",
            "energy": 1.0 - status.get('emocje', {}).get('last_state', {}).get('tension', 0.5)
        })
        
        return fragments[:n]
    
    # ========================================================================
    # MOST DO TRIO_ADAPTER
    # ========================================================================
    
    def get_trio_state(self) -> Dict[str, str]:
        """Zwraca stan dla TRIO_ADAPTER (ISKRA + PIECZĘĆ + PERFEKCJA)"""
        status = self.system.status()
        mode = status.get("mode", "MECHANIZM")
        
        iskra = "AKTYWNA" if status.get("tick", 0) > 0 else "NIEAKTYWNA"
        pieczec = "AKTYWNA" if mode in ("0H_ACTIVE", "SYSTEM_DOMKNIETY") else "NIEAKTYWNA"
        perfekcja = "AKTYWNA" if mode == "0H_ACTIVE" else "NIEAKTYWNA"
        
        return {
            "ISKRA": iskra,
            "PIECZĘĆ": pieczec,
            "PERFEKCJA": perfekcja,
            "tryb": "HEILONG_OS_v2.3",
            "mode": mode,
            "guardian": "AKTYWNY" if status.get("guardian", {}).get("guardian_active") else "NIEAKTYWNY"
        }


# =============================================================================
# FUNKCJA JEDNOLINIOWA — uruchom system
# =============================================================================

def uruchom_heilong_os(verbose: bool = True) -> HEILONG_OS_v2_3:
    """
    Uruchamia HEILONG_OS_v2.3 i zwraca gotowy system.
    """
    system = HEILONG_OS_v2_3(verbose=verbose)
    if verbose:
        logger.info("🐉 HEILONG_OS_v2.3 uruchomiony")
        logger.info(f"   Tryb: {system.mode} | Stan: {system.state}")
    return system


