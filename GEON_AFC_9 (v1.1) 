@dataclass
class AFCVector:
    """Wektor w przestrzeni AFC-9 z bezpieczną numeryką."""
    values: List[float]
    name: str = "unknown"
    energy: float = 0.0
    entropy: float = 0.0
    
    def __post_init__(self):
        self.energy = sum(self.values) if self.values else 0.0
        self.entropy = self._compute_entropy()
    
    def _compute_entropy(self) -> float:
        """Oblicza entropię Shannona odporną na ujemne i zerowe wartości."""
        if not self.values:
            return 0.0
        
        # Przesunięcie skali (Shift-to-positive) w celu uniknięcia błędu dziedziny logarytmu
        min_val = min(self.values)
        shifted = [v - min_val + 1e-9 for v in self.values]
        total = sum(shifted)
        
        if total == 0:
            return 0.0
        
        probs = [v / total for v in shifted]
        return -sum(p * math.log2(p) for p in probs if p > 0)
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "name": self.name,
            "values": [round(v, 4) for v in self.values],
            "energy": round(self.energy, 4),
            "entropy": round(self.entropy, 4)
        }
    
    def __len__(self) -> int:
        return len(self.values)


@dataclass
class AFCState:
    """Stan przetwarzania AFC-9."""
    D1: Optional[AFCVector] = None  # Fundament
    D2: Optional[AFCVector] = None  # Dynamika
    D3: Optional[AFCVector] = None  # Harmonia
    D4: Optional[AFCVector] = None  # Korekcja
    D5: Optional[AFCVector] = None  # Integracja
    D6: Optional[AFCVector] = None  # Stabilizacja
    D7: Optional[AFCVector] = None  # Adaptacja
    D8: Optional[AFCVector] = None  # Fraktalna Harmonia
    D9: Optional[AFCVector] = None  # Pełna Równowaga (ATRAKTOR)
    
    history: List[Dict[str, Any]] = field(default_factory=list)
    tick: int = 0
    spiral_energy: float = 0.0
    coherence_index: float = 1.0
    spiral_level: int = 0
    
    def get_all_vectors(self) -> Dict[str, Optional[AFCVector]]:
        return {
            "D1": self.D1, "D2": self.D2, "D3": self.D3,
            "D4": self.D4, "D5": self.D5, "D6": self.D6,
            "D7": self.D7, "D8": self.D8, "D9": self.D9
        }
    
    def get_energy_sequence(self) -> List[float]:
        energies = []
        for name in ["D1", "D2", "D3", "D4", "D5", "D6", "D7", "D8", "D9"]:
            vec = getattr(self, name)
            energies.append(round(vec.energy, 4) if vec else 0.0)
        return energies
    
    def get_entropy_sequence(self) -> List[float]:
        entropies = []
        for name in ["D1", "D2", "D3", "D4", "D5", "D6", "D7", "D8", "D9"]:
            vec = getattr(self, name)
            entropies.append(round(vec.entropy, 4) if vec else 0.0)
        return entropies
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "tick": self.tick,
            "spiral_level": self.spiral_level,
            "spiral_energy": round(self.spiral_energy, 4),
            "coherence_index": round(self.coherence_index, 4),
            "vectors": {name: vec.to_dict() if vec else None for name, vec in self.get_all_vectors().items()},
            "energy_sequence": self.get_energy_sequence(),
            "entropy_sequence": self.get_entropy_sequence()
        }


