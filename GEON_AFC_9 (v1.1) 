class AFC9:
    """
    AFC-9 — Dziewięciowymiarowy Atraktor Fraktalny (v1.1).
    Przetwarza dane przez 9 warstw, redukując entropię i stabilizując sygnał.
    """
    
    VECTOR_LENGTH = 9
    
    def __init__(self):
        self.state = AFCState()
        self.stats = {
            "cycles": 0,
            "spiral_jumps": 0,
            "energy_reduction": 0.0,
            "entropy_reduction": 0.0
        }
        
        LOG("AFC_9", "🐉 AFC-9 v1.1 — Atraktor Fraktalny aktywowany")
        LOG("AFC_9", f"   Sygnatura: {FRACTAL_SIGNATURE}")
        LOG("AFC_9", f"   Długość wektora: {self.VECTOR_LENGTH}")
    
    def process(self, D1: List[float], D2: List[float], D3: List[float], D4: List[float]) -> AFCState:
        """Przetwarza dane przez 9 warstw AFC-9."""
        self.stats["cycles"] += 1
        self.state.tick += 1
        
        if not all(len(v) == self.VECTOR_LENGTH for v in [D1, D2, D3, D4]):
            LOG("AFC_9", "⚠️ Błąd: Wszystkie wektory wejściowe muszą mieć długość 9", "ERROR")
            return self.state
        
        # Warstwy Podstawowe
        self.state.D1 = AFCVector(D1, "D1_Fundament")
        self.state.D2 = AFCVector(D2, "D2_Dynamika")
        self.state.D3 = AFCVector(D3, "D3_Harmonia")
        self.state.D4 = AFCVector(D4, "D4_Korekcja")
        
        # Warstwy Pochodne (Fraktalne)
        D5 = self._average_vectors([D1, D2, D3, D4])
        self.state.D5 = AFCVector(D5, "D5_Integracja")
        
        D6 = self._average_vectors([D1, D3, D5])
        self.state.D6 = AFCVector(D6, "D6_Stabilizacja")
        
        D7 = self._average_vectors([D2, D4, D6])
        self.state.D7 = AFCVector(D7, "D7_Adaptacja")
        
        D8 = self._average_vectors([D1, D3, D5, D7])
        self.state.D8 = AFCVector(D8, "D8_FraktalnaHarmonia")
        
        # 9D — ATRAKTOR
        D9 = self._average_vectors([D1, D8])
        self.state.D9 = AFCVector(D9, "D9_Atraktor")
        
        # Metryki redukcji
        if self.state.D1 and self.state.D9:
            self.stats["energy_reduction"] = self.state.D1.energy - self.state.D9.energy
            self.stats["entropy_reduction"] = self.state.D1.entropy - self.state.D9.entropy
        
        self._update_coherence()
        self._check_spiral_signature()
        
        # Przechowywanie w historii
        self.state.history.append(self.state.to_dict())
        if len(self.state.history) > 100:
            self.state.history = self.state.history[-100:]
        
        LOG("AFC_9", f"🔄 Cykl #{self.stats['cycles']} | Energia: {self.state.D1.energy:.2f} → {self.state.D9.energy:.2f}")
        return self.state
    
    def _average_vectors(self, vectors: List[List[float]]) -> List[float]:
        if not vectors:
            return [0.0] * self.VECTOR_LENGTH
        
        result = []
        for i in range(self.VECTOR_LENGTH):
            values = [v[i] for v in vectors if i < len(v)]
            result.append(sum(values) / len(values) if values else 0.0)
        return result
    
    def _update_coherence(self) -> None:
        """Wylicza indeks koherencji (korelacja Pearsona z zabezpieczeniem płaskim)."""
        if not self.state.D1 or not self.state.D9:
            return
        
        d1 = self.state.D1.values
        d9 = self.state.D9.values
        
        mean1 = sum(d1) / len(d1)
        mean9 = sum(d9) / len(d9)
        
        num = sum((d1[i] - mean1) * (d9[i] - mean9) for i in range(len(d1)))
        den1 = math.sqrt(sum((v - mean1) ** 2 for v in d1))
        den9 = math.sqrt(sum((v - mean9) ** 2 for v in d9))
        
        if den1 > 0 and den9 > 0:
            coherence = num / (den1 * den9)
            self.state.coherence_index = max(0.0, min(1.0, coherence))
        else:
            # W przypadku sygnału płaskiego (brak wariancji) koherencja wynosi 1.0
            self.state.coherence_index = 1.0
    
    def _check_spiral_signature(self) -> None:
        if self._pattern_matches_in_history(SIG_736577):
            self._perform_spiral_jump()
            return
        
        if self.state.spiral_energy >= 5.0:
            self._perform_spiral_jump()
            self.state.spiral_energy = 0.0
    
    def _perform_spiral_jump(self) -> None:
        self.state.spiral_level += 1
        self.stats["spiral_jumps"] += 1
        LOG("AFC_9", f"🌀 SKOK SPIRALNY! Osiągnięto Poziom: {self.state.spiral_level}")
    
    def _pattern_matches_in_history(self, pattern: List[int]) -> bool:
        """Ścisła weryfikacja dopasowania wzorca całkowitego w ostatnich wpisach."""
        if len(self.state.history) < len(pattern):
            return False
            
        recent_ticks = [entry.get("tick", 0) % 10 for entry in self.state.history[-len(pattern):]]
        return recent_ticks == pattern

    def get_atraktor(self) -> Optional[AFCVector]:
        return self.state.D9
    
    def get_status(self) -> Dict[str, Any]:
        return {
            "version": VERSION,
            "signature": FRACTAL_SIGNATURE,
            "stats": self.stats,
            "state": self.state.to_dict(),
            "atraktor": self.get_atraktor().to_dict() if self.get_atraktor() else None,
            "vibe": VIBE,
            "haslo": HASLO
        }
    
    def get_full_report(self) -> str:
        if not self.state.D9:
            return "⚠️ Brak danych w strefie atraktora."
        
        return f"""
╔════════════════════════════════════════════════════════════════════════════╗
║ 🐉 AFC-9 v1.1 — RAPORT ATRAKTORA FRAKTALNEGO 🐉 ║
