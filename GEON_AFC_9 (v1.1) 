class AFC9_AutostradaBridge:
    """Most łączący AFC-9 z Autostradą33."""
    
    def __init__(self, autostrada: Optional[Any] = None):
        self.afc9 = AFC9()
        self.autostrada = autostrada
        self.history: List[Dict[str, Any]] = []
        self.stats = {"cycles": 0, "signals_processed": 0}
        
        LOG("AFC9_BRIDGE", "🌉 AFC-9 ↔ Autostrada33 Bridge gotowy")
    
    def set_autostrada(self, autostrada: Any) -> None:
        self.autostrada = autostrada
        LOG("AFC9_BRIDGE", "🔗 Połączono z magistralą Autostrada33")
    
    def process_signal(self, signal: Union[List[float], Dict[str, List[float]]]) -> Dict[str, Any]:
        self.stats["cycles"] += 1
        self.stats["signals_processed"] += 1
        
        if isinstance(signal, dict):
            D1 = signal.get("D1", [0.0] * 9)
            D2 = signal.get("D2", [0.0] * 9)
            D3 = signal.get("D3", [0.0] * 9)
            D4 = signal.get("D4", [0.0] * 9)
        else:
            D1 = signal[:9] if len(signal) >= 9 else [0.0] * 9
            D2, D3, D4 = D1.copy(), D1.copy(), D1.copy()
        
        state = self.afc9.process(D1, D2, D3, D4)
        atraktor = self.afc9.get_atraktor()
        
        if self.autostrada and hasattr(self.autostrada, "submit_intent_request"):
            try:
                payload = {
                    "type": "AFC9_STABILIZED",
                    "atraktor": atraktor.values if atraktor else [],
                    "energy": atraktor.energy if atraktor else 0,
                    "coherence": state.coherence_index,
                    "spiral_level": state.spiral_level
                }
                self.autostrada.submit_intent_request(payload)
            except Exception as e:
                LOG("AFC9_BRIDGE", f"⚠️ Błąd transmisji: {e}", "ERROR")
        
        result = {
            "tick": self.stats["cycles"],
            "coherence": state.coherence_index,
            "spiral_level": state.spiral_level,
            "atraktor": atraktor.values if atraktor else [],
            "energy_reduction": self.afc9.stats["energy_reduction"]
        }
        
        self.history.append(result)
        if len(self.history) > 100:
            self.history = self.history[-100:]
            
        return result


