class RingsCore:
    """
    12 PIERŚCIENI — podstawowa architektura operacyjna systemu.
    
    API:
        aktywuj_pierścień(id, archetyp_nazwa) -> Dict
        wybierz_archetyp(pierścień_id, presja) -> str
        krok(presja, preferencje) -> Dict
        status() -> Dict
        raport() -> str
        reset() -> None
    """
    
    def __init__(self, verbose: bool = True):
        # === INICJALIZACJA PIERŚCIENI ===
        self.pierścienie: Dict[int, Pierścień] = {}
        self._inicjalizuj_pierścienie()
        
        # === STAN ===
        self.tick = 0
        self.historia: deque = deque(maxlen=200)
        self._ostatni_wybór: Dict[int, str] = {}
        
        # === HOOKI ===
        self._aktywacja_hooki: List[Callable] = []
        self._zmiana_hooki: List[Callable] = []
        
        # === LOG ===
        self._verbose = verbose
        if self._verbose:
            print(f"🐉 RINGS_CORE aktywowany | {FRACTAL_SIGNATURE}")
            print(f"   PIERŚCIENIE: 12 | ARCHETYPY: 36")
    
    # ========================================================================
    # INICJALIZACJA
    # ========================================================================
    
    def _inicjalizuj_pierścienie(self) -> None:
        """Tworzy 12 pierścieni z definicji"""
        for pid, definicja in DEFINICJE_PIERŚCIENI.items():
            archetypy = [
                Archetyp(
                    nazwa=a["nazwa"],
                    rola=a["rola"],
                    energia=0.5 + random.random() * 0.1
                )
                for a in definicja["archetypy"]
            ]
            
            pierścień = Pierścień(
                id=pid,
                nazwa=definicja["nazwa"],
                wektor=definicja["wektor"],
                opis=definicja["opis"],
                archetypy=archetypy
            )
            
            # Domyślnie aktywuj pierwszy archetyp
            pierścień.aktywny_archetyp = archetypy[0]
            self.pierścienie[pid] = pierścień
            self._ostatni_wybór[pid] = archetypy[0].nazwa
    
    # ========================================================================
    # PUBLIC API
    # ========================================================================
    
    def aktywuj_pierścień(self, pierścień_id: int, archetyp_nazwa: str) -> Dict[str, Any]:
        """
        Aktywuje konkretny archetyp w pierścieniu.
        
        Args:
            pierścień_id: 1-12
            archetyp_nazwa: Nazwa archetypu do aktywacji
            
        Returns:
            Stan pierścienia po aktywacji
        """
        if pierścień_id not in self.pierścienie:
            return {"status": "ERROR", "message": f"Nieznany pierścień: {pierścień_id}"}
        
        pierścień = self.pierścienie[pierścień_id]
        
        # Znajdź archetyp
        archetyp = None
        for a in pierścień.archetypy:
            if a.nazwa == archetyp_nazwa:
                archetyp = a
                break
        
        if not archetyp:
            return {"status": "ERROR", "message": f"Nieznany archetyp: {archetyp_nazwa}"}
        
        # Aktywuj
        pierścień.aktywuj_archetyp(archetyp)
        self._ostatni_wybór[pierścień_id] = archetyp_nazwa
        
        # Hooki
        self._on_aktywacja(pierścień_id, archetyp_nazwa)
        
        return {
            "status": "OK",
            "pierścień": pierścień_id,
            "archetyp": archetyp_nazwa,
            "energia": round(pierścień.energia, 3),
            "timestamp": time.time()
        }
    
    def wybierz_archetyp(self, pierścień_id: int, presja: float = 0.5,
                         preferencje: Optional[List[str]] = None) -> str:
        """
        Wybiera archetyp na podstawie presji i preferencji.
        
        Args:
            pierścień_id: 1-12
            presja: 0.0-1.0
            preferencje: Lista preferowanych archetypów
            
        Returns:
            Nazwa wybranego archetypu
        """
        if pierścień_id not in self.pierścienie:
            return "ERROR"
        
        pierścień = self.pierścienie[pierścień_id]
        wybrany = pierścień.wybierz_archetyp(presja, preferencje)
        self._ostatni_wybór[pierścień_id] = wybrany.nazwa
        return wybrany.nazwa
    
    def krok(self, presja: float = 0.5, preferencje: Optional[List[str]] = None) -> Dict[str, Any]:
        """
        Wykonuje pełny krok systemu — wybiera archetypy dla wszystkich pierścieni.
        
        Args:
            presja: 0.0-1.0
            preferencje: Lista preferowanych archetypów
            
        Returns:
            Stan wszystkich pierścieni po kroku
        """
        self.tick += 1
        
        wyniki = {}
        for pid, pierścień in self.pierścienie.items():
            wybrany = pierścień.wybierz_archetyp(presja, preferencje)
            if wybrany != pierścień.aktywny_archetyp:
                pierścień.aktywuj_archetyp(wybrany)
                self._on_zmiana(pid, wybrany.nazwa)
            wyniki[pid] = {
                "archetyp": wybrany.nazwa,
                "energia": round(pierścień.energia, 3),
                "aktywowany": wybrany.aktywowany
            }
        
        # Zapis do historii
        self.historia.append({
            "tick": self.tick,
            "presja": presja,
            "wyniki": wyniki.copy()
        })
        
        return {
            "tick": self.tick,
            "presja": presja,
            "pierścienie": wyniki
        }
    
    def aktywuj_wszystkie(self, archetypy: Dict[int, str]) -> Dict[str, Any]:
        """
        Aktywuje określone archetypy we wszystkich pierścieniach.
        
        Args:
            archetypy: {pierścień_id: archetyp_nazwa}
            
        Returns:
            Status aktywacji
        """
        wyniki = {}
        for pid, nazwa in archetypy.items():
            if pid in self.pierścienie:
                wynik = self.aktywuj_pierścień(pid, nazwa)
                wyniki[pid] = wynik
        return {
            "status": "OK",
            "wyniki": wyniki,
            "timestamp": time.time()
        }
    
    def pobierz_aktywne(self) -> Dict[int, str]:
        """Zwraca aktualnie aktywne archetypy we wszystkich pierścieniach"""
        return {
            pid: p.aktywny_archetyp.nazwa if p.aktywny_archetyp else "BRAK"
            for pid, p in self.pierścienie.items()
        }
    
    def pobierz_energie(self) -> Dict[int, float]:
        """Zwraca energie wszystkich pierścieni"""
        return {
            pid: round(p.energia, 3)
            for pid, p in self.pierścienie.items()
        }
    
    def pobierz_statystyki(self) -> Dict[str, Any]:
        """Zwraca statystyki aktywacji archetypów"""
        staty = {}
        for p in self.pierścienie.values():
            for a in p.archetypy:
                if a.aktywowany > 0:
                    staty[a.nazwa] = staty.get(a.nazwa, 0) + a.aktywowany
        return dict(sorted(staty.items(), key=lambda x: x[1], reverse=True)[:10])
    
    # ========================================================================
    # STATUS I RAPORTY
    # ========================================================================
    
    def status(self) -> Dict[str, Any]:
        """Pełny status systemu pierścieni"""
        return {
            "system": "RINGS_CORE",
            "wersja": VERSION,
            "tick": self.tick,
            "pierścienie": len(self.pierścienie),
            "archetypy": sum(len(p.archetypy) for p in self.pierścienie.values()),
            "aktywne": self.pobierz_aktywne(),
            "energie": self.pobierz_energie(),
            "statystyki": self.pobierz_statystyki(),
            "historia": len(self.historia)
        }
    
    def raport(self) -> str:
        """Formatowany raport systemu"""
        s = self.status()
        aktywne = "\n".join([
            f"   [{pid}] {nazwa:12s} | energia={s['energie'][pid]:.2f}"
            for pid, nazwa in s['aktywne'].items()
        ])
        staty = "\n".join([
            f"   {nazwa:12s}: {count} aktywacji"
            for nazwa, count in list(s['statystyki'].items())[:5]
        ])
        
        return f"""
╔════════════════════════════════════════════════════════════════════════════╗
║ 🐉 12 PIERŚCIENI — RAPORT SYSTEMOWY                                     ║
╠════════════════════════════════════════════════════════════════════════════╣
║ TICK: {s['tick']}                                                        ║
║ PIERŚCIENIE: {s['pierścienie']} | ARCHETYPY: {s['archetypy']}            ║
╠════════════════════════════════════════════════════════════════════════════╣
║ AKTYWNE ARCHETYPY:                                                       ║
{aktywne}
╠════════════════════════════════════════════════════════════════════════════╣
║ STATYSTYKI AKTYWACJI:                                                    ║
{staty if staty else "   (brak danych)"}
║                                                                           ║
║ HISTORIA: {s['historia']} kroków                                         ║
╚════════════════════════════════════════════════════════════════════════════╝
{HASLO}
"""
    
    def reset(self) -> None:
        """Resetuje wszystkie pierścienie do stanu początkowego"""
        for p in self.pierścienie.values():
            p.energia = 1.0
            p.tryb = TrybPierścienia.AKTYWNY
            p.aktywny_archetyp = p.archetypy[0]
            p.ostatnia_zmiana = time.time()
            for a in p.archetypy:
                a.energia = 0.5
                a.aktywowany = 0
        self.tick = 0
        self.historia.clear()
        if self._verbose:
            print("[RINGS] Reset wykonany")
    
    # ========================================================================
    # HOOKI
    # ========================================================================
    
    def register_aktywacja_hook(self, hook: Callable) -> None:
        """Rejestruje hook wołany po aktywacji archetypu"""
        self._aktywacja_hooki.append(hook)
    
    def register_zmiana_hook(self, hook: Callable) -> None:
        """Rejestruje hook wołany po zmianie archetypu"""
        self._zmiana_hooki.append(hook)
    
    def _on_aktywacja(self, pierścień_id: int, archetyp_nazwa: str) -> None:
        for hook in self._aktywacja_hooki:
            try:
                hook(pierścień_id, archetyp_nazwa)
            except Exception as e:
                if self._verbose:
                    print(f"[HOOK ERROR] aktywacja: {e}")
    
    def _on_zmiana(self, pierścień_id: int, archetyp_nazwa: str) -> None:
        for hook in self._zmiana_hooki:
            try:
                hook(pierścień_id, archetyp_nazwa)
            except Exception as e:
                if self._verbose:
                    print(f"[HOOK ERROR] zmiana: {e}")
    
    # ========================================================================
    # METODY POMOCNICZE
    # ========================================================================
    
    def __str__(self) -> str:
        return self.raport()
    
    def to_dict(self) -> Dict[str, Any]:
        """Zwraca pełną reprezentację słownikową"""
        return {
            "pierścienie": {pid: p.to_dict() for pid, p in self.pierścienie.items()},
            "tick": self.tick,
            "historia": list(self.historia)[-10:]
        }

# =============================================================================
# MOST INTEGRACYJNY — POŁĄCZENIE Z ARCHITEKTURĄ
# =============================================================================

class RingsBridge:
    """
    Most integracyjny między RINGS_CORE a resztą architektury.
    Łączy: GEX, G_CORE, MetaGovernor, NARRATIVE, OPH_CORE
    """
    
    def __init__(self, rings: RingsCore):
        self.rings = rings
    
    # ========================================================================
    # MOST DO GEX HEILONG (Archetype Ring)
    # ========================================================================
    
    def get_archetype_context(self) -> Dict[str, Any]:
        """Zwraca kontekst archetypów dla GEX"""
        aktywne = self.rings.pobierz_aktywne()
        return {
            "tryb": "RINGS_CORE",
            "aktywne_archetypy": aktywne,
            "dominujące": list(aktywne.values())[:6],
            "energie": self.rings.pobierz_energie(),
            "statystyki": self.rings.pobierz_statystyki()
        }
    
    # ========================================================================
    # MOST DO G_CORE (Autopilot)
    # ========================================================================
    
    def get_autopilot_state(self) -> Dict[str, Any]:
        """Zwraca stan dla autopilota G_CORE"""
        energie = self.rings.pobierz_energie()
        avg_energia = sum(energie.values()) / len(energie) if energie else 0.5
        aktywne = self.rings.pobierz_aktywne()
        
        return {
            "mode": "RINGS_CORE",
            "stability": avg_energia,
            "energy": avg_energia,
            "pressure": 1.0 - avg_energia,
            "resilience": min(1.0, avg_energia * 1.2),
            "flow_quality": avg_energia,
            "aktywne_pierścienie": len([a for a in aktywne.values() if a != "BRAK"])
        }
    
    # ========================================================================
    # MOST DO META-GOVERNOR (Kontekst decyzyjny)
    # ========================================================================
    
    def get_governor_context(self) -> Dict[str, Any]:
        """Zwraca kontekst dla MetaGovernor"""
        energie = self.rings.pobierz_energie()
        aktywne = self.rings.pobierz_aktywne()
        staty = self.rings.pobierz_statystyki()
        
        return {
            "intent": "OPERATIONAL",
            "confidence": sum(energie.values()) / len(energie) if energie else 0.5,
            "entropy": 1.0 - (sum(energie.values()) / len(energie) if energie else 0.5),
            "aktywne_pierścienie": len(aktywne),
            "dominujący_archetyp": list(staty.keys())[0] if staty else "BRAK"
        }
    
    # ========================================================================
    # MOST DO NARRATIVE (Źródło opowieści)
    # ========================================================================
    
    def get_narrative_fragments(self, n: int = 5) -> List[Dict[str, Any]]:
        """Zwraca fragmenty narracyjne z pierścieni"""
        fragments = []
        aktywne = self.rings.pobierz_aktywne()
        energie = self.rings.pobierz_energie()
        
        for pid, nazwa in list(aktywne.items())[:n]:
            if nazwa != "BRAK":
                fragments.append({
                    "source": f"PIERŚCIEŃ_{pid}",
                    "content": f"{nazwa} | energia={energie.get(pid, 0):.2f}",
                    "energy": energie.get(pid, 0.5)
                })
        
        # Dodaj fragment statystyk
        staty = self.rings.pobierz_statystyki()
        if staty:
            top = list(staty.items())[0]
            fragments.append({
                "source": "RINGS_STATS",
                "content": f"Najczęściej aktywowany: {top[0]} ({top[1]} razy)",
                "energy": 0.8
            })
        
        return fragments
    
    # ========================================================================
    # MOST DO OPH_CORE (Optimus Praim Heilong)
    # ========================================================================
    
    def get_oph_context(self) -> Dict[str, Any]:
        """Zwraca kontekst dla OPH_CORE (12 pierścieni)"""
        aktywne = self.rings.pobierz_aktywne()
        energie = self.rings.pobierz_energie()
        
        return {
            "pierścienie": {
                pid: {
                    "archetyp": aktywne.get(pid, "BRAK"),
                    "energia": energie.get(pid, 0.5)
                }
                for pid in range(1, 13)
            },
            "tick": self.rings.tick,
            "statystyki": self.rings.pobierz_statystyki()
        }
    
    # ========================================================================
    # MOST DO TRIO_ADAPTER
    # ========================================================================
    
    def get_trio_state(self) -> Dict[str, str]:
        """Zwraca stan dla TRIO_ADAPTER (ISKRA + PIECZĘĆ + PERFEKCJA)"""
        energie = self.rings.pobierz_energie()
        avg = sum(energie.values()) / len(energie) if energie else 0.5
        
        iskra = "AKTYWNA" if self.rings.tick > 0 else "NIEAKTYWNA"
        pieczec = "AKTYWNA" if avg > 0.4 else "NIEAKTYWNA"
        perfekcja = "AKTYWNA" if avg > 0.7 else "NIEAKTYWNA"
        
        return {
            "ISKRA": iskra,
            "PIECZĘĆ": pieczec,
            "PERFEKCJA": perfekcja,
            "tryb": "RINGS_CORE",
            "średnia_energia": f"{avg:.2f}"
        }

