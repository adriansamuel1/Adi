@dataclass
class Archetyp:
    """Archetyp zwierzęcy — styl działania"""
    nazwa: str
    rola: str
    energia: float = 0.5
    aktywowany: int = 0
    ostatnia_aktywacja: float = field(default_factory=time.time)
    
    def aktywuj(self) -> None:
        """Aktualizuje stan archetypu po aktywacji"""
        self.aktywowany += 1
        self.energia = min(1.0, self.energia + 0.05)
        self.ostatnia_aktywacja = time.time()
    
    def decaY(self, czynnik: float = 0.995) -> None:
        """Naturalny zanik energii"""
        self.energia = max(0.1, self.energia * czynnik)
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "nazwa": self.nazwa,
            "rola": self.rola,
            "energia": round(self.energia, 3),
            "aktywowany": self.aktywowany
        }

@dataclass
class Pierścień:
    """Jeden z 12 pierścieni — warstwa operacyjna"""
    id: int
    nazwa: str
    wektor: str
    opis: str
    archetypy: List[Archetyp]
    aktywny_archetyp: Optional[Archetyp] = None
    energia: float = 1.0
    tryb: TrybPierścienia = TrybPierścienia.AKTYWNY
    ostatnia_zmiana: float = field(default_factory=time.time)
    
    def aktywuj_archetyp(self, archetyp: Archetyp) -> None:
        """Aktywuje wybrany archetyp w pierścieniu"""
        if self.aktywny_archetyp:
            self.aktywny_archetyp.decaY()
        self.aktywny_archetyp = archetyp
        archetyp.aktywuj()
        self.energia = max(0.0, self.energia - 0.05)
        self.ostatnia_zmiana = time.time()
    
    def wybierz_archetyp(self, presja: float, preferencje: Optional[List[str]] = None) -> Archetyp:
        """
        Wybiera archetyp na podstawie presji i preferencji.
        
        Args:
            presja: 0.0-1.0 — im wyższa, tym bardziej dominujący archetyp
            preferencje: Lista preferowanych nazw archetypów
        """
        # Sortuj archetypy według energii (malejąco)
        posortowane = sorted(self.archetypy, key=lambda a: a.energia, reverse=True)
        
        # Jeśli są preferencje, spróbuj wybrać z nich
        if preferencje:
            for a in posortowane:
                if a.nazwa in preferencje:
                    return a
        
        # Wysoka presja → pierwszy archetyp (dominujący)
        if presja > 0.7:
            return posortowane[0]
        # Średnia presja → losowy z top 2
        elif presja > 0.3:
            return random.choice(posortowane[:2])
        # Niska presja → ostatni archetyp (kontrujący)
        else:
            return posortowane[-1] if len(posortowane) > 1 else posortowane[0]
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "id": self.id,
            "nazwa": self.nazwa,
            "wektor": self.wektor,
            "opis": self.opis,
            "energia": round(self.energia, 3),
            "tryb": self.tryb.value,
            "aktywny_archetyp": self.aktywny_archetyp.nazwa if self.aktywny_archetyp else None,
            "archetypy": [a.to_dict() for a in self.archetypy]
        }

