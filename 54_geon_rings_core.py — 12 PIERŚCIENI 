def uruchom_pierścienie(presja: float = 0.5, kroki: int = 10) -> str:
    """
    Szybkie uruchomienie systemu pierścieni.
    
    Args:
        presja: 0.0-1.0
        kroki: Liczba kroków do wykonania
    
    Returns:
        Raport końcowy
    """
    rings = RingsCore(verbose=True)
    for i in range(kroki):
        wynik = rings.krok(presja + random.uniform(-0.1, 0.1))
        if i % 5 == 0:
            print(f"Krok {i+1}: presja={wynik['presja']:.2f}")
    return rings.raport()

