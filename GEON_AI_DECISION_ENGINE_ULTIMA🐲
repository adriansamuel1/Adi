# 3. SEMANTYCZNY SKANER KONTEKSTU v3.0
# ============================================================
class ContextScanner:
    """Zaawansowany skaner semantyczno‑entropijny v3.0."""

    THREAT_KEYWORDS = ["error", "fail", "threat", "attack", "danger", "crash", "exploit", "blad", "awaria", "zagrozenie"]
    CREATIVE_KEYWORDS = ["koncepcja", "wizja", "art", "stworz", "design", "wiersz", "idea", "future", "architektura"]
    ANALYTICAL_KEYWORDS = ["analiza", "dane", "math", "oblicz", "porownaj", "skan", "metrics", "statystyka"]
    PROTECTIVE_KEYWORDS = ["kod", "skrypt", "fix", "wykonaj", "uruchom", "zabezpiecz", "patch", "deploy"]

    def __init__(self, config: Optional[Dict[str, Any]] = None, dragon_layers: Optional[DragonLayersInterface] = None):
        self.config = config or {}
        self.history: List[Dict[str, Any]] = []
        self.dragon_layers = dragon_layers
        LOG("CONTEXT_SCANNER", "INIT", "🔍 Skaner Semantyczny v3.0 OMEGA aktywowany")

    def _clamp(self, val: float) -> float:
        return max(0.0, min(1.0, float(val)))

    def scan(self, input_data: Any) -> Dict[str, Any]:
        if isinstance(input_data, dict):
            ctx = self._scan_dict(input_data)
        elif isinstance(input_data, str):
            ctx = self._scan_string(input_data)
        elif isinstance(input_data, list):
            ctx = self._scan_list(input_data)
        else:
            ctx = self._scan_unknown(input_data)

        if self.dragon_layers:
            ctx = self.dragon_layers.apply_relations_41_60(ctx)
            ctx = self.dragon_layers.apply_survival_120_140(ctx)

        self.history.append(ctx)
        if len(self.history) > 300:
            self.history.pop(0)

        return ctx

    def _scan_dict(self, data: Dict[str, Any]) -> Dict[str, Any]:
        has_threats = any(k in data for k in ["error", "threats", "bug", "exception"])
        chaos = data.get("chaos", 0.85 if has_threats else 0.15)
        load = data.get("load", min(1.0, len(data) / 12.0))
        intent = data.get("intent", self._detect_intent_dict(data))
        depth = data.get("depth", 0.85 if ("goal" in data or "architecture" in data) else 0.45)
        precision = data.get("precision", 0.90 if ("data" in data or "math" in data) else 0.50)
        momentum = data.get("momentum", 0.80 if ("speed" in data or "priority" in data) else 0.35)
        vision = data.get("vision", 0.90 if ("vision" in data or "concept" in data) else 0.40)

        return {
            "chaos": self._clamp(chaos),
            "load": self._clamp(load),
            "intent": intent,
            "depth": self._clamp(depth),
            "precision": self._clamp(precision),
            "momentum": self._clamp(momentum),
            "vision": self._clamp(vision),
            "type": "dict",
            "timestamp": time.time()
        }

    def _scan_string(self, text: str) -> Dict[str, Any]:
        words = re.findall(r'\w+', text.lower())
        word_count = len(words)
        unique_words = len(set(words))

        lexical_diversity = unique_words / max(1, word_count)
        special_chars = len(re.findall(r'[^a-zA-Z0-9\s_]', text))
        noise_ratio = special_chars / max(1, len(text))
        threat_hits = sum(1 for w in words if w in self.THREAT_KEYWORDS)

        chaos_calc = (noise_ratio * 2.0) + (threat_hits * 0.25) + ((1.0 - lexical_diversity) * 0.3)
        chaos = self._clamp(chaos_calc)
        load = self._clamp(math.log1p(len(text)) / 7.0)

        intent = self._detect_intent_text(text)
        vision_hits = sum(1 for w in words if w in self.CREATIVE_KEYWORDS)
        analytical_hits = sum(1 for w in words if w in self.ANALYTICAL_KEYWORDS)

        vision = self._clamp(0.4 + (vision_hits * 0.2))
        precision = self._clamp(0.4 + (analytical_hits * 0.2) + (lexical_diversity * 0.3))
        depth = self._clamp((unique_words / 30.0) + (len(text) / 2000.0))

        return {
            "chaos": chaos,
            "load": load,
            "intent": intent,
            "depth": depth,
            "precision": precision,
            "momentum": self._clamp(load * 0.9),
            "vision": vision,
            "type": "string",
            "timestamp": time.time()
        }

    def _scan_list(self, data: List[Any]) -> Dict[str, Any]:
        if not data:
            return {"chaos": 0.0, "load": 0.0, "intent": "general", "depth": 0.0, "precision": 1.0, "momentum": 0.0, "vision": 0.0, "type": "empty_list", "timestamp": time.time()}
        
        total_items = len(data)
        null_items = sum(1 for item in data if item is None or item == "")
        chaos = self._clamp(null_items / max(1, total_items))
        load = self._clamp(math.log1p(total_items) / 5.0)

        return {
            "chaos": chaos,
            "load": load,
            "intent": "batch_processing",
            "depth": self._clamp(total_items / 50.0),
            "precision": self._clamp(1.0 - chaos),
            "momentum": self._clamp(load * 0.85),
            "vision": 0.50,
            "type": "list",
            "timestamp": time.time()
        }

    def _scan_unknown(self, data: Any) -> Dict[str, Any]:
        return {"chaos": 0.5, "load": 0.5, "intent": "general", "depth": 0.3, "precision": 0.5, "momentum": 0.3, "vision": 0.3, "type": type(data).__name__, "timestamp": time.time()}

    def _detect_intent_dict(self, data: Dict[str, Any]) -> str:
        d_type = str(data.get("type", "")).lower()
        if d_type in ["creative", "vision", "art"]: return "creative"
        if d_type in ["analysis", "data", "math"]: return "analytical"
        if d_type in ["strategy", "defense", "security"]: return "strategic"
        if d_type in ["action", "execution", "code"]: return "protective"
        return "general"

    def _detect_intent_text(self, text: str) -> str:
        t = text.lower()
        if any(k in t for k in self.PROTECTIVE_KEYWORDS): return "protective"
        if any(k in t for k in self.ANALYTICAL_KEYWORDS): return "analytical"
        if any(k in t for k in self.CREATIVE_KEYWORDS): return "creative"
        if any(k in t for k in ["plan", "strategia", "cel", "przyszlosc", "roadmap"]): return "strategic"
        return "general"


