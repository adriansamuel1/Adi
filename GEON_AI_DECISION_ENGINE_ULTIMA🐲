    def __init__(self, config: Optional[Dict[str, Any]] = None):
        self.config = config or {}
        self.tick = 0
        self.state = "ACTIVE"
        self.history: List[Dict[str, Any]] = []
        self.stats: Dict[str, Any] = {
            "decisions_made": 0,
            "contexts_scanned": 0,
            "modes_selected": {},
            "master_cycles": 0,
            "trinity_executions": 0,
            "regulations_applied": 0,
            "pipelines_run": 0
        }

        self.dragon_layers = DragonLayersInterface(self.config)
        self.context_scanner = ContextScanner(self.config, self.dragon_layers)
        self.heart_cortex_memory = HeartCortexMemory()
        self.mode_selector = ModeSelectorULTIMA(self.config)
        self.master_code = MasterCode212203_v3()
        self.trinity_core = TrinityCore_v3()
        self.state_regulator = StateRegulator_v3(self.dragon_layers)
        self.octopus_arms = OctopusArms()
        self.execution_pipeline = ExecutionPipeline_v3()

        LOG("ENGINE_v3", "INIT", f"🐉 GEON_AI_DECISION_ENGINE_ULTIMA v{VERSION} aktywowany")
        LOG("ENGINE_v3", "INIT", f"   Sygnatura: {FRACTAL_SIGNATURE}")

    def decide(self, input_data: Any) -> Dict[str, Any]:
        self.tick += 1
        self.stats["decisions_made"] += 1
        LOG("ENGINE_v3", "START", f"Cykl decyzyjny v3.0 OMEGA #{self.tick}", self.tick)

        try:
            ctx = self.context_scanner.scan(input_data)
            self.stats["contexts_scanned"] += 1

            heart_vec = self.heart_cortex_memory.compute_heart_vector(ctx)
            cortex_vec = self.heart_cortex_memory.compute_cortex_vector(ctx)
            memory_bias = self.heart_cortex_memory.compute_memory_bias()

            mode = self.mode_selector.select(ctx, memory_bias)
            self.stats["modes_selected"][mode] = self.stats["modes_selected"].get(mode, 0) + 1

            cycle = self.master_code.run(mode, ctx, heart_vec, cortex_vec)
            self.stats["master_cycles"] += 1

            trinity = self.trinity_core.execute(cycle, ctx, heart_vec, cortex_vec)
            self.stats["trinity_executions"] += 1

            regulated = self.state_regulator.stabilize(trinity)
            self.stats["regulations_applied"] += 1

            arms = self.octopus_arms.route(mode, ctx)

            output = self.execution_pipeline.run(regulated, ctx, arms)
            self.stats["pipelines_run"] += 1

            self.heart_cortex_memory.update_memory(mode, ctx, output["execution_confidence"])

            result = {
                "status": "success",
                "tick": self.tick,
                "context": ctx,
                "mode": mode,
                "cycle": cycle,
                "trinity": trinity,
                "regulated": regulated,
                "arms": arms,
                "output": output,
                "signature": FRACTAL_SIGNATURE,
                "version": VERSION
            }

            self.history.append(result)
            if len(self.history) > 300:
                self.history.pop(0)

            LOG("ENGINE_v3", "COMPLETE", f"Decyzja v3.0 OMEGA #{self.tick} w trybie [{mode}]", self.tick)
            return result

        except Exception as e:
            LOG("ENGINE_v3", "ERROR", f"Błąd pętli v3.0 OMEGA: {e}", self.tick)
            return {
                "status": "error",
                "tick": self.tick,
                "error": str(e),
                "signature": FRACTAL_SIGNATURE
            }

    def get_status(self) -> Dict[str, Any]:
        return {
            "state": self.state,
            "tick": self.tick,
            "stats": self.stats,
            "history_size": len(self.history),
            "version": VERSION
        }


