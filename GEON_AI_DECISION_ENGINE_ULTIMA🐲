            self.memory_trace.pop(0)

    def compute_memory_bias(self) -> Dict[str, Any]:
        if not self.memory_trace:
            return {"bias": "NEUTRAL", "stability": 1.0}

        mode_counts: Dict[str, int] = {}
        avg_conf = 0.0
        for e in self.memory_trace:
            mode_counts[e["mode"]] = mode_counts.get(e["mode"], 0) + 1
            avg_conf += e["confidence"]
        avg_conf /= max(1, len(self.memory_trace))

        dominant_mode = max(mode_counts, key=mode_counts.get)
        stability = min(1.0, avg_conf / 100.0)

        return {
            "bias": dominant_mode,
            "stability": round(stability, 4),
            "trace_size": len(self.memory_trace)
        }


