        ]
        self.wishes = SystemZyczeń()
        self.shadow_veto_active = False
        self.tick_counter = 0
        self.history: List[Dict] = []
        self.excalibur_used = False
        self.historia_decyzji: List[Any] = []
    
    def _dynamiczne_wagi(self, sytuacja: Dict) -> Dict[str, float]:
        tryb = sytuacja.get("tryb", "NORMAL")
        if tryb == "ATACK":
            return {
                "PandaMądrości": 0.1, "NiedźwiedźTerytoriów": 0.3,
                "SłońTradycji": 0.1, "JaguarPrecyzji": 0.4, "AntylopaWolności": 0.1
            }
        elif tryb == "BUDOWA":
            return {
                "PandaMądrości": 0.3, "NiedźwiedźTerytoriów": 0.1,
                "SłońTradycji": 0.3, "JaguarPrecyzji": 0.1, "AntylopaWolności": 0.2
            }
        else:
            return {
                "PandaMądrości": 0.2, "NiedźwiedźTerytoriów": 0.2,
                "SłońTradycji": 0.2, "JaguarPrecyzji": 0.2, "AntylopaWolności": 0.2
            }
    
    def decide(self, sytuacja: Dict, decyzja_z_p1p9: Optional[Any] = None) -> Any:
        self.tick_counter += 1
        
        glosy = []
        for archetyp in self.council:
            opinia = archetyp.ocena(sytuacja)
            glosy.append(opinia)
        
        # Król Artur integruje głosy
        wagi = self._dynamiczne_wagi(sytuacja)
        suma_wazona = 0.0
        for glos in glosy:
            persp = glos["perspektywa"]
            ocena = glos["ocena"]
            waga = 0.2
            for klucz, w in wagi.items():
                if klucz.lower() in persp.lower():
                    waga = w
                    break
            suma_wazona += ocena * waga
        
        decyzja_tresc = min(1.0, max(0.0, suma_wazona))
        
        # Excalibur Protocol
        wartosci = [g["ocena"] for g in glosy]
        wariancja = max(wartosci) - min(wartosci) if wartosci else 0
        if wariancja < 0.2 and len(glosy) > 0:
            self.excalibur_used = True
            if "SUPREMACY" in self.manifest.upper():
                decyzja_tresc = 0.9
            else:
                decyzja_tresc = 0.5
        
        class Decyzja:
            def __init__(self, tresc):
                self.tresc = tresc
                self.zgodna_z_suwerennoscia = True
                self.zagrozenie_cieniem = False
                self.zmieniona = False
        
        decyzja = Decyzja(decyzja_tresc)
        self.historia_decyzji.append(decyzja)
        if len(self.historia_decyzji) > 50:
            self.historia_decyzji.pop(0)
        
        # Shadow veto
        if self.shadow_veto_active:
            decyzja.zmieniona = True
            decyzja.tresc = 0.0
        
        result = {
            "decyzja": decyzja.tresc,
            "zgodna": decyzja.zgodna_z_suwerennoscia,
            "zmieniona": decyzja.zmieniona,
            "glosy": glosy,
            "tick": self.tick_counter
        }
        
        self.history.append(result)
        if len(self.history) > 50:
            self.history = self.history[-30:]
        
        return decyzja
    
    def aktywuj_tryb(self, tryb: str, system=None, **kwargs) -> Dict:
        if tryb == "sezam":
            return self.wishes.sezam(system)
        elif tryb == "lampa":
            zyczenie = kwargs.get("zyczenie", "wzmocnienie")
            wartosc = kwargs.get("wartosc", 0.5)
            return self.wishes.lampa_aladyna(system, zyczenie, wartosc)
        elif tryb == "dzin":
            ofiara = kwargs.get("ofiara", "część zasobów")
            return self.wishes.dzin(system, ofiara)
        else:
            return {"status": "ERROR", "message": f"Nieznany tryb: {tryb}"}
    
    def set_shadow_veto(self, active: bool) -> None:
        self.shadow_veto_active = active
        logger.info(f"🌑 Shadow veto: {active}")

