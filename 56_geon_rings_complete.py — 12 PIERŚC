class CoreIdentity:
    """Nietykalny rdzeń systemu — przechowywany w Axis Mundi (P7)"""
    def __init__(self, architect_name: str, foundation_status: str,
                 patents: List[str], plz_z_state: float,
                 secret_salt: str = "HEILONG_OS"):
        self.architect = architect_name
        self.foundation = foundation_status
        self.patents = patents.copy()
        self.plz_z_snapshot = plz_z_state
        self.secret_salt = secret_salt
        self.signature = self._generate_signature()
    
    def _generate_signature(self) -> str:
        data = f"{self.architect}|{self.foundation}|{sorted(self.patents)}|{self.plz_z_snapshot}|{self.secret_salt}"
        return hashlib.sha256(data.encode()).hexdigest()[:16]
    
    def verify(self) -> bool:
        return self.signature == self._generate_signature()
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            "architect": self.architect,
            "foundation": self.foundation,
            "patents": self.patents,
            "plz_z_snapshot": self.plz_z_snapshot,
            "signature": self.signature
        }


class FailureDetector:
    """Wykrywa błędy, konflikty, przeciążenia, utratę spójności"""
    def __init__(self, instability_threshold: float = 0.7):
        self.threshold = instability_threshold
        self.last_failure_type: Optional[str] = None
        self.failure_log: List[Dict[str, Any]] = []
    
    def detect(self, system_state: Dict[str, Any]) -> Tuple[bool, str, Dict[str, Any]]:
        error = system_state.get("error", None)
        instability = system_state.get("instability", 0.0)
        integrity = system_state.get("integrity", 1.0)
        
        if error:
            self.last_failure_type = "local"
            context = {"error": error, "module": system_state.get("failed_module")}
            self.failure_log.append(context)
            return True, "local", context
        
        if instability > self.threshold:
            self.last_failure_type = "structural"
            context = {"instability": instability, "source": system_state.get("instability_source")}
            self.failure_log.append(context)
            return True, "structural", context
        
        if integrity < 0.3:
            self.last_failure_type = "total"
            context = {"integrity": integrity, "reason": "critical_integrity_loss"}
            self.failure_log.append(context)
            return True, "total", context
        
        return False, "none", {}


class BurnEngine:
    """Przepala błędne stany, ale zapamiętuje wzorce"""
    def __init__(self):
        self.entropy_log: List[Dict[str, Any]] = []
        self.burned_patterns: List[str] = []
    
    def burn(self, system: Any, failure_context: Dict[str, Any], failure_type: str) -> None:
        pattern = self._extract_pattern(failure_context, failure_type)
        self.entropy_log.append({
            "timestamp": time.time(),
            "type": failure_type,
            "pattern": pattern,
            "context": failure_context
        })
        
        if hasattr(system, 'temp'):
            system.temp.clear()
        if hasattr(system, 'cache'):
            system.cache.clear()
        if hasattr(system, 'error_states'):
            system.error_states.clear()
        
        if len(self.entropy_log) > 50:
            self.entropy_log.pop(0)
    
    def _extract_pattern(self, context: Dict[str, Any], failure_type: str) -> str:
        if failure_type == "local":
            return f"module_{context.get('module', 'unknown')}"
        elif failure_type == "structural":
            return f"instability_{context.get('source', 'unknown')}"
        else:
            return "total_system_collapse"
    
    def get_immunity(self, pattern: str) -> bool:
        return pattern in self.burned_patterns
    
    def add_immunity(self, pattern: str) -> None:
        if pattern not in self.burned_patterns:
            self.burned_patterns.append(pattern)
            logger.info(f"🛡️ Immunitet nadany dla wzorca: {pattern}")


