        self.honor_no_shame = True
        self.authority_unbroken = True
        self.archetypes = {
            "Paw": {"tag": "BEAUTY", "weight": 0.9, "description": "piękno i duma"},
            "Rajski_Ptak": {"tag": "UNIQUENESS", "weight": 0.8, "description": "niepowtarzalność"},
            "Lew_Krolewski": {"tag": "MAJESTY", "weight": 1.0, "description": "królewska postawa"},
            "Labedz": {"tag": "ELEGANCE", "weight": 0.85, "description": "wdzięk i lekkość"},
            "Mustang_Spirit": {"tag": "FREEDOM", "weight": 0.7, "description": "dzika wolność"},
            "Wilk_Alfa": {"tag": "LINEAGE", "weight": 1.0, "description": "odpowiedzialność za ród"},
            "Orzel_Zloty": {"tag": "VISION", "weight": 0.95, "description": "dalekowzroczność"},
            "Slon_Krolewski": {"tag": "MEMORY", "weight": 0.9, "description": "pamięć i tradycja"},
            "Koliber": {"tag": "PRECISION", "weight": 0.8, "description": "precyzja i szybkość"}
        }
        self.shame_log: List[Any] = []
        self.legacy_protection_active = True
        self.noise_threshold = 0.3
        self.shadow_dignity = False
        self.silent_witness: Optional[Dict] = None
        self.tick_counter = 0
        self.history: List[Dict] = []
    
    def preemptive_shame_check(self, option: Any) -> Tuple[bool, str]:
        if isinstance(option, dict):
            risky = any(k in str(option).lower() for k in ["chaos", "strach", "zdrada", "upokorzenie"])
            if risky:
                self.shame_log.append(("PREEMPTIVE", option, "risk_of_shame"))
                logger.warning(f"🛡️ DIGNITAS: Pre‑emptive shame – odrzucono opcję")
                return False, "SHAME_PREVENTED"
        return True, "OK"
    
    def legacy_protection(self, decision: Any) -> Tuple[bool, str]:
        if not self.legacy_protection_active:
            return True, "LEGACY_PROTECTION_OFF"
        decision_str = str(decision).upper()
        if any(vile in decision_str for vile in ["ZDRA DA", "PODDAŃSTWO", "HAŃBA"]):
            self.shame_log.append(("LEGACY", decision, "dishonors_lineage"))
            logger.warning(f"👑 DIGNITAS: Legacy protection – decyzja hańbi ród")
            return False, "LEGACY_VIOLATION"
        return True, "OK"
    
    def noise_reduction_filter(self, signal: Any) -> Tuple[bool, Any]:
        if self.mode != "SILENT_SOVEREIGN":
            return True, signal
        noise_level = 0.0
        signal_str = str(signal).lower()
        noisy_keywords = ["strach", "panika", "chaos", "prowokacja", "atak", "obrona"]
        for kw in noisy_keywords:
            if kw in signal_str:
                noise_level += 0.2
        noise_level = min(1.0, noise_level)
        if noise_level > self.noise_threshold:
            logger.info(f"🔇 DIGNITAS: Noise reduction – zignorowano sygnał")
            self.silent_witness = {"signal": signal, "noise": noise_level, "ignored": True}
            return False, None
        self.silent_witness = {"signal": signal, "noise": noise_level, "ignored": False}
        return True, signal
    
    def activate_shadow_dignity(self) -> None:
        self.shadow_dignity = True
        logger.info("🌑 DIGNITAS: Shadow dignity activated")
    
    def deactivate_shadow_dignity(self) -> None:
        self.shadow_dignity = False
        logger.info("🦚 DIGNITAS: Shadow dignity deactivated")
    
    def collect_signals(self, input_signal: Any) -> Dict:
        signal_str = str(input_signal).lower()
        for archetype, data in self.archetypes.items():
            if data["tag"].lower() in signal_str or archetype.lower() in signal_str:
                return {"archetype": archetype, "tag": data["tag"], "weight": data["weight"], "raw": input_signal}
        return {"archetype": "Paw", "tag": "BEAUTY", "weight": 0.5, "raw": input_signal}
    
    def fractal_layers(self, signal: Dict) -> Dict:
        return {
            "FORM": signal.get("raw"),
            "FUNCTION": f"decyzja_{signal.get('tag', 'UNKNOWN')}",
            "CONTEXT": self.mode,
            "IMPACT": signal.get("weight", 0.5)
        }
    
    def eliminate_invalid(self, layers: List[Any]) -> List[Any]:
        valid = []
        for layer in layers:
            ok, _ = self.preemptive_shame_check(layer)
            if ok:
                valid.append(layer)
        return valid
    
    def intersection(self, valid_layers: List[Any]) -> Any:
        if not valid_layers:
            return None
        return valid_layers[0]
    
    def final_judgment(self, result: Any) -> str:
        if result is None:
            return "BELOW_STANDARD"
        ok, reason = self.legacy_protection(result)
        if not ok:
            self.shame_log.append(("FINAL", result, reason))
            return f"BELOW_STANDARD ({reason})"
        return "WORTHY"
    
    def evaluate(self, environment_signal: Any, apply_noise_filter: bool = True) -> Dict[str, Any]:
        self.tick_counter += 1
        
        if apply_noise_filter:
            process, clean_signal = self.noise_reduction_filter(environment_signal)
            if not process:
                result = {
                    "verdict": "IGNORED_NOISE",
                    "mode": self.mode,
                    "noise_level": getattr(self.silent_witness, 'noise', 0.0),
                    "shadow_dignity": self.shadow_dignity,
                    "tick": self.tick_counter
                }
                self.history.append(result)
                return result
        else:
            clean_signal = environment_signal
        
        signal_dict = self.collect_signals(clean_signal)
        layers = self.fractal_layers(signal_dict)
        valid_layers = self.eliminate_invalid(list(layers.values()))
        common = self.intersection(valid_layers)
        verdict = self.final_judgment(common)
        
        if self.shadow_dignity:
            verdict = "HIDDEN"
        
        result = {
            "verdict": verdict,
            "mode": self.mode,
            "archetype_used": signal_dict.get("archetype"),
            "noise_reduction_applied": apply_noise_filter,
            "shadow_dignity": self.shadow_dignity,
            "shame_log_count": len(self.shame_log),
            "tick": self.tick_counter
        }
        
        self.history.append(result)
        if len(self.history) > 50:
            self.history = self.history[-30:]
        
        return result
    
    def pre_filter_decision(self, decision: Any) -> Tuple[bool, str]:
        ok, reason = self.preemptive_shame_check(decision)
        if not ok:
            return False, reason
        ok, reason = self.legacy_protection(decision)
        if not ok:
            return False, reason
        return True, "DIGNIFIED"

