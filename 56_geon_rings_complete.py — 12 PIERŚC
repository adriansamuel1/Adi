    p8 = FeniksP8(axis, core)
    
    # P9 — Arkana
    p9 = Ring9_Arkana()
    
    # P10 — Korona Shifu
    p10 = Ring10_KoronaShifu(manifest_adriana="HEILONG SUPREMACY")
    
    # P11 — Dignitas
    p11 = Ring11_Dignitas(rodowod="ADRIAN SAMUEL BOGUSŁAWSKI")
    
    # P12 — Arkhé
    p12 = Ring12_Arkhe_HEILONG_QILIN(owner="ADRIAN SAMUEL BOGUSŁAWSKI")
    
