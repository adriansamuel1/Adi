        self.tick_counter = 0
        self.history: List[Dict] = []
    
    def _get_system_state(self, system: Any) -> Dict[str, Any]:
        error = None
        instability = 0.0
        integrity = 1.0
        failed_module = None
        instability_source = None
        
        if hasattr(system, 'p3') and hasattr(system.p3, 'uncertainty'):
            instability = system.p3.uncertainty
            instability_source = "P3_uncertainty"
        
        if hasattr(system, 'p1') and hasattr(system.p1, 'fuel_remaining') and system.p1.fuel_remaining < 0.1:
            error = "LOW_FUEL"
            failed_module = "P1"
        
        if hasattr(system, 'p4') and hasattr(system.p4, 'active') and system.p4.active:
            instability = max(instability, 0.5)
        
        return {
            "error": error,
            "instability": instability,
            "integrity": integrity,
            "failed_module": failed_module,
            "instability_source": instability_source
        }
    
    def _check_energy_for_regeneration(self, required_energy: float) -> bool:
        power = self.axis.get_power_supply() if hasattr(self.axis, 'get_power_supply') else 50.0
        if power < required_energy:
            logger.warning(f"⚠️ Za mało energii do regeneracji (wymagane {required_energy}, dostępne {power:.1f})")
            return False
        return True
    
    def _consume_energy(self, amount: float) -> bool:
        if hasattr(self.axis, 'assets') and 'PLZ_Z' in self.axis.assets:
            if self.axis.assets['PLZ_Z'] >= amount:
                self.axis.assets['PLZ_Z'] -= amount
                return True
        return False
    
    def cycle(self, system: Any) -> Dict[str, Any]:
        self.tick_counter += 1
        state_info = self._get_system_state(system)
        has_failure, failure_type, context = self.detector.detect(state_info)
        
        if not has_failure:
            self.state = "IDLE"
            return {"status": "OK", "state": self.state}
        
        self.last_failure = failure_type
        self.state = "BURNING"
        logger.warning(f"🔥 DETEKCJA AWARII: {failure_type} – {context}")
        
        if failure_type == "local":
            energy_req = 10.0
        elif failure_type == "structural":
            energy_req = 30.0
        else:
            energy_req = 100.0
        
        if not self._check_energy_for_regeneration(energy_req):
            self.state = "HIBERNATION"
            return {
                "status": "HIBERNATION",
                "state": self.state,
                "message": f"Brak energii do regeneracji (potrzeba {energy_req})",
                "failure_type": failure_type
            }
        
        self.burn_engine.burn(system, context, failure_type)
        self.state = "REGENERATING"
        
        mode = "aksolotl" if failure_type == "local" else ("salamandra" if failure_type == "structural" else "planaria")
        regen_result = self.regeneration_engine.regenerate(
            system, mode, self.core if mode == "planaria" else None
        )
        
        if regen_result.get("status") != "OK":
            self.state = "FAILED"
            return {
                "status": "REGENERATION_FAILED",
                "state": self.state,
                "failure_type": failure_type,
                "regen_result": regen_result
            }
        
        self._consume_energy(energy_req)
        amp_result = self.amplifier.apply(system, failure_type, context, self.burn_engine)
        self.state = "REBORN"
        
        logger.info("✅ FENIKS: regeneracja zakończona, system wzmocniony")
        
        if hasattr(self.axis, 'assets') and 'intellectual_ip' in self.axis.assets:
            self.axis.assets['intellectual_ip'].append(
                f"FENIKS_REBIRTH_{self.regeneration_engine.rebirth_count}"
            )
        
        result = {
            "status": "REBORN",
            "state": self.state,
            "failure_type": failure_type,
            "mode_used": mode,
            "regen_result": regen_result,
            "amplification": amp_result,
            "rebirth_count": self.regeneration_engine.rebirth_count
        }
        
        self.history.append({"tick": self.tick_counter, "result": result})
        if len(self.history) > 50:
            self.history = self.history[-30:]
        
        return result
    
    def get_core_integrity_status(self) -> Dict[str, Any]:
        return {
            "core_valid": self.core.verify(),
            "core_data": self.core.to_dict(),
            "rebirth_count": self.regeneration_engine.rebirth_count,
            "burned_patterns": self.burn_engine.burned_patterns
        }

