            self.recover_and_enhance(wound)
        self.state = "REBUILT"
        logger.info("🏯 ARKHÉ: Pałac odbudowany (Kintsugi complete)")
        return "PAŁAC ODBUDOWANY"
    
    def map_fragment_to_courtyard(self, fragment: Any) -> str:
        ftype = str(fragment).lower()
        if any(k in ftype for k in ["idea", "pomysł", "koncept"]):
            return "Poranka"
        if any(k in ftype for k in ["rod", "przodek", "archiwum"]):
            return "Wiecznosci"
        if any(k in ftype for k in ["relacje", "dyplomacja", "kontakt"]):
            return "Harmonii"
        if any(k in ftype for k in ["geopolityka", "rynek", "gospodarka"]):
            return "Obserwacyjny"
        if any(k in ftype for k in ["estetyka", "piękno", "vibe"]):
            return "Zachod_Slonca"
        if any(k in ftype for k in ["introspekcja", "refleksja"]):
            return "Sala_Luster"
        if any(k in ftype for k in ["strategia", "taktyka", "plan"]):
            return "Wojownikow"
        if any(k in ftype for k in ["decyzja", "ruch", "wybór"]):
            return "Wolnosci"
        return "Brama_Rodu"
    
    def integrate_all(self, rings_data: List[Any]) -> Dict[str, List[Any]]:
        palace_map = {name: [] for name in self.courtyards.keys()}
        for fragment in rings_data:
            courtyard = self.map_fragment_to_courtyard(fragment)
            palace_map[courtyard].append(fragment)
        logger.info(f"📦 ARKHÉ: zintegrowano {len(rings_data)} fragmentów w 9 dziedzińcach")
        return palace_map
    
    def shadow_mirror_report(self) -> Dict:
        wasted_energy = random.uniform(0.0, 0.2)
        report = {
            "timestamp": time.time(),
            "wasted_energy": wasted_energy,
            "suggestion": "Sprawdź procesy, które generują szum bez wartości.",
            "clean_qi": self.qi_level - wasted_energy
        }
        self.shadow_mirror_log.append(report)
        logger.info(f"🪞 Sala Luster: raport cienia – strata energii: {wasted_energy:.2f}")
        return report
    
    def vibe_guard_generate(self, description: str = "sukces w Czekance") -> str:
        image_path = f"/tmp/arkhe_vibe_{int(time.time())}.png"
        self.vibe_images.append(image_path)
        self.feed_qi("aesthetic_act")
        logger.info(f"🎨 Vibe Guard: wygenerowano obraz dla opisu '{description}'")
        return image_path
    
    def ancestral_filter(self, entity: str, intent_document: str) -> bool:
        manifest_keywords = ["suwerenność", "rozwój", "fundacja", "heilong", "crystal palace"]
        intent_lower = intent_document.lower()
        if any(kw in intent_lower for kw in manifest_keywords):
            logger.info(f"🚪 Brama Rodu: przepuszczono {entity}")
            return True
        else:
            self.ancestral_blacklist.append({"entity": entity, "timestamp": time.time(), "intent": intent_document})
            logger.warning(f"⛔ Brama Rodu: zablokowano {entity}")
            return False
    
    def integrate_with_heilong(self, p11_dignitas: Optional[Ring11_Dignitas] = None) -> None:
        self.p11_dignitas = p11_dignitas
        logger.info("🔗 ARKHÉ: zintegrowany z P11 Dignitas")
    
    def process(self, rings_data: List[Any], intent_level: float = 0.5) -> Dict[str, Any]:
        self.tick_counter += 1
        
        # 1. Qi flow
        self.qi_flow_dynamics(daily_activity=bool(rings_data))
        
        # 2. Beny check
        access = self.beny_check_zero(intent_level)
        
        # 3. Integracja danych
        integrated = self.integrate_all(rings_data)
        
        # 4. Synteza (średnia z dziedzińców)
        synthesis_values = []
        for courtyard, items in integrated.items():
            if items:
                logic = 0.5 + random.uniform(-0.2, 0.2)
                intuition = 0.5 + random.uniform(-0.2, 0.2)
                val = self.synthesis_engine(logic, intuition, courtyard)
                synthesis_values.append(val)
        
        avg_synthesis = sum(synthesis_values) / max(1, len(synthesis_values))
        
        result = {
            "access": access,
            "integrated": integrated,
            "synthesis": avg_synthesis,
            "qi": self.qi_level,
            "wounds": len(self.wounds),
            "rebuilt": len(self.rebuilt_fragments),
            "tick": self.tick_counter
        }
        
        self.history.append(result)
        if len(self.history) > 50:
            self.history = self.history[-30:]
        
        return result

