class DiamentSeraphim:
    """
    DIAMENT-SERAPHIM — filtr metapierścieniowy.
    Rezonans zamiast progu — przepuszcza impulsy rezonujące z metapierścieniem.
    """
    
    def __init__(self):
        self.rezonans_aktualny = 0.6
        self.krystalizacje = 0
        self.szum_odrzucony = 0
        self.historia: List[Dict] = []
    
    def filtruj(self, tekst: str, metaring: float, intencja: float) -> Optional[Dict[str, Any]]:
        """Filtracja oparta na rezonansie metapierścieniowym"""
        if not tekst or len(tekst) < 3:
            self.szum_odrzucony += 1
            return None
        
        # Oblicz rezonans
        kluczowe = ["archanioł", "metapierścień", "pole", "świadomość", "jednia", "transformacja"]
        obecność = sum(1 for k in kluczowe if k in tekst.lower()) / len(kluczowe)
        rezonans = (obecność * 0.6 + metaring * 0.4) * (0.8 + intencja * 0.4)
        rezonans = max(KonfiguracjaOPH60.REZONANS_MIN, 
                      min(KonfiguracjaOPH60.REZONANS_MAX, rezonans))
        
        self.rezonans_aktualny = self.rezonans_aktualny * 0.95 + rezonans * 0.05
        
        if rezonans < KonfiguracjaOPH60.REZONANS_MIN:
            self.szum_odrzucony += 1
            return None
        
        self.historia.append({
            "timestamp": time.time(),
