class GexAscension:
    """
    GEX-ASCENSION — transformacja wielowymiarowa.
    Zmienia stan pola, nie tylko energię.
    """
    
    def __init__(self, geon_mem: 'GeonMemOmegaOmega'):
        self.geon = geon_mem
        self.transformacje = 0
        self.historia: List[Dict] = []
    
    def _transformuj_pole(self, punkt: PunktHiperpola, metaring: float, intencja: float) -> None:
        """Transformacja stanu pola — wielowymiarowa zmiana"""
        punkt.energia = max(KonfiguracjaOPH60.ENERGIA_MIN,
                           min(KonfiguracjaOPH60.ENERGIA_MAX,
                               punkt.energia + random.uniform(-0.1, 0.1)))
        punkt.metaring = metaring
        punkt.intencja = intencja
        punkt.wektor_pola = [v * (0.95 + metaring * 0.1) for v in punkt.wektor_pola]
    
    def ascencja(self, punkt: PunktHiperpola, metaring: float, intencja: float,
                 promień: int = 3) -> None:
        """
        Transformacja wielowymiarowa — kaskada zmian stanu pola.
        """
        self.transformacje += 1
        self._transformuj_pole(punkt, metaring, intencja)
        
        # Wpływ na sąsiednie punkty pola
        for _ in range(promień):
            if self.geon.punkty:
                losowy = random.choice(self.geon.punkty)
                self._transformuj_pole(losowy, metaring * 0.7, intencja * 0.7)
        
        self.historia.append({
            "timestamp": time.time(),
            "typ": "ASCENSION",
            "metaring": metaring,
            "intencja": intencja,
            "promień": promień,
            "punkt_id": punkt.id
        })
        if len(self.historia) > 50:
            self.historia = self.historia[-30:]
    
    def statystyki(self) -> Dict[str, Any]:
        return {
            "transformacje": self.transformacje,
            "historia": self.historia[-5:]
        }

