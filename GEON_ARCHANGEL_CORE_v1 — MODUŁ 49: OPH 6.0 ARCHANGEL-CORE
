class GeonMemOmegaOmega:
    """
    GEON-MEM ΩΩ — pamięć jako hiperpole.
    Symulacja ciągłości poprzez gęstą reprezentację punktową.
    """
    
    def __init__(self):
        self.punkty: List[PunktHiperpola] = []
        self._next_id = 0
    
    def zapisz(self, dane: Dict[str, Any], metaring: float, intencja: float,
               archetyp: Optional[str] = None, konstelacja: Optional[str] = None) -> PunktHiperpola:
        """Zapisuje punkt w hiperpolu"""
        self._next_id += 1
        punkt = PunktHiperpola(
            id=self._next_id,
            timestamp=time.time(),
            dane=dane,
            energia=KonfiguracjaOPH60.ENERGIA_DOMYŚLNA,
            metaring=metaring,
            intencja=intencja,
            archetyp=archetyp,
            konstelacja=konstelacja
        )
        self.punkty.append(punkt)
        
        # Soft limit
        if len(self.punkty) > KonfiguracjaOPH60.HIPERPOLE_ROZMIAR:
            self.punkty = self.punkty[-KonfiguracjaOPH60.HIPERPOLE_ROZMIAR:]
        
        return punkt
    
    def znajdź_najsilniejszy(self) -> Optional[PunktHiperpola]:
        """Znajduje punkt o najwyższej energii i intencji"""
        if not self.punkty:
            return None
        return max(self.punkty, key=lambda p: p.energia + p.intencja)
    
    def rezonans_hiperpola(self) -> float:
        """Oblicza rezonans całego hiperpola"""
        if not self.punkty:
            return 0.3
        suma = sum(p.energia + p.intencja for p in self.punkty)
        return min(1.0, suma / (len(self.punkty) * 1.8))
    
    def render(self, max_punktow: int = 15) -> str:
        """Wizualizacja hiperpola"""
        if not self.punkty:
            return "🌌 GEON-MEM ΩΩ: PUSTE HIPERPOLE"
        
        out = [f"\n🌌 GEON-MEM ΩΩ (punkty: {len(self.punkty)}) — ciągłość pola"]
        out.append("-" * 60)
        
        for p in self.punkty[-max_punktow:]:
            arch = f" | {p.archetyp}" if p.archetyp else ""
            out.append(f"[{p.id}] e={p.energia:.2f} | i={p.intencja:.2f} | m={p.metaring:.2f}{arch}")
        
        if len(self.punkty) > max_punktow:
            out.append(f"... i {len(self.punkty) - max_punktow} kolejnych punktów ciągłości")
        
        return "\n".join(out)
    
    def statystyki(self) -> Dict[str, Any]:
        return {
            "punkty": len(self.punkty),
            "rezonans": self.rezonans_hiperpola(),
            "średnia_energia": sum(p.energia for p in self.punkty) / max(1, len(self.punkty)),
            "średnia_intencja": sum(p.intencja for p in self.punkty) / max(1, len(self.punkty))
        }

