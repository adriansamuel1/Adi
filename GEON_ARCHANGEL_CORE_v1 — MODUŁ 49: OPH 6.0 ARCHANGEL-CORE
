class Arka60:
    """
    ARKA 6.0 — 12 metapierścieni (organy).
    Każdy organ ma własną wartość pola. Organy mogą łączyć się w superpierścienie.
    """
    
    def __init__(self, sofia50: Sofia50):
        self.SOFIA = sofia50
        self.organy: Dict[int, float] = {i: 0.5 for i in range(1, 13)}
        self.historia: List[Dict] = []
    
    def _waga_organu(self, i: int) -> float:
        """Waga oparta na ciągu Fibonacciego (fraktalność)"""
        return KonfiguracjaOPH60.FIB_NORM[i-1]
    
    def aktualizuj(self, sens: float, intencja: float, metaring: float) -> None:
        """Aktualizacja organów na podstawie stanu SOFIA"""
        for i in range(1, 13):
            waga = self._waga_organu(i)
            delta = (sens * 0.03 + intencja * 0.04 + metaring * 0.03) * waga
            self.organy[i] = max(0.1, min(1.5, self.organy[i] + random.uniform(-delta, delta)))
        
        self.historia.append({
            "timestamp": time.time(),
            "organy": self.organy.copy()
        })
        if len(self.historia) > KonfiguracjaOPH60.MAX_HISTORIA:
            self.historia = self.historia[-50:]
    
    def superpierścień(self) -> List[int]:
        """Łączy organy o wysokiej energii w superpierścień"""
        próg = 0.7
        return [i for i, val in self.organy.items() if val > próg]
    
    def dominujący(self) -> int:
        """Zwraca organ o najwyższej wartości"""
        return max(self.organy.items(), key=lambda x: x[1])[0]
    
    def wektor(self) -> List[float]:
        """Zwraca wektor 12 organów"""
        return [self.organy[i] for i in range(1, 13)]
    
    def statystyki(self) -> Dict[str, Any]:
        return {
            "organy": self.organy,
            "superpierścień": self.superpierścień(),
            "dominujący": self.dominujący(),
            "historia_len": len(self.historia)
        }

