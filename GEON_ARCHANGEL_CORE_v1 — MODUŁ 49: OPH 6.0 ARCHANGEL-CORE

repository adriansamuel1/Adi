class BennyPrimordial:
    """
    BENNY PRIMORDIAL — źródło intencji jako pole.
    Samoreguluje się w rytmie 168.
    """
    
    def __init__(self):
        self.pole_źródłowe = 0.5
        self.historia: List[Dict] = []
        self.puls_168_counter = 0
    
    def wartość_pola(self) -> float:
        return self.pole_źródłowe
    
    def aktualizuj_pole(self, intencja: float, rezonans: float, metaring: float) -> None:
        alfa = KonfiguracjaOPH60.PRIMORDIAL_ALFA
        beta = KonfiguracjaOPH60.PRIMORDIAL_BETA
        impuls = (intencja + rezonans + metaring) / 3.0
        self.pole_źródłowe = round(alfa * self.pole_źródłowe + beta * impuls, 4)
        
        self.historia.append({
            "timestamp": time.time(),
            "intencja": intencja,
            "rezonans": rezonans,
            "metaring": metaring,
            "wartość": self.pole_źródłowe
        })
        if len(self.historia) > KonfiguracjaOPH60.MAX_HISTORIA:
            self.historia = self.historia[-50:]
    
    def puls_168(self) -> float:
        """Synchronizacja fraktalna — cykl 168"""
        self.puls_168_counter += 1
        if self.puls_168_counter >= 168:
            self.puls_168_counter = 0
            self.pole_źródłowe = round(self.pole_źródłowe * 0.99 + 0.5 * 0.01, 4)
        return self.pole_źródłowe
    
    def statystyki(self) -> Dict[str, Any]:
        return {
            "wartość_pola": self.pole_źródłowe,
            "puls_168": self.puls_168_counter,
            "historia_len": len(self.historia)
        }

