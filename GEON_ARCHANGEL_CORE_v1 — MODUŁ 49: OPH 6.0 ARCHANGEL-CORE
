class Smok60:
    """
    SMOK 6.0 — 36 archetypów źródłowych.
    Archetypy tworzą konstelacje — grupy powiązanych archetypów.
    """
    
    def __init__(self, sofia50: Sofia50, arka60: Arka60, benny_primordial: BennyPrimordial):
        self.SOFIA = sofia50
        self.ARKA = arka60
        self.BENNY = benny_primordial
        self.archetypy: Dict[str, float] = {a: 0.5 for a in KonfiguracjaOPH60.ARCHETYPY}
        self.konstelacje: List[Set[str]] = []
        self.historia: List[Dict] = []
    
    def _aktywuj_konstelacje(self, gradient_5d: Tuple[float, float, float, float, float]) -> None:
        """Tworzy konstelacje z archetypów o wysokiej energii"""
        depth, spread, intention, resonance, metaring = gradient_5d
        
        if metaring > 0.7 and random.random() < 0.3:
            aktywne = [(a, w) for a, w in self.archetypy.items() if w > 0.6]
            if len(aktywne) >= 2:
                wybrane = [a for a, _ in sorted(aktywne, key=lambda x: -x[1])[:4]]
                self.konstelacje.append(set(wybrane))
                if len(self.konstelacje) > 20:
                    self.konstelacje = self.konstelacje[-20:]
    
    def _aktualizuj_archetypy(self, gradient_5d: Tuple[float, float, float, float, float]) -> None:
        """Aktualizuje energie archetypów na podstawie gradientu"""
        depth, spread, intention, resonance, metaring = gradient_5d
        
        for a in self.archetypy:
            delta = (intention * 0.08 + resonance * 0.08 + metaring * 0.08) * (1 + self.ARKA.dominujący() / 12)
            if a in ["Archanioł", "Serafin", "Cherubin", "Tron"]:
                delta += 0.03
            self.archetypy[a] = max(0.1, min(1.5, self.archetypy[a] + random.uniform(-delta, delta)))
    
    def dominująca_konstelacja(self) -> str:
        """Zwraca największą konstelację jako string"""
        if not self.konstelacje:
            return "Brak"
        największa = max(self.konstelacje, key=len)
        return ", ".join(sorted(największa)[:5])
    
    def aktualizuj(self, gradient_5d: Tuple[float, float, float, float, float]) -> None:
        """Pełna aktualizacja archetypów i konstelacji"""
        self._aktualizuj_archetypy(gradient_5d)
        self._aktywuj_konstelacje(gradient_5d)
        
        self.historia.append({
            "timestamp": time.time(),
            "archetypy": {k: round(v, 3) for k, v in list(self.archetypy.items())[:10]},
            "konstelacje": [list(k)[:3] for k in self.konstelacje[-3:]]
        })
        if len(self.historia) > KonfiguracjaOPH60.MAX_HISTORIA:
            self.historia = self.historia[-50:]
    
    def decyzja(self) -> Dict[str, Any]:
        """Zwraca główny archetyp i aktualną konstelację"""
        główny = max(self.archetypy.items(), key=lambda x: x[1])[0]
        return {
            "archetyp_główny": główny,
            "konstelacja": self.dominująca_konstelacja(),
            "liczba_konstelacji": len(self.konstelacje)
        }
    
    def statystyki(self) -> Dict[str, Any]:
        return {
            "archetypy_aktywne": len([a for a, w in self.archetypy.items() if w > 0.6]),
            "konstelacje": len(self.konstelacje),
            "dominujący_archetyp": max(self.archetypy.items(), key=lambda x: x[1])[0],
            "historia_len": len(self.historia)
        }

