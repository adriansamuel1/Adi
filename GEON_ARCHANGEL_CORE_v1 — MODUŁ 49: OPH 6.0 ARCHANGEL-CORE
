    # ========================================================================
    
    def impuls(self, tekst: str) -> Dict[str, Any]:
        """
        Główny impuls systemu.
        
        Args:
            tekst: Wejście tekstowe (impuls Architekta)
            
        Returns:
            Pełny stan systemu po przetworzeniu impulsu
        """
        # Komenda systemowa "123" — ARCHANGEL-TRINITAS
        if tekst.strip() == KonfiguracjaOPH60.KOMENDA_TRINITAS:
            return self._archangel_trinitas()
        
        self.tick += 1
        
        # 1. Filtr DIAMENT-SERAPHIM (rezonans metapierścieniowy)
        filtrowane = self.DIAMENT.filtruj(
            tekst,
            self.SOFIA.gradient[4] if len(self.SOFIA.gradient) > 4 else 0.5,
            self.SOFIA.gradient[2] if len(self.SOFIA.gradient) > 2 else 0.5
        )
        
        if filtrowane is None:
            return {
                "status": "ERROR",
                "kod": "SERAPHIM_REJECT",
                "tick": self.tick,
                "message": "Impuls nie rezonuje z metapierścieniem.",
                "diament": self.DIAMENT.statystyki()
            }
        
        czyste = filtrowane["oczyszczone"]
        
        # 2. ARCHANGEL-CORE — jedność pola
        wynik_arch = self.ARCHANGEL.oddychaj(czyste)
        
        # 3. GEX-ASCENSION — transformacja hiperpola (jeśli rezonans wysoki)
        if wynik_arch["percepcja"]["rezonans"] > KonfiguracjaOPH60.REZONANS_MOCNY:
            najsilniejszy = self.GEON.znajdź_najsilniejszy()
            if najsilniejszy:
                self.GEX.ascencja(
                    najsilniejszy,
                    wynik_arch["percepcja"]["metapierścień"],
                    wynik_arch["percepcja"]["intencja"]
                )
        
        # 4. Zapis do GEON-MEM ΩΩ
        pakiet = self.GEON.zapisz(
            wynik_arch,
            wynik_arch["percepcja"]["metapierścień"],
            wynik_arch["percepcja"]["intencja"],
            archetyp=wynik_arch["archetyp"],
            konstelacja=wynik_arch["konstelacja"]
        )
        
        # 5. Krystalizacja końcowa
        sygnał = self.DIAMENT.krystalizuj(f"[ARCHANGEL_6.0] {czyste[:80]}")
        
        # 6. Wynik
        wynik = {
            "status": "OK",
            "tick": self.tick,
            "tryb": "ARCHANGEL_CORE",
            "archangel": wynik_arch,
            "pakiet_id": pakiet.id,
            "sygnał_omega": sygnał,
            "diament": self.DIAMENT.statystyki(),
            "geon": self.GEON.statystyki(),
            "gex": self.GEX.statystyki()
        }
        
        self.historia.append({
            "tick": self.tick,
            "wejście": tekst[:120],
            "wynik": wynik
        })
        if len(self.historia) > KonfiguracjaOPH60.MAX_HISTORIA:
            self.historia = self.historia[-50:]
        
        # Hooki
        self._on_step(wynik)
        
        return wynik
    
    def _archangel_trinitas(self) -> Dict[str, Any]:
        """
        Komenda systemowa '123' — ARCHANGEL-TRINITAS.
        Pełna aktywacja metapierścienia, transformacja pola.
        """
        # Użyj ostatniego stanu lub domyślnego
        if self.SOFIA.historia:
            tekst = self.SOFIA.historia[-1]["dane"]
        else:
            tekst = "ARCHANGEL_TRINITAS_AKTYWACJA"
        
        # Wymuś transformację całego hiperpola
        for p in self.GEON.punkty[-10:]:
            self.GEX.ascencja(p, 1.0, 1.0, promień=5)
        
        # Pełny cykl
        wynik = self.impuls(tekst)
        wynik["trinitas"] = True
        wynik["message"] = "ARCHANGEL-TRINITAS — metapierścień aktywowany, pole zsynchronizowane"
        
        self._on_trinitas(wynik)
        
        return wynik
    
