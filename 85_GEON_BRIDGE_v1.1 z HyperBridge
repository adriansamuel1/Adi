class TransitionLayer:
    @staticmethod
    def normalize_state(state: Dict[str, List[int]], source_size: int) -> List[float]:
        axes = ['A', 'B', 'C']
        normalized = []
        for axis in axes:
            values = state[axis]
            min_val, max_val = 1, source_size
            norm = [(v - min_val) / (max_val - min_val) for v in values]
            normalized.extend(norm)
        return normalized

    @staticmethod
    def denormalize_state(normalized: List[float], target_size: int) -> Dict[str, List[int]]:
        axes = ['A', 'B', 'C']
        state = {}
        idx = 0
        for axis in axes:
            length = target_size
            values = []
            for i in range(length):
                v = int(normalized[idx] * (target_size - 1)) + 1
                values.append(clamp(v, 1, target_size))
                idx += 1
            state[axis] = values
        return state

    @staticmethod
    def apply_rule(source_state: Dict, source_size: int, target_size: int,
                   pressure: float = 0.5, archetype: str = "Nowicjusz") -> Dict:
        norm = TransitionLayer.normalize_state(source_state, source_size)
        
        if pressure > 0.75:
            norm = [min(1.0, x + 0.1) for x in norm]
        elif pressure < 0.35:
            norm = [x * 0.8 + 0.1 for x in norm]
        
        if archetype == "Przodek":
            norm = [min(1.0, x * 1.05) for x in norm]
        
        return TransitionLayer.denormalize_state(norm, target_size)

