    def get_nearest_anchor(self, current_state_27: List[float]) -> Optional[Dict]:
        """Znajduje najbliższy Punkt Kotwiczący w przestrzeni 27D."""
        if not self.anchoring_points:
            return None
        
        best_anchor = None
        best_distance = float('inf')
        
        for anchor in self.anchoring_points:
            anchor_state = anchor.get("state_27", [])
            if len(anchor_state) != len(current_state_27):
                continue
            
            # Odległość euklidesowa w 27D
            distance = math.sqrt(sum((a - b) ** 2 for a, b in zip(anchor_state, current_state_27)))
            if distance < best_distance:
                best_distance = distance
                best_anchor = anchor
        
        return best_anchor

    def reset_to_anchor(self, anchor_id: str) -> Optional[Dict]:
        """Resetuje system do wskazanego Punktu Kotwiczącego."""
        for anchor in self.anchoring_points:
            if anchor.get("anchor_id") == anchor_id:
                self.kroniki.log_event("RESET_TO_ANCHOR", {"anchor_id": anchor_id, "trs": anchor.get("trs")})
                return anchor
        return None

    def get_trs_trend(self) -> Dict:
        """Analizuje trend TRS z historii."""
        if len(self.trs_history) < 2:
            return {"trend": "INSUFFICIENT_DATA", "direction": "NEUTRAL"}
        
        recent = self.trs_history[-5:]
        if len(recent) >= 3:
            avg_first = sum(recent[:2]) / 2
            avg_last = sum(recent[-2:]) / 2
            diff = avg_last - avg_first
            
            if diff > 0.02:
                direction = "RISING"
            elif diff < -0.02:
                direction = "FALLING"
            else:
                direction = "STABLE"
            
            return {
                "trend": direction,
                "current_trs": recent[-1],
                "avg_trs": sum(recent) / len(recent),
                "diff": diff
            }
        
        return {"trend": "STABLE", "direction": "NEUTRAL", "current_trs": self.trs_history[-1]}

