class VerneCube:
    def __init__(self):
        self.axis_A = list(range(1, 4))
        self.axis_B = list(range(1, 4))
        self.axis_C = list(range(1, 4))
        self.size = 3

    def state(self) -> Dict[str, List[int]]:
        return {"A": self.axis_A.copy(), "B": self.axis_B.copy(), "C": self.axis_C.copy()}
    
    def from_state(self, s: Dict[str, List[int]]) -> None:
        self.axis_A = s["A"].copy()
        self.axis_B = s["B"].copy()
        self.axis_C = s["C"].copy()
    
    def move(self, code: str) -> None:
        axis = code[0].upper()
        shift = 1 if code[1:] == '+' else -1 if code[1:] == '-' else int(code[1:])
        shift %= 3
        if axis == 'A':
            self.axis_A = self.axis_A[shift:] + self.axis_A[:shift]
        elif axis == 'B':
            self.axis_B = self.axis_B[shift:] + self.axis_B[:shift]
        elif axis == 'C':
            self.axis_C = self.axis_C[shift:] + self.axis_C[:shift]
    
    def apply_moves(self, moves: List[str]) -> None:
        for m in moves:
            self.move(m)
    
    def eval(self, x: int, y: int, z: int) -> Dict:
        x, y, z = clamp(x, 1, 3), clamp(y, 1, 3), clamp(z, 1, 3)
        return {
            "vector": [self.axis_A[x-1], self.axis_B[y-1], self.axis_C[z-1]],
            "magnitude": (self.axis_A[x-1] + self.axis_B[y-1] + self.axis_C[z-1]) / 9.0
        }
    
    def show(self) -> None:
        print(f"Verne (3×3×3): A={self.axis_A}, B={self.axis_B}, C={self.axis_C}")

