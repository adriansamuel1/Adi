class SyncLayer:
    @staticmethod
    def to_vector(cube_state: Dict, cube_size: int) -> List[float]:
        values = []
        for axis in ['A', 'B', 'C']:
            vals = cube_state[axis][:3]
            norm_vals = [v / cube_size for v in vals]
            values.extend(norm_vals)
        return values

    @staticmethod
    def combine(verne_state: Dict, maya_state: Dict, sien_state: Dict,
                v_size: int = 3, m_size: int = 7, s_size: int = 9) -> List[float]:
        v_vec = SyncLayer.to_vector(verne_state, v_size)
        m_vec = SyncLayer.to_vector(maya_state, m_size)
        s_vec = SyncLayer.to_vector(sien_state, s_size)
        return v_vec + m_vec + s_vec

