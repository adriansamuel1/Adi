class SentinoCore:
    """
    PIERŚCIEŃ 3 — SENTINO
    Mózg systemu: ośmiornica, kruk, pająk, atrament, emocje
    """
    def __init__(self):
        self.global_state = "NORMAL"
        self.uncertainty = 0.0
        self.pressure = 0.0
        self.aggression = 0.0
        self.caution = 0.0
        self.curiosity = 0.0
        self.regret = 0.0
        self.surprise = 0.0
        self.system_mood = "NEUTRALNY"
        self.tick_counter = 0
        self.history: List[Dict] = []
        self.drgania_history: List[float] = []
    
    def tick(self, handoff: Dict, status: Dict) -> Dict[str, Any]:
        """Główny krok pierścienia Sentino"""
        self.tick_counter += 1
        
        risk = handoff.get("current_risk", 0.0)
        morale = status.get("morale", 1.0)
        energy = status.get("energia", 1.0)
        
        # Presja
        self.pressure = risk * 0.6 + (1.0 - morale) * 0.4 + (1.0 - energy) * 0.2
        self.pressure = min(1.0, self.pressure)
        
        # Niepewność
        self.uncertainty = 0.3 + (self.pressure * 0.5) + random.uniform(-0.1, 0.1)
        self.uncertainty = max(0.0, min(1.0, self.uncertainty))
        
        # Stan globalny
        if self.pressure > 0.75:
            self.global_state = "KRYZYS"
        elif self.pressure > 0.45:
            self.global_state = "ADAPTACJA"
        else:
            self.global_state = "NORMAL"
        
        # Drgania (pająk)
        drganie = 0.0
        if morale < 0.5 and status.get("jednostki", 5) == status.get("initial_units", 5) and not status.get("ogien", False):
            drganie = 0.7
        self.drgania_history.append(drganie)
        if len(self.drgania_history) > 10:
            self.drgania_history.pop(0)
        drgania_avg = sum(self.drgania_history) / max(1, len(self.drgania_history))
        
        # Ghost pulse
        ghost_pulse = self.pressure > 0.8 and self.global_state == "KRYZYS"
        
        # Słaby punkt
        weak_spot = None
        if random.random() < 0.2:
            weak_spot = "comm_coherence" if random.random() > 0.5 else "integrity"
        
        # Emocje
        self.aggression = min(1.0, self.pressure * 1.2)
        self.caution = min(1.0, 1.0 - self.aggression + drgania_avg)
        self.curiosity = min(1.0, self.uncertainty * (1.0 - self.aggression) * 1.5)
        
        if self.aggression > 0.7:
            self.system_mood = "AGRESYWNY"
        elif self.caution > 0.7:
            self.system_mood = "DEFENSYWNY"
        elif self.curiosity > 0.6:
            self.system_mood = "BADANIE"
        else:
            self.system_mood = "NEUTRALNY"
        
        result = {
            "global_state": self.global_state,
            "pressure": self.pressure,
            "uncertainty": self.uncertainty,
            "weak_spot": weak_spot,
            "ghost_pulse": ghost_pulse,
            "drgania": drgania_avg,
            "aggression": self.aggression,
            "caution": self.caution,
            "curiosity": self.curiosity,
            "mood": self.system_mood,
            "tick": self.tick_counter
        }
        
        self.history.append({"tick": self.tick_counter, "result": result})
        if len(self.history) > 50:
            self.history = self.history[-30:]
        
        return result


