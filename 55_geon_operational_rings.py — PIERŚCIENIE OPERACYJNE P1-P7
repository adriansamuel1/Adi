@dataclass
class Point:
    """Punkt w przestrzeni 2D"""
    x: float
    y: float
    
    def __add__(self, other: "Point") -> "Point":
        return Point(self.x + other.x, self.y + other.y)
    
    def __sub__(self, other: "Point") -> "Point":
        return Point(self.x - other.x, self.y - other.y)
    
    def scale(self, k: float) -> "Point":
        return Point(self.x * k, self.y * k)
    
    def dist(self, other: "Point") -> float:
        return math.hypot(self.x - other.x, self.y - other.y)
    
    def __repr__(self) -> str:
        return f"({self.x:.1f},{self.y:.1f})"


@dataclass
class RectArea:
    """Prostokątny obszar"""
    x1: float
    y1: float
    x2: float
    y2: float
    
    def __post_init__(self):
        self.x1, self.x2 = min(self.x1, self.x2), max(self.x1, self.x2)
        self.y1, self.y2 = min(self.y1, self.y2), max(self.y1, self.y2)
    
    def contains(self, point: Point) -> bool:
        return self.x1 <= point.x <= self.x2 and self.y1 <= point.y <= self.y2


@dataclass
class Target:
    """Cel strategiczny"""
    id: str
    value: float
    priority: float
    vector: Point


@dataclass
class ThreatZone:
    """Strefa zagrożenia"""
    id: str
    danger_level: float
    area: RectArea
    signature_required: List[str] = field(default_factory=list)
    
    def is_dangerous_for(self, signature: str) -> bool:
        return not self.signature_required or signature in self.signature_required


