class AxisMundi:
    """
    PIERŚCIEŃ 7 — AXIS MUNDI
    Fundament: zasoby, cień, terytorium, energia, lichwa, patenty
    """
    def __init__(self):
        self.assets = {
            "PLZ_Z": 0.0,
            "copper_reserve": 0.0,
            "land_value": 0.0,
            "intellectual_ip": []
        }
        self.shadow_assets = {
            "shadow_PLZ": 0.0,
            "shadow_copper": 0.0,
            "shadow_ip": []
        }
        self.territory: Dict[str, Dict] = {
            "Czekanka_130": {"status": "SECURE", "control": 1.0, "resonance_boost": 1.0}
        }
        self.energy_vector = [1.0, 0.5, 0.8]  # stabilność, szczytowość, rezerwa
        self.emergency_mode = False
        self.usury_debt = 0.0
        self.tick_counter = 0
        self.history: List[Dict] = []
    
    def inject_resource(self, resource_type: str, amount: float, shadow: bool = False) -> None:
        """Wstrzykuje zasób do systemu"""
        if shadow:
            if resource_type == "copper_reserve":
                self.shadow_assets["shadow_copper"] += amount
            elif resource_type == "land_value":
                self.shadow_assets["shadow_PLZ"] += amount * 1.2
            self._recalc_shadow()
        else:
            if resource_type in self.assets:
                self.assets[resource_type] += amount
            self._recalc()
    
    def _recalc(self) -> None:
        self.assets["PLZ_Z"] = self.assets["copper_reserve"] * 0.8 + self.assets["land_value"] * 1.2
    
    def _recalc_shadow(self) -> None:
        self.shadow_assets["shadow_PLZ"] = self.shadow_assets["shadow_copper"] * 0.8
    
    def get_power_supply(self) -> float:
        """Zwraca aktualną moc systemu"""
        base = self.assets["PLZ_Z"]
        if self.emergency_mode:
            base += self.shadow_assets["shadow_PLZ"] * 0.5
        vortex = self.energy_vector[0] * self.energy_vector[1] + self.energy_vector[2] * 0.3
        debt_penalty = max(0.0, 1.0 - self.usury_debt / (base + 0.01))
        return base * vortex * debt_penalty
    
    def secure_zone(self, zone_id: str) -> bool:
        """Zabezpiecza strefę"""
        if zone_id in self.territory:
            self.territory[zone_id]["status"] = "BASTION"
            self.territory[zone_id]["control"] = 1.0
            self.energy_vector[1] = min(1.0, self.energy_vector[1] + 0.1)
            return True
        return False
    
    def get_territory_pulse(self) -> float:
        """Zwraca puls terytorialny"""
        return sum(z["resonance_boost"] for z in self.territory.values()
                   if z["status"] == "BASTION")
    
    def emergency_hoard(self, threshold: float = 20.0) -> bool:
        """Aktywuje rezerwę awaryjną"""
        if self.get_power_supply() < threshold and not self.emergency_mode:
            self.emergency_mode = True
            self.assets["PLZ_Z"] += self.shadow_assets["shadow_PLZ"] * 0.3
            self._recalc()
            logger.warning("⚠️ AKTYWACJA REZERWY AWARYJNEJ (SHADOW HOARD)")
            return True
        if self.get_power_supply() > threshold * 1.5 and self.emergency_mode:
            self.emergency_mode = False
            logger.info("✅ Rezerwa awaryjna wyłączona")
            return False
        return False
    
    def take_usury(self, amount: float) -> bool:
        """Zaciąga pożyczkę (lichwa)"""
        if amount <= 0:
            return False
        self.assets["PLZ_Z"] += amount
        self.usury_debt += amount * 1.2
        self._recalc()
        logger.info(f"💰 Lichwa: pożyczka {amount:.1f}, dług {self.usury_debt:.1f}")
        return True
    
    def register_patent(self, name: str, value: float = 10.0, shadow: bool = False) -> None:
        """Rejestruje patent (IP)"""
        if shadow:
            self.shadow_assets["shadow_ip"].append({"name": name, "value": value})
            self.shadow_assets["shadow_PLZ"] += value * 0.2
        else:
            self.assets["intellectual_ip"].append(name)
            self.assets["PLZ_Z"] += value


