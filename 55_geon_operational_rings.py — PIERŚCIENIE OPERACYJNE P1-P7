class RosomakPack:
    """
    PIERŚCIEŃ 2 — ROSOMAK
    Sfora wilków: morale, energia, berserk, ShadowLink, TargetMemory
    """
    def __init__(self, units: int = 5):
        self.units = units
        self.initial_units = units
        self.morale = 1.0
        self.energy = 1.0
        self.target: Optional[Point] = None
        self.formation: str = "KOLUMNA"
        self.shadow_mode: bool = False
        self.fire: bool = False
        self.last_handoff: Optional[Dict] = None
        self.last_vectors: List[Point] = []
        self.tick_counter = 0
        self.history: List[Dict] = []
    
    def tick(self, handoff: Optional[Dict] = None) -> Dict[str, Any]:
        """Główny krok pierścienia Rosomak"""
        self.tick_counter += 1
        self.last_handoff = handoff
        
        if handoff:
            self.target = handoff.get("target_vector")
            self.shadow_mode = handoff.get("stealth_handoff", False)
        
        # Dynamika
        self.energy = max(0.0, self.energy - 0.05)
        
        if self.target:
            self.morale = min(1.0, self.morale + 0.02)
            self.fire = self.energy > 0.3 and random.random() > 0.6
        else:
            self.morale = max(0.0, self.morale - 0.03)
            self.fire = False
        
        if self.shadow_mode:
            self.energy -= 0.02
        
        if self.target:
            self.last_vectors.append(self.target)
            if len(self.last_vectors) > 5:
                self.last_vectors.pop(0)
        
        result = {
            "morale": self.morale,
            "energia": self.energy,
            "jednostki": self.units,
            "initial_units": self.initial_units,
            "ogien": self.fire,
            "cel": self.target,
            "ostatnie_wektory": self.last_vectors,
            "shadow_mode": self.shadow_mode
        }
        
        self.history.append({"tick": self.tick_counter, "result": result})
        if len(self.history) > 50:
            self.history = self.history[-30:]
        
        return result


