class HeilongOperationalIntegrator:
    """
    Integrator 7 pierścieni operacyjnych P1-P7.
    Zarządza synchronizacją i przepływem danych między pierścieniami.
    """
    def __init__(self, p1: B2SpiritCore, p2: RosomakPack, p3: SentinoCore,
                 p4: BazyliszekP4, p5: ArchitectP5, p6: OrcaCore, p7: AxisMundi):
        self.p1 = p1
        self.p2 = p2
        self.p3 = p3
        self.p4 = p4
        self.p5 = p5
        self.p6 = p6
        self.p7 = p7
        self.tick_counter = 0
        self.history: List[Dict] = []
        self._step_hooks: List[Callable] = []
    
    def sync_p5_to_p6(self) -> None:
        """Synchronizacja Kondor (P5) → Orka (P6)"""
        packet = {
            "intent_echo": getattr(self.p5, 'intent_echo', {}),
            "meta_index": self.p5.meta_index
        }
        self.p6.receive_p5_sync(packet)
    
    def sync_p6_to_p7(self) -> None:
        """Synchronizacja Orka (P6) → Axis (P7)"""
        demand = self.p6.state.last_consensus or {}
        if demand.get("winner") == "attack":
            self.p7.energy_vector[1] = min(1.0, self.p7.energy_vector[1] + 0.1)
        elif demand.get("winner") == "retreat":
            self.p7.energy_vector[2] = min(1.0, self.p7.energy_vector[2] + 0.1)
    
    def sync_p7_to_p6(self) -> None:
        """Synchronizacja Axis (P7) → Orka (P6)"""
        territorial = self.p7.get_territory_pulse()
        power = self.p7.get_power_supply()
        strength = min(1.0, (territorial * power) / 100.0)
        self.p6.broadcast_resonance("TERRITORIAL_POWER", strength)
    
    def sync_p6_to_p5(self) -> None:
        """Synchronizacja Orka (P6) → Kondor (P5)"""
        mood = self.p6.get_collective_mood()
        self.p5.receive_collective_feedback({"mood": mood})
    
    def sync_p1_to_p6(self) -> None:
        """Synchronizacja B-2 (P1) → Orka (P6)"""
        shadow_flag = getattr(self.p1, 'shadow_mode', False)
        self.p6.broadcast_resonance("SHADOW_ACTIVE", 0.8 if shadow_flag else 0.2)
    
    def sync_p7_to_p1(self) -> None:
        """Synchronizacja Axis (P7) → B-2 (P1)"""
        if self.p7.emergency_mode:
            self.p1.fuel_remaining = min(1.0, self.p1.fuel_remaining + 0.15)
    
    def sync_p3_to_p5(self) -> None:
        """Synchronizacja Sentino (P3) → Kondor (P5)"""
        uncertainty = getattr(self.p3, 'uncertainty', 0.0)
        self.p5.meta_index = max(0.0, self.p5.meta_index - uncertainty * 0.08)
    
    def heartbeat(self) -> Dict[str, Any]:
        """Główny cykl synchronizacji między pierścieniami"""
        self.tick_counter += 1
        
        self.sync_p5_to_p6()
        self.sync_p6_to_p7()
        self.sync_p7_to_p6()
        self.sync_p6_to_p5()
        self.sync_p1_to_p6()
        self.sync_p7_to_p1()
        self.sync_p3_to_p5()
        self.p6.synchronize()
        
        result = {
            "tick": self.tick_counter,
            "p5_meta": self.p5.meta_index,
            "p6_mood": self.p6.get_collective_mood(),
            "p7_power": self.p7.get_power_supply(),
            "p1_fuel": self.p1.fuel_remaining,
            "p3_state": self.p3.global_state,
            "p4_lethality": self.p4.lethality_index
        }
        
        self.history.append(result)
        if len(self.history) > 100:
            self.history = self.history[-50:]
        
        self._on_step(result)
        
        return result
    
    def register_step_hook(self, hook: Callable) -> None:
        """Rejestruje hook wołany po każdym cyklu synchronizacji"""
        self._step_hooks.append(hook)
    
    def _on_step(self, data: Dict) -> None:
        for hook in self._step_hooks:
            try:
                hook(data)
            except Exception as e:
                logger.warning(f"[HOOK ERROR] {e}")


