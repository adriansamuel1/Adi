class FlightState:
    """Stan lotu B-2 Spirit"""
    def __init__(self, global_map: Any, targets: List[Target], threats: List[ThreatZone],
                 lock_candidates: List[Target], fuel: float, risk_level: float,
                 time_window: float, shadow_mode: bool = False):
        self.global_map = global_map
        self.targets = targets
        self.threats = threats
        self.lock_candidates = lock_candidates
        self.fuel = fuel
        self.risk_level = risk_level
        self.time_window = time_window
        self.shadow_mode = shadow_mode
        self.nav_vector: Optional[Point] = None
        self.no_fly: List[RectArea] = []
        self.attack_vector: Optional[Point] = None
        self.attack_profile: str = "NO_ATTACK"
        self.ticks_in_threat: int = 0
    
    def with_nav(self, nav_output: Dict) -> "FlightState":
        ns = FlightState(self.global_map, self.targets, self.threats, self.lock_candidates,
                         self.fuel, self.risk_level, self.time_window, self.shadow_mode)
        ns.nav_vector = nav_output.get("nav_vector")
        ns.no_fly = nav_output.get("no_fly", [])
        return ns
    
    def with_target(self, attack_output: Dict) -> "FlightState":
        ns = FlightState(self.global_map, self.targets, self.threats, self.lock_candidates,
                         self.fuel, self.risk_level, self.time_window, self.shadow_mode)
        ns.nav_vector = self.nav_vector
        ns.no_fly = self.no_fly
        ns.attack_vector = attack_output.get("attack_vector")
        ns.attack_profile = attack_output.get("attack_profile", "NO_ATTACK")
        return ns
    
    def get_signature(self) -> str:
        return "SILENT" if self.shadow_mode else "LOUD"
    
    def in_threat_zone(self) -> bool:
        if not self.nav_vector:
            return False
        sig = self.get_signature()
        for z in self.threats:
            if z.area.contains(self.nav_vector) and z.is_dangerous_for(sig):
                return True
        return False
    
    def update_risk(self) -> None:
        if self.in_threat_zone() and not self.shadow_mode:
            self.ticks_in_threat += 1
            self.risk_level = min(1.0, self.risk_level + 0.05 * self.ticks_in_threat)
        else:
            self.ticks_in_threat = max(0, self.ticks_in_threat - 1)
            self.risk_level = max(0.0, self.risk_level - 0.02)


class B2SpiritCore:
    """
    PIERŚCIEŃ 1 — B-2 SPIRIT
    Oko systemu: nawigacja, zagrożenia, decyzje lotnicze
    """
    def __init__(self, base_vector: Point):
        self.base_vector = base_vector
        self.shadow_mode = False
        self.fuel_remaining = 1.0
        self.risk_level = 0.0
        self.hold_count = 0
        self.tick_counter = 0
        self.history: List[Dict] = []
    
    def tick(self, state: FlightState) -> Dict[str, Any]:
        """Główny krok pierścienia B-2"""
        self.tick_counter += 1
        
        # PANIC — krytyczne paliwo
        if state.fuel < 0.1:
            return {
                "nav_vector": self.base_vector,
                "no_fly": [],
                "attack_vector": None,
                "attack_profile": "ABORT",
                "fire": False,
                "mode": "RTB",
                "shadow_mode": state.shadow_mode,
                "hold_count": 0,
                "risk_level": state.risk_level,
                "handoff_to_ring2": None
            }
        
        # 1. Orzeł — nawigacja strategiczna
        e_sensed = {"terrain_map": state.global_map, "threats": state.threats, "targets": state.targets}
        e_decided = self._eagle_decide(e_sensed)
        e_acted = self._eagle_act(e_decided)
        state1 = state.with_nav(e_acted)
        
        # 2. Jastrząb — selekcja celu
        h_sensed = {"lock_candidates": state1.lock_candidates, "shadow_mode": state1.shadow_mode}
        h_decided = self._hawk_decide(h_sensed)
        h_acted = self._hawk_act(h_decided)
        state2 = state1.with_target(h_acted)
        
        # 3. Sokół — decyzja o ogniu
        f_sensed = {
            "fuel": state2.fuel,
            "risk": state2.risk_level,
            "time_window": state2.time_window,
            "shadow_mode": state2.shadow_mode,
            "hold_count": self.hold_count
        }
        f_decided = self._falcon_decide(f_sensed)
        f_acted = self._falcon_act(f_decided)
        
        # Wymuszenie Shadow Mode przy długim wstrzymaniu
        if f_acted["force_shadow"]:
            state2.shadow_mode = True
            self.shadow_mode = True
        
        state2.update_risk()
        self.risk_level = state2.risk_level
        self.shadow_mode = state2.shadow_mode
        self.hold_count = f_acted["hold_count"]
        
        # Handoff do Pierścienia 2
        handoff = None
        if not f_acted["fire"] and state2.risk_level > 0.8:
            stealth = state2.shadow_mode or (state2.risk_level > 0.8)
            handoff = {
                "target_vector": h_acted["attack_vector"],
                "attack_profile": h_acted["attack_profile"],
                "fuel_remaining": state2.fuel,
                "current_risk": state2.risk_level,
                "stealth_handoff": stealth,
                "reason": "HIGH_RISK_NO_FIRE"
            }
        
        result = {
            "nav_vector": e_acted["nav_vector"],
            "no_fly": e_acted["no_fly"],
            "attack_vector": h_acted["attack_vector"],
            "attack_profile": h_acted["attack_profile"],
            "fire": f_acted["fire"],
            "mode": f_acted["mode"],
            "shadow_mode": state2.shadow_mode,
            "hold_count": f_acted["hold_count"],
            "risk_level": state2.risk_level,
            "handoff_to_ring2": handoff
        }
        
        self.history.append({"tick": self.tick_counter, "result": result})
        if len(self.history) > 50:
            self.history = self.history[-30:]
        
        return result
    
    def _eagle_decide(self, sensed: Dict) -> Dict:
        targets = sensed.get("targets", [])
        threats = sensed.get("threats", [])
        if not targets:
            return {"priority_zone": None, "avoid_zones": threats}
        priority_zone = max(targets, key=lambda t: t.value)
        avoid_zones = [z for z in threats if z.danger_level > 0.6]
        return {"priority_zone": priority_zone, "avoid_zones": avoid_zones}
    
    def _eagle_act(self, decision: Dict) -> Dict:
        if decision["priority_zone"] is None:
            return {"nav_vector": None, "no_fly": [z.area for z in decision["avoid_zones"]]}
        return {
            "nav_vector": decision["priority_zone"].vector,
            "no_fly": [z.area for z in decision["avoid_zones"]]
        }
    
    def _hawk_decide(self, sensed: Dict) -> Dict:
        candidates = sensed.get("lock_candidates", [])
        if not candidates:
            return {"lock_target": None}
        if sensed.get("shadow_mode", False):
            target = max(candidates, key=lambda t: t.value * 0.7 + t.priority * 0.3)
        else:
            target = max(candidates, key=lambda t: t.priority)
        return {"lock_target": target}
    
    def _hawk_act(self, decision: Dict) -> Dict:
        if decision["lock_target"] is None:
            return {"attack_vector": None, "attack_profile": "NO_ATTACK"}
        return {
            "attack_vector": decision["lock_target"].vector,
            "attack_profile": "STEALTH_PRECISION"
        }
    
    def _falcon_decide(self, sensed: Dict) -> Dict:
        fuel_ok = sensed["fuel"] > 0.4
        time_pressure = sensed["time_window"] <= 0.3
        risk_ok = sensed["risk"] <= (0.5 if sensed["shadow_mode"] else 0.7)
        go = fuel_ok and risk_ok and time_pressure
        if not go:
            self.hold_count += 1
        else:
            self.hold_count = 0
        force_shadow = self.hold_count > 5 and not sensed["shadow_mode"]
        return {"execute_now": go, "hold_count": self.hold_count, "force_shadow": force_shadow}
    
    def _falcon_act(self, decision: Dict) -> Dict:
        return {
            "fire": decision["execute_now"],
            "mode": "INSTANT" if decision["execute_now"] else "HOLD",
            "hold_count": decision["hold_count"],
            "force_shadow": decision["force_shadow"]
        }


