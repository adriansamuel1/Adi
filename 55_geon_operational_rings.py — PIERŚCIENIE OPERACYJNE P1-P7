class OrcaCore:
    """
    PIERŚCIEŃ 6 — ORKA
    Stado: kultura, strategie, rezonans, synchronizacja, decyzje kolektywne
    """
    def __init__(self):
        self.state = CollectiveState()
        self.agents: List[OrcaAgent] = []
        self.tick_counter = 0
        self.history: List[Dict] = []
    
    def register_agent(self, agent: OrcaAgent) -> None:
        """Rejestruje agenta w stadzie"""
        self.agents.append(agent)
    
    def broadcast_resonance(self, signal: str, strength: float) -> None:
        """Rozgłasza rezonans do stada"""
        self.state.resonance_map[signal] = strength
    
    def synchronize(self) -> None:
        """Synchronizuje stan stada"""
        # W pełnej implementacji wysyła pakiety do agentów
        pass
    
    def get_collective_mood(self) -> str:
        """Zwraca nastrój kolektywny stada"""
        avg = sum(self.state.resonance_map.values()) / max(1, len(self.state.resonance_map))
        if avg > 0.7:
            return "DOMINANCE"
        if avg < 0.3:
            return "STEALTH"
        return "ADAPTIVE"
    
    def receive_p5_sync(self, packet: Dict) -> None:
        """Odbiera synchronizację od Kondora (P5)"""
        self.state.culture["p5_intent"] = packet.get("intent_echo", {})
    
    def collective_decision(self, issue: str, options: List[str]) -> Dict[str, Any]:
        """Podejmuje decyzję kolektywną przez głosowanie"""
        votes = {opt: 0.0 for opt in options}
        for agent in self.agents:
            v = agent.vote(issue)
            chosen = random.choices(options, weights=[1.0] * len(options))[0]
            votes[chosen] += v * agent.weight
        
        total = sum(votes.values())
        if total > 0:
            votes = {k: v / total for k, v in votes.items()}
        
        winner = max(votes, key=votes.get)
        consensus = votes[winner] > 0.6
        
        self.state.last_consensus = {
            "issue": issue,
            "winner": winner,
            "distribution": votes,
            "consensus_reached": consensus
        }
        
        self.tick_counter += 1
        self.history.append({"tick": self.tick_counter, "decision": self.state.last_consensus})
        if len(self.history) > 50:
            self.history = self.history[-30:]
        
        return self.state.last_consensus


